            @keyframes treat-fly { 0%{transform:translate(0,0) scale(0.4) rotate(0deg);opacity:1} 15%{transform:translate(var(--dx15),var(--dy15)) scale(1.2) rotate(var(--r15));opacity:1} 100%{transform:translate(var(--dx),var(--dy)) scale(0.7) rotate(var(--r));opacity:0} }
