<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Roboto+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script>
        function aprilFools(enable) {
            if (enable) {
                document.documentElement.style.setProperty('--body-font', "'Comic Sans MS', 'Comic Sans', cursive");
                document.documentElement.style.setProperty('--heading-font', "'MinecraftEnchant', 'Orbitron', sans-serif");
            } else {
                document.documentElement.style.removeProperty('--body-font');
                document.documentElement.style.removeProperty('--heading-font');
            }
        }

        const d = new Date();
        if (d.getMonth() === 3 && d.getDate() === 1) aprilFools(true);
    </script>
</head>
<body>
    <nav id="main-nav">
        <div class="nav-container">
            <a href="/" class="logo">PROFITEERS PMC</a>

            <button class="menu-toggle" id="menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <ul class="nav-links" id="navLinks">
                <li><a href="/">Home</a></li>
                <li><a href="/about">About us</a></li>

                <li class="dropdown">
                    <a href="#" class="dropbtn" data-dropdown>Roster <span class="chevron">▾</span></a>
                    <div class="dropdown-content">
                        <a href="/roster">Member Roster</a>
                        <a href="/loa/all">Leave of Absence</a>
                    </div>
                </li>

                <li class="dropdown">
                    <a href="#" class="dropbtn" data-dropdown>Operations <span class="chevron">▾</span></a>
                    <div class="dropdown-content">
                        <a href="/operations/upcoming">Upcoming Operations</a>
                        <a href="/operations/all">All Operations</a>
                        <a href="/orbat/view/2">Main ORBAT</a>
                        <a href="/orbat/view-all">ORBAT Templates</a>
                        <a href="/modpacks">Modpacks</a>
                        <% if (user && (user.isAdmin || user.isZeus)) { %>
                            <a href="/operations/manage/list" class="dropdown-divider">Manage Operations</a>
                            <a href="/modpacks/upload/new">Upload Modpack</a>
                        <% } %>
                    </div>
                </li>

                <!-- <li><a href="/lore">Lore</a> -->
                <li><a href="/info">Information</a></li>
                <li><a href="/join">Join Us</a></li>
                <li><a href="/gallery">Gallery</a></li>
                <li><a href="/tools" class="btn nav-tools-btn">Internal Tools</a></li>

                <% if (user) { %>
                    <li class="dropdown">
                        <a href="#" class="dropbtn" data-dropdown><%= user.username %> <span class="chevron">▾</span></a>
                        <div class="dropdown-content dropdown-right">
                            <a href="/profile">My Profile</a>
                            <a href="/loa/all">Leave of Absence</a>
                            <% if (user.isAdmin) { %>
                                <a href="/admin">Admin Panel</a>
                            <% } %>
                            <a href="/logout" class="dropdown-divider dropdown-danger">Logout</a>
                        </div>
                    </li>
                <% } else { %>
                    <li><a href="/login">Login</a></li>
                <% } %>
            </ul>
        </div>
    </nav>

    <div class="nav-overlay" id="nav-overlay"></div>

    <script>
    (function () {
        const toggle   = document.getElementById('menu-toggle');
        const navLinks = document.getElementById('navLinks');
        const overlay  = document.getElementById('nav-overlay');

        function openMenu() {
            navLinks.classList.add('active');
            overlay.classList.add('active');
            toggle.classList.add('open');
            toggle.setAttribute('aria-expanded', 'true');
        }

        function closeMenu() {
            navLinks.classList.remove('active');
            overlay.classList.remove('active');
            toggle.classList.remove('open');
            toggle.setAttribute('aria-expanded', 'false');
            /* Collapse all open dropdowns */
            document.querySelectorAll('.dropdown.open').forEach(d => d.classList.remove('open'));
        }

        toggle.addEventListener('click', () => {
            navLinks.classList.contains('active') ? closeMenu() : openMenu();
        });

        overlay.addEventListener('click', closeMenu);

        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMenu(); });

        /* Dropdown toggles — on mobile tap the dropbtn, on desktop hover works via CSS */
        document.querySelectorAll('.dropbtn[data-dropdown]').forEach(btn => {
            btn.addEventListener('click', function (e) {
                /* Only intercept on mobile (menu-toggle is visible) */
                if (getComputedStyle(toggle).display === 'none') return;
                e.preventDefault();
                const li = this.closest('.dropdown');
                const wasOpen = li.classList.contains('open');
                /* Close all, then open this one if it wasn't open */
                document.querySelectorAll('.dropdown.open').forEach(d => d.classList.remove('open'));
                if (!wasOpen) li.classList.add('open');
            });
        });
    })();
    </script>
</body>
<!-- body closed in footer -->
