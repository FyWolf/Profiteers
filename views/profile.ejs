<%- include('partials/header') %>

<div class="container">
    <header>
        <h1><%= isOwnProfile ? 'MY PROFILE' : 'MEMBER PROFILE' %></h1>
        <div class="subtitle"><%= isOwnProfile ? 'Your Profiteers PMC Profile' : 'Profiteers PMC Member' %></div>
    </header>

    <% if (!isOwnProfile) { %>
        <div style="text-align: center; margin-bottom: 20px; padding: 12px; background: rgba(52, 152, 219, 0.1); border: 1px solid #3498DB; border-radius: 8px;">
            <p style="color: #3498DB; margin: 0;">
                👁️ Viewing public profile
            </p>
        </div>
    <% } %>

    <div class="grid grid-2">
        <!-- Profile Info Card -->
        <section class="section">
            <h2 style="margin-bottom: 20px;">Profile Information</h2>
            
            <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 25px;">
                <% if (profileUser.discord_avatar && profileUser.discord_id) { %>
                    <img src="https://cdn.discordapp.com/avatars/<%= profileUser.discord_id %>/<%= profileUser.discord_avatar %>.png?size=128" 
                         alt="<%= profileUser.username %>" 
                         style="width: 80px; height: 80px; border-radius: 50%; border: 3px solid var(--accent);">
                <% } else { %>
                    <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, var(--olive) 0%, var(--olive-light) 100%); display: flex; align-items: center; justify-content: center; font-size: 2em; color: white; font-weight: 900; border: 3px solid var(--accent);">
                        <%= profileUser.username.charAt(0).toUpperCase() %>
                    </div>
                <% } %>
                
                <div>
                    <h2 style="margin: 0; color: var(--accent);">
                        <%= profileUser.discord_global_name || profileUser.username %>
                    </h2>
                    <% if (isLoggedIn) { %>
                        <!-- Only show Discord handle to logged-in users -->
                        <p style="margin: 5px 0; color: var(--khaki);">
                            <% if (profileUser.discord_username) { %>
                                @<%= profileUser.discord_username %>
                            <% } else { %>
                                <%= profileUser.username %>
                            <% } %>
                        </p>
                    <% } %>
                    <% if (profileUser.is_admin) { %>
                        <span style="display: inline-block; padding: 4px 12px; background: var(--accent); color: var(--camo-dark); border-radius: 4px; font-weight: 700; font-size: 0.85em; margin-top: 5px;">
                            ⭐ ADMIN
                        </span>
                    <% } %>
                </div>
            </div>

            <div class="stats-overview" style="grid-template-columns: repeat(2, 1fr);">
                <div class="stat-card">
                    <div class="stat-label">Member Since</div>
                    <div class="stat-value" style="font-size: 1.2em;">
                        <%= new Date(stats.memberSince).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-label">Last Login</div>
                    <div class="stat-value" style="font-size: 1.2em;">
                        <% if (stats.lastLogin) { %>
                            <%= new Date(stats.lastLogin).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                        <% } else { %>
                            <span style="color: var(--khaki); font-size: 0.9em;">First time!</span>
                        <% } %>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-label">Medals Earned</div>
                    <div class="stat-value" style="color: var(--accent);">
                        <%= stats.medalCount %>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-label">Trainings Completed</div>
                    <div class="stat-value" style="color: #3498DB;">
                        <%= stats.trainingCount %>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-label">Account Type</div>
                    <div class="stat-value" style="font-size: 1.2em;">
                        <% if (stats.authType === 'discord') { %>
                            🔵 Discord
                        <% } else { %>
                            🟢 Local
                        <% } %>
                    </div>
                </div>
            </div>
        </section>

        <!-- Quick Actions Card -->
        <% if (isOwnProfile) { %>
            <section class="section">
                <h2 style="margin-bottom: 20px;">Quick Actions</h2>
                
                <div style="display: flex; flex-direction: column; gap: 15px;">
                    <a href="/" class="btn btn-primary" style="width: 100%; text-align: center;">
                        🏠 Go to Homepage
                    </a>
                    
                    <a href="/tools" class="btn btn-primary" style="width: 100%; text-align: center;">
                        🔧 View Tools
                    </a>
                    
                    <a href="/gallery" class="btn btn-primary" style="width: 100%; text-align: center;">
                        🖼️ View Gallery
                    </a>
                    
                    <% if (profileUser.is_admin) { %>
                        <a href="/admin" class="btn" style="width: 100%; text-align: center; background: var(--accent); color: var(--camo-dark);">
                            ⭐ Admin Dashboard
                        </a>
                    <% } %>
                    
                    <a href="/logout" class="btn" style="width: 100%; text-align: center; background: #e74c3c;">
                        🚪 Logout
                    </a>
                </div>
            </section>
        <% } else { %>
            <section class="section">
                <h2 style="margin-bottom: 20px;">Navigation</h2>
                
                <div style="display: flex; flex-direction: column; gap: 15px;">
                    <a href="/roster" class="btn btn-primary" style="width: 100%; text-align: center;">
                        ← Back to Roster
                    </a>
                    
                    <a href="/" class="btn" style="width: 100%; text-align: center;">
                        🏠 Homepage
                    </a>
                </div>
            </section>
        <% } %>
    </div>

    <!-- Medals Section -->
    <section class="section">
        <h2 style="margin-bottom: 20px;">
            🏅 My Medals
            <span style="color: var(--khaki); font-size: 0.7em; font-weight: normal;">
                (<%= medals.length %>)
            </span>
        </h2>

        <% if (medals.length === 0) { %>
            <div class="card text-center" style="padding: 40px;">
                <div style="font-size: 4em; opacity: 0.3; margin-bottom: 15px;">🏅</div>
                <h3 style="color: var(--khaki); margin-bottom: 10px;">No Medals Yet</h3>
                <p style="color: var(--khaki); opacity: 0.8;">
                    Keep contributing to the unit to earn medals!<br>
                    Medals are awarded by admins for achievements and contributions.
                </p>
            </div>
        <% } else { %>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
                <% medals.forEach(medal => { %>
                    <div class="card" style="border-left: 4px solid <%= medal.color %>; position: relative;">
                        <div style="display: flex; align-items: start; gap: 15px;">
                            <div style="font-size: 3em; opacity: 0.9;">
                                <%= medal.icon %>
                            </div>
                            <div style="flex: 1;">
                                <h3 style="color: <%= medal.color %>; margin-bottom: 8px;">
                                    <%= medal.name %>
                                </h3>
                                <p style="color: var(--khaki); margin-bottom: 12px; font-size: 0.95em;">
                                    <%= medal.description %>
                                </p>
                                <div style="font-size: 0.85em; color: var(--khaki); opacity: 0.7;">
                                    <div>
                                        <strong>Awarded:</strong> 
                                        <%= new Date(medal.awarded_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                    </div>
                                    <div>
                                        <strong>By:</strong> <%= medal.awarded_by_username %>
                                    </div>
                                    <% if (medal.notes) { %>
                                        <div style="margin-top: 8px; padding: 8px; background: rgba(0,0,0,0.3); border-radius: 4px; font-style: italic;">
                                            "<%= medal.notes %>"
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </section>

    <!-- Trainings Section -->
    <section class="section">
        <h2 style="margin-bottom: 20px;">
            🎓 My Trainings
            <span style="color: var(--khaki); font-size: 0.7em; font-weight: normal;">
                (<%= trainings.length %>)
            </span>
        </h2>

        <% if (profileUser.auth_type === 'discord') { %>
            <div style="padding: 15px; background: rgba(52, 152, 219, 0.1); border: 1px solid #3498DB; border-radius: 8px; margin-bottom: 20px;">
                <strong style="color: #3498DB;">🔄 Auto-Synced:</strong>
                <span style="color: var(--khaki);">Your trainings are automatically synced from your Discord roles when you login.</span>
            </div>
        <% } %>

        <% if (trainings.length === 0) { %>
            <div class="card text-center" style="padding: 40px;">
                <div style="font-size: 4em; opacity: 0.3; margin-bottom: 15px;">🎓</div>
                <h3 style="color: var(--khaki); margin-bottom: 10px;">No Trainings Completed</h3>
                <p style="color: var(--khaki); opacity: 0.8;">
                    <% if (profileUser.auth_type === 'discord') { %>
                        Complete unit trainings and get the Discord role to have them appear here!<br>
                        Your trainings will automatically sync when you login.
                    <% } else { %>
                        Trainings are automatically assigned based on Discord roles.
                    <% } %>
                </p>
            </div>
        <% } else { %>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
                <% trainings.forEach(training => { %>
                    <div class="card" style="border-left: 4px solid <%= training.color %>;">
                        <div style="display: flex; align-items: start; gap: 15px; margin-bottom: 12px;">
                            <img src="<%= training.image_url || '/images/badges/default-training.png' %>" 
                                 alt="<%= training.name %>" 
                                 style="width: 70px; height: 70px; object-fit: contain; border-radius: 8px; border: 2px solid <%= training.color %>;"
                                 onerror="this.src='/images/badges/default-training.png';">
                            <div style="flex: 1;">
                                <h3 style="color: <%= training.color %>; margin-bottom: 6px; font-size: 1.1em;">
                                    <%= training.name %>
                                </h3>
                                <% if (training.description) { %>
                                    <p style="color: var(--khaki); font-size: 0.9em; margin-bottom: 10px;">
                                        <%= training.description %>
                                    </p>
                                <% } %>
                            </div>
                        </div>
                        
                        <div style="font-size: 0.85em; color: var(--khaki); opacity: 0.7; padding-top: 12px; border-top: 1px solid rgba(178, 178, 125, 0.2);">
                            <div><strong>Certified:</strong> <%= new Date(training.synced_at).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %></div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </section>
</div>

<%- include('partials/footer') %>
