<%- include('partials/header') %>

<div class="container">
    <header>
        <h1><%= isOwnProfile ? 'MY PROFILE' : 'MEMBER PROFILE' %></h1>
        <div class="subtitle"><%= isOwnProfile ? 'Your Profiteers PMC Profile' : 'Profiteers PMC Member' %></div>
    </header>

    <% if (!isOwnProfile) { %>
        <div style="margin-bottom: 20px; padding: 8px 14px; background: rgba(52,152,219,0.1); border: 1px solid #3498DB; border-radius: 6px;">
            <p style="color: #3498DB; margin: 0; font-size: 0.88em;">👁️ Viewing public profile</p>
        </div>
    <% } %>

    <div style="display: grid; grid-template-columns: 220px 1fr; gap: 24px; align-items: start;">

        <%/* ── LEFT: PROFILE INFO ── */%>
        <div class="card" style="padding: 20px; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 10px;">
            <% if (profileUser.discord_avatar && profileUser.discord_id) { %>
                <img src="https://cdn.discordapp.com/avatars/<%= profileUser.discord_id %>/<%= profileUser.discord_avatar %>.png?size=128"
                     alt="<%= profileUser.username %>"
                     style="width: 72px; height: 72px; border-radius: 50%; border: 2px solid var(--accent);">
            <% } else { %>
                <div style="width: 72px; height: 72px; border-radius: 50%; background: linear-gradient(135deg, var(--olive) 0%, var(--olive-light) 100%); display: flex; align-items: center; justify-content: center; font-size: 1.6em; color: white; font-weight: 900; border: 2px solid var(--accent);">
                    <%= profileUser.username.charAt(0).toUpperCase() %>
                </div>
            <% } %>

            <div>
                <div style="color: var(--accent); font-weight: 700; font-size: 1em; margin-bottom: 2px;">
                    <%= profileUser.discord_global_name || profileUser.username %>
                </div>
                <% if (isLoggedIn && profileUser.discord_username) { %>
                    <div style="color: var(--khaki); font-size: 0.8em;">@<%= profileUser.discord_username %></div>
                <% } %>
            </div>

            <% if (profileUser.is_admin) { %>
                <span style="padding: 2px 10px; background: var(--accent); color: var(--camo-dark); border-radius: 4px; font-weight: 700; font-size: 0.75em;">⭐ ADMIN</span>
            <% } %>

            <div style="width: 100%; border-top: 1px solid rgba(178,178,125,0.2); padding-top: 10px; display: flex; flex-direction: column; gap: 6px; font-size: 0.8em; color: var(--khaki);">
                <div>📅 Since <%= new Date(stats.memberSince).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %></div>
                <% if (stats.lastLogin) { %>
                    <div>🕐 Last seen <%= new Date(stats.lastLogin).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></div>
                <% } %>
                <% if (user && user.isAdmin) { %>
                    <div><%= stats.authType === 'discord' ? '🔵 Discord' : '🟢 Local' %></div>
                <% } %>
            </div>

            <% if (isOwnProfile) { %>
                <a href="/logout" class="btn btn-danger" style="width: 100%; text-align: center; padding: 6px; font-size: 0.82em; margin-top: 4px;">🚪 Logout</a>
            <% } else { %>
                <a href="/roster" class="btn" style="width: 100%; text-align: center; padding: 6px; font-size: 0.82em; margin-top: 4px;">← Roster</a>
            <% } %>
        </div>

        <%/* ── RIGHT: MEDALS + TRAININGS ── */%>
        <div style="display: flex; flex-direction: column; gap: 24px;">

            <%/* MEDALS */%>
            <section>
                <h2 style="margin-bottom: 14px;">
                    🏅 Medals
                    <span style="color: var(--khaki); font-size: 0.7em; font-weight: normal;">(<%= medals.length %>)</span>
                </h2>
                <% if (medals.length === 0) { %>
                    <div class="card text-center" style="padding: 20px; opacity: 0.6;">
                        <p style="margin: 0; color: var(--khaki); font-size: 0.9em;">No medals earned yet.</p>
                    </div>
                <% } else { %>
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px;">
                        <% medals.forEach(medal => { %>
                            <div class="card" style="border-left: 4px solid <%= medal.color %>; padding: 12px;">
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <div style="font-size: 2em; flex-shrink: 0;"><%= medal.icon %></div>
                                    <div style="flex: 1; min-width: 0;">
                                        <div style="color: <%= medal.color %>; font-weight: 700; font-size: 0.9em;"><%= medal.name %></div>
                                        <div style="color: var(--khaki); font-size: 0.8em; margin-top: 1px; line-height: 1.3;"><%= medal.description %></div>
                                        <div style="color: var(--khaki); font-size: 0.72em; opacity: 0.7; margin-top: 5px;">
                                            <%= new Date(medal.awarded_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %> — by <%= medal.awarded_by_username %>
                                            <% if (medal.notes) { %><div style="margin-top: 3px; font-style: italic;">"<%= medal.notes %>"</div><% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            </section>

            <%/* TRAININGS */%>
            <section>
                <h2 style="margin-bottom: 14px;">
                    🎓 Trainings
                    <span style="color: var(--khaki); font-size: 0.7em; font-weight: normal;">(<%= trainings.length %>)</span>
                </h2>
                <% if (trainings.length === 0) { %>
                    <div class="card text-center" style="padding: 20px; opacity: 0.6;">
                        <p style="margin: 0; color: var(--khaki); font-size: 0.9em;">No trainings completed yet.</p>
                    </div>
                <% } else { %>
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px;">
                        <% trainings.forEach(training => { %>
                            <div class="card" style="border-left: 4px solid <%= training.color %>; padding: 12px;">
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <img src="<%= training.image_url || '/images/badges/default-training.png' %>"
                                         alt="<%= training.name %>"
                                         style="width: 44px; height: 44px; object-fit: contain; border-radius: 6px; border: 2px solid <%= training.color %>; flex-shrink: 0;"
                                         onerror="this.src='/images/badges/default-training.png';">
                                    <div style="flex: 1; min-width: 0;">
                                        <div style="color: <%= training.color %>; font-weight: 700; font-size: 0.9em;"><%= training.name %></div>
                                        <% if (training.description) { %>
                                            <div style="color: var(--khaki); font-size: 0.78em; margin-top: 1px; line-height: 1.3;"><%= training.description %></div>
                                        <% } %>
                                        <div style="color: var(--khaki); font-size: 0.72em; opacity: 0.7; margin-top: 4px;">
                                            Certified <%= new Date(training.synced_at).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            </section>

        </div>
    </div>
</div>

<%- include('partials/footer') %>
