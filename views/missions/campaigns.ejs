<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>MISSION CAMPAIGNS</h1>
        <div class="subtitle">Group missions into campaigns (categories)</div>
    </header>

    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <section class="section">
        <div style="margin-bottom:18px;"><a href="/missions" class="btn ms-btn-sm">← Back to board</a></div>

        <h2 style="margin-top:0;">New Campaign</h2>
        <form method="POST" action="/missions/campaigns">
            <div class="mission-form-row">
                <div class="form-group">
                    <label for="name">Name *</label>
                    <input type="text" id="name" name="name" maxlength="120" required placeholder="e.g. Operation Iron Tide">
                </div>
                <div class="form-group">
                    <label for="color">Colour</label>
                    <input type="color" id="color" name="color" value="#fcb00d" style="height:44px;padding:4px;">
                </div>
            </div>
            <div class="form-group">
                <label for="description">Description (optional)</label>
                <textarea id="description" name="description" rows="2" placeholder="What is this campaign about?"></textarea>
            </div>
            <div class="form-group" style="max-width:200px;">
                <label for="display_order">Sort order</label>
                <input type="number" id="display_order" name="display_order" value="0">
            </div>
            <button type="submit" class="btn btn-primary">➕ Create Campaign</button>
        </form>
    </section>

    <section class="section">
        <h2 style="margin-top:0;">Campaigns <span style="color:var(--khaki);font-weight:400;font-size:0.6em;">(<%= campaigns.length %>)</span></h2>
        <% if (campaigns.length === 0) { %>
            <p style="color:var(--khaki);">No campaigns yet.</p>
        <% } else { %>
            <% campaigns.forEach(c => { %>
                <div class="card" style="margin-bottom:16px;">
                    <form method="POST" action="/missions/campaigns/<%= c.id %>/edit">
                        <div class="mission-form-row">
                            <div class="form-group" style="margin-bottom:10px;">
                                <label>Name</label>
                                <input type="text" name="name" maxlength="120" required value="<%= c.name %>">
                            </div>
                            <div class="form-group" style="margin-bottom:10px;">
                                <label>Colour</label>
                                <input type="color" name="color" value="<%= /^#[0-9a-fA-F]{6}$/.test(c.color || '') ? c.color : '#fcb00d' %>" style="height:44px;padding:4px;">
                            </div>
                        </div>
                        <div class="form-group" style="margin-bottom:10px;">
                            <label>Description</label>
                            <textarea name="description" rows="2"><%= c.description || '' %></textarea>
                        </div>
                        <div style="display:flex;gap:14px;align-items:flex-end;flex-wrap:wrap;">
                            <div class="form-group" style="margin-bottom:0;max-width:140px;">
                                <label>Sort order</label>
                                <input type="number" name="display_order" value="<%= c.display_order || 0 %>">
                            </div>
                            <span style="color:var(--khaki);font-size:0.85em;"><%= c.mission_count %> mission<%= c.mission_count === 1 ? '' : 's' %></span>
                            <div style="margin-left:auto;display:flex;gap:10px;">
                                <button type="submit" class="btn ms-btn-sm">💾 Save</button>
                            </div>
                        </div>
                    </form>
                    <form method="POST" action="/missions/campaigns/<%= c.id %>/delete" style="margin-top:10px;"
                          onsubmit="return confirm('Delete campaign &quot;<%= c.name.replace(/"/g, '&quot;') %>&quot;? Its missions are kept and become uncategorised.')">
                        <button type="submit" class="btn btn-danger ms-btn-sm">🗑️ Delete</button>
                    </form>
                </div>
            <% }) %>
        <% } %>
    </section>
</div>

<%- include('../partials/footer') %>
