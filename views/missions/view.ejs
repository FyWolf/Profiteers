<%
const STATUS_LABELS = {
    planning: 'Planning', in_progress: 'In Progress', blocked: 'Blocked',
    review: 'Review', completed: 'Completed', cancelled: 'Cancelled'
};
function ymd(d) {
    if (!d) return '—';
    const x = new Date(d);
    if (isNaN(x)) return '—';
    return `${x.getFullYear()}-${String(x.getMonth() + 1).padStart(2, '0')}-${String(x.getDate()).padStart(2, '0')}`;
}
function fmtBytes(n) {
    n = Number(n || 0);
    if (!n) return '—';
    const u = ['B', 'KB', 'MB', 'GB']; let i = 0;
    while (n >= 1024 && i < u.length - 1) { n /= 1024; i++; }
    return `${n.toFixed(i ? 1 : 0)} ${u[i]}`;
}
function avatar(discordId, hash, size) {
    return (discordId && hash)
        ? `https://cdn.discordapp.com/avatars/${discordId}/${hash}.png?size=${size}`
        : '/logo.png';
}
const currentVersion = versions.length ? versions[0].version_number : null;
%>
<%- include('../partials/header') %>

<div class="container">
    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <div class="mission-detail-head">
        <div>
            <a href="/missions" class="mission-back">← Mission Board</a>
            <h1 style="margin:6px 0;"><%= project.title %></h1>
            <div class="mission-tags">
                <span class="mission-status-badge status-<%= project.status %>"><%= STATUS_LABELS[project.status] %></span>
                <span class="mission-priority priority-<%= project.priority %>"><%= project.priority %> priority</span>
            </div>
        </div>
        <% if (canManage) { %>
            <div class="mission-detail-actions">
                <a href="/missions/<%= project.id %>/edit" class="btn">✏️ Edit</a>
                <form method="POST" action="/missions/<%= project.id %>/delete" onsubmit="return confirm('Delete this mission project and all its files? This cannot be undone.')">
                    <button type="submit" class="btn btn-danger">🗑️ Delete</button>
                </form>
            </div>
        <% } %>
    </div>

    <div class="mission-grid">
        <%# ── Main column ─────────────────────────────────────────── %>
        <div class="mission-main">
            <section class="section">
                <h2 style="margin-top:0;">Briefing</h2>
                <% if (project.description && project.description.trim()) { %>
                    <div class="mission-description"><%- project.description %></div>
                <% } else { %>
                    <p style="color:var(--khaki);">No briefing provided.</p>
                <% } %>
            </section>

            <%# ── Mission file versions ───────────────────────────── %>
            <section class="section">
                <h2 style="margin-top:0;">Mission Files <span style="color:var(--khaki);font-weight:400;font-size:0.6em;">(raw + compiled PBO, versioned)</span></h2>
                <% if (versions.length === 0) { %>
                    <p style="color:var(--khaki);">No versions uploaded yet.</p>
                <% } else { %>
                    <div style="overflow-x:auto;">
                        <table class="mission-table">
                            <thead>
                                <tr><th>Ver</th><th>Label / Changelog</th><th>Raw</th><th>PBO</th><th>Uploaded</th><% if (canManage) { %><th></th><% } %></tr>
                            </thead>
                            <tbody>
                                <% versions.forEach(v => { %>
                                    <tr>
                                        <td>
                                            <strong>v<%= v.version_number %></strong>
                                            <% if (v.version_number === currentVersion) { %><span class="mission-current">current</span><% } %>
                                        </td>
                                        <td>
                                            <% if (v.version_label) { %><div style="font-weight:700;color:var(--accent);"><%= v.version_label %></div><% } %>
                                            <% if (v.changelog) { %><div style="white-space:pre-wrap;font-size:0.85em;color:var(--sand);"><%= v.changelog %></div><% } %>
                                            <% if (!v.version_label && !v.changelog) { %><span style="color:var(--khaki);">—</span><% } %>
                                        </td>
                                        <td>
                                            <% if (v.raw_stored_name) { %>
                                                <a href="/missions/<%= project.id %>/files/<%= v.id %>/download/raw" class="mission-dl">⬇ <%= fmtBytes(v.raw_size) %></a>
                                            <% } else { %><span style="color:var(--khaki);">—</span><% } %>
                                        </td>
                                        <td>
                                            <% if (v.pbo_stored_name) { %>
                                                <a href="/missions/<%= project.id %>/files/<%= v.id %>/download/pbo" class="mission-dl">⬇ <%= fmtBytes(v.pbo_size) %></a>
                                            <% } else { %><span style="color:var(--khaki);">—</span><% } %>
                                        </td>
                                        <td style="font-size:0.85em;color:var(--khaki);">
                                            <%= v.uploaded_by_name || 'Unknown' %><br>
                                            <%= v.uploaded_at ? new Date(v.uploaded_at).toLocaleDateString() : '' %>
                                        </td>
                                        <% if (canManage) { %>
                                            <td>
                                                <form method="POST" action="/missions/<%= project.id %>/files/<%= v.id %>/delete" onsubmit="return confirm('Delete version <%= v.version_number %>?')">
                                                    <button type="submit" class="btn btn-danger" style="padding:4px 8px;font-size:0.8em;">🗑️</button>
                                                </form>
                                            </td>
                                        <% } %>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>

                <% if (canManage) { %>
                    <details class="mission-upload">
                        <summary>➕ Upload new version</summary>
                        <form method="POST" action="/missions/<%= project.id %>/files" enctype="multipart/form-data">
                            <div class="form-group">
                                <label>Version name *</label>
                                <input type="text" name="version_label" maxlength="100" required placeholder="e.g. v1.2 — first playable">
                            </div>
                            <div class="form-group">
                                <label>Changelog (optional)</label>
                                <textarea name="changelog" rows="3" placeholder="What changed in this version?"></textarea>
                            </div>
                            <div class="form-group">
                                <label>Raw mission files (.zip / .pbo / .7z / .rar)</label>
                                <input type="file" name="raw_file" accept=".zip,.pbo,.7z,.rar,.gz">
                            </div>
                            <div class="form-group">
                                <label>Compiled PBO (.pbo)</label>
                                <input type="file" name="pbo_file" accept=".pbo">
                            </div>
                            <small style="color:var(--khaki);display:block;margin-bottom:10px;">Provide at least one file. Version number is assigned automatically.</small>
                            <button type="submit" class="btn btn-primary">Upload Version</button>
                        </form>
                    </details>
                <% } %>
            </section>

            <%# ── Info attachments ────────────────────────────────── %>
            <section class="section">
                <h2 style="margin-top:0;">Attachments <span style="color:var(--khaki);font-weight:400;font-size:0.6em;">(briefings, images, docs)</span></h2>
                <% if (attachments.length === 0) { %>
                    <p style="color:var(--khaki);">No attachments.</p>
                <% } else { %>
                    <ul class="mission-attach-list">
                        <% attachments.forEach(a => { %>
                            <li>
                                <% if (a.viewable) { %>
                                    <a href="/missions/<%= project.id %>/attachments/<%= a.id %>/download" class="mission-dl" target="_blank" rel="noopener" title="Opens in browser">👁 <%= a.original_name %></a>
                                <% } else { %>
                                    <a href="/missions/<%= project.id %>/attachments/<%= a.id %>/download" class="mission-dl" title="Download">📎 <%= a.original_name %></a>
                                <% } %>
                                <span style="color:var(--khaki);font-size:0.85em;"><%= fmtBytes(a.size) %> · <%= a.uploaded_by_name || 'Unknown' %></span>
                                <% if (canManage) { %>
                                    <form method="POST" action="/missions/<%= project.id %>/attachments/<%= a.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this attachment?')">
                                        <button type="submit" class="btn btn-danger" style="padding:2px 7px;font-size:0.78em;">✕</button>
                                    </form>
                                <% } %>
                            </li>
                        <% }) %>
                    </ul>
                <% } %>

                <% if (canManage) { %>
                    <details class="mission-upload">
                        <summary>➕ Add attachment</summary>
                        <form method="POST" action="/missions/<%= project.id %>/attachments" enctype="multipart/form-data">
                            <div class="form-group">
                                <input type="file" name="attachment" required>
                            </div>
                            <button type="submit" class="btn btn-primary">Upload Attachment</button>
                        </form>
                    </details>
                <% } %>
            </section>
        </div>

        <%# ── Sidebar ─────────────────────────────────────────────── %>
        <aside class="mission-side">
            <section class="section">
                <h3 style="margin-top:0;">Details</h3>
                <div class="mission-progress" style="margin-bottom:14px;">
                    <div class="mission-progress-fill" style="width:<%= project.progress || 0 %>%"></div>
                </div>
                <div style="text-align:right;color:var(--khaki);font-size:0.85em;margin-top:-10px;margin-bottom:12px;"><%= project.progress || 0 %>% complete</div>

                <dl class="mission-dl-list">
                    <% if (project.campaign_name) { %>
                        <dt>Campaign</dt><dd><span class="mission-campaign-tag"><span class="mission-campaign-dot" style="background:<%= project.campaign_color || '#fcb00d' %>"></span><%= project.campaign_name %></span></dd>
                    <% } %>
                    <dt>Start</dt><dd><%= ymd(project.start_date) %></dd>
                    <dt>Due</dt><dd><%= ymd(project.due_date) %></dd>
                    <dt>Lead</dt><dd><%= project.lead_display_name || '—' %></dd>
                    <% if (project.operation_title) { %>
                        <dt>Operation</dt><dd><a href="/operations/<%= project.operation_id %>" style="color:var(--accent);"><%= project.operation_title %></a></dd>
                    <% } %>
                    <% if (project.modpack_name) { %>
                        <dt>Modpack</dt><dd><a href="/modpacks/<%= project.modpack_id %>" style="color:var(--accent);"><%= project.modpack_name %></a></dd>
                    <% } %>
                    <% if (project.map_world) { %>
                        <dt>Terrain</dt><dd><%= project.map_world %></dd>
                    <% } %>
                    <dt>Created by</dt><dd><%= project.created_by_display_name || '—' %></dd>
                </dl>
            </section>

            <section class="section">
                <h3 style="margin-top:0;">Team <span style="color:var(--khaki);font-weight:400;font-size:0.7em;">(<%= assignees.length %>)</span></h3>
                <% if (assignees.length === 0) { %>
                    <p style="color:var(--khaki);">No one assigned yet.</p>
                <% } else { %>
                    <ul class="mission-team">
                        <% assignees.forEach(a => { %>
                            <li>
                                <img src="<%= avatar(a.discord_id, a.discord_avatar, 64) %>" onerror="this.src='/logo.png'" alt="">
                                <div>
                                    <div class="mission-team-name"><%= a.display_name %></div>
                                    <% if (a.role) { %><div class="mission-team-role"><%= a.role %></div><% } %>
                                </div>
                            </li>
                        <% }) %>
                    </ul>
                <% } %>
            </section>
        </aside>
    </div>
</div>

<%- include('../partials/footer') %>
