<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1><%= plan ? 'EDIT PLAN' : 'NEW PLAN' %></h1>
        <div class="subtitle">Mission planning instance</div>
    </header>

    <section class="section" style="max-width:760px;margin:0 auto;">
        <form method="POST" action="<%= plan ? '/plans/' + plan.id + '/edit' : '/plans' %>">
            <div class="form-group">
                <label for="name">Plan Name *</label>
                <input type="text" id="name" name="name" required maxlength="150"
                       value="<%= plan ? plan.name : '' %>"
                       placeholder="e.g. Saturday Op — Stratis North">
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="3"
                          placeholder="Optional notes about this plan…"><%= plan ? (plan.description || '') : '' %></textarea>
            </div>

            <div class="form-group">
                <label>🗺 Terrain</label>
                <input type="hidden" id="map_world" name="map_world" value="<%= plan ? (plan.map_world || '') : '' %>">

                <div id="map-selector-display" style="border:1px solid var(--olive);border-radius:4px;padding:12px;background:rgba(0,0,0,0.2);display:flex;align-items:center;gap:12px;min-height:64px;">
                    <div id="selected-map-thumb" style="width:80px;height:50px;border-radius:3px;background:#1a1a1a;flex-shrink:0;overflow:hidden;display:flex;align-items:center;justify-content:center;">
                        <% if (plan && plan.map_world) { %>
                            <img src="/images/maps/<%= plan.map_world %>/preview_512.png" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none'">
                        <% } else { %>
                            <span style="color:#444;font-size:1.4em;">🗺</span>
                        <% } %>
                    </div>
                    <div style="flex:1;min-width:0;">
                        <div id="selected-map-name" style="color:var(--accent);font-weight:700;font-size:0.95em;">
                            <%= (plan && plan.map_world) ? plan.map_world : 'No terrain selected' %>
                        </div>
                        <div style="color:var(--khaki);font-size:0.8em;margin-top:2px;">Pick a terrain installed on the server</div>
                    </div>
                    <div style="display:flex;gap:8px;">
                        <button type="button" id="btn-browse-maps" style="padding:6px 14px;border-radius:4px;border:1px solid var(--accent);background:transparent;color:var(--accent);cursor:pointer;font-size:0.85em;">Browse Terrains</button>
                        <button type="button" id="btn-clear-map" style="padding:6px 10px;border-radius:4px;border:1px solid #555;background:transparent;color:#888;cursor:pointer;font-size:0.85em;display:<%= (plan && plan.map_world) ? 'block' : 'none' %>;">✕</button>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label for="orbat_template_id">ORBAT Template (optional)</label>
                <select id="orbat_template_id" name="orbat_template_id">
                    <option value="">— No ORBAT —</option>
                    <% orbats.forEach(o => { %>
                        <option value="<%= o.id %>" <%= plan && parseInt(plan.orbat_template_id) === o.id ? 'selected' : '' %>><%= o.name %></option>
                    <% }); %>
                </select>
                <small style="color:var(--khaki);margin-top:5px;display:block;">
                    Linking an ORBAT lets you place its squads as units on the map. Changing or removing the ORBAT later won't break existing markers.
                </small>
            </div>

            <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:24px;">
                <a href="<%= plan ? '/plans/' + plan.id : '/plans' %>" class="btn">Cancel</a>
                <button type="submit" class="btn btn-primary"><%= plan ? 'Save' : 'Create' %></button>
            </div>
        </form>
    </section>
</div>

<!-- Terrain picker modal -->
<div id="map-picker-modal" style="display:none;position:fixed;inset:0;z-index:9000;background:rgba(0,0,0,0.75);backdrop-filter:blur(3px);align-items:center;justify-content:center;">
    <div style="background:linear-gradient(135deg,rgba(20,32,20,0.99),rgba(15,26,15,0.99));border:2px solid var(--olive);border-radius:10px;width:min(900px,94vw);max-height:90vh;display:flex;flex-direction:column;">
        <div style="padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;">
            <h3 style="flex:1;color:var(--accent);margin:0;font-size:1em;letter-spacing:0.06em;">SELECT TERRAIN</h3>
            <button id="map-picker-close" type="button" style="background:none;border:none;color:#666;font-size:1.2em;cursor:pointer;">✕</button>
        </div>
        <div style="flex:1;overflow-y:auto;padding:16px;">
            <div id="map-picker-loading" style="text-align:center;padding:40px;color:var(--khaki);">Loading terrains…</div>
            <div id="map-picker-grid" style="grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;display:none;"></div>
            <div id="map-picker-empty" style="display:none;text-align:center;padding:40px;color:#555;">
                No terrains found. Ask an admin to import one.
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    const modal       = document.getElementById('map-picker-modal');
    const grid        = document.getElementById('map-picker-grid');
    const loading     = document.getElementById('map-picker-loading');
    const empty       = document.getElementById('map-picker-empty');
    const hiddenInput = document.getElementById('map_world');
    const nameLabel   = document.getElementById('selected-map-name');
    const thumb       = document.getElementById('selected-map-thumb');
    const clearBtn    = document.getElementById('btn-clear-map');

    let mapsFetched = false;

    function openModal() {
        modal.style.display = 'flex';
        if (!mapsFetched) fetchMaps();
    }
    function closeModal() { modal.style.display = 'none'; }

    function setMap(worldName, displayName, previewUrl) {
        hiddenInput.value = worldName || '';
        nameLabel.textContent = worldName ? displayName : 'No terrain selected';
        thumb.innerHTML = previewUrl
            ? `<img src="${previewUrl}" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none'">`
            : '<span style="color:#444;font-size:1.4em;">🗺</span>';
        clearBtn.style.display = worldName ? 'block' : 'none';
        closeModal();
    }

    async function fetchMaps() {
        try {
            const res = await fetch('/operations/maps');
            const data = await res.json();
            loading.style.display = 'none';
            mapsFetched = true;

            if (!data.success || !data.maps.length) {
                empty.style.display = 'block';
                return;
            }
            grid.style.display = 'grid';
            grid.innerHTML = data.maps.map(m => `
                <div class="map-card" data-world="${m.worldName}" data-display="${m.displayName.replace(/"/g,'&quot;')}" data-preview="${m.previewUrl || ''}"
                     style="background:rgba(0,0,0,0.4);border:1px solid var(--olive);border-radius:6px;cursor:pointer;overflow:hidden;transition:border-color 0.15s;">
                    <div style="height:120px;background:#1a1a1a;">
                        ${m.previewUrl ? `<img src="${m.previewUrl}" style="width:100%;height:100%;object-fit:cover;">` : '<div style="height:100%;display:flex;align-items:center;justify-content:center;color:#333;font-size:2em;">🗺</div>'}
                    </div>
                    <div style="padding:10px 12px;">
                        <div style="font-weight:700;color:var(--accent);font-size:0.9em;margin-bottom:3px;">${m.displayName}</div>
                        ${m.worldSize ? `<div style="color:var(--khaki);font-size:0.75em;">${(m.worldSize/1000).toFixed(1)} km × ${(m.worldSize/1000).toFixed(1)} km</div>` : ''}
                        ${m.author ? `<div style="color:#666;font-size:0.72em;margin-top:2px;">${m.author}</div>` : ''}
                    </div>
                </div>
            `).join('');

            grid.querySelectorAll('.map-card').forEach(card => {
                card.addEventListener('click', () => {
                    setMap(card.dataset.world, card.dataset.display, card.dataset.preview);
                });
            });
        } catch (err) {
            console.error('fetchMaps', err);
            loading.style.display = 'none';
            empty.style.display = 'block';
        }
    }

    document.getElementById('btn-browse-maps').addEventListener('click', openModal);
    document.getElementById('map-picker-close').addEventListener('click', closeModal);
    clearBtn.addEventListener('click', () => setMap('', 'No terrain selected', ''));
    modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
})();
</script>

<%- include('../partials/footer') %>
