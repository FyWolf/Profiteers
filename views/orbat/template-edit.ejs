<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>EDIT ORBAT TEMPLATE</h1>
        <div class="subtitle"><%= template.name %></div>
    </header>

    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <section class="section">
        <h2>Template Information</h2>
        <form method="POST" action="/orbat/templates/edit/<%= template.id %>">
            <div style="display: grid; gap: 15px;">
                <div class="form-group">
                    <label for="name">Template Name</label>
                    <input type="text" id="name" name="name" value="<%= template.name %>" required>
                </div>
                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="2"><%= template.description || '' %></textarea>
                </div>
                <button type="submit" class="btn btn-primary">💾 Save Template Info</button>
            </div>
        </form>
    </section>

    <section class="section">
        <h2>➕ Add New Squad</h2>
        <form id="addSquadForm" class="card">
            <div style="display: grid; grid-template-columns: 2fr 1fr 80px auto; gap: 10px; align-items: end;">
                <div class="form-group" style="margin: 0;">
                    <label for="newSquadName">Squad Name</label>
                    <input type="text" id="newSquadName" placeholder="e.g., Alpha Squad" required>
                </div>
                <div class="form-group" style="margin: 0;">
                    <label for="newSquadColor">Color</label>
                    <input type="color" id="newSquadColor" value="#3498DB" style="width: 100%; height: 42px;">
                </div>
                <div class="form-group" style="margin: 0;">
                    <label for="newSquadOrder">Order</label>
                    <input type="number" id="newSquadOrder" value="0" min="0" style="width: 100%;">
                </div>
                <button type="submit" class="btn btn-primary" style="height: 42px;">➕ Add Squad</button>
            </div>
        </form>
    </section>

    <% if (squads.length === 0) { %>
        <section class="section">
            <div class="card text-center">
                <p style="color: var(--khaki);">No squads created yet. Add a squad above to get started!</p>
            </div>
        </section>
    <% } else { %>
        <section class="section">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 20px;">
                <% squads.forEach(squad => { %>
                    <div class="card" id="squadCard_<%= squad.id %>" style="border-left: 4px solid <%= squad.color %>; padding: 20px;">

                        <div style="margin-bottom: 15px; padding-bottom: 12px; border-bottom: 2px solid <%= squad.color %>;">
                            <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px;">
                                <h3 style="color: <%= squad.color %>; margin: 0;">
                                    <%= squad.name %>
                                </h3>
                                <div style="display: flex; gap: 6px;">
                                    <button onclick="toggleSquadEdit(<%= squad.id %>)" class="btn" style="padding: 4px 8px; font-size: 0.8em;" title="Edit squad">✏️</button>
                                    <button onclick="deleteSquad(<%= squad.id %>)" class="btn btn-danger" style="padding: 4px 8px; font-size: 0.8em;" title="Delete squad">🗑️</button>
                                </div>
                            </div>
                            <p style="font-size: 0.8em; color: var(--khaki); margin: 4px 0 0 0;">
                                <%= squad.role_count %> role<%= squad.role_count !== 1 ? 's' : '' %> | Order: <%= squad.display_order %>
                            </p>
                        </div>

                        <div id="squadEdit_<%= squad.id %>" style="display: none; padding: 12px; background: rgba(107,142,35,0.1); border-radius: 4px; margin-bottom: 12px;">
                            <div style="display: grid; grid-template-columns: 2fr 1fr 70px auto; gap: 8px; align-items: end;">
                                <div class="form-group" style="margin: 0;">
                                    <label style="font-size: 0.8em;">Name</label>
                                    <input type="text" id="editSquadName_<%= squad.id %>" value="<%= squad.name %>" required style="margin: 0;">
                                </div>
                                <div class="form-group" style="margin: 0;">
                                    <label style="font-size: 0.8em;">Color</label>
                                    <input type="color" id="editSquadColor_<%= squad.id %>" value="<%= squad.color %>" style="width: 100%; height: 36px;">
                                </div>
                                <div class="form-group" style="margin: 0;">
                                    <label style="font-size: 0.8em;">Order</label>
                                    <input type="number" id="editSquadOrder_<%= squad.id %>" value="<%= squad.display_order %>" min="0" style="margin: 0;">
                                </div>
                                <div style="display: flex; gap: 4px;">
                                    <button onclick="saveSquadEdit(<%= squad.id %>)" class="btn btn-primary" style="height: 36px; padding: 0 10px;">💾</button>
                                    <button onclick="toggleSquadEdit(<%= squad.id %>)" class="btn" style="height: 36px; padding: 0 10px;">✕</button>
                                </div>
                            </div>
                        </div>

                        <% const squadRoles = rolesBySquad[squad.id] || []; %>
                        <div id="roles-<%= squad.id %>" style="display: grid; gap: 10px;">
                            <% squadRoles.forEach(role => { %>
                                <% const assignment = assignmentsByRole[role.id]; %>
                                <div class="card" data-role-id="<%= role.id %>" style="padding: 12px; background: rgba(0,0,0,0.3); cursor: grab;">

                                    <div id="roleView_<%= role.id %>">
                                        <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 8px;">
                                            <div style="font-weight: 700; color: <%= squad.color %>; font-size: 0.9em;">
                                                <%= role.role_name %>
                                                <% if (role.is_editor) { %>
                                                    <span style="font-size: 0.7em; font-weight: 700; background: rgba(52,152,219,0.2); color: #3498DB; border: 1px solid #3498DB; padding: 1px 6px; border-radius: 3px; margin-left: 4px; vertical-align: middle;">EDITOR</span>
                                                <% } %>
                                            </div>
                                            <div style="display: flex; gap: 4px;">
                                                <button onclick="showRoleEdit(<%= role.id %>)" class="btn" style="padding: 2px 7px; font-size: 0.75em;" title="Edit slot">✏️</button>
                                                <button onclick="deleteRole(<%= role.id %>)" class="btn btn-danger" style="padding: 2px 7px; font-size: 0.75em;" title="Delete slot">🗑️</button>
                                            </div>
                                        </div>

                                        <% if (assignment) { %>
                                            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                                                <% if (assignment.discord_avatar) { %>
                                                    <img src="https://cdn.discordapp.com/avatars/<%= assignment.discord_id %>/<%= assignment.discord_avatar %>.png?size=64"
                                                         style="width: 28px; height: 28px; border-radius: 50%; border: 2px solid <%= squad.color %>;">
                                                <% } else { %>
                                                    <div style="width: 28px; height: 28px; border-radius: 50%; background: <%= squad.color %>; display: flex; align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 0.75em;">
                                                        <%= (assignment.discord_global_name || assignment.username).charAt(0).toUpperCase() %>
                                                    </div>
                                                <% } %>
                                                <div style="flex: 1; min-width: 0;">
                                                    <div style="font-weight: 600; color: var(--sand); font-size: 0.85em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                        <%= assignment.discord_global_name || assignment.username %>
                                                    </div>
                                                </div>
                                                <div style="display: flex; gap: 4px;">
                                                    <button onclick="showAssignModal(<%= role.id %>, '<%= role.role_name.replace(/'/g, "\\'") %>')" class="btn" style="padding: 3px 8px; font-size: 0.78em;" title="Change player">🔄</button>
                                                    <button onclick="unassignPlayer(<%= role.id %>)" class="btn btn-danger" style="padding: 3px 8px; font-size: 0.78em;" title="Remove player">✖️</button>
                                                </div>
                                            </div>
                                        <% } else { %>
                                            <div style="display: flex; align-items: center; justify-content: space-between;">
                                                <span style="color: var(--khaki); opacity: 0.7; font-size: 0.85em; font-style: italic;">Empty</span>
                                                <button onclick="showAssignModal(<%= role.id %>, '<%= role.role_name.replace(/'/g, "\\'") %>')" class="btn" style="padding: 3px 8px; font-size: 0.78em; background: <%= squad.color %>; color: white;">➕ Assign</button>
                                            </div>
                                        <% } %>
                                    </div>

                                    <div id="roleEdit_<%= role.id %>" style="display: none;">
                                        <div style="display: grid; grid-template-columns: 1fr 65px auto; gap: 6px; align-items: center;">
                                            <input type="text" id="roleEditName_<%= role.id %>" value="<%= role.role_name %>"
                                                   style="padding: 6px 10px; background: rgba(40,40,40,0.9); color: var(--sand); border: 1px solid var(--olive); border-radius: 4px; font-size: 0.9em;">
                                            <input type="number" id="roleEditOrder_<%= role.id %>" value="<%= role.display_order %>" min="0"
                                                   style="padding: 6px 8px; background: rgba(40,40,40,0.9); color: var(--sand); border: 1px solid var(--olive); border-radius: 4px; font-size: 0.9em;" title="Display order">
                                            <div style="display: flex; gap: 4px;">
                                                <button onclick="saveRoleEdit(<%= role.id %>)" class="btn btn-primary" style="padding: 5px 10px; font-size: 0.85em;">💾</button>
                                                <button onclick="hideRoleEdit(<%= role.id %>)" class="btn" style="padding: 5px 10px; font-size: 0.85em;">✕</button>
                                            </div>
                                        </div>
                                        <label style="display: flex; align-items: center; gap: 6px; margin-top: 8px; font-size: 0.82em; color: var(--khaki); cursor: pointer;" title="Assigned user can manage this squad's assignments">
                                            <input type="checkbox" id="roleEditIsEditor_<%= role.id %>" <%= role.is_editor ? 'checked' : '' %> style="width: 15px; height: 15px;">
                                            Editor (can manage this squad's assignments)
                                        </label>
                                    </div>

                                </div>
                            <% }); %>
                        </div>

                        <div style="margin-top: 12px; padding: 10px; border: 2px dashed <%= squad.color %>; border-radius: 4px; background: rgba(<%= parseInt(squad.color.slice(1,3), 16) %>, <%= parseInt(squad.color.slice(3,5), 16) %>, <%= parseInt(squad.color.slice(5,7), 16) %>, 0.07);">
                            <div style="display: flex; gap: 8px; align-items: center;">
                                <input type="text" id="newRoleName_<%= squad.id %>" placeholder="New slot name..."
                                       style="flex: 1; padding: 6px 10px; background: rgba(40,40,40,0.9); color: var(--sand); border: 1px solid var(--olive); border-radius: 4px; font-size: 0.88em;"
                                       onkeydown="if(event.key==='Enter') addRole(<%= squad.id %>)">
                                <label style="display: flex; align-items: center; gap: 4px; font-size: 0.82em; color: var(--khaki); white-space: nowrap; cursor: pointer;" title="Assigned user can manage this squad's assignments">
                                    <input type="checkbox" id="newRoleIsEditor_<%= squad.id %>" style="width: 14px; height: 14px;">
                                    Editor
                                </label>
                                <button onclick="addRole(<%= squad.id %>)" class="btn" style="padding: 6px 12px; background: <%= squad.color %>; color: white; font-size: 0.85em; white-space: nowrap;">
                                    ➕ Add Slot
                                </button>
                            </div>
                        </div>

                    </div>
                <% }); %>
            </div>
        </section>
    <% } %>

    <section class="section">
        <a href="/orbat/templates" class="btn">← Back to Templates</a>
    </section>
</div>

<div id="assignModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); z-index: 2000; align-items: center; justify-content: center;">
    <div class="card" style="max-width: 500px; width: 90%;">
        <h3 style="margin-bottom: 15px;">Assign Player to <span id="modalRoleName"></span></h3>
        <div class="form-group">
            <label for="playerSearch">Search Roster</label>
            <input type="text" id="playerSearch" placeholder="Type player name..." oninput="searchPlayers(this.value)">
        </div>
        <div id="playerResults" style="max-height: 300px; overflow-y: auto; margin-bottom: 15px;">
            <p style="color: var(--khaki); text-align: center;">Start typing to search...</p>
        </div>
        <div style="display: flex; gap: 10px;">
            <button onclick="closeAssignModal()" class="btn" style="flex: 1;">Cancel</button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<style>.sortable-ghost { opacity: 0.4; }</style>

<script>
const templateId = '<%= template.id %>';
let currentRoleId = null;

function toggleSquadEdit(squadId) {
    const el = document.getElementById('squadEdit_' + squadId);
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
}

async function saveSquadEdit(squadId) {
    const name = document.getElementById('editSquadName_' + squadId).value.trim();
    const color = document.getElementById('editSquadColor_' + squadId).value;
    const displayOrder = document.getElementById('editSquadOrder_' + squadId).value;
    if (!name) { alert('Squad name cannot be empty'); return; }
    try {
        const response = await fetch(`/orbat/api/squads/${squadId}/edit`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, color, displayOrder })
        });
        const data = await response.json();
        if (data.success) { location.reload(); }
        else { alert(data.error || 'Failed to update squad'); }
    } catch (error) {
        alert('Failed to update squad');
    }
}

async function deleteSquad(squadId) {
    if (!confirm('Delete this squad and all its roles?')) return;
    try {
        const response = await fetch(`/orbat/api/squads/${squadId}/delete`, { method: 'POST' });
        const data = await response.json();
        if (data.success) { location.reload(); }
        else { alert(data.error || 'Failed to delete squad'); }
    } catch (error) {
        alert('Failed to delete squad');
    }
}

function showRoleEdit(roleId) {
    document.getElementById('roleView_' + roleId).style.display = 'none';
    document.getElementById('roleEdit_' + roleId).style.display = 'block';
    document.getElementById('roleEditName_' + roleId).focus();
}

function hideRoleEdit(roleId) {
    document.getElementById('roleEdit_' + roleId).style.display = 'none';
    document.getElementById('roleView_' + roleId).style.display = 'block';
}

async function saveRoleEdit(roleId) {
    const name = document.getElementById('roleEditName_' + roleId).value.trim();
    const displayOrder = document.getElementById('roleEditOrder_' + roleId).value;
    const isEditor = document.getElementById('roleEditIsEditor_' + roleId).checked;
    if (!name) { alert('Role name cannot be empty'); return; }
    try {
        const response = await fetch(`/orbat/api/roles/${roleId}/edit`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ roleName: name, displayOrder, isEditor })
        });
        const data = await response.json();
        if (data.success) { location.reload(); }
        else { alert(data.error || 'Failed to update slot'); }
    } catch (error) {
        alert('Failed to update slot');
    }
}

async function deleteRole(roleId) {
    if (!confirm('Delete this slot? This will also remove any player assigned to it.')) return;
    try {
        const response = await fetch(`/orbat/api/roles/${roleId}/delete`, { method: 'POST' });
        const data = await response.json();
        if (data.success) { location.reload(); }
        else { alert(data.error || 'Failed to delete slot'); }
    } catch (error) {
        alert('Failed to delete slot');
    }
}

async function addRole(squadId) {
    const input = document.getElementById('newRoleName_' + squadId);
    const name = input.value.trim();
    const isEditor = document.getElementById('newRoleIsEditor_' + squadId).checked;
    if (!name) { input.focus(); return; }
    try {
        const response = await fetch(`/orbat/api/squads/${squadId}/add-role`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ roleName: name, isEditor })
        });
        const data = await response.json();
        if (data.success) { location.reload(); }
        else { alert(data.error || 'Failed to add slot'); }
    } catch (error) {
        alert('Failed to add slot');
    }
}

function showAssignModal(roleId, roleName) {
    currentRoleId = roleId;
    document.getElementById('modalRoleName').textContent = roleName;
    document.getElementById('assignModal').style.display = 'flex';
    document.getElementById('playerSearch').value = '';
    document.getElementById('playerResults').innerHTML = '<p style="color: var(--khaki); text-align: center;">Start typing to search...</p>';
}

function closeAssignModal() {
    document.getElementById('assignModal').style.display = 'none';
    currentRoleId = null;
}

async function searchPlayers(query) {
    if (query.length < 2) {
        document.getElementById('playerResults').innerHTML = '<p style="color: var(--khaki); text-align: center;">Type at least 2 characters...</p>';
        return;
    }
    try {
        const response = await fetch(`/roster/search?q=${encodeURIComponent(query)}`);
        const players = await response.json();
        if (players.length === 0) {
            document.getElementById('playerResults').innerHTML = '<p style="color: var(--khaki); text-align: center;">No players found</p>';
            return;
        }
        let html = '<div style="display: grid; gap: 8px;">';
        players.forEach(player => {
            const badge = player.needs_registration ? '<span style="background: rgba(241,196,15,0.3); color: #f1c40f; padding: 2px 6px; border-radius: 3px; font-size: 0.75em; margin-left: 8px;">Not logged in</span>' : '';
            html += `<div onclick='assignPlayer(${JSON.stringify(player)})'
                          style="padding: 10px; background: rgba(0,0,0,0.3); border-radius: 4px; cursor: pointer; transition: background 0.2s;"
                          onmouseover="this.style.background='rgba(107,142,35,0.3)'"
                          onmouseout="this.style.background='rgba(0,0,0,0.3)'">
                         <strong>${player.name}</strong>${badge}
                     </div>`;
        });
        html += '</div>';
        document.getElementById('playerResults').innerHTML = html;
    } catch (error) {
        console.error('Error searching players:', error);
    }
}

async function assignPlayer(player) {
    const confirmMsg = player.needs_registration
        ? `Assign ${player.name}? (They haven't logged in yet - we'll create an account for them)`
        : `Assign ${player.name} to this slot?`;
    if (!confirm(confirmMsg)) return;
    try {
        const response = await fetch(`/orbat/assign/${currentRoleId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: player.user_id, discordId: player.discord_id })
        });
        const data = await response.json();
        if (data.success) { location.reload(); }
        else { alert(data.error || 'Failed to assign player'); }
    } catch (error) {
        alert('Failed to assign player');
    }
}

async function unassignPlayer(roleId) {
    if (!confirm('Remove player from this slot?')) return;
    try {
        const response = await fetch(`/orbat/unassign/${roleId}`, { method: 'POST' });
        const data = await response.json();
        if (data.success) { location.reload(); }
        else { alert(data.error || 'Failed to remove player'); }
    } catch (error) {
        alert('Failed to remove player');
    }
}

document.getElementById('assignModal')?.addEventListener('click', (e) => {
    if (e.target.id === 'assignModal') closeAssignModal();
});

document.getElementById('addSquadForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('newSquadName').value;
    const color = document.getElementById('newSquadColor').value;
    const displayOrder = document.getElementById('newSquadOrder').value;
    try {
        const response = await fetch(`/orbat/api/templates/${templateId}/squads/add`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, color, displayOrder })
        });
        const data = await response.json();
        if (data.success) { location.reload(); }
        else { alert(data.error || 'Failed to add squad'); }
    } catch (error) {
        alert('Failed to add squad');
    }
});

document.addEventListener('DOMContentLoaded', () => {
    <% squads.forEach(squad => { %>
    new Sortable(document.getElementById('roles-<%= squad.id %>'), {
        animation: 150,
        ghostClass: 'sortable-ghost',
        handle: '[data-role-id]',
        onEnd: async function() {
            const container = document.getElementById('roles-<%= squad.id %>');
            const roleIds = Array.from(container.querySelectorAll('[data-role-id]'))
                .map(el => el.getAttribute('data-role-id'));
            try {
                await fetch('/orbat/api/squads/<%= squad.id %>/reorder-roles', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ roleIds })
                });
            } catch (e) {
                console.error('Failed to save role order:', e);
            }
        }
    });
    <% }); %>
});
</script>

<%- include('../partials/footer') %>
