<%- include('../partials/header') %>
<%
function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function renderTemplateRoleCard(role, squad) {
    const assignment = assignmentsByRole[role.id];
    const editorBadge = role.is_editor
        ? `<span style="font-size:0.6em;font-weight:700;background:rgba(52,152,219,0.2);color:#3498DB;border:1px solid #3498DB;padding:1px 4px;border-radius:3px;margin-left:3px;vertical-align:middle;">ED</span>`
        : '';

    let avatarHtml = '';
    if (assignment) {
        if (assignment.discord_avatar) {
            avatarHtml = `<img src="https://cdn.discordapp.com/avatars/${esc(assignment.discord_id)}/${esc(assignment.discord_avatar)}.png?size=32" style="width:20px;height:20px;border-radius:50%;border:1px solid ${squad.color};flex-shrink:0;">`;
        } else {
            const initial = esc((assignment.roster_nickname || assignment.discord_global_name || assignment.username).charAt(0).toUpperCase());
            avatarHtml = `<div style="width:20px;height:20px;border-radius:50%;background:${squad.color};display:flex;align-items:center;justify-content:center;font-weight:900;color:white;font-size:0.62em;flex-shrink:0;">${initial}</div>`;
        }
    } else {
        avatarHtml = `<div style="width:20px;height:20px;border-radius:50%;border:1px dashed rgba(178,178,125,0.25);flex-shrink:0;"></div>`;
    }

    const assignedName = assignment
        ? esc(assignment.roster_nickname || assignment.discord_global_name || assignment.username)
        : `<span style="color:var(--khaki);opacity:0.4;font-style:italic;">empty</span>`;
    const escapedRoleName = esc(JSON.stringify(role.role_name));

    const assignBtns = assignment
        ? `<button onclick="showAssignModal(${role.id}, ${escapedRoleName})" class="btn" style="padding:2px 5px;font-size:0.72em;" title="Change">🔄</button><button onclick="unassignPlayer(${role.id})" class="btn btn-danger" style="padding:2px 5px;font-size:0.72em;" title="Remove">✕</button>`
        : `<button onclick="showAssignModal(${role.id}, ${escapedRoleName})" class="btn" style="padding:2px 5px;font-size:0.72em;background:${squad.color};color:white;" title="Assign">➕</button>`;

    return `<div data-role-id="${role.id}" style="border-bottom:1px solid rgba(255,255,255,0.04);cursor:grab;">
        <div id="roleView_${role.id}" style="display:flex;align-items:center;gap:6px;padding:5px 8px;">
            <div style="font-size:0.77em;font-weight:700;color:${squad.color};width:95px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${esc(role.role_name)}">${esc(role.role_name)}${editorBadge}</div>
            ${avatarHtml}
            <div style="flex:1;min-width:0;font-size:0.8em;color:var(--sand);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${assignedName}</div>
            <div style="display:flex;gap:3px;flex-shrink:0;">
                ${assignBtns}
                <button onclick="showRoleEdit(${role.id})" class="btn" style="padding:2px 5px;font-size:0.72em;" title="Edit">✏️</button>
                <button onclick="deleteRole(${role.id})" class="btn btn-danger" style="padding:2px 5px;font-size:0.72em;" title="Delete">🗑️</button>
            </div>
        </div>
        <div id="roleEdit_${role.id}" style="display:none;padding:6px 8px;background:rgba(0,0,0,0.2);border-top:1px solid rgba(255,255,255,0.06);">
            <div style="display:grid;grid-template-columns:1fr 55px auto;gap:6px;align-items:center;">
                <input type="text" id="roleEditName_${role.id}" value="${esc(role.role_name)}"
                       style="padding:4px 8px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;font-size:0.85em;margin:0;">
                <input type="number" id="roleEditOrder_${role.id}" value="${role.display_order}" min="0"
                       style="padding:4px 6px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;font-size:0.85em;margin:0;" title="Display order">
                <div style="display:flex;gap:4px;">
                    <button onclick="saveRoleEdit(${role.id})" class="btn btn-primary" style="padding:3px 8px;font-size:0.8em;">💾</button>
                    <button onclick="hideRoleEdit(${role.id})" class="btn" style="padding:3px 8px;font-size:0.8em;">✕</button>
                </div>
            </div>
            <label style="display:flex;align-items:center;gap:6px;margin-top:6px;font-size:0.8em;color:var(--khaki);cursor:pointer;" title="Assigned user can manage this squad's assignments">
                <input type="checkbox" id="roleEditIsEditor_${role.id}" ${role.is_editor ? 'checked' : ''} style="width:14px;height:14px;">
                Editor (can manage this squad's assignments)
            </label>
        </div>
    </div>`;
}

function renderTemplateSquadCard(squad) {
    const roles = rolesBySquad[squad.id] || [];
    const rolesHtml = roles.map(role => renderTemplateRoleCard(role, squad)).join('');

    const addRoleSection = `
        <div style="margin-top: 12px; padding: 10px; border: 2px dashed ${squad.color}; border-radius: 4px; background: rgba(0,0,0,0.2); overflow: hidden;">
            <div style="display: flex; gap: 6px; align-items: center; min-width: 0;">
                <input type="text" id="newRoleName_${squad.id}" placeholder="New slot name..."
                       style="flex: 1; min-width: 0; padding: 6px 8px; background: rgba(40,40,40,0.9); color: var(--sand); border: 1px solid var(--olive); border-radius: 4px; font-size: 0.88em; margin: 0;"
                       onkeydown="if(event.key==='Enter') addRole(${squad.id})">
                <label style="display: flex; align-items: center; gap: 4px; font-size: 0.82em; color: var(--khaki); white-space: nowrap; flex-shrink: 0; cursor: pointer;" title="Assigned user can manage this squad's assignments">
                    <input type="checkbox" id="newRoleIsEditor_${squad.id}" style="width: 14px; height: 14px;">
                    Editor
                </label>
                <button onclick="addRole(${squad.id})" class="btn" style="flex-shrink: 0; padding: 6px 10px; background: ${squad.color}; color: white; font-size: 0.85em; white-space: nowrap;">➕</button>
            </div>
        </div>`;

    const addSubgroupSection = `
        <div id="addSubForm_${squad.id}" style="display: none; margin-top: 10px; padding: 10px; border: 1px dashed var(--khaki); border-radius: 4px; background: rgba(0,0,0,0.2); overflow: hidden;">
            <div style="display: flex; gap: 6px; align-items: center; min-width: 0;">
                <input type="text" id="addSubName_${squad.id}" placeholder="Sub-group name..." style="flex: 1; min-width: 0; padding: 6px 8px; background: rgba(40,40,40,0.9); color: var(--sand); border: 1px solid var(--olive); border-radius: 4px; font-size: 0.88em; margin: 0;" onkeydown="if(event.key==='Enter'){event.preventDefault();submitAddChildSquad(${squad.id})}">
                <input type="color" id="addSubColor_${squad.id}" value="#6b8e23" style="width: 34px; height: 34px; flex-shrink: 0; border: none; background: none; cursor: pointer; padding: 0;">
                <button onclick="submitAddChildSquad(${squad.id})" class="btn btn-primary" style="flex-shrink: 0; height: 34px; padding: 0 10px; font-size: 0.85em;">➕</button>
                <button onclick="document.getElementById('addSubForm_${squad.id}').style.display='none'" class="btn" style="flex-shrink: 0; height: 34px; padding: 0 8px; font-size: 0.85em;">✕</button>
            </div>
        </div>
        <button onclick="toggleAddSub(${squad.id})" class="btn" style="margin-top: 8px; width: 100%; background: rgba(0,0,0,0.2); border: 1px dashed var(--khaki); font-size: 0.8em; padding: 6px;">➕ Add Sub-group</button>`;

    return `<div class="card orbat-squad-card" id="squadCard_${squad.id}" style="border-left: 4px solid ${squad.color}; padding: 10px 12px;">
        <div style="margin-bottom: 6px; padding-bottom: 6px; border-bottom: 2px solid ${squad.color};">
            <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px;">
                <h3 style="color: ${squad.color}; margin: 0; font-size: 0.92em;">${esc(squad.name)}</h3>
                <div style="display: flex; gap: 4px;">
                    <button onclick="toggleSquadEdit(${squad.id})" class="btn" style="padding: 2px 6px; font-size: 0.75em;" title="Edit group">✏️</button>
                    <button onclick="deleteSquad(${squad.id})" class="btn btn-danger" style="padding: 2px 6px; font-size: 0.75em;" title="Delete group">🗑️</button>
                </div>
            </div>
        </div>
        <div id="squadEdit_${squad.id}" style="display: none; padding: 10px; background: rgba(107,142,35,0.1); border-radius: 4px; margin-bottom: 8px;">
            <div style="display: grid; grid-template-columns: 2fr 1fr 70px auto; gap: 8px; align-items: end;">
                <div class="form-group" style="margin: 0;">
                    <label style="font-size: 0.8em;">Name</label>
                    <input type="text" id="editSquadName_${squad.id}" value="${esc(squad.name)}" required style="margin: 0;">
                </div>
                <div class="form-group" style="margin: 0;">
                    <label style="font-size: 0.8em;">Color</label>
                    <input type="color" id="editSquadColor_${squad.id}" value="${squad.color}" style="width: 100%; height: 36px;">
                </div>
                <div class="form-group" style="margin: 0;">
                    <label style="font-size: 0.8em;">Order</label>
                    <input type="number" id="editSquadOrder_${squad.id}" value="${squad.display_order}" min="0" style="margin: 0;">
                </div>
                <div style="display: flex; gap: 4px;">
                    <button onclick="saveSquadEdit(${squad.id})" class="btn btn-primary" style="height: 36px; padding: 0 10px;">💾</button>
                    <button onclick="toggleSquadEdit(${squad.id})" class="btn" style="height: 36px; padding: 0 10px;">✕</button>
                </div>
            </div>
        </div>
        <div id="roles-${squad.id}" style="display:flex;flex-direction:column;">${rolesHtml}</div>
        ${addRoleSection}
        ${addSubgroupSection}
    </div>`;
}

function renderTemplateNode(node, isRoot) {
    const wrapClass = isRoot ? 'org-node' : 'org-col';
    const cardHtml = renderTemplateSquadCard(node);
    let childrenHtml = '';
    if (node.children && node.children.length > 0) {
        childrenHtml = `<div class="org-v-bar"></div><div class="org-row">${node.children.map(child => renderTemplateNode(child, false)).join('')}</div>`;
    }
    return `<div class="${wrapClass}">${cardHtml}${childrenHtml}</div>`;
}
%>

<div class="container orbat-wide">
    <header>
        <h1>EDIT ORBAT TEMPLATE</h1>
        <div class="subtitle"><%= template.name %></div>
    </header>

    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <section class="section">
        <h2>Template Information</h2>
        <form method="POST" action="/orbat/templates/edit/<%= template.id %>">
            <div style="display: grid; gap: 15px;">
                <div class="form-group">
                    <label for="name">Template Name</label>
                    <input type="text" id="name" name="name" value="<%= template.name %>" required>
                </div>
                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="2"><%= template.description || '' %></textarea>
                </div>
                <button type="submit" class="btn btn-primary">💾 Save Template Info</button>
            </div>
        </form>
    </section>

    <section class="section">
        <h2>➕ Add Root Group</h2>
        <form id="addSquadForm" class="card">
            <div style="display: grid; grid-template-columns: 2fr 1fr 80px auto; gap: 10px; align-items: end;">
                <div class="form-group" style="margin: 0;">
                    <label for="newSquadName">Group Name</label>
                    <input type="text" id="newSquadName" placeholder="e.g., 1st Platoon" required>
                </div>
                <div class="form-group" style="margin: 0;">
                    <label for="newSquadColor">Color</label>
                    <input type="color" id="newSquadColor" value="#3498DB" style="width: 100%; height: 42px;">
                </div>
                <div class="form-group" style="margin: 0;">
                    <label for="newSquadOrder">Order</label>
                    <input type="number" id="newSquadOrder" value="0" min="0" style="width: 100%;">
                </div>
                <button type="submit" class="btn btn-primary" style="height: 42px;">➕ Add</button>
            </div>
        </form>
    </section>

    <% if (squads.length === 0) { %>
        <section class="section">
            <div class="card text-center">
                <p style="color: var(--khaki);">No groups created yet. Add a group above to get started!</p>
            </div>
        </section>
    <% } else { %>
        <section class="section">
            <div class="org-tree-scroll">
                <div class="org-tree-root">
                    <%- squadTree.map(root => renderTemplateNode(root, true)).join('') %>
                </div>
            </div>
        </section>
    <% } %>

    <section class="section">
        <a href="/orbat/templates" class="btn">← Back to Templates</a>
    </section>
</div>

<div id="assignModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); z-index: 2000; align-items: center; justify-content: center;">
    <div class="card" style="max-width: 500px; width: 90%;">
        <h3 style="margin-bottom: 15px;">Assign Player to <span id="modalRoleName"></span></h3>
        <div class="form-group">
            <label for="playerSearch">Search Roster</label>
            <input type="text" id="playerSearch" placeholder="Type player name..." oninput="searchPlayers(this.value)">
        </div>
        <div id="playerResults" style="max-height: 300px; overflow-y: auto; margin-bottom: 15px;">
            <p style="color: var(--khaki); text-align: center;">Start typing to search...</p>
        </div>
        <div style="display: flex; gap: 10px;">
            <button onclick="closeAssignModal()" class="btn" style="flex: 1;">Cancel</button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<style>.sortable-ghost { opacity: 0.4; }</style>

<script>
const templateId = '<%= template.id %>';
let currentRoleId = null;

function toggleSquadEdit(squadId) {
    const el = document.getElementById('squadEdit_' + squadId);
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
}

async function saveSquadEdit(squadId) {
    const name = document.getElementById('editSquadName_' + squadId).value.trim();
    const color = document.getElementById('editSquadColor_' + squadId).value;
    const displayOrder = document.getElementById('editSquadOrder_' + squadId).value;
    if (!name) { alert('Group name cannot be empty'); return; }
    try {
        const r = await fetch(`/orbat/api/squads/${squadId}/edit`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, color, displayOrder })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to update group');
    } catch { alert('Failed to update group'); }
}

async function deleteSquad(squadId) {
    if (!confirm('Delete this group and all its roles?')) return;
    try {
        const r = await fetch(`/orbat/api/squads/${squadId}/delete`, { method: 'POST' });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to delete group');
    } catch { alert('Failed to delete group'); }
}

function showRoleEdit(roleId) {
    document.getElementById('roleView_' + roleId).style.display = 'none';
    document.getElementById('roleEdit_' + roleId).style.display = 'block';
    document.getElementById('roleEditName_' + roleId).focus();
}

function hideRoleEdit(roleId) {
    document.getElementById('roleEdit_' + roleId).style.display = 'none';
    document.getElementById('roleView_' + roleId).style.display = 'block';
}

async function saveRoleEdit(roleId) {
    const name = document.getElementById('roleEditName_' + roleId).value.trim();
    const displayOrder = document.getElementById('roleEditOrder_' + roleId).value;
    const isEditor = document.getElementById('roleEditIsEditor_' + roleId).checked;
    if (!name) { alert('Role name cannot be empty'); return; }
    try {
        const r = await fetch(`/orbat/api/roles/${roleId}/edit`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ roleName: name, displayOrder, isEditor })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to update slot');
    } catch { alert('Failed to update slot'); }
}

async function deleteRole(roleId) {
    if (!confirm('Delete this slot? This will also remove any player assigned to it.')) return;
    try {
        const r = await fetch(`/orbat/api/roles/${roleId}/delete`, { method: 'POST' });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to delete slot');
    } catch { alert('Failed to delete slot'); }
}

async function addRole(squadId) {
    const input = document.getElementById('newRoleName_' + squadId);
    const name = input.value.trim();
    const isEditor = document.getElementById('newRoleIsEditor_' + squadId).checked;
    if (!name) { input.focus(); return; }
    try {
        const r = await fetch(`/orbat/api/squads/${squadId}/add-role`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ roleName: name, isEditor })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to add slot');
    } catch { alert('Failed to add slot'); }
}

function toggleAddSub(squadId) {
    const form = document.getElementById('addSubForm_' + squadId);
    if (form.style.display === 'none') {
        form.style.display = 'block';
        document.getElementById('addSubName_' + squadId).focus();
    } else {
        form.style.display = 'none';
    }
}

async function submitAddChildSquad(parentSquadId) {
    const nameInput = document.getElementById('addSubName_' + parentSquadId);
    const colorInput = document.getElementById('addSubColor_' + parentSquadId);
    const name = nameInput.value.trim();
    if (!name) { nameInput.focus(); return; }
    try {
        const r = await fetch(`/orbat/api/templates/${templateId}/squads/add`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, color: colorInput.value, displayOrder: 0, parentSquadId })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to add sub-group');
    } catch { alert('Failed to add sub-group'); }
}

function showAssignModal(roleId, roleName) {
    currentRoleId = roleId;
    document.getElementById('modalRoleName').textContent = roleName;
    document.getElementById('assignModal').style.display = 'flex';
    document.getElementById('playerSearch').value = '';
    document.getElementById('playerResults').innerHTML = '<p style="color: var(--khaki); text-align: center;">Start typing to search...</p>';
}

function closeAssignModal() {
    document.getElementById('assignModal').style.display = 'none';
    currentRoleId = null;
}

let _playerSearchResults = [];

async function searchPlayers(query) {
    if (query.length < 2) {
        document.getElementById('playerResults').innerHTML = '<p style="color: var(--khaki); text-align: center;">Type at least 2 characters...</p>';
        return;
    }
    try {
        const r = await fetch(`/roster/search?q=${encodeURIComponent(query)}`);
        const players = await r.json();
        if (players.length === 0) {
            document.getElementById('playerResults').innerHTML = '<p style="color: var(--khaki); text-align: center;">No players found</p>';
            return;
        }
        _playerSearchResults = players;
        let html = '<div style="display: grid; gap: 8px;">';
        players.forEach((p, i) => {
            const badge = p.needs_registration ? '<span style="background: rgba(241,196,15,0.3); color: #f1c40f; padding: 2px 6px; border-radius: 3px; font-size: 0.75em; margin-left: 8px;">Not logged in</span>' : '';
            const safeName = p.name.replace(/</g, '&lt;').replace(/>/g, '&gt;');
            html += `<div onclick="assignPlayer(${i})" style="padding: 10px; background: rgba(0,0,0,0.3); border-radius: 4px; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='rgba(107,142,35,0.3)'" onmouseout="this.style.background='rgba(0,0,0,0.3)'"><strong>${safeName}</strong>${badge}</div>`;
        });
        html += '</div>';
        document.getElementById('playerResults').innerHTML = html;
    } catch (e) { console.error('Error searching players:', e); }
}

async function assignPlayer(playerOrIndex) {
    const player = typeof playerOrIndex === 'number' ? _playerSearchResults[playerOrIndex] : playerOrIndex;
    const msg = player.needs_registration
        ? `Assign ${player.name}? (They haven't logged in yet - we'll create an account for them)`
        : `Assign ${player.name} to this slot?`;
    if (!confirm(msg)) return;
    try {
        const r = await fetch(`/orbat/assign/${currentRoleId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: player.user_id, discordId: player.discord_id })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to assign player');
    } catch { alert('Failed to assign player'); }
}

async function unassignPlayer(roleId) {
    if (!confirm('Remove player from this slot?')) return;
    try {
        const r = await fetch(`/orbat/unassign/${roleId}`, { method: 'POST' });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to remove player');
    } catch { alert('Failed to remove player'); }
}

document.getElementById('assignModal')?.addEventListener('click', e => {
    if (e.target.id === 'assignModal') closeAssignModal();
});

document.getElementById('addSquadForm').addEventListener('submit', async e => {
    e.preventDefault();
    try {
        const r = await fetch(`/orbat/api/templates/${templateId}/squads/add`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                name: document.getElementById('newSquadName').value,
                color: document.getElementById('newSquadColor').value,
                displayOrder: document.getElementById('newSquadOrder').value
            })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to add group');
    } catch { alert('Failed to add group'); }
});

document.addEventListener('DOMContentLoaded', () => {
    <% squads.forEach(squad => { %>
    if (document.getElementById('roles-<%= squad.id %>')) {
        new Sortable(document.getElementById('roles-<%= squad.id %>'), {
            animation: 150,
            ghostClass: 'sortable-ghost',
            handle: '[data-role-id]',
            onEnd: async function() {
                const container = document.getElementById('roles-<%= squad.id %>');
                const roleIds = Array.from(container.querySelectorAll('[data-role-id]')).map(el => el.getAttribute('data-role-id'));
                try {
                    await fetch('/orbat/api/squads/<%= squad.id %>/reorder-roles', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ roleIds })
                    });
                } catch (e) { console.error('Failed to save role order:', e); }
            }
        });
    }
    <% }); %>
});
</script>

<%- include('../partials/footer') %>
