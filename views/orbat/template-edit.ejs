<%- include('../partials/header') %>
<script>document.documentElement.style.removeProperty('--heading-font');</script>
<%
function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function renderTemplateRoleCard(role, squad) {
    const assignment = assignmentsByRole[role.id];
    const editorBadge = role.is_editor
        ? `<span style="font-size:0.6em;font-weight:700;background:rgba(52,152,219,0.2);color:#3498DB;border:1px solid #3498DB;padding:1px 4px;border-radius:3px;margin-left:3px;vertical-align:middle;">ED</span>`
        : '';

    let avatarHtml = '';
    if (assignment) {
        if (assignment.discord_avatar) {
            avatarHtml = `<img src="https://cdn.discordapp.com/avatars/${esc(assignment.discord_id)}/${esc(assignment.discord_avatar)}.png?size=32" style="width:20px;height:20px;border-radius:50%;border:1px solid ${squad.color};flex-shrink:0;display:block;margin:auto 0;">`;
        } else {
            const initial = esc((assignment.roster_nickname || assignment.discord_global_name || assignment.username).charAt(0).toUpperCase());
            avatarHtml = `<div style="width:20px;height:20px;border-radius:50%;background:${squad.color};display:flex;align-items:center;justify-content:center;font-weight:900;color:white;font-size:0.62em;flex-shrink:0;">${initial}</div>`;
        }
    } else {
        avatarHtml = `<div style="width:20px;height:20px;border-radius:50%;border:1px dashed rgba(178,178,125,0.25);flex-shrink:0;"></div>`;
    }

    const nameText = assignment ? esc(assignment.roster_nickname || assignment.discord_global_name || assignment.username) : null;

    const playerSlot = assignment
        ? `<a href="/profile/${assignment.user_id}" style="display:flex;align-items:center;gap:6px;flex:1;min-width:0;text-decoration:none;overflow:hidden;">
            ${avatarHtml}
            <div style="min-width:0;overflow:hidden;">
                <div style="font-size:0.77em;font-weight:700;color:${squad.color};white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${esc(role.role_name)}">${esc(role.role_name)}${editorBadge}</div>
                <div style="font-size:0.72em;color:var(--sand);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${nameText}</div>
            </div>
           </a>`
        : `<div style="display:flex;align-items:center;gap:6px;flex:1;min-width:0;">
            ${avatarHtml}
            <div style="min-width:0;overflow:hidden;">
                <div style="font-size:0.77em;font-weight:700;color:${squad.color};white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${esc(role.role_name)}">${esc(role.role_name)}${editorBadge}</div>
                <div style="font-size:0.72em;color:var(--khaki);opacity:0.4;font-style:italic;white-space:nowrap;">empty</div>
            </div>
           </div>`;
    const escapedRoleName = esc(JSON.stringify(role.role_name));

    const roleMenuItems = assignment
        ? `<button class="ctrl-menu-item" onclick="showAssignModal(${role.id}, ${escapedRoleName})">Change player</button>
           <button class="ctrl-menu-item ctrl-menu-danger" onclick="unassignPlayer(${role.id})">Kill player</button>
           <button class="ctrl-menu-item" onclick="showRoleEdit(${role.id})">Edit slot</button>
           <button class="ctrl-menu-item ctrl-menu-danger" onclick="deleteRole(${role.id})">Delete slot</button>`
        : `<button class="ctrl-menu-item" onclick="showAssignModal(${role.id}, ${escapedRoleName})">Assign player</button>
           <button class="ctrl-menu-item" onclick="showRoleEdit(${role.id})">Edit slot</button>
           <button class="ctrl-menu-item ctrl-menu-danger" onclick="deleteRole(${role.id})">Delete slot</button>`;

    return `<div data-role-id="${role.id}" style="border-bottom:1px solid rgba(255,255,255,0.04);cursor:grab;">
        <div id="roleView_${role.id}" style="display:flex;align-items:center;gap:6px;padding:5px 8px;">
            ${playerSlot}
            <div class="ctrl-menu">
                <button class="ctrl-menu-btn" onclick="toggleCtrlMenu(this)">···</button>
                <div class="ctrl-menu-list">${roleMenuItems}</div>
            </div>
        </div>
        <div id="roleEdit_${role.id}" style="display:none;padding:6px 8px;background:rgba(0,0,0,0.2);border-top:1px solid rgba(255,255,255,0.06);">
            <input type="text" id="roleEditName_${role.id}" value="${esc(role.role_name)}"
                   style="width:100%;box-sizing:border-box;padding:4px 8px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;font-size:0.85em;margin:0 0 5px 0;">
            <div style="display:flex;gap:4px;align-items:center;flex-wrap:wrap;">
                <label style="display:flex;align-items:center;gap:4px;font-size:0.8em;color:var(--khaki);cursor:pointer;flex:1;white-space:nowrap;" title="Assigned user can manage this squad's assignments">
                    <input type="checkbox" id="roleEditIsEditor_${role.id}" ${role.is_editor ? 'checked' : ''} style="width:14px;height:14px;">
                    Editor
                </label>
                <input type="number" id="roleEditOrder_${role.id}" value="${role.display_order}" min="0"
                       style="width:52px;flex-shrink:0;padding:3px 5px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;font-size:0.8em;margin:0;" title="Display order">
                <button onclick="saveRoleEdit(${role.id})" class="btn btn-primary" style="flex-shrink:0;padding:3px 8px;font-size:0.8em;">💾</button>
                <button onclick="hideRoleEdit(${role.id})" class="btn" style="flex-shrink:0;padding:3px 8px;font-size:0.8em;">✕</button>
            </div>
        </div>
    </div>`;
}

function renderTemplateSquadCard(squad) {
    const roles = rolesBySquad[squad.id] || [];
    const teams = teamsBySquad[squad.id] || [];
    const lrBadge = squad.lr_frequency ? `<span title="Long Range" style="font-size:0.68em;background:rgba(0,100,200,0.25);color:#7bb3e0;padding:1px 5px;border-radius:3px;white-space:nowrap;">LR ${esc(squad.lr_frequency)}</span>` : '';
    const srBadge = squad.sr_frequency ? `<span title="Short Range" style="font-size:0.68em;background:rgba(0,180,100,0.25);color:#7de0a5;padding:1px 5px;border-radius:3px;white-space:nowrap;">SR ${esc(squad.sr_frequency)}</span>` : '';
    const squadFreqForm = `
        <div id="sqFreqForm_${squad.id}" style="display:none;padding:6px 8px;background:rgba(0,0,0,0.25);border-radius:4px;margin-bottom:6px;">
            <div style="display:flex;gap:4px;align-items:center;flex-wrap:wrap;">
                <span style="font-size:0.75em;color:var(--khaki);white-space:nowrap;">LR</span>
                <input type="text" id="sqLrFreq_${squad.id}" value="${esc(squad.lr_frequency || '')}" placeholder="e.g. 45.300" style="width:80px;flex-shrink:0;margin:0;font-size:0.8em;padding:3px 6px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;">
                <span style="font-size:0.75em;color:var(--khaki);white-space:nowrap;">SR</span>
                <input type="text" id="sqSrFreq_${squad.id}" value="${esc(squad.sr_frequency || '')}" placeholder="e.g. 50.100" style="width:80px;flex-shrink:0;margin:0;font-size:0.8em;padding:3px 6px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;">
                <button onclick="submitSquadFrequencies(${squad.id})" class="btn btn-primary" style="padding:2px 8px;font-size:0.78em;flex-shrink:0;">Save</button>
                <button onclick="document.getElementById('sqFreqForm_${squad.id}').style.display='none'" class="btn" style="padding:2px 6px;font-size:0.78em;flex-shrink:0;">✕</button>
            </div>
        </div>`;

    const unassigned = roles.filter(r => !r.team_id);
    const unassignedHtml = `<div id="unassigned-${squad.id}" data-team-roles="${squad.id}" data-team-id="" style="min-height:6px;">
        ${''}
        ${unassigned.map(r => renderTemplateRoleCard(r, squad)).join('')}
    </div>`;

    const teamsHtml = teams.map(team => {
        const teamRoles = roles.filter(r => r.team_id === team.id);
        const teamLrBadge = team.lr_frequency ? `<span title="Long Range" style="font-size:0.65em;background:rgba(0,100,200,0.25);color:#7bb3e0;padding:1px 4px;border-radius:3px;white-space:nowrap;">LR ${esc(team.lr_frequency)}</span>` : '';
        const teamSrBadge = team.sr_frequency ? `<span title="Short Range" style="font-size:0.65em;background:rgba(0,180,100,0.25);color:#7de0a5;padding:1px 4px;border-radius:3px;white-space:nowrap;">SR ${esc(team.sr_frequency)}</span>` : '';
        const teamFreqBadges = (teamLrBadge || teamSrBadge) ? `<div style="display:flex;gap:2px;flex-wrap:wrap;margin-top:2px;">${teamLrBadge}${teamSrBadge}</div>` : '';
        const teamFreqForm = `
            <div id="tmFreqForm_${team.id}" style="display:none;padding:4px 8px;background:rgba(0,0,0,0.25);">
                <div style="display:flex;gap:4px;align-items:center;flex-wrap:wrap;">
                    <span style="font-size:0.75em;color:var(--khaki);white-space:nowrap;">LR</span>
                    <input type="text" id="tmLrFreq_${team.id}" value="${esc(team.lr_frequency || '')}" placeholder="e.g. 45.300" style="width:80px;flex-shrink:0;margin:0;font-size:0.8em;padding:3px 6px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;">
                    <span style="font-size:0.75em;color:var(--khaki);white-space:nowrap;">SR</span>
                    <input type="text" id="tmSrFreq_${team.id}" value="${esc(team.sr_frequency || '')}" placeholder="e.g. 50.100" style="width:80px;flex-shrink:0;margin:0;font-size:0.8em;padding:3px 6px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;">
                    <button onclick="submitTeamFrequencies(${team.id})" class="btn btn-primary" style="padding:2px 8px;font-size:0.78em;flex-shrink:0;">Save</button>
                    <button onclick="document.getElementById('tmFreqForm_${team.id}').style.display='none'" class="btn" style="padding:2px 6px;font-size:0.78em;flex-shrink:0;">✕</button>
                </div>
            </div>`;
        return `<div data-team-block="${team.id}">
            <div class="team-hdr" style="cursor:grab;display:flex;align-items:center;gap:4px;padding:3px 8px;margin-top:4px;background:rgba(0,0,0,0.25);border-left:3px solid ${team.color};">
                <div style="flex:1;min-width:0;overflow:hidden;">
                    <div style="font-size:0.7em;font-weight:700;color:${team.color};letter-spacing:0.04em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(team.name)}</div>
                    ${teamFreqBadges}
                </div>
                <div class="ctrl-menu">
                    <button class="ctrl-menu-btn" onclick="toggleCtrlMenu(this)">···</button>
                    <div class="ctrl-menu-list">
                        <button class="ctrl-menu-item" onclick="toggleFreqForm('tm', ${team.id})">Radio Freq</button>
                        <button class="ctrl-menu-item" onclick="startEditTeam(${team.id})">Rename</button>
                        <button class="ctrl-menu-item ctrl-menu-danger" onclick="deleteTeam(${team.id})">Delete team</button>
                    </div>
                </div>
            </div>
            <div id="editTeamForm_${team.id}" style="display:none;padding:4px 8px;background:rgba(0,0,0,0.25);">
                <div style="display:flex;gap:4px;align-items:center;">
                    <input type="text" id="editTeamName_${team.id}" value="${esc(team.name)}" style="flex:1;margin:0;font-size:0.82em;padding:3px 6px;">
                    <input type="color" id="editTeamColor_${team.id}" value="${esc(team.color)}" style="width:28px;height:28px;flex-shrink:0;border:none;background:none;cursor:pointer;padding:0;">
                    <button onclick="submitEditTeam(${team.id})" class="btn btn-primary" style="flex-shrink:0;padding:2px 8px;font-size:0.78em;">Save</button>
                    <button onclick="document.getElementById('editTeamForm_${team.id}').style.display='none'" class="btn" style="flex-shrink:0;padding:2px 6px;font-size:0.78em;">✕</button>
                </div>
            </div>
            ${teamFreqForm}
            <div id="team-roles-${team.id}" data-team-roles="${squad.id}" data-team-id="${team.id}" style="min-height:10px;">
                ${teamRoles.map(r => renderTemplateRoleCard(r, squad)).join('')}
            </div>
        </div>`;
    }).join('');

    const addTeamHtml = `<div id="addTeamForm_${squad.id}" style="display:none;margin-top:6px;padding:6px 8px;background:rgba(0,0,0,0.2);border-radius:4px;border:1px dashed ${squad.color};">
            <div style="display:flex;gap:4px;align-items:center;">
                <input type="text" id="addTeamName_${squad.id}" placeholder="Team name..." style="flex:1;min-width:0;margin:0;font-size:0.82em;padding:4px 6px;">
                <input type="color" id="addTeamColor_${squad.id}" value="${squad.color}" style="width:28px;height:28px;flex-shrink:0;border:none;background:none;cursor:pointer;padding:0;">
                <button onclick="submitAddTeam(${squad.id})" class="btn btn-primary" style="flex-shrink:0;height:28px;padding:0 8px;font-size:0.8em;">➕</button>
                <button onclick="document.getElementById('addTeamForm_${squad.id}').style.display='none'" class="btn" style="flex-shrink:0;height:28px;padding:0 6px;font-size:0.8em;">✕</button>
            </div>
           </div>
           <button onclick="toggleAddTeam(${squad.id})" class="btn" style="margin-top:5px;width:100%;background:rgba(0,0,0,0.15);border:1px dashed rgba(178,178,125,0.3);font-size:0.75em;padding:3px;">➕ Add Team</button>`;

    const addRoleSection = `
        <div style="margin-top: 8px; padding: 8px; border: 2px dashed ${squad.color}; border-radius: 4px; background: rgba(0,0,0,0.2); overflow: hidden;">
            <div style="display: flex; gap: 6px; align-items: center; min-width: 0;">
                <input type="text" id="newRoleName_${squad.id}" placeholder="New slot name..."
                       style="flex: 1; min-width: 0; padding: 6px 8px; background: rgba(40,40,40,0.9); color: var(--sand); border: 1px solid var(--olive); border-radius: 4px; font-size: 0.88em; margin: 0;"
                       onkeydown="if(event.key==='Enter') addRole(${squad.id})">
                <label style="display: flex; align-items: center; gap: 4px; font-size: 0.82em; color: var(--khaki); white-space: nowrap; flex-shrink: 0; cursor: pointer;" title="Assigned user can manage this squad's assignments">
                    <input type="checkbox" id="newRoleIsEditor_${squad.id}" style="width: 14px; height: 14px;">
                    Editor
                </label>
                <button onclick="addRole(${squad.id})" class="btn" style="flex-shrink: 0; padding: 6px 10px; background: ${squad.color}; color: white; font-size: 0.85em; white-space: nowrap;">➕</button>
            </div>
        </div>`;

    const addSubgroupSection = `
        <div id="addSubForm_${squad.id}" style="display: none; margin-top: 10px; padding: 10px; border: 1px dashed var(--khaki); border-radius: 4px; background: rgba(0,0,0,0.2); overflow: hidden;">
            <div style="display: flex; gap: 6px; align-items: center; min-width: 0;">
                <input type="text" id="addSubName_${squad.id}" placeholder="Sub-group name..." style="flex: 1; min-width: 0; padding: 6px 8px; background: rgba(40,40,40,0.9); color: var(--sand); border: 1px solid var(--olive); border-radius: 4px; font-size: 0.88em; margin: 0;" onkeydown="if(event.key==='Enter'){event.preventDefault();submitAddChildSquad(${squad.id})}">
                <input type="color" id="addSubColor_${squad.id}" value="#6b8e23" style="width: 34px; height: 34px; flex-shrink: 0; border: none; background: none; cursor: pointer; padding: 0;">
                <button onclick="submitAddChildSquad(${squad.id})" class="btn btn-primary" style="flex-shrink: 0; height: 34px; padding: 0 10px; font-size: 0.85em;">➕</button>
                <button onclick="document.getElementById('addSubForm_${squad.id}').style.display='none'" class="btn" style="flex-shrink: 0; height: 34px; padding: 0 8px; font-size: 0.85em;">✕</button>
            </div>
        </div>
        <button onclick="toggleAddSub(${squad.id})" class="btn" style="margin-top: 8px; width: 100%; background: rgba(0,0,0,0.2); border: 1px dashed var(--khaki); font-size: 0.8em; padding: 6px;">➕ Add Sub-group</button>`;

    const iconHtml = squad.icon
        ? `<img id="squadIcon_${squad.id}" src="/uploads/squad-icons/${esc(squad.icon)}" style="width:28px;height:28px;border-radius:4px;object-fit:cover;border:1px solid ${squad.color};flex-shrink:0;">`
        : `<div id="squadIcon_${squad.id}" style="width:28px;height:28px;border-radius:4px;background:rgba(0,0,0,0.3);border:1px dashed rgba(178,178,125,0.3);flex-shrink:0;"></div>`;

    return `<div class="card orbat-squad-card" id="squadCard_${squad.id}" style="border-left: 4px solid ${squad.color}; padding: 10px 12px;">
        <input type="file" id="iconInput_${squad.id}" accept="image/*" style="display:none" onchange="uploadSquadIcon(${squad.id}, this)">
        <div style="margin-bottom: 6px; padding-bottom: 6px; border-bottom: 2px solid ${squad.color};">
            <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px;">
                <div style="display:flex;align-items:center;gap:6px;flex:1;min-width:0;">
                    <span class="squad-drag-handle" title="Drag to reorder" style="cursor:grab;color:var(--khaki);opacity:0.35;flex-shrink:0;font-size:1.05em;user-select:none;padding:0 2px;">⠿</span>
                    ${iconHtml}
                    <div style="min-width:0;">
                        <div style="display:flex;align-items:center;gap:4px;flex-wrap:wrap;">
                            <h3 style="color: ${squad.color}; margin: 0; font-size: 0.92em; word-break: break-word;">${esc(squad.name)}</h3>
                            ${lrBadge}${srBadge}
                        </div>
                    </div>
                </div>
                <div class="ctrl-menu">
                    <button class="ctrl-menu-btn" onclick="toggleCtrlMenu(this)">···</button>
                    <div class="ctrl-menu-list">
                        <button class="ctrl-menu-item" onclick="document.getElementById('iconInput_${squad.id}').click()">${squad.icon ? 'Change icon' : 'Upload icon'}</button>
                        ${squad.icon ? `<button class="ctrl-menu-item ctrl-menu-danger" onclick="removeSquadIcon(${squad.id})">Remove icon</button>` : ''}
                        <button class="ctrl-menu-item" onclick="toggleFreqForm('sq', ${squad.id})">Radio Freq</button>
                        <button class="ctrl-menu-item" onclick="toggleSquadEdit(${squad.id})">Edit group</button>
                        <button class="ctrl-menu-item ctrl-menu-danger" onclick="deleteSquad(${squad.id})">Delete group</button>
                    </div>
                </div>
            </div>
        </div>
        <div id="squadEdit_${squad.id}" style="display: none; padding: 8px; background: rgba(107,142,35,0.1); border-radius: 4px; margin-bottom: 8px;">
            <input type="text" id="editSquadName_${squad.id}" value="${esc(squad.name)}" required
                   style="width:100%;box-sizing:border-box;margin:0 0 6px 0;padding:4px 8px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;font-size:0.85em;">
            <div style="display:flex;gap:6px;align-items:center;justify-content:flex-end;">
                <label style="font-size:0.78em;color:var(--khaki);flex-shrink:0;">Order</label>
                <input type="number" id="editSquadOrder_${squad.id}" value="${squad.display_order}" min="0"
                       style="width:52px;flex-shrink:0;padding:4px 5px;margin:0;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;font-size:0.85em;">
                <input type="color" id="editSquadColor_${squad.id}" value="${squad.color}"
                       style="width:34px;height:30px;flex-shrink:0;border:none;background:none;cursor:pointer;padding:0;">
                <button onclick="saveSquadEdit(${squad.id})" class="btn btn-primary" style="flex-shrink:0;padding:4px 10px;">💾</button>
                <button onclick="toggleSquadEdit(${squad.id})" class="btn" style="flex-shrink:0;padding:4px 10px;">✕</button>
            </div>
        </div>
        ${squadFreqForm}
        ${unassignedHtml}
        <div id="teams-order-${squad.id}">${teamsHtml}</div>
        ${addTeamHtml}
        ${addRoleSection}
        ${addSubgroupSection}
    </div>`;
}

function renderTemplateNode(node, isRoot) {
    const wrapClass = isRoot ? 'org-node' : 'org-col';
    const cardHtml = renderTemplateSquadCard(node);
    let childrenHtml = '';
    if (node.children && node.children.length > 0) {
        childrenHtml = `<div class="org-v-bar"></div><div class="org-row">${node.children.map(child => renderTemplateNode(child, false)).join('')}</div>`;
    }
    return `<div class="${wrapClass}" data-squad-id="${node.id}">${cardHtml}${childrenHtml}</div>`;
}
%>


<div class="container orbat-wide">
    <header>
        <h1>EDIT ORBAT TEMPLATE</h1>
        <div class="subtitle"><%= template.name %></div>
    </header>

    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <section class="section">
        <div style="position:relative;">
            <div class="org-tree-scroll" style="min-height:120px;">
                <% if (squads.length === 0) { %>
                    <div class="card text-center" style="margin:60px auto;max-width:400px;">
                        <p style="color: var(--khaki);">No groups yet. Use the panel to add one.</p>
                    </div>
                <% } else { %>
                    <div class="org-tree-root">
                        <%- squadTree.map(root => renderTemplateNode(root, true)).join('') %>
                    </div>
                <% } %>
            </div>

            <div id="editPanel" style="position:absolute;top:10px;left:10px;z-index:100;background:rgba(15,24,15,0.96);border:1px solid var(--olive);border-radius:6px;box-shadow:0 4px 18px rgba(0,0,0,0.6);width:220px;">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 10px;border-bottom:1px solid rgba(107,142,35,0.3);cursor:pointer;" onclick="toggleEditPanel()">
                    <span style="font-size:0.75em;font-weight:700;color:var(--olive);letter-spacing:0.06em;text-transform:uppercase;">Settings</span>
                    <span id="editPanelChevron" style="font-size:0.7em;color:var(--khaki);transition:transform 0.2s;">▾</span>
                </div>
                <div id="editPanelBody" style="padding:8px 10px;display:flex;flex-direction:column;gap:8px;">
                    <form method="POST" action="/orbat/templates/edit/<%= template.id %>" style="display:flex;flex-direction:column;gap:5px;">
                        <label style="font-size:0.7em;color:var(--khaki);margin:0;">Name</label>
                        <input type="text" name="name" value="<%= template.name %>" required placeholder="Template name" style="margin:0;font-size:0.8em;padding:4px 7px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;">
                        <label style="font-size:0.7em;color:var(--khaki);margin:0;">Description</label>
                        <input type="text" name="description" value="<%= template.description || '' %>" placeholder="Optional" style="margin:0;font-size:0.8em;padding:4px 7px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;">
                        <button type="submit" class="btn btn-primary" style="font-size:0.78em;padding:3px 8px;margin-top:2px;">Save info</button>
                    </form>
                    <div style="height:1px;background:rgba(255,255,255,0.07);"></div>
                    <form id="addSquadForm" style="display:flex;flex-direction:column;gap:5px;">
                        <div style="font-size:0.72em;font-weight:700;color:var(--olive);text-transform:uppercase;letter-spacing:0.05em;">Add top-level group</div>
                        <div style="font-size:0.68em;color:var(--khaki);opacity:0.7;margin-bottom:2px;">A platoon, section or any top-level unit. Sub-groups can be nested inside after creation.</div>
                        <label style="font-size:0.7em;color:var(--khaki);margin:0;">Group name</label>
                        <input type="text" id="newSquadName" placeholder="e.g. 1st Platoon" required style="margin:0;font-size:0.8em;padding:4px 7px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;">
                        <div style="display:flex;gap:6px;">
                            <div style="display:flex;flex-direction:column;gap:2px;flex:1;min-width:0;">
                                <label style="font-size:0.7em;color:var(--khaki);margin:0;">Order</label>
                                <input type="number" id="newSquadOrder" value="0" min="0" style="margin:0;font-size:0.8em;padding:4px 7px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;width:100%;box-sizing:border-box;">
                            </div>
                            <div style="display:flex;flex-direction:column;gap:2px;align-items:center;flex-shrink:0;">
                                <label style="font-size:0.7em;color:var(--khaki);margin:0;">Color</label>
                                <input type="color" id="newSquadColor" value="#3498DB" style="width:32px;height:28px;border:none;background:none;cursor:pointer;padding:0;">
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary" style="font-size:0.78em;padding:3px 8px;margin-top:2px;">Add group</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <section class="section">
        <a href="/orbat/templates" class="btn">← Back to Templates</a>
    </section>
</div>

<script>
const templateId = '<%= template.id %>';

function toggleSquadEdit(squadId) {
    const el = document.getElementById('squadEdit_' + squadId);
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
}

async function saveSquadEdit(squadId) {
    const name = document.getElementById('editSquadName_' + squadId).value.trim();
    const color = document.getElementById('editSquadColor_' + squadId).value;
    const displayOrder = document.getElementById('editSquadOrder_' + squadId).value;
    if (!name) { alert('Group name cannot be empty'); return; }
    try {
        const r = await fetch(`/orbat/api/squads/${squadId}/edit`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, color, displayOrder })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to update group');
    } catch { alert('Failed to update group'); }
}

async function deleteSquad(squadId) {
    if (!confirm('Delete this group and all its roles?')) return;
    try {
        const r = await fetch(`/orbat/api/squads/${squadId}/delete`, { method: 'POST' });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to delete group');
    } catch { alert('Failed to delete group'); }
}

function showRoleEdit(roleId) {
    document.getElementById('roleView_' + roleId).style.display = 'none';
    document.getElementById('roleEdit_' + roleId).style.display = 'block';
    document.getElementById('roleEditName_' + roleId).focus();
}

function hideRoleEdit(roleId) {
    document.getElementById('roleEdit_' + roleId).style.display = 'none';
    document.getElementById('roleView_' + roleId).style.display = 'block';
}

async function saveRoleEdit(roleId) {
    const name = document.getElementById('roleEditName_' + roleId).value.trim();
    const displayOrder = document.getElementById('roleEditOrder_' + roleId).value;
    const isEditor = document.getElementById('roleEditIsEditor_' + roleId).checked;
    if (!name) { alert('Role name cannot be empty'); return; }
    try {
        const r = await fetch(`/orbat/api/roles/${roleId}/edit`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ roleName: name, displayOrder, isEditor })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to update slot');
    } catch { alert('Failed to update slot'); }
}

async function deleteRole(roleId) {
    if (!confirm('Delete this slot? This will also remove any player assigned to it.')) return;
    try {
        const r = await fetch(`/orbat/api/roles/${roleId}/delete`, { method: 'POST' });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to delete slot');
    } catch { alert('Failed to delete slot'); }
}

async function addRole(squadId) {
    const input = document.getElementById('newRoleName_' + squadId);
    const name = input.value.trim();
    const isEditor = document.getElementById('newRoleIsEditor_' + squadId).checked;
    if (!name) { input.focus(); return; }
    try {
        const r = await fetch(`/orbat/api/squads/${squadId}/add-role`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ roleName: name, isEditor })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to add slot');
    } catch { alert('Failed to add slot'); }
}

async function submitAddChildSquad(parentSquadId) {
    const nameInput = document.getElementById('addSubName_' + parentSquadId);
    const colorInput = document.getElementById('addSubColor_' + parentSquadId);
    const name = nameInput.value.trim();
    if (!name) { nameInput.focus(); return; }
    try {
        const r = await fetch(`/orbat/api/templates/${templateId}/squads/add`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, color: colorInput.value, displayOrder: 0, parentSquadId })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to add sub-group');
    } catch { alert('Failed to add sub-group'); }
}

document.getElementById('addSquadForm').addEventListener('submit', async e => {
    e.preventDefault();
    try {
        const r = await fetch(`/orbat/api/templates/${templateId}/squads/add`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                name: document.getElementById('newSquadName').value,
                color: document.getElementById('newSquadColor').value,
                displayOrder: document.getElementById('newSquadOrder').value
            })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to add group');
    } catch { alert('Failed to add group'); }
});

function toggleEditPanel() {
    const body = document.getElementById('editPanelBody');
    const chevron = document.getElementById('editPanelChevron');
    const collapsed = body.style.display === 'none';
    body.style.display = collapsed ? 'flex' : 'none';
    chevron.style.transform = collapsed ? '' : 'rotate(-90deg)';
}

document.addEventListener('DOMContentLoaded', () => {
    <% squads.forEach(squad => { %>
    {
    document.querySelectorAll('[data-team-roles="<%= squad.id %>"]').forEach(container => {
        new Sortable(container, {
            group: 'roles-<%= squad.id %>',
            animation: 150,
            ghostClass: 'sortable-ghost',
            handle: '[data-role-id]',
            onEnd: async function(evt) {
                const roleId = evt.item.getAttribute('data-role-id');
                const newTeamId = evt.to.getAttribute('data-team-id') || null;
                const oldTeamId = evt.from.getAttribute('data-team-id') || null;
                if (String(newTeamId) !== String(oldTeamId)) {
                    try {
                        await fetch(`/orbat/api/roles/${roleId}/set-team`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ teamId: newTeamId ? parseInt(newTeamId) : null })
                        });
                    } catch(e) { console.error('Failed to set team:', e); }
                }
                const allRoleIds = [];
                document.querySelectorAll('[data-team-roles="<%= squad.id %>"] [data-role-id]').forEach(el => {
                    allRoleIds.push(el.getAttribute('data-role-id'));
                });
                try {
                    await fetch('/orbat/api/squads/<%= squad.id %>/reorder-roles', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ roleIds: allRoleIds })
                    });
                } catch(e) { console.error('Failed to reorder roles:', e); }
            }
        });
    });
    const teamsOrderEl = document.getElementById('teams-order-<%= squad.id %>');
    if (teamsOrderEl) {
        new Sortable(teamsOrderEl, {
            animation: 150,
            handle: '.team-hdr',
            ghostClass: 'sortable-ghost',
            onEnd: async function() {
                const teamIds = Array.from(teamsOrderEl.querySelectorAll('[data-team-block]')).map(el => el.getAttribute('data-team-block'));
                try {
                    await fetch('/orbat/api/squads/<%= squad.id %>/reorder-teams', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ teamIds })
                    });
                } catch(e) { console.error('Failed to reorder teams:', e); }
            }
        });
    }
    } // end block scope for squad
    <% }); %>

    // Squad drag-to-reorder
    [document.querySelector('.org-tree-root'), ...document.querySelectorAll('.org-row')].forEach(container => {
        if (!container) return;
        new Sortable(container, {
            animation: 150,
            ghostClass: 'sortable-ghost',
            handle: '.squad-drag-handle',
            onEnd: async function() {
                const ids = Array.from(container.querySelectorAll(':scope > [data-squad-id]'))
                                 .map(el => el.getAttribute('data-squad-id'));
                if (ids.length < 2) return;
                try {
                    await fetch(`/orbat/api/squads/${ids[0]}/reorder-siblings`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ squadIds: ids })
                    });
                } catch(e) { console.error('Failed to reorder squads:', e); }
            }
        });
    });
});
</script>

<%- include('./_orbat-shared') %>
<%- include('../partials/footer') %>
