<%- include('../partials/header') %>
<script>document.documentElement.style.removeProperty('--heading-font');</script>
<%
function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function renderPubRoleCard(role, squad, canEdit) {
    const assignment = assignments[role.id];
    const escapedRoleName = esc(JSON.stringify(role.role_name));

    let avatarHtml = '';
    if (assignment) {
        if (assignment.discord_avatar) {
            avatarHtml = `<img src="https://cdn.discordapp.com/avatars/${esc(assignment.discord_id)}/${esc(assignment.discord_avatar)}.png?size=32" style="width:20px;height:20px;border-radius:50%;border:1px solid ${squad.color};flex-shrink:0;display:block;margin:auto 0;">`;
        } else {
            const initial = esc((assignment.roster_nickname || assignment.discord_global_name || assignment.username).charAt(0).toUpperCase());
            avatarHtml = `<div style="width:20px;height:20px;border-radius:50%;background:${squad.color};display:flex;align-items:center;justify-content:center;font-weight:900;color:white;font-size:0.62em;flex-shrink:0;">${initial}</div>`;
        }
    } else {
        avatarHtml = `<div style="width:20px;height:20px;border-radius:50%;border:1px dashed rgba(178,178,125,0.25);flex-shrink:0;"></div>`;
    }

    const nameText = assignment ? esc(assignment.roster_nickname || assignment.discord_global_name || assignment.username) : null;

    const playerSlot = assignment
        ? `<a href="/profile/${assignment.user_id}" style="display:flex;align-items:center;gap:6px;flex:1;min-width:0;text-decoration:none;overflow:hidden;">
            ${avatarHtml}
            <div style="min-width:0;overflow:hidden;">
                <div style="font-size:0.77em;font-weight:700;color:${squad.color};white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${esc(role.role_name)}">${esc(role.role_name)}</div>
                <div style="font-size:0.72em;color:var(--sand);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${nameText}</div>
            </div>
           </a>`
        : `<div style="display:flex;align-items:center;gap:6px;flex:1;min-width:0;">
            ${avatarHtml}
            <div style="min-width:0;overflow:hidden;">
                <div style="font-size:0.77em;font-weight:700;color:${squad.color};white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${esc(role.role_name)}">${esc(role.role_name)}</div>
                <div style="font-size:0.72em;color:var(--khaki);opacity:0.4;font-style:italic;white-space:nowrap;">empty</div>
            </div>
           </div>`;

    const actionBtns = canEdit
        ? `<div class="ctrl-menu">
               <button class="ctrl-menu-btn" onclick="toggleCtrlMenu(this)">···</button>
               <div class="ctrl-menu-list">
                   ${assignment
                       ? `<button class="ctrl-menu-item" onclick="showAssignModal(${role.id}, ${escapedRoleName})">Change player</button>
                          <button class="ctrl-menu-item ctrl-menu-danger" onclick="unassignPlayer(${role.id})">Remove player</button>`
                       : `<button class="ctrl-menu-item" onclick="showAssignModal(${role.id}, ${escapedRoleName})">Assign player</button>`}
                   <button class="ctrl-menu-item" onclick="showRoleEdit(${role.id})">Edit slot</button>
                   <button class="ctrl-menu-item ctrl-menu-danger" onclick="deleteRole(${role.id})">Delete slot</button>
               </div>
           </div>`
        : '';

    const _slotOpts = (typeof slotTypes !== 'undefined' ? slotTypes : []).map(st =>
        `<option value="${st.id}"${st.id == role.slot_type_id ? ' selected' : ''}>${esc(st.name)}${st.abbreviation ? ' (' + esc(st.abbreviation) + ')' : ''}</option>`
    ).join('');
    const editZone = canEdit
        ? `<div id="roleEdit_${role.id}" style="display:none;padding:6px 8px;background:rgba(0,0,0,0.2);border-top:1px solid rgba(255,255,255,0.06);">
            <select id="roleEditSlotType_${role.id}"
                    style="width:100%;box-sizing:border-box;padding:4px 8px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;font-size:0.85em;margin:0 0 5px 0;">
                ${_slotOpts}
            </select>
            <div style="display:flex;gap:4px;justify-content:flex-end;">
                <button onclick="saveRoleEdit(${role.id})" class="btn btn-primary" style="flex-shrink:0;padding:3px 8px;font-size:0.8em;">💾</button>
                <button onclick="hideRoleEdit(${role.id})" class="btn" style="flex-shrink:0;padding:3px 8px;font-size:0.8em;">✕</button>
            </div>
           </div>`
        : '';

    return `<div data-role-id="${role.id}" style="border-bottom:1px solid rgba(255,255,255,0.04);${canEdit ? ' cursor:grab;' : ''}">
        <div id="roleView_${role.id}" style="display:flex;align-items:center;gap:6px;padding:5px 8px;">
            ${playerSlot}
            ${actionBtns}
        </div>
        ${editZone}
    </div>`;
}

function renderPubSquadCard(squad) {
    const _pubEditorIds = (user && editorSquadIds && Array.isArray(editorSquadIds)) ? editorSquadIds.map(Number) : [];
    const canEdit = _pubEditorIds.includes(Number(squad.id));
    const yourSquadBadge = canEdit
        ? `<span style="font-size:0.55em;font-weight:700;background:rgba(52,152,219,0.2);color:#3498DB;border:1px solid #3498DB;padding:2px 8px;border-radius:3px;vertical-align:middle;letter-spacing:0.05em;">YOUR SQUAD</span>`
        : '';
    const _addSlotOpts = (typeof slotTypes !== 'undefined' ? slotTypes : []).map(st =>
        `<option value="${st.id}">${esc(st.name)}${st.abbreviation ? ' (' + esc(st.abbreviation) + ')' : ''}</option>`
    ).join('');
    const addRoleOverrideHtml = canEdit
        ? `<div style="margin-top:8px;padding:8px;border:2px dashed ${squad.color};border-radius:4px;background:rgba(0,0,0,0.2);overflow:hidden;">
            <div style="display:flex;gap:6px;align-items:center;min-width:0;">
                <select id="newRoleSlotType_${squad.id}"
                        style="flex:1;min-width:0;padding:6px 8px;background:rgba(40,40,40,0.9);color:var(--sand);border:1px solid var(--olive);border-radius:4px;font-size:0.88em;margin:0;">
                    <option value="">Select slot type...</option>
                    ${_addSlotOpts}
                </select>
                <button onclick="addRoleFromTemplate(${squad.id})" class="btn" style="flex-shrink:0;padding:6px 10px;background:${squad.color};color:white;font-size:0.85em;">➕</button>
            </div>
           </div>`
        : '';
    return buildSquadCard(squad, {
        canEdit,
        canDynamic: canEdit,
        canDeleteSquad: canEdit && !!squad.parent_squad_id,
        badgeHtml: yourSquadBadge,
        addRoleOverrideHtml,
        renderRole: r => renderPubRoleCard(r, squad, canEdit)
    });
}

function renderPubNode(node, isRoot) {
    const wrapClass = isRoot ? 'org-node' : 'org-col';
    const cardHtml = renderPubSquadCard(node);
    let childrenHtml = '';
    if (node.children && node.children.length > 0) {
        childrenHtml = `<div class="org-v-bar"></div><div class="org-row">${node.children.map(child => renderPubNode(child, false)).join('')}</div>`;
    }
    return `<div class="${wrapClass}" data-squad-id="${node.id}">${cardHtml}${childrenHtml}</div>`;
}
%>


<div class="container orbat-wide">
    <header>
        <h1><%= template.name %></h1>
        <% if (template.description) { %>
            <div class="subtitle"><%= template.description %></div>
        <% } %>
    </header>

    <% if (squads.length === 0) { %>
        <section class="section">
            <div class="card text-center">
                <p style="color: var(--khaki);">This ORBAT template has no squads defined yet.</p>
            </div>
        </section>
    <% } else { %>
        <section class="section">
            <div class="org-tree-scroll">
                <div class="org-tree-root">
                    <%- squadTree.map(root => renderPubNode(root, true)).join('') %>
                </div>
            </div>
        </section>
    <% } %>

    <%# ─── Change History Toggle ─────────────────────────────────────── %>
    <section class="section" style="margin-top: 30px;">
        <button onclick="toggleChangeHistory()" class="btn" style="width: 100%; text-align: center; padding: 12px; font-size: 0.95em; display: flex; align-items: center; justify-content: center; gap: 8px;">
            <span id="chToggleIcon">▶</span>
            <span>Change History</span>
            <span id="chCount" style="opacity: 0.6; font-size: 0.85em;"></span>
        </button>

        <div id="changeHistoryPanel" style="display: none; margin-top: 15px;">
            <div id="changeHistoryLoading" style="text-align: center; padding: 20px; color: var(--khaki);">Loading change history...</div>
            <div id="changeHistoryContent"></div>
            <div id="changeHistoryMore" style="text-align: center; padding: 10px; display: none;">
                <button onclick="loadMoreHistory()" class="btn" style="font-size: 0.85em;">Load more</button>
            </div>
        </div>
    </section>

    <section class="section">
        <a href="/orbat/view-all" class="btn">← Back to ORBAT Templates</a>
    </section>
</div>

<style>
.change-entry {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: background 0.2s;
}
.change-entry:hover {
    background: rgba(255,255,255,0.03);
}
.change-entry:last-child {
    border-bottom: none;
}
.change-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--olive);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.75em;
    color: white;
    overflow: hidden;
}
.change-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.change-body {
    flex: 1;
    min-width: 0;
}
.change-desc {
    font-size: 0.88em;
    color: var(--sand);
    line-height: 1.4;
}
.change-meta {
    font-size: 0.75em;
    color: var(--khaki);
    opacity: 0.6;
    margin-top: 3px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}
.change-action-badge {
    display: inline-block;
    padding: 1px 7px;
    border-radius: 3px;
    font-size: 0.7em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    margin-top: 2px;
}
.badge-assign { background: rgba(52,152,219,0.2); color: #3498DB; }
.badge-unassign { background: rgba(231,76,60,0.2); color: #e74c3c; }
.badge-claim { background: rgba(46,204,113,0.2); color: #2ecc71; }
.badge-unclaim { background: rgba(231,76,60,0.15); color: #e67e22; }
.badge-role_added { background: rgba(107,142,35,0.2); color: #6b8e23; }
.badge-role_deleted { background: rgba(231,76,60,0.2); color: #e74c3c; }
.badge-role_edited { background: rgba(52,152,219,0.15); color: #85c1e9; }
.badge-roster_auto_remove { background: rgba(142,68,173,0.2); color: #af7ac5; }
</style>

<script>
const templateId = '<%= template.id %>';
let chOffset = 0;
let chTotal = 0;
const chLimit = 50;

function toggleChangeHistory() {
    const panel = document.getElementById('changeHistoryPanel');
    const icon = document.getElementById('chToggleIcon');
    if (panel.style.display === 'none') {
        panel.style.display = 'block';
        icon.textContent = '▼';
        if (!panel.dataset.loaded) {
            loadChangeHistory();
        }
    } else {
        panel.style.display = 'none';
        icon.textContent = '▶';
    }
}

async function loadChangeHistory() {
    const loading = document.getElementById('changeHistoryLoading');
    const content = document.getElementById('changeHistoryContent');
    const moreBtn = document.getElementById('changeHistoryMore');

    loading.style.display = 'block';

    try {
        const r = await fetch(`/orbat/api/change-log/${templateId}?limit=${chLimit}&offset=${chOffset}`);
        const data = await r.json();

        loading.style.display = 'none';

        if (!data.success) {
            content.innerHTML = '<p style="color: var(--khaki); text-align: center; padding: 20px;">Failed to load change history.</p>';
            return;
        }

        chTotal = data.total;
        document.getElementById('chCount').textContent = `(${chTotal} change${chTotal !== 1 ? 's' : ''})`;

        if (data.logs.length === 0) {
            content.innerHTML = '<p style="color: var(--khaki); text-align: center; padding: 20px; opacity: 0.6;">No changes recorded yet.</p>';
            return;
        }

        let html = '<div style="background: rgba(0,0,0,0.15); border-radius: 8px; overflow: hidden;">';
        data.logs.forEach(log => {
            const performerName = log.performer_global_name || log.performer_name || 'System';
            const performerInitial = performerName.charAt(0).toUpperCase();
            const performerAvatar = log.performer_avatar
                ? `<img src="https://cdn.discordapp.com/avatars/${log.performer_discord_id}/${log.performer_avatar}.png?size=32" alt="">`
                : performerInitial;
            const timeAgo = timeSince(new Date(log.created_at).getTime());
            const actionLabel = log.action_type.replace(/_/g, ' ');
            const badgeClass = 'badge-' + log.action_type;

            html += `<div class="change-entry">
                <div class="change-avatar">${performerAvatar}</div>
                <div class="change-body">
                    <div class="change-desc">${escHtml(log.description || actionLabel)}</div>
                    <div class="change-meta">
                        <span>${escHtml(performerName)}</span>
                        <span>•</span>
                        <span>${timeAgo}</span>
                        <span class="change-action-badge ${badgeClass}">${escHtml(actionLabel)}</span>
                    </div>
                </div>
            </div>`;
        });
        html += '</div>';
        content.innerHTML = html;

        if (chOffset + chLimit < chTotal) {
            moreBtn.style.display = 'block';
        } else {
            moreBtn.style.display = 'none';
        }

        document.getElementById('changeHistoryPanel').dataset.loaded = 'true';
    } catch (e) {
        loading.style.display = 'none';
        content.innerHTML = '<p style="color: #e74c3c; text-align: center; padding: 20px;">Error loading change history.</p>';
        console.error('Error loading change history:', e);
    }
}

async function loadMoreHistory() {
    chOffset += chLimit;
    await loadChangeHistory();
}

function timeSince(timestamp) {
    const now = Date.now();
    const seconds = Math.floor((now - timestamp) / 1000);
    if (seconds < 60) return 'just now';
    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return minutes + 'm ago';
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return hours + 'h ago';
    const days = Math.floor(hours / 24);
    if (days < 30) return days + 'd ago';
    const months = Math.floor(days / 30);
    return months + 'mo ago';
}

function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

<% if (user && editorSquadIds && editorSquadIds.length > 0) { %>
async function submitAddChildSquad(parentSquadId) {
    const nameInput = document.getElementById('addSubName_' + parentSquadId);
    const colorInput = document.getElementById('addSubColor_' + parentSquadId);
    const name = nameInput.value.trim();
    if (!name) { nameInput.focus(); return; }
    try {
        const r = await fetch(`/orbat/api/templates/${templateId}/squads/add`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, color: colorInput.value, displayOrder: 0, parentSquadId })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to add sub-group');
    } catch { alert('Failed to add sub-group'); }
}

function showRoleEdit(roleId) {
    document.getElementById('roleView_' + roleId).style.display = 'none';
    document.getElementById('roleEdit_' + roleId).style.display = 'block';
    document.getElementById('roleEditSlotType_' + roleId).focus();
}

function hideRoleEdit(roleId) {
    document.getElementById('roleEdit_' + roleId).style.display = 'none';
    document.getElementById('roleView_' + roleId).style.display = 'block';
}

async function saveRoleEdit(roleId) {
    const slotTypeId = document.getElementById('roleEditSlotType_' + roleId).value;
    if (!slotTypeId) { alert('Please select a slot type'); return; }
    try {
        const r = await fetch(`/orbat/api/roles/${roleId}/edit`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slotTypeId: parseInt(slotTypeId) })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to update slot');
    } catch { alert('Failed to update slot'); }
}

async function addRoleFromTemplate(squadId) {
    const sel = document.getElementById('newRoleSlotType_' + squadId);
    const slotTypeId = sel.value;
    if (!slotTypeId) { sel.focus(); return; }
    try {
        const r = await fetch(`/orbat/api/squads/${squadId}/add-role`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slotTypeId: parseInt(slotTypeId) })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to add slot');
    } catch { alert('Failed to add slot'); }
}

async function deleteRole(roleId) {
    if (!confirm('Delete this slot? This will also remove any player assigned to it.')) return;
    try {
        const r = await fetch(`/orbat/api/roles/${roleId}/delete`, { method: 'POST' });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to delete slot');
    } catch { alert('Failed to delete slot'); }
}

document.addEventListener('DOMContentLoaded', () => {
    <% squads.forEach(squad => { %>
    <% const canEditThis = user && editorSquadIds && Array.isArray(editorSquadIds) && editorSquadIds.map(Number).includes(Number(squad.id)); %>
    <% if (canEditThis) { %>
    {
    document.querySelectorAll('[data-team-roles="<%= squad.id %>"]').forEach(container => {
        new Sortable(container, {
            group: 'roles-<%= squad.id %>',
            animation: 150,
            ghostClass: 'sortable-ghost',
            handle: '[data-role-id]',
            onEnd: async function(evt) {
                const roleId = evt.item.getAttribute('data-role-id');
                const newTeamId = evt.to.getAttribute('data-team-id') || null;
                const oldTeamId = evt.from.getAttribute('data-team-id') || null;
                if (String(newTeamId) !== String(oldTeamId)) {
                    try {
                        await fetch(`/orbat/api/roles/${roleId}/set-team`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ teamId: newTeamId ? parseInt(newTeamId) : null })
                        });
                    } catch(e) { console.error('Failed to set team:', e); }
                }
                const allRoleIds = [];
                document.querySelectorAll('[data-team-roles="<%= squad.id %>"] [data-role-id]').forEach(el => {
                    allRoleIds.push(el.getAttribute('data-role-id'));
                });
                try {
                    await fetch('/orbat/api/squads/<%= squad.id %>/reorder-roles', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ roleIds: allRoleIds })
                    });
                } catch(e) { console.error('Failed to reorder roles:', e); }
            }
        });
    });
    const teamsOrderEl = document.getElementById('teams-order-<%= squad.id %>');
    if (teamsOrderEl) {
        new Sortable(teamsOrderEl, {
            animation: 150,
            handle: '.team-hdr',
            ghostClass: 'sortable-ghost',
            onEnd: async function() {
                const teamIds = Array.from(teamsOrderEl.querySelectorAll('[data-team-block]')).map(el => el.getAttribute('data-team-block'));
                try {
                    await fetch('/orbat/api/squads/<%= squad.id %>/reorder-teams', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ teamIds })
                    });
                } catch(e) { console.error('Failed to reorder teams:', e); }
            }
        });
    }
    } // end block scope for squad
    <% } %>
    <% }); %>

    // Squad drag-to-reorder
    [document.querySelector('.org-tree-root'), ...document.querySelectorAll('.org-row')].forEach(container => {
        if (!container) return;
        new Sortable(container, {
            animation: 150,
            ghostClass: 'sortable-ghost',
            handle: '.squad-drag-handle',
            onEnd: async function() {
                const ids = Array.from(container.querySelectorAll(':scope > [data-squad-id]'))
                                 .map(el => el.getAttribute('data-squad-id'));
                if (ids.length < 2) return;
                try {
                    await fetch(`/orbat/api/squads/${ids[0]}/reorder-siblings`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ squadIds: ids })
                    });
                } catch(e) { console.error('Failed to reorder squads:', e); }
            }
        });
    });
});
<% } %>
</script>

<%- include('./_orbat-shared') %>
<%- include('../partials/footer') %>
