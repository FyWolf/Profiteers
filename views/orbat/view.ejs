<%- include('../partials/header') %>
<script>document.documentElement.style.removeProperty('--heading-font');</script>
<%
function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function renderRoleCard(role, squad) {
    const assignment = assignments[role.id];
    const isEmpty = !assignment;
    const isOwnAssignment = assignment && user && assignment.user_id === user.id;
    const attendanceStatus = assignment ? assignment.attendance_status : null;

    const _editorIds = (typeof editorSquadIds !== 'undefined' && Array.isArray(editorSquadIds)) ? editorSquadIds.map(Number) : [];
    const isEditorOfThisSquad = _editorIds.includes(Number(squad.id));

    if (operation.orbat_type === 'fixed' && !canManage && !isEditorOfThisSquad) {
        if (!assignment || attendanceStatus === 'absent') return '';
    }

    let opacity = '1';
    if (operation.orbat_type === 'fixed' && attendanceStatus === 'tentative') opacity = '0.5';
    else if (operation.orbat_type === 'fixed' && attendanceStatus === 'absent') opacity = '0.3';

    // Tiny avatar
    let avatarHtml = '';
    if (assignment) {
        if (assignment.discord_avatar) {
            avatarHtml = `<img src="https://cdn.discordapp.com/avatars/${esc(assignment.discord_id)}/${esc(assignment.discord_avatar)}.png?size=32" style="width:20px;height:20px;border-radius:50%;border:1px solid ${squad.color};flex-shrink:0;display:block;margin:auto 0;">`;
        } else {
            const initial = esc((assignment.roster_nickname || assignment.discord_global_name || assignment.username).charAt(0).toUpperCase());
            avatarHtml = `<div style="width: 20px; height: 20px; border-radius: 50%; background: ${squad.color}; display: flex; align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 0.62em; flex-shrink: 0;">${initial}</div>`;
        }
    } else {
        avatarHtml = `<div style="width: 20px; height: 20px; border-radius: 50%; border: 1px dashed rgba(178,178,125,0.25); flex-shrink: 0;"></div>`;
    }

    // Inline icon badges
    let statusIcon = '';
    if (attendanceStatus === 'present') statusIcon = `<span title="Present" style="flex-shrink:0;font-size:0.72em;">✅</span>`;
    else if (operation.orbat_type === 'fixed' && attendanceStatus === 'tentative') statusIcon = `<span title="Tentative" style="flex-shrink:0;font-size:0.72em;">⏸️</span>`;

    let loaIcon = '';
    if (assignment && assignment.loa_id) {
        const loaEnd = new Date(assignment.loa_end * 1000).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        const tip = esc(`On LOA until ${loaEnd}${canManage && assignment.loa_reason ? ': ' + assignment.loa_reason : ''}`);
        loaIcon = `<span title="${tip}" style="flex-shrink:0;font-size:0.72em;cursor:help;">🛑</span>`;
    }

    const nameText = assignment ? esc(assignment.roster_nickname || assignment.discord_global_name || assignment.username) : null;

    const playerSlot = assignment
        ? `<a href="/profile/${assignment.user_id}" style="display:flex;align-items:center;gap:6px;flex:1;min-width:0;text-decoration:none;overflow:hidden;">
            ${avatarHtml}
            <div style="min-width:0;overflow:hidden;">
                <div style="font-size:0.77em;font-weight:700;color:${squad.color};white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${esc(role.role_name)}">${esc(role.role_name)}</div>
                <div style="font-size:0.72em;color:var(--sand);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${nameText}</div>
            </div>
           </a>`
        : `<div style="display:flex;align-items:center;gap:6px;flex:1;min-width:0;">
            ${avatarHtml}
            <div style="min-width:0;overflow:hidden;">
                <div style="font-size:0.77em;font-weight:700;color:${squad.color};white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${esc(role.role_name)}">${esc(role.role_name)}</div>
                <div style="font-size:0.72em;color:var(--khaki);opacity:0.4;font-style:italic;white-space:nowrap;">empty</div>
            </div>
           </div>`;

    let claimBtn = '';
    if (canClaim && isEmpty && user) {
        claimBtn = `<button onclick="claimSlot(${role.id})" class="btn btn-primary" style="padding:2px 7px;font-size:0.72em;">Claim</button>`;
    } else if (canClaim && isOwnAssignment) {
        claimBtn = `<button onclick="unclaimSlot(${role.id})" class="btn" style="background:#e74c3c;padding:2px 7px;font-size:0.72em;">Leave</button>`;
    }
    const canDynamicManage = canManage && operation.orbat_type === 'dynamic';
    const canAssignFixed = operation.orbat_type === 'fixed' && (canManage || isEditorOfThisSquad);

    const manageMenu = canDynamicManage
        ? `<div class="ctrl-menu">
               <button class="ctrl-menu-btn" onclick="toggleCtrlMenu(this)">···</button>
               <div class="ctrl-menu-list">
                   ${assignment
                       ? `<button class="ctrl-menu-item" onclick="showAssignModal(${role.id}, ${esc(JSON.stringify(role.role_name))})">Change player</button>
                          <button class="ctrl-menu-item ctrl-menu-danger" onclick="unassignPlayer(${role.id})">Remove player</button>`
                       : `<button class="ctrl-menu-item" onclick="showAssignModal(${role.id}, ${esc(JSON.stringify(role.role_name))})">Assign player</button>`}
                   <button class="ctrl-menu-item ctrl-menu-danger" onclick="deleteRole(${role.id})">Delete slot</button>
               </div>
           </div>`
        : canAssignFixed
        ? `<div class="ctrl-menu">
               <button class="ctrl-menu-btn" onclick="toggleCtrlMenu(this)">···</button>
               <div class="ctrl-menu-list">
                   ${assignment
                       ? `<button class="ctrl-menu-item" onclick="showAssignModal(${role.id}, ${esc(JSON.stringify(role.role_name))})">Change player</button>
                          <button class="ctrl-menu-item ctrl-menu-danger" onclick="unassignPlayer(${role.id})">Remove player</button>`
                       : `<button class="ctrl-menu-item" onclick="showAssignModal(${role.id}, ${esc(JSON.stringify(role.role_name))})">Assign player</button>`}
               </div>
           </div>`
        : '';
    const buttonsHtml = (claimBtn || manageMenu)
        ? `<div style="display:flex;gap:3px;align-items:center;flex-shrink:0;">${claimBtn}${manageMenu}</div>`
        : '';

    const grabStyle = canDynamicManage ? ' cursor: grab;' : '';

    return `<div data-role-id="${role.id}" style="display:flex;align-items:center;gap:6px;padding:5px 8px;opacity:${opacity};transition:opacity 0.2s;border-bottom:1px solid rgba(255,255,255,0.04);${grabStyle}">
        ${playerSlot}
        ${loaIcon}${statusIcon}
        ${buttonsHtml}
    </div>`;
}

function renderSquadCard(squad) {
    const isDynamic = canManage && operation.orbat_type === 'dynamic';
    const _editorIds = (typeof editorSquadIds !== 'undefined' && Array.isArray(editorSquadIds)) ? editorSquadIds.map(Number) : [];
    const canEditFreq = canManage || _editorIds.includes(Number(squad.id));
    return buildSquadCard(squad, {
        canEdit: canEditFreq,
        canDynamic: isDynamic,
        canDeleteSquad: isDynamic,
        renderRole: r => renderRoleCard(r, squad)
    });
}

function renderOpNode(node, isRoot) {
    const wrapClass = isRoot ? 'org-node' : 'org-col';
    const cardHtml = renderSquadCard(node);
    let childrenHtml = '';
    if (node.children && node.children.length > 0) {
        childrenHtml = `<div class="org-v-bar"></div><div class="org-row">${node.children.map(child => renderOpNode(child, false)).join('')}</div>`;
    }
    return `<div class="${wrapClass}" data-squad-id="${node.id}">${cardHtml}${childrenHtml}</div>`;
}
%>


<div class="container orbat-wide">
    <header>
        <h1>ORBAT</h1>
        <div class="subtitle"><%= operation.title %></div>
    </header>

    <% if (canManage && operation.orbat_type === 'dynamic' && !orbatPublished) { %>
        <div style="margin-bottom: 20px; padding: 15px; background: rgba(243, 156, 18, 0.15); border: 2px solid #F39C12; border-radius: 8px;">
            <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;">
                <div>
                    <strong style="color: #F39C12; font-size: 1.05em;">DRAFT - ORBAT not visible to players</strong>
                    <div style="color: var(--khaki); font-size: 0.85em; margin-top: 4px; opacity: 0.8;">Work on your ORBAT here. When ready, publish it to make it available.</div>
                </div>
                <div style="display: flex; align-items: center; gap: 10px; flex-shrink: 0;">
                    <label style="display: flex; align-items: center; gap: 6px; font-size: 0.85em; color: var(--khaki); cursor: pointer; white-space: nowrap;">
                        <input type="checkbox" id="publishNotify" checked style="accent-color: #6b8e23;">
                        Notify players
                    </label>
                    <button onclick="publishOrbat()" class="btn btn-primary" style="white-space: nowrap;">Publish ORBAT</button>
                </div>
            </div>
        </div>
    <% } else if (canManage && operation.orbat_type === 'dynamic' && orbatPublished) { %>
        <div style="margin-bottom: 20px; padding: 15px; background: rgba(52, 152, 219, 0.1); border: 1px solid #3498DB; border-radius: 8px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;">
            <strong style="color: #3498DB;">🎯 Dynamic ORBAT - First come, first served</strong>
            <button onclick="unpublishOrbat()" class="btn" style="font-size: 0.8em; padding: 4px 12px; opacity: 0.7;">Unpublish</button>
        </div>
    <% } else { %>
        <div style="margin-bottom: 20px; padding: 15px; background: rgba(52, 152, 219, 0.1); border: 1px solid #3498DB; border-radius: 8px;">
            <strong style="color: #3498DB;">
                <% if (operation.orbat_type === 'fixed') { %>
                    📋 Fixed ORBAT - Showing only attending players
                    <% if (canManage) { %>
                        <br>
                        <small style="opacity: 0.8; font-weight: normal;">
                            To assign players to this ORBAT, edit the template in <a href="/orbat/templates" style="color: #3498DB; text-decoration: underline;">ORBAT Management</a>
                        </small>
                    <% } %>
                <% } else if (operation.orbat_type === 'dynamic') { %>
                    🎯 Dynamic ORBAT - First come, first served
                <% } %>
            </strong>
        </div>
    <% } %>

    <% if (squads.length === 0) { %>
        <section class="section">
            <div class="card text-center">
                <h3>No ORBAT Created</h3>
                <% if (canManage && operation.orbat_type === 'dynamic') { %>
                    <p>Create squads and roles for this operation.</p>
                    <div style="max-width: 600px; margin: 20px auto; text-align: left;">
                        <h4 style="margin-bottom: 15px;">Create Your First Group</h4>
                        <form id="createSquadForm">
                            <div class="form-group">
                                <label for="squadName">Group Name</label>
                                <input type="text" id="squadName" placeholder="e.g., 1st Platoon" required>
                            </div>
                            <div class="form-group">
                                <label for="squadColor">Color</label>
                                <input type="color" id="squadColor" value="#3498DB" style="width: 100%; height: 50px;">
                            </div>
                            <div class="form-group">
                                <label for="initialRole">First Role Name</label>
                                <input type="text" id="initialRole" placeholder="e.g., Platoon Leader" required>
                            </div>
                            <button type="submit" class="btn btn-primary" style="width: 100%;">
                                ➕ Create Group
                            </button>
                        </form>
                    </div>
                <% } else if (operation.orbat_type === 'dynamic' && !orbatPublished) { %>
                    <h3>ORBAT Not Ready Yet</h3>
                    <p style="color: var(--khaki);">The host is still working on the ORBAT. Check back later!</p>
                <% } else if (operation.orbat_type === 'dynamic') { %>
                    <p>The Zeus has not set up an ORBAT for this operation yet.</p>
                <% } else { %>
                    <p>No ORBAT has been set up for this operation.</p>
                <% } %>
            </div>
        </section>
    <% } else { %>
        <% if (canManage && operation.orbat_type === 'dynamic') { %>
            <section class="section">
                <h2>➕ Add Root Group</h2>
                <form id="addSquadForm" class="card">
                    <div style="display: grid; grid-template-columns: 2fr 1fr auto; gap: 10px; align-items: end;">
                        <div class="form-group" style="margin: 0;">
                            <label for="newSquadName">Group Name</label>
                            <input type="text" id="newSquadName" placeholder="e.g., 1st Platoon" required>
                        </div>
                        <div class="form-group" style="margin: 0;">
                            <label for="newSquadColor">Color</label>
                            <input type="color" id="newSquadColor" value="#E74C3C" style="width: 100%; height: 42px;">
                        </div>
                        <button type="submit" class="btn btn-primary" style="height: 42px;">➕ Add</button>
                    </div>
                </form>
            </section>
        <% } %>

        <section class="section">
            <div class="org-tree-scroll">
                <div class="org-tree-root">
                    <%- squadTree.map(root => renderOpNode(root, true)).join('') %>
                </div>
            </div>
        </section>
    <% } %>

    <%# ─── Change History Toggle ─────────────────────────────────────── %>
    <section class="section" style="margin-top: 30px;">
        <button onclick="toggleChangeHistory()" class="btn" style="width: 100%; text-align: center; padding: 12px; font-size: 0.95em; display: flex; align-items: center; justify-content: center; gap: 8px;">
            <span id="chToggleIcon">▶</span>
            <span>Change History</span>
            <span id="chCount" style="opacity: 0.6; font-size: 0.85em;"></span>
        </button>

        <div id="changeHistoryPanel" style="display: none; margin-top: 15px;">
            <div id="changeHistoryLoading" style="text-align: center; padding: 20px; color: var(--khaki);">Loading change history...</div>
            <div id="changeHistoryContent"></div>
            <div id="changeHistoryMore" style="text-align: center; padding: 10px; display: none;">
                <button onclick="loadMoreHistory()" class="btn" style="font-size: 0.85em;">Load more</button>
            </div>
        </div>
    </section>

    <section class="section">
        <a href="/operations/<%= operation.id %>" class="btn">← Back to Operation</a>
    </section>
</div>

<style>
