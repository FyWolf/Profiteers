<%- include('../partials/header') %>
<%
function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function renderRoleCard(role, squad) {
    const assignment = assignments[role.id];
    const isEmpty = !assignment;
    const isOwnAssignment = assignment && user && assignment.user_id === user.id;
    const attendanceStatus = assignment ? assignment.attendance_status : null;

    if (operation.orbat_type === 'fixed' && !canManage) {
        if (!assignment || attendanceStatus === 'absent') return '';
    }

    let opacity = '1';
    if (operation.orbat_type === 'fixed' && attendanceStatus === 'tentative') opacity = '0.5';
    else if (operation.orbat_type === 'fixed' && attendanceStatus === 'absent') opacity = '0.3';

    // Tiny avatar
    let avatarHtml = '';
    if (assignment) {
        if (assignment.discord_avatar) {
            avatarHtml = `<img src="https://cdn.discordapp.com/avatars/${esc(assignment.discord_id)}/${esc(assignment.discord_avatar)}.png?size=32" style="width:20px;height:20px;border-radius:50%;border:1px solid ${squad.color};flex-shrink:0;display:block;margin:auto 0;">`;
        } else {
            const initial = esc((assignment.roster_nickname || assignment.discord_global_name || assignment.username).charAt(0).toUpperCase());
            avatarHtml = `<div style="width: 20px; height: 20px; border-radius: 50%; background: ${squad.color}; display: flex; align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 0.62em; flex-shrink: 0;">${initial}</div>`;
        }
    } else {
        avatarHtml = `<div style="width: 20px; height: 20px; border-radius: 50%; border: 1px dashed rgba(178,178,125,0.25); flex-shrink: 0;"></div>`;
    }

    // Inline icon badges
    let statusIcon = '';
    if (attendanceStatus === 'present') statusIcon = `<span title="Present" style="flex-shrink:0;font-size:0.72em;">✅</span>`;
    else if (operation.orbat_type === 'fixed' && attendanceStatus === 'tentative') statusIcon = `<span title="Tentative" style="flex-shrink:0;font-size:0.72em;">⏸️</span>`;

    let loaIcon = '';
    if (assignment && assignment.loa_id) {
        const loaEnd = new Date(assignment.loa_end).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        const tip = esc(`On LOA until ${loaEnd}${canManage && assignment.loa_reason ? ': ' + assignment.loa_reason : ''}`);
        loaIcon = `<span title="${tip}" style="flex-shrink:0;font-size:0.72em;cursor:help;">🛑</span>`;
    }

    const playerSlot = assignment
        ? `<a href="/profile/${assignment.user_id}" style="display:flex;align-items:center;gap:5px;flex:1;min-width:0;text-decoration:none;overflow:hidden;">
            ${avatarHtml}<span style="font-size:0.8em;color:var(--sand);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(assignment.roster_nickname || assignment.discord_global_name || assignment.username)}</span>
           </a>`
        : `<div style="display:flex;align-items:center;gap:5px;flex:1;min-width:0;">
            ${avatarHtml}<span style="font-size:0.8em;color:var(--khaki);opacity:0.4;font-style:italic;">empty</span>
           </div>`;

    // Buttons — compact icon-size
    let buttonsHtml = '';
    const showButtons = (canClaim && isEmpty && user) || (canClaim && isOwnAssignment) || (canManage && operation.orbat_type === 'dynamic');
    if (showButtons) {
        let claimBtn = '';
        if (canClaim && isEmpty && user) {
            claimBtn = `<button onclick="claimSlot(${role.id})" class="btn btn-primary" style="padding:2px 7px;font-size:0.72em;">Claim</button>`;
        } else if (canClaim && isOwnAssignment) {
            claimBtn = `<button onclick="unclaimSlot(${role.id})" class="btn" style="background:#e74c3c;padding:2px 7px;font-size:0.72em;">Leave</button>`;
        }
        let manageBtn = '';
        if (canManage && operation.orbat_type === 'dynamic') {
            const unassignBtn = assignment ? `<button onclick="unassignPlayer(${role.id})" class="btn btn-danger" style="padding:2px 5px;font-size:0.72em;">✕</button>` : '';
            const assignIcon = assignment ? '🔄' : '➕';
            manageBtn = `${unassignBtn}<button onclick="showAssignModal(${role.id}, ${esc(JSON.stringify(role.role_name))})" class="btn" style="padding:2px 5px;font-size:0.72em;">${assignIcon}</button>`;
        }
        buttonsHtml = `<div style="display:flex;gap:3px;flex-shrink:0;">${claimBtn}${manageBtn}</div>`;
    }

    const grabStyle = (canManage && operation.orbat_type === 'dynamic') ? ' cursor: grab;' : '';

    return `<div data-role-id="${role.id}" style="display:flex;align-items:center;gap:6px;padding:5px 8px;opacity:${opacity};transition:opacity 0.2s;border-bottom:1px solid rgba(255,255,255,0.04);${grabStyle}">
        <div style="font-size:0.77em;font-weight:700;color:${squad.color};width:95px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${esc(role.role_name)}">${esc(role.role_name)}</div>
        ${playerSlot}
        ${loaIcon}${statusIcon}
        ${buttonsHtml}
    </div>`;
}

function renderSquadCard(squad) {
    const roles = rolesBySquad[squad.id] || [];
    const rolesHtml = roles.map(role => renderRoleCard(role, squad)).join('');

    const addRoleForm = (canManage && operation.orbat_type === 'dynamic') ? `
        <form class="addRoleForm" data-squad-id="${squad.id}" style="margin-top: 12px; padding: 10px; background: rgba(0,0,0,0.2); border-radius: 4px; border: 2px dashed ${squad.color}; overflow: hidden;">
            <div style="display: flex; gap: 6px; align-items: center; min-width: 0;">
                <input type="text" class="roleNameInput" placeholder="Role name" required style="flex: 1; min-width: 0; margin: 0; font-size: 0.88em; padding: 6px 8px;">
                <input type="number" class="roleOrderInput" value="${roles.length}" min="0" style="width: 52px; flex-shrink: 0; margin: 0; font-size: 0.88em; padding: 6px 4px;">
                <button type="submit" class="btn" style="background: ${squad.color}; color: white; flex-shrink: 0; height: 34px; padding: 0 10px; font-size: 0.85em;">➕</button>
            </div>
        </form>` : '';

    const addSubgroupSection = (canManage && operation.orbat_type === 'dynamic') ? `
        <div id="addSubForm_${squad.id}" style="display: none; margin-top: 10px; padding: 10px; border: 1px dashed var(--khaki); border-radius: 4px; background: rgba(0,0,0,0.2); overflow: hidden;">
            <div style="display: flex; gap: 6px; align-items: center; min-width: 0;">
                <input type="text" id="addSubName_${squad.id}" placeholder="Sub-group name..." style="flex: 1; min-width: 0; padding: 6px 8px; background: rgba(40,40,40,0.9); color: var(--sand); border: 1px solid var(--olive); border-radius: 4px; font-size: 0.88em; margin: 0;" onkeydown="if(event.key==='Enter'){event.preventDefault();submitAddChildSquad(${squad.id})}">
                <input type="color" id="addSubColor_${squad.id}" value="#6b8e23" style="width: 34px; height: 34px; flex-shrink: 0; border: none; background: none; cursor: pointer; padding: 0;">
                <button onclick="submitAddChildSquad(${squad.id})" class="btn btn-primary" style="flex-shrink: 0; height: 34px; padding: 0 10px; font-size: 0.85em;">➕</button>
                <button onclick="document.getElementById('addSubForm_${squad.id}').style.display='none'" class="btn" style="flex-shrink: 0; height: 34px; padding: 0 8px; font-size: 0.85em;">✕</button>
            </div>
        </div>
        <button onclick="toggleAddSub(${squad.id})" class="btn" style="margin-top: 8px; width: 100%; background: rgba(0,0,0,0.2); border: 1px dashed var(--khaki); font-size: 0.8em; padding: 6px;">➕ Add Sub-group</button>` : '';

    return `<div class="card orbat-squad-card" style="border-left: 4px solid ${squad.color}; padding: 10px 12px;">
        <div style="margin-bottom: 6px; padding-bottom: 6px; border-bottom: 2px solid ${squad.color};">
            <h3 style="color: ${squad.color}; margin: 0; font-size: 0.92em;">${esc(squad.name)}</h3>
        </div>
        <div id="roles-${squad.id}" style="display: flex; flex-direction: column;">${rolesHtml}</div>
        ${addRoleForm}
        ${addSubgroupSection}
    </div>`;
}

function renderOpNode(node, isRoot) {
    const wrapClass = isRoot ? 'org-node' : 'org-col';
    const cardHtml = renderSquadCard(node);
    let childrenHtml = '';
    if (node.children && node.children.length > 0) {
        childrenHtml = `<div class="org-v-bar"></div><div class="org-row">${node.children.map(child => renderOpNode(child, false)).join('')}</div>`;
    }
    return `<div class="${wrapClass}">${cardHtml}${childrenHtml}</div>`;
}
%>

<div class="container orbat-wide">
    <header>
        <h1>ORBAT</h1>
        <div class="subtitle"><%= operation.title %></div>
    </header>

    <div style="margin-bottom: 20px; padding: 15px; background: rgba(52, 152, 219, 0.1); border: 1px solid #3498DB; border-radius: 8px;">
        <strong style="color: #3498DB;">
            <% if (operation.orbat_type === 'fixed') { %>
                📋 Fixed ORBAT - Showing only attending players
                <% if (canManage) { %>
                    <br>
                    <small style="opacity: 0.8; font-weight: normal;">
                        To assign players to this ORBAT, edit the template in <a href="/orbat/templates" style="color: #3498DB; text-decoration: underline;">ORBAT Management</a>
                    </small>
                <% } %>
            <% } else if (operation.orbat_type === 'dynamic') { %>
                🎯 Dynamic ORBAT - First come, first served
            <% } %>
        </strong>
    </div>

    <% if (squads.length === 0) { %>
        <section class="section">
            <div class="card text-center">
                <h3>No ORBAT Created</h3>
                <% if (canManage && operation.orbat_type === 'dynamic') { %>
                    <p>Create squads and roles for this operation.</p>
                    <div style="max-width: 600px; margin: 20px auto; text-align: left;">
                        <h4 style="margin-bottom: 15px;">Create Your First Group</h4>
                        <form id="createSquadForm">
                            <div class="form-group">
                                <label for="squadName">Group Name</label>
                                <input type="text" id="squadName" placeholder="e.g., 1st Platoon" required>
                            </div>
                            <div class="form-group">
                                <label for="squadColor">Color</label>
                                <input type="color" id="squadColor" value="#3498DB" style="width: 100%; height: 50px;">
                            </div>
                            <div class="form-group">
                                <label for="initialRole">First Role Name</label>
                                <input type="text" id="initialRole" placeholder="e.g., Platoon Leader" required>
                            </div>
                            <button type="submit" class="btn btn-primary" style="width: 100%;">
                                ➕ Create Group
                            </button>
                        </form>
                    </div>
                <% } else if (operation.orbat_type === 'dynamic') { %>
                    <p>The Zeus has not set up an ORBAT for this operation yet.</p>
                <% } else { %>
                    <p>No ORBAT has been set up for this operation.</p>
                <% } %>
            </div>
        </section>
    <% } else { %>
        <% if (canManage && operation.orbat_type === 'dynamic') { %>
            <section class="section">
                <h2>➕ Add Root Group</h2>
                <form id="addSquadForm" class="card">
                    <div style="display: grid; grid-template-columns: 2fr 1fr auto; gap: 10px; align-items: end;">
                        <div class="form-group" style="margin: 0;">
                            <label for="newSquadName">Group Name</label>
                            <input type="text" id="newSquadName" placeholder="e.g., 1st Platoon" required>
                        </div>
                        <div class="form-group" style="margin: 0;">
                            <label for="newSquadColor">Color</label>
                            <input type="color" id="newSquadColor" value="#E74C3C" style="width: 100%; height: 42px;">
                        </div>
                        <button type="submit" class="btn btn-primary" style="height: 42px;">➕ Add</button>
                    </div>
                </form>
            </section>
        <% } %>

        <section class="section">
            <div class="org-tree-scroll">
                <div class="org-tree-root">
                    <%- squadTree.map(root => renderOpNode(root, true)).join('') %>
                </div>
            </div>
        </section>
    <% } %>

    <section class="section">
        <a href="/operations/<%= operation.id %>" class="btn">← Back to Operation</a>
    </section>
</div>

<% if (canManage && operation.orbat_type === 'dynamic') { %>
<div id="assignModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); z-index: 2000; align-items: center; justify-content: center;">
    <div class="card" style="max-width: 500px; width: 90%;">
        <h3 style="margin-bottom: 15px;">Assign Player to <span id="modalRoleName"></span></h3>
        <div class="form-group">
            <label for="playerSearch">Search Roster</label>
            <input type="text" id="playerSearch" placeholder="Type player name..." oninput="searchPlayers(this.value)">
        </div>
        <div id="playerResults" style="max-height: 300px; overflow-y: auto; margin-bottom: 15px;">
            <p style="color: var(--khaki); text-align: center;">Start typing to search...</p>
        </div>
        <div style="display: flex; gap: 10px;">
            <button onclick="closeAssignModal()" class="btn" style="flex: 1;">Cancel</button>
        </div>
    </div>
</div>
<% } %>

<% if (canManage && operation.orbat_type === 'dynamic') { %>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<style>.sortable-ghost { opacity: 0.4; }</style>
<% } %>

<script>
const operationId = <%= operation.id %>;
let currentRoleId = null;

<% if (canClaim) { %>
async function claimSlot(roleId) {
    try {
        const r = await fetch(`/orbat/claim/${roleId}`, { method: 'POST' });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to claim slot');
    } catch { alert('Failed to claim slot'); }
}

async function unclaimSlot(roleId) {
    if (!confirm('Leave this slot?')) return;
    try {
        const r = await fetch(`/orbat/unclaim/${roleId}`, { method: 'POST' });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to leave slot');
    } catch { alert('Failed to leave slot'); }
}
<% } %>

<% if (canManage && operation.orbat_type === 'dynamic') { %>
function showAssignModal(roleId, roleName) {
    currentRoleId = roleId;
    document.getElementById('modalRoleName').textContent = roleName;
    document.getElementById('assignModal').style.display = 'flex';
    document.getElementById('playerSearch').value = '';
    document.getElementById('playerResults').innerHTML = '<p style="color: var(--khaki); text-align: center;">Start typing to search...</p>';
}

function closeAssignModal() {
    document.getElementById('assignModal').style.display = 'none';
    currentRoleId = null;
}

let _playerSearchResults = [];

async function searchPlayers(query) {
    if (query.length < 2) {
        document.getElementById('playerResults').innerHTML = '<p style="color: var(--khaki); text-align: center;">Type at least 2 characters...</p>';
        return;
    }
    try {
        const r = await fetch(`/roster/search?q=${encodeURIComponent(query)}`);
        const players = await r.json();
        if (players.length === 0) {
            document.getElementById('playerResults').innerHTML = '<p style="color: var(--khaki); text-align: center;">No players found</p>';
            return;
        }
        _playerSearchResults = players;
        let html = '<div style="display: grid; gap: 8px;">';
        players.forEach((p, i) => {
            const badge = p.needs_registration ? '<span style="background: rgba(241,196,15,0.3); color: #f1c40f; padding: 2px 6px; border-radius: 3px; font-size: 0.75em; margin-left: 8px;">Not logged in</span>' : '';
            const safeName = p.name.replace(/</g, '&lt;').replace(/>/g, '&gt;');
            html += `<div onclick="assignPlayer(${i})" style="padding: 10px; background: rgba(0,0,0,0.3); border-radius: 4px; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='rgba(107,142,35,0.3)'" onmouseout="this.style.background='rgba(0,0,0,0.3)'"><strong>${safeName}</strong>${badge}</div>`;
        });
        html += '</div>';
        document.getElementById('playerResults').innerHTML = html;
    } catch (e) { console.error('Error searching players:', e); }
}

async function assignPlayer(playerOrIndex) {
    const player = typeof playerOrIndex === 'number' ? _playerSearchResults[playerOrIndex] : playerOrIndex;
    const msg = player.needs_registration
        ? `Assign ${player.name}? (They haven't logged in yet - we'll create an account for them)`
        : `Assign ${player.name} to this slot?`;
    if (!confirm(msg)) return;
    try {
        const r = await fetch(`/orbat/assign/${currentRoleId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: player.user_id, discordId: player.discord_id })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to assign player');
    } catch { alert('Failed to assign player'); }
}

async function unassignPlayer(roleId) {
    if (!confirm('Remove player from this slot?')) return;
    try {
        const r = await fetch(`/orbat/unassign/${roleId}`, { method: 'POST' });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to remove player');
    } catch { alert('Failed to remove player'); }
}

function toggleAddSub(squadId) {
    const form = document.getElementById('addSubForm_' + squadId);
    if (form.style.display === 'none') {
        form.style.display = 'block';
        document.getElementById('addSubName_' + squadId).focus();
    } else {
        form.style.display = 'none';
    }
}

async function submitAddChildSquad(parentSquadId) {
    const nameInput = document.getElementById('addSubName_' + parentSquadId);
    const colorInput = document.getElementById('addSubColor_' + parentSquadId);
    const name = nameInput.value.trim();
    if (!name) { nameInput.focus(); return; }
    try {
        const r = await fetch(`/orbat/operation/${operationId}/add-squad`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ squadName: name, squadColor: colorInput.value, parentSquadId })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to add sub-group');
    } catch { alert('Failed to add sub-group'); }
}

document.getElementById('assignModal')?.addEventListener('click', e => {
    if (e.target.id === 'assignModal') closeAssignModal();
});

document.addEventListener('DOMContentLoaded', () => {
    <% squads.forEach(squad => { %>
    if (document.getElementById('roles-<%= squad.id %>')) {
        new Sortable(document.getElementById('roles-<%= squad.id %>'), {
            animation: 150,
            ghostClass: 'sortable-ghost',
            handle: '[data-role-id]',
            onEnd: async function() {
                const container = document.getElementById('roles-<%= squad.id %>');
                const roleIds = Array.from(container.querySelectorAll('[data-role-id]')).map(el => el.getAttribute('data-role-id'));
                try {
                    await fetch('/orbat/api/squads/<%= squad.id %>/reorder-roles', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ roleIds })
                    });
                } catch (e) { console.error('Failed to save role order:', e); }
            }
        });
    }
    <% }); %>
});

document.getElementById('createSquadForm')?.addEventListener('submit', async e => {
    e.preventDefault();
    try {
        const r = await fetch('/orbat/operation/<%= operation.id %>/create-dynamic', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                squadName: document.getElementById('squadName').value,
                squadColor: document.getElementById('squadColor').value,
                roleName: document.getElementById('initialRole').value
            })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to create group');
    } catch { alert('Failed to create group'); }
});

document.getElementById('addSquadForm')?.addEventListener('submit', async e => {
    e.preventDefault();
    try {
        const r = await fetch('/orbat/operation/<%= operation.id %>/add-squad', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                squadName: document.getElementById('newSquadName').value,
                squadColor: document.getElementById('newSquadColor').value
            })
        });
        const d = await r.json();
        if (d.success) location.reload(); else alert(d.error || 'Failed to add group');
    } catch { alert('Failed to add group'); }
});

document.querySelectorAll('.addRoleForm').forEach(form => {
    form.addEventListener('submit', async e => {
        e.preventDefault();
        const squadId = form.getAttribute('data-squad-id');
        try {
            const r = await fetch(`/orbat/squads/${squadId}/add-role-dynamic`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    roleName: form.querySelector('.roleNameInput').value,
                    displayOrder: form.querySelector('.roleOrderInput').value
                })
            });
            const d = await r.json();
            if (d.success) location.reload(); else alert(d.error || 'Failed to add role');
        } catch { alert('Failed to add role'); }
    });
});
<% } %>
</script>

<%- include('../partials/footer') %>
