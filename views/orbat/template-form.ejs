<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>CREATE ORBAT TEMPLATE</h1>
        <div class="subtitle">Fixed ORBAT Template</div>
    </header>

    <section class="section" style="max-width: 700px; margin: 0 auto;">
        <form method="POST" action="/orbat/templates/create">
            <div class="form-group">
                <label for="name">Template Name *</label>
                <input type="text" id="name" name="name" required maxlength="100" placeholder="e.g., Standard Infantry ORBAT">
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="3" placeholder="Brief description of this ORBAT template..."></textarea>
            </div>

            <div style="padding: 15px; background: rgba(52, 152, 219, 0.1); border: 1px solid #3498DB; border-radius: 8px; margin-bottom: 20px;">
                <p style="color: #3498DB; margin: 0;">
                    After creating the template, you'll be able to add squads and roles.
                </p>
            </div>

            <div style="display: flex; gap: 15px;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">
                    Create Template
                </button>
                <a href="/orbat/templates" class="btn" style="flex: 1; text-align: center;">
                    Cancel
                </a>
            </div>
        </form>
    </section>
</div>

<%- include('../partials/footer') %>
