<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>MANAGE USERS</h1>
        <div class="subtitle">User Account Administration</div>
    </header>

    <section class="section">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h2 style="margin: 0;">All Users</h2>
        </div>

        <% if (success) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>
        
        <% if (error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>

        <% if (users.length === 0) { %>
            <div class="card text-center">
                <h3>No Users Yet</h3>
                <p>Users will appear here when they login via Discord.</p>
            </div>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Auth Type</th>
                        <th>Admin</th>
                        <th>Joined</th>
                        <th>Last Login</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                        <tr>
                            <td>
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <% if (user.discord_avatar) { %>
                                        <img src="https://cdn.discordapp.com/avatars/<%= user.discord_id %>/<%= user.discord_avatar %>.png?size=64" 
                                             alt="<%= user.username %>" 
                                             style="width: 32px; height: 32px; border-radius: 50%;">
                                    <% } else { %>
                                        <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--olive); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700;">
                                            <%= user.username.charAt(0).toUpperCase() %>
                                        </div>
                                    <% } %>
                                    <div>
                                        <strong><%= user.username %></strong>
                                        <% if (user.discord_username) { %>
                                            <br><small style="color: var(--khaki);"><%= user.discord_username %>#<%= user.discord_discriminator %></small>
                                        <% } %>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <% if (user.auth_type === 'discord') { %>
                                    <span style="padding: 4px 8px; background: rgba(88, 101, 242, 0.2); border: 1px solid #5865F2; border-radius: 4px; font-size: 0.85em;">
                                        Discord
                                    </span>
                                <% } else { %>
                                    <span style="padding: 4px 8px; background: rgba(107,142,35,0.2); border: 1px solid var(--olive); border-radius: 4px; font-size: 0.85em;">
                                        Local
                                    </span>
                                <% } %>
                            </td>
                            <td>
                                <button onclick="toggleAdmin(<%= user.id %>)" 
                                        class="btn" 
                                        style="<%= user.is_admin ? 'background: var(--olive);' : 'background: #888;' %> padding: 6px 12px;"
                                        <%= user.id === locals.user.id ? 'disabled title="Cannot modify yourself"' : '' %>>
                                    <%= user.is_admin ? '✅ Admin' : '❌ User' %>
                                </button>
                            </td>
                            <td>
                                <%= new Date(user.created_at).toLocaleDateString() %>
                            </td>
                            <td>
                                <% if (user.last_login) { %>
                                    <%= new Date(user.last_login).toLocaleDateString() %>
                                <% } else { %>
                                    <span style="color: var(--khaki);">Never</span>
                                <% } %>
                            </td>
                            <td>
                                <form method="POST" 
                                      action="/admin/users/delete/<%= user.id %>" 
                                      style="display: inline;" 
                                      onsubmit="return <%= user.id === locals.user.id ? 'false' : 'confirm(\'Are you sure you want to delete this user?\')' %>">
                                    <button type="submit" 
                                            class="btn btn-danger" 
                                            style="padding: 6px 12px;"
                                            <%= user.id === locals.user.id ? 'disabled title="Cannot delete yourself"' : '' %>>
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>

            <div style="margin-top: 20px; padding: 15px; background: rgba(107,142,35,0.1); border: 1px solid var(--olive); border-radius: 8px;">
                <h4 style="color: var(--olive-light); margin-bottom: 10px;">📊 Summary</h4>
                <p>
                    <strong>Total Users:</strong> <%= users.length %><br>
                    <strong>Admins:</strong> <%= users.filter(u => u.is_admin).length %><br>
                    <strong>Discord Users:</strong> <%= users.filter(u => u.auth_type === 'discord').length %><br>
                    <strong>Local Users:</strong> <%= users.filter(u => u.auth_type === 'local').length %>
                </p>
            </div>
        <% } %>
    </section>

    <section class="section">
        <a href="/admin" class="btn">← Back to Dashboard</a>
    </section>
</div>

<script>
async function toggleAdmin(id) {
    if (!confirm('Are you sure you want to toggle admin status for this user?')) return;
    
    try {
        const response = await fetch(`/admin/users/toggle-admin/${id}`, {
            method: 'POST'
        });
        const data = await response.json();
        
        if (data.success) {
            location.reload();
        } else {
            alert(data.error || 'Failed to toggle admin status');
        }
    } catch (error) {
        alert('Error toggling admin status');
    }
}
</script>

<%- include('../partials/footer') %>
