<%- include('partials/header') %>

<style>
/* ── Section anchors ── */
.info-section { scroll-margin-top: 80px; }

/* ── Server status ── */
.servers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    margin-top: 20px;
}
.server-card {
    background: linear-gradient(135deg, rgba(0,0,0,0.45) 0%, rgba(10,20,10,0.45) 100%);
    border: 1px solid rgba(107,142,35,0.4);
    border-radius: 10px;
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.2s;
}
.server-card.online  { border-color: rgba(46,204,113,0.5); }
.server-card.offline { border-color: rgba(231,76,60,0.35); }
.server-card.loading { border-color: rgba(107,142,35,0.3); }
.server-status-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
}
.dot-online  { background: #2ecc71; box-shadow: 0 0 6px #2ecc71; }
.dot-offline { background: #e74c3c; }
.dot-loading { background: var(--khaki); opacity: 0.5; animation: pulse 1.2s infinite; }
@keyframes pulse { 0%,100%{opacity:0.5} 50%{opacity:1} }
.server-name-row { display: flex; align-items: center; gap: 8px; }
.server-label { font-family: var(--heading-font); font-size: 0.88em; color: var(--sand); flex: 1; min-width: 0; }
.server-meta { display: flex; gap: 12px; flex-wrap: wrap; font-size: 0.8em; color: var(--khaki); }
.server-meta span { display: flex; align-items: center; gap: 4px; }
.players-bar-wrap { height: 4px; background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden; }
.players-bar { height: 100%; background: #2ecc71; border-radius: 2px; transition: width 0.5s; }

/* ── TFAR Guide ── */
.tfar-steps { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; margin-top: 20px; }
.tfar-step {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(107,142,35,0.35);
    border-radius: 10px;
    overflow: hidden;
}
.tfar-step img {
    width: 100%;
    max-height: 180px;
    object-fit: contain;
    display: block;
    border-bottom: 1px solid rgba(107,142,35,0.3);
    background: rgba(0,0,0,0.85);
    padding: 10px 0;
    box-sizing: border-box;
    cursor: zoom-in;
}

/* Lightbox */
#lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.88);
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
}
#lightbox.open { display: flex; }
#lightbox img {
    max-width: 92vw;
    max-height: 88vh;
    object-fit: contain;
    border-radius: 6px;
    box-shadow: 0 8px 48px rgba(0,0,0,0.7);
    cursor: default;
}
#lightbox-close {
    position: absolute;
    top: 18px; right: 24px;
    font-size: 2em;
    color: var(--sand);
    cursor: pointer;
    line-height: 1;
    opacity: 0.8;
    background: none;
    border: none;
    padding: 0;
}
.tfar-step-body { padding: 14px 16px; }
.tfar-step-num {
    display: inline-block;
    font-family: var(--heading-font);
    font-size: 0.7em;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 5px;
}
.tfar-step-body h4 { margin: 0 0 6px; font-size: 0.95em; color: var(--sand); }
.tfar-step-body p  { margin: 0; font-size: 0.82em; color: var(--khaki); line-height: 1.6; }

.tfar-intro {
    padding: 16px 20px;
    background: rgba(52,152,219,0.07);
    border: 1px solid rgba(52,152,219,0.3);
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: 0.88em;
    color: var(--khaki);
    line-height: 1.7;
}
.tfar-intro strong { color: #7bb3f0; }

/* ── Kit regulations ── */
.kit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 20px;
}
.kit-card {
    background: linear-gradient(135deg, rgba(0,0,0,0.45) 0%, rgba(10,20,10,0.45) 100%);
    border: 1px solid rgba(107,142,35,0.4);
    border-radius: 10px;
    overflow: hidden;
}
.kit-card-header {
    padding: 12px 18px;
    background: rgba(107,142,35,0.12);
    border-bottom: 2px solid rgba(107,142,35,0.35);
    font-family: var(--heading-font);
    font-size: 0.9em;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
}
.kit-slot-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
}
.kit-slot-row:last-child { border-bottom: none; }
.kit-slot-name {
    padding: 8px 14px;
    font-size: 0.78em;
    font-weight: 700;
    color: var(--khaki);
    letter-spacing: 0.03em;
    border-right: 1px solid rgba(255,255,255,0.05);
    background: rgba(0,0,0,0.15);
}
.kit-slot-value {
    padding: 8px 14px;
    font-size: 0.78em;
    color: var(--sand);
    line-height: 1.5;
}
.kit-empty { padding: 14px 18px; color: var(--khaki); font-size: 0.84em; opacity: 0.6; font-style: italic; }
</style>

<div class="container">
    <header>
        <h1>INFORMATION</h1>
        <div class="subtitle">Server Status · TFAR Setup · Kit Regulations</div>
    </header>

    <!-- ── 1. Server Status ─────────────────────────────────────────────────── -->
    <% if (servers.length > 0) { %>
    <section class="section info-section" id="servers">
        <h2 style="font-size:1em;color:var(--khaki);letter-spacing:2px;margin-bottom:4px;">SERVER STATUS</h2>
        <div class="servers-grid" id="servers-grid">
            <% servers.forEach(srv => { %>
            <div class="server-card loading" data-server-id="<%= srv.id %>">
                <div class="server-name-row">
                    <span class="server-status-dot dot-loading" id="dot-<%= srv.id %>"></span>
                    <span class="server-label"><%= srv.name %></span>
                </div>
                <div class="server-meta" id="meta-<%= srv.id %>">
                    <span style="opacity:0.5">Querying...</span>
                </div>
            </div>
            <% }) %>
        </div>
    </section>
    <% } %>

    <!-- ── 2. TFAR Installation Guide ────────────────────────────────────────── -->
    <section class="section info-section" id="tfar">
        <h2 style="font-size:1em;color:var(--khaki);letter-spacing:2px;margin-bottom:4px;">TFAR INSTALLATION GUIDE</h2>
        <p style="color:var(--khaki);font-size:0.88em;margin-bottom:16px;">Task Force Arrowhead Radio (TFAR) bridges Arma 3 and TeamSpeak 3 for positional audio. Follow the steps below to install the plugin.</p>

        <div class="tfar-intro">
            <strong>Requirements:</strong> TeamSpeak 3 client installed · Arma 3 with the TFAR mod active in your modpack<br>
            <strong>Note:</strong> You only need to install the TS3 plugin once — it stays active for all sessions.
        </div>

        <div class="tfar-steps">
            <div class="tfar-step">
                <img src="/images/info/tfar-step1.jpg" alt="Step 1 - Open folder in Windows Explorer" onclick="openLightbox(this)" onerror="this.style.display='none'">
                <div class="tfar-step-body">
                    <span class="tfar-step-num">STEP 01</span>
                    <h4>Open the Mod Folder</h4>
                    <p>On the Steam Workshop page for <strong>Task Force Arrowhead Radio (BETA!!!)</strong>, click the <strong>Open folder in Windows Explorer</strong> button on the right side. This opens the mod's local directory directly.</p>
                </div>
            </div>
            <div class="tfar-step">
                <img src="/images/info/tfar-step2.jpg" alt="Step 2 - Find the TFAR folder" onclick="openLightbox(this)" onerror="this.style.display='none'">
                <div class="tfar-step-body">
                    <span class="tfar-step-num">STEP 02</span>
                    <h4>Find the TFAR Folder</h4>
                    <p>In your Arma 3 mods directory, locate and open the folder named <strong>@Task Force Arrowhead Radio (BETA!!!)</strong>.</p>
                </div>
            </div>
            <div class="tfar-step">
                <img src="/images/info/tfar-step3.jpg" alt="Step 3 - Open the teamspeak folder" onclick="openLightbox(this)" onerror="this.style.display='none'">
                <div class="tfar-step-body">
                    <span class="tfar-step-num">STEP 03</span>
                    <h4>Install from the TeamSpeak Folder</h4>
                    <p>Inside the TFAR folder you will find <strong>addons</strong>, <strong>keys</strong>, and <strong>teamspeak</strong>. Open the <strong>teamspeak</strong> folder and double-click the <code style="font-size:0.9em;background:rgba(0,0,0,0.35);padding:1px 5px;border-radius:3px;">.ts3_plugin</code> file to install it. Restart TeamSpeak if prompted.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── 3. Kit Regulations ─────────────────────────────────────────────────── -->
    <% if (kitRoles.length > 0) { %>
    <section class="section info-section" id="kit">
        <h2 style="font-size:1em;color:var(--khaki);letter-spacing:2px;margin-bottom:4px;">KIT REGULATIONS</h2>
        <p style="color:var(--khaki);font-size:0.88em;margin-bottom:20px;">Authorized loadouts and equipment per role.</p>

        <div class="kit-grid">
            <% kitRoles.forEach(role => { %>
            <div class="kit-card">
                <div class="kit-card-header"><%= role.name %></div>
                <% const slots = slotsByRole[role.id] || []; %>
                <% if (slots.length === 0) { %>
                    <div class="kit-empty">No equipment defined.</div>
                <% } else { %>
                    <% slots.forEach(slot => { %>
                    <div class="kit-slot-row">
                        <div class="kit-slot-name"><%= slot.slot_name %></div>
                        <div class="kit-slot-value"><%= slot.slot_value || '—' %></div>
                    </div>
                    <% }) %>
                <% } %>
            </div>
            <% }) %>
        </div>
    </section>
    <% } %>
</div>

<% if (servers.length > 0) { %>
<script>
(async function() {
    try {
        const res = await fetch('/info/api/server-status');
        const data = await res.json();
        data.forEach(srv => {
            const card = document.querySelector(`[data-server-id="${srv.id}"]`);
            const dot  = document.getElementById(`dot-${srv.id}`);
            const meta = document.getElementById(`meta-${srv.id}`);
            if (!card) return;

            card.classList.remove('loading');
            dot.classList.remove('dot-loading');

            if (srv.online) {
                card.classList.add('online');
                dot.classList.add('dot-online');
                const pct = srv.maxPlayers > 0 ? Math.round((srv.players / srv.maxPlayers) * 100) : 0;
                meta.innerHTML = `
                    <span>👥 ${srv.players}/${srv.maxPlayers}</span>
                    <span>🗺️ ${srv.map || 'Unknown'}</span>
                    <span>📶 ${srv.ping}ms</span>
                `;
                card.insertAdjacentHTML('beforeend', `
                    <div class="players-bar-wrap">
                        <div class="players-bar" style="width:${pct}%"></div>
                    </div>
                `);
            } else {
                card.classList.add('offline');
                dot.classList.add('dot-offline');
                meta.innerHTML = `<span style="color:#e74c3c;opacity:0.8;">Offline</span>`;
            }
        });
    } catch (e) {
        document.querySelectorAll('.server-card').forEach(c => {
            c.classList.remove('loading');
            c.classList.add('offline');
            const dot = c.querySelector('.server-status-dot');
            if (dot) { dot.classList.remove('dot-loading'); dot.classList.add('dot-offline'); }
        });
    }
})();
</script>
<% } %>

<div id="lightbox" onclick="closeLightbox()">
    <button id="lightbox-close" onclick="closeLightbox()">✕</button>
    <img id="lightbox-img" src="" alt="" onclick="event.stopPropagation()">
</div>

<script>
function openLightbox(img) {
    document.getElementById('lightbox-img').src = img.src;
    document.getElementById('lightbox-img').alt = img.alt;
    document.getElementById('lightbox').classList.add('open');
    document.body.style.overflow = 'hidden';
}
function closeLightbox() {
    document.getElementById('lightbox').classList.remove('open');
    document.body.style.overflow = '';
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>

<%- include('partials/footer') %>
