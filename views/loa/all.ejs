<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>ALL LEAVE OF ABSENCE</h1>
        <div class="subtitle">Staff View - All Member Leave Requests</div>
    </header>

    <section class="section">
        <% if (activeLoas.length > 0) { %>
            <h2 style="color: #e74c3c; margin-bottom: 20px;">🔴 Currently On Leave (<%= activeLoas.length %>)</h2>
            <% activeLoas.forEach(loa => { %>
                <div class="card" style="margin-bottom: 15px; border-left: 4px solid #e74c3c;">
                    <div style="display: flex; align-items: start; gap: 15px;">
                        <% if (loa.discord_avatar) { %>
                            <img src="https://cdn.discordapp.com/avatars/<%= loa.discord_id %>/<%= loa.discord_avatar %>.png?size=128"
                                 style="width: 50px; height: 50px; border-radius: 50%; border: 2px solid #e74c3c;">
                        <% } else { %>
                            <div style="width: 50px; height: 50px; border-radius: 50%; background: #e74c3c; display: flex; align-items: center; justify-content: center; font-weight: 900; color: white;">
                                <%= (loa.discord_global_name || loa.username).charAt(0).toUpperCase() %>
                            </div>
                        <% } %>

                        <div style="flex: 1;">
                            <h3 style="color: var(--sand); margin-bottom: 8px;">
                                <%= loa.discord_global_name || loa.username %>
                            </h3>

                            <div style="margin-bottom: 8px;">
                                <div style="color: var(--khaki); font-size: 0.95em;">
                                    📅 <%= new Date(loa.start_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                                    → <%= new Date(loa.end_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                                </div>
                            </div>

                            <% if (loa.superior_display_name || loa.superior_username) { %>
                                <div style="color: var(--khaki); font-size: 0.85em; margin-bottom: 8px;">
                                    👤 Superior: <%= loa.superior_display_name || loa.superior_username %>
                                </div>
                            <% } %>

                            <div style="padding: 10px; background: rgba(0,0,0,0.3); border-radius: 4px; margin-top: 10px;">
                                <div style="color: var(--olive-light); font-weight: 700; font-size: 0.85em; margin-bottom: 4px;">
                                    Reason:
                                </div>
                                <div style="color: var(--khaki); font-size: 0.9em;">
                                    <%= loa.reason %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="card text-center" style="margin-bottom: 30px;">
                <h3>No Active Leave of Absence</h3>
                <p>All members are currently available.</p>
            </div>
        <% } %>

        <% if (pastLoas.length > 0) { %>
            <h2 style="color: var(--khaki); margin: 40px 0 20px;">📋 Past & Upcoming Leave (<%= pastLoas.length %>)</h2>
            
            <details style="margin-bottom: 20px;">
                <summary style="cursor: pointer; padding: 15px; background: rgba(0,0,0,0.2); border-radius: 4px; color: var(--sand); font-weight: 700;">
                    Show All Past & Upcoming Leave (<%= pastLoas.length %>)
                </summary>
                
                <div style="margin-top: 15px;">
                    <% pastLoas.forEach(loa => { %>
                        <%
                        const now = new Date();
                        const startDate = new Date(loa.start_date);
                        const endDate = new Date(loa.end_date);
                        const isUpcoming = startDate > now;
                        const borderColor = isUpcoming ? '#f39c12' : '#95a5a6';
                        %>
                        
                        <div class="card" style="margin-bottom: 15px; border-left: 4px solid <%= borderColor %>; opacity: 0.8;">
                            <div style="display: flex; align-items: start; gap: 15px;">
                                <% if (loa.discord_avatar) { %>
                                    <img src="https://cdn.discordapp.com/avatars/<%= loa.discord_id %>/<%= loa.discord_avatar %>.png?size=128"
                                         style="width: 40px; height: 40px; border-radius: 50%; border: 2px solid <%= borderColor %>;">
                                <% } else { %>
                                    <div style="width: 40px; height: 40px; border-radius: 50%; background: <%= borderColor %>; display: flex; align-items: center; justify-content: center; font-weight: 900; color: white; font-size: 0.9em;">
                                        <%= (loa.discord_global_name || loa.username).charAt(0).toUpperCase() %>
                                    </div>
                                <% } %>

                                <div style="flex: 1;">
                                    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 6px;">
                                        <h4 style="color: var(--sand); margin: 0;">
                                            <%= loa.discord_global_name || loa.username %>
                                        </h4>
                                        <span style="padding: 2px 8px; background: <%= borderColor %>; color: white; border-radius: 3px; font-size: 0.75em; font-weight: 700;">
                                            <%= isUpcoming ? 'UPCOMING' : 'ENDED' %>
                                        </span>
                                    </div>

                                    <div style="color: var(--khaki); font-size: 0.85em;">
                                        <%= startDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                        → <%= endDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                    </div>

                                    <% if (loa.superior_display_name || loa.superior_username) { %>
                                        <div style="color: var(--khaki); font-size: 0.8em; margin-top: 4px;">
                                            👤 <%= loa.superior_display_name || loa.superior_username %>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </details>
        <% } %>
    </section>

    <section class="section">
        <a href="/admin" class="btn">← Back to Admin Dashboard</a>
    </section>
</div>

<%- include('../partials/footer') %>
