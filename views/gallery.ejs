<%- include('partials/header') %>

<div class="container">
    <header>
        <h1>GALLERY</h1>
        <div class="subtitle"><%= currentFolder ? currentFolder.name : 'All Images' %></div>
    </header>

    <section class="section">
        <div style="display: flex; gap: 20px; flex-wrap: wrap;">
            <!-- Sidebar with folders -->
            <div style="flex: 0 0 250px;">
                <h3>Folders</h3>
                <div style="background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px; margin-top: 15px;">
                    <a href="/gallery" style="display: block; padding: 10px; color: <%= !currentFolder ? 'var(--accent)' : 'var(--sand)' %>; text-decoration: none; border-radius: 6px; margin-bottom: 5px; <%= !currentFolder ? 'background: rgba(252,176,13,0.2);' : '' %>">
                        📁 All Images
                    </a>
                    <% 
                    function renderFolders(folders, parentId, level) {
                        const filtered = folders.filter(f => f.parent_id === parentId);
                        filtered.forEach(folder => {
                            const isActive = currentFolder && currentFolder.id === folder.id;
                    %>
                            <a href="/gallery/folder/<%= folder.id %>" style="display: block; padding: 10px; padding-left: <%= 10 + (level * 15) %>px; color: <%= isActive ? 'var(--accent)' : 'var(--sand)' %>; text-decoration: none; border-radius: 6px; margin-bottom: 5px; <%= isActive ? 'background: rgba(252,176,13,0.2);' : '' %>">
                                <%= level > 0 ? '└ ' : '' %>📁 <%= folder.name %>
                            </a>
                    <%
                            renderFolders(folders, folder.id, level + 1);
                        });
                    }
                    renderFolders(folders, null, 0);
                    %>
                </div>

                <% if (user && user.isAdmin) { %>
                    <div style="margin-top: 15px;">
                        <a href="/admin/gallery" class="btn" style="width: 100%;">Manage Gallery</a>
                    </div>
                <% } %>
            </div>

            <!-- Main content area -->
            <div style="flex: 1; min-width: 300px;">
                <% if (viewMode === 'folder' && subfolders && subfolders.length > 0) { %>
                    <h3>Subfolders</h3>
                    <div class="grid grid-4" style="margin-bottom: 30px;">
                        <% subfolders.forEach(subfolder => { %>
                            <a href="/gallery/folder/<%= subfolder.id %>" class="card text-center" style="text-decoration: none; color: var(--sand);">
                                <div style="font-size: 3em; margin-bottom: 10px;">📁</div>
                                <h4><%= subfolder.name %></h4>
                            </a>
                        <% }); %>
                    </div>
                <% } %>

                <% if (images.length === 0) { %>
                    <div class="card text-center">
                        <h3>No Images</h3>
                        <p>This <%= currentFolder ? 'folder' : 'gallery' %> is empty.</p>
                        <% if (user && user.isAdmin) { %>
                            <a href="/admin/gallery/upload" class="btn btn-primary mt-2">Upload Images</a>
                        <% } %>
                    </div>
                <% } else { %>
                    <h3>Images (<%= images.length %>)</h3>
                    <div class="grid grid-3">
                        <% images.forEach(image => { %>
                            <div class="card">
                                <img src="/uploads/gallery/<%= image.filename %>" 
                                     alt="<%= image.original_name %>" 
                                     style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px; cursor: pointer;"
                                     onclick="viewImage('<%= image.filename %>', '<%= image.caption || image.original_name %>')">
                                
                                <% if (image.caption) { %>
                                    <p style="margin-top: 10px; font-size: 0.9em;"><%= image.caption %></p>
                                <% } %>
                                
                                <p style="font-size: 0.85em; color: var(--khaki); margin-top: 5px;">
                                    <% if (viewMode === 'all') { %>
                                        📁 <%= image.folder_name %><br>
                                    <% } %>
                                    👤 <%= image.username %>
                                </p>

                                <% if (user && user.isAdmin) { %>
                                    <button onclick="deleteImage(<%= image.id %>)" class="btn btn-danger" style="width: 100%; margin-top: 10px; padding: 8px;">
                                        Delete
                                    </button>
                                <% } %>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
</div>

<!-- Image viewer modal -->
<div id="imageModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 9999; padding: 20px;" onclick="closeImageModal()">
    <div style="max-width: 1200px; margin: 0 auto; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <img id="modalImage" src="" alt="" style="max-width: 100%; max-height: 80vh; object-fit: contain; border-radius: 8px;">
        <p id="modalCaption" style="color: var(--sand); margin-top: 20px; font-size: 1.2em; text-align: center;"></p>
        <button onclick="closeImageModal()" class="btn" style="margin-top: 20px;">Close</button>
    </div>
</div>

<script>
function viewImage(filename, caption) {
    document.getElementById('modalImage').src = '/uploads/gallery/' + filename;
    document.getElementById('modalCaption').textContent = caption;
    document.getElementById('imageModal').style.display = 'block';
}

function closeImageModal() {
    document.getElementById('imageModal').style.display = 'none';
}

async function deleteImage(id) {
    if (!confirm('Are you sure you want to delete this image?')) return;
    
    try {
        const response = await fetch(`/admin/gallery/delete-image/${id}`, {
            method: 'POST'
        });
        const data = await response.json();
        
        if (data.success) {
            location.reload();
        } else {
            alert('Failed to delete image');
        }
    } catch (error) {
        alert('Error deleting image');
    }
}
</script>

<%- include('partials/footer') %>
