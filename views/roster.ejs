<%- include('partials/header') %>

<div class="container">
    <header>
        <h1>UNIT ROSTER</h1>
        <div class="subtitle">Profiteers PMC Personnel</div>
    </header>

    <% if (lastSync) { %>
        <div style="text-align: center; margin-bottom: 30px; padding: 15px; background: rgba(52, 152, 219, 0.1); border: 1px solid #3498DB; border-radius: 8px;">
            <p style="color: var(--khaki); margin: 0;">
                <strong style="color: #3498DB;">Last Updated:</strong>
                <%= new Date(lastSync).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
            </p>
        </div>
    <% } %>

    <% roles.forEach(role => { %>
        <% const members = membersByRole[role.id] || []; %>
        <% if (members.length > 0) { %>
            <section class="section" style="margin-bottom: 40px;">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 25px; padding-bottom: 15px; border-bottom: 3px solid <%= role.color %>;">
                    <div style="width: 6px; height: 50px; background: <%= role.color %>; border-radius: 3px;"></div>
                    <div>
                        <h2 style="margin: 0; color: <%= role.color %>; font-size: 1.8em;">
                            <%= role.name %>
                        </h2>
                        <% if (role.description) { %>
                            <p style="margin: 5px 0 0 0; color: var(--khaki); font-size: 0.9em;">
                                <%= role.description %>
                            </p>
                        <% } %>
                        <p style="margin: 5px 0 0 0; color: var(--khaki); font-size: 0.85em;">
                            <%= members.length %> <%= members.length === 1 ? 'member' : 'members' %>
                        </p>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px;">
                    <% members.forEach(member => { %>
                        <% if (member.user_id) { %>
                            <!-- Registered user - link to profile -->
                            <a href="/profile/<%= member.user_id %>" style="text-decoration: none; color: inherit;">
                        <% } else { %>
                            <!-- Not registered - no link -->
                            <div style="text-decoration: none; color: inherit;">
                        <% } %>
                            <div class="card" style="border-left: 4px solid <%= role.color %>; padding: 20px; transition: all 0.2s ease; <%= member.user_id ? 'cursor: pointer;' : 'opacity: 0.8;' %>">
                                <div style="display: flex; align-items: center; gap: 15px;">
                                    <% if (member.discord_avatar) { %>
                                        <img 
                                            src="https://cdn.discordapp.com/avatars/<%= member.discord_id %>/<%= member.discord_avatar %>.png?size=128" 
                                            alt="<%= member.discord_global_name || member.discord_username %>" 
                                            style="width: 64px; height: 64px; border-radius: 50%; border: 3px solid <%= role.color %>;"
                                        >
                                    <% } else { %>
                                        <div style="width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, <%= role.color %> 0%, rgba(0,0,0,0.5) 100%); display: flex; align-items: center; justify-content: center; font-size: 1.8em; color: white; font-weight: 900; border: 3px solid <%= role.color %>;">
                                            <%= (member.discord_global_name || member.discord_username).charAt(0).toUpperCase() %>
                                        </div>
                                    <% } %>
                                    
                                    <div style="flex: 1; min-width: 0;">
                                        <div style="font-weight: 700; font-size: 1.1em; color: var(--sand); margin-bottom: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                            <%= member.nickname || member.discord_username %>
                                        </div>
                                        
                                            <div style="font-size: 0.9em; color: var(--khaki); margin-bottom: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                AKA: <%= member.discord_global_name %>
                                            </div>
                                        
                                        <% if (user) { %>
                                            <!-- Only show Discord handle to logged-in users -->
                                            <div style="font-size: 0.85em; color: var(--khaki); opacity: 0.7; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                @<%= member.discord_username %>
                                            </div>
                                        <% } %>
                                        
                                        <% if (member.joined_at) { %>
                                            <div style="font-size: 0.75em; color: <%= role.color %>; margin-top: 6px;">
                                                Joined <%= new Date(member.joined_at).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% if (member.user_id) { %>
                            </a>
                        <% } else { %>
                            </div>
                        <% } %>
                    <% }); %>
                </div>
            </section>
        <% } %>
    <% }); %>

    <section class="section">
        <div style="text-align: center; padding: 30px; background: rgba(107,142,35,0.1); border: 2px solid var(--olive); border-radius: 8px;">
            <h3 style="color: var(--olive-light); margin-bottom: 10px;">Total Personnel</h3>
            <div style="font-size: 3em; font-weight: 900; color: var(--accent); margin-bottom: 10px;">
                <%= Object.values(membersByRole).reduce((sum, members) => sum + members.length, 0) %>
            </div>
            <p style="color: var(--khaki);">Active Unit Members</p>
        </div>
    </section>

    <% if (user && user.isAdmin) { %>
        <section class="section">
            <div style="padding: 20px; background: rgba(155, 89, 182, 0.1); border: 2px solid #9B59B6; border-radius: 8px;">
                <h3 style="color: #9B59B6; margin-bottom: 15px;">Admin Controls</h3>
                <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                    <button id="syncBtn" onclick="syncRoster()" class="btn btn-primary">
                        Sync Roster from Discord
                    </button>
                    <!-- <a href="/admin/roster-roles" class="btn">
                        Manage Role Hierarchy
                    </a> -->
                </div>
                <div id="syncResult" style="margin-top: 15px; display: none;"></div>
            </div>
        </section>
    <% } %>
</div>

<style>
.card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 20px rgba(255, 215, 0, 0.2);
}

a:has(.card) {
    display: block;
}
</style>

<% if (user && user.isAdmin) { %>
<script>
async function syncRoster() {
    const btn = document.getElementById('syncBtn');
    const result = document.getElementById('syncResult');
    
    btn.disabled = true;
    btn.textContent = '🔄 Syncing from Discord...';
    result.style.display = 'none';
    
    try {
        const response = await fetch('/roster/sync', {
            method: 'POST'
        });
        const data = await response.json();
        
        result.style.display = 'block';
        
        if (data.success) {
            result.className = 'alert alert-success';
            result.textContent = `✅ ${data.message} (Total: ${data.total}, Synced: ${data.synced}, Skipped: ${data.skipped} bots)`;
            
            // Reload page after 2 seconds
            setTimeout(() => location.reload(), 2000);
        } else {
            result.className = 'alert alert-error';
            result.textContent = `❌ ${data.error}`;
            btn.disabled = false;
            btn.textContent = '🔄 Sync Roster from Discord';
        }
    } catch (error) {
        result.style.display = 'block';
        result.className = 'alert alert-error';
        result.textContent = '❌ Error syncing roster';
        btn.disabled = false;
        btn.textContent = '🔄 Sync Roster from Discord';
    }
}
</script>
<% } %>

<%- include('partials/footer') %>
