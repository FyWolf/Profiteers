<%- include('../partials/header') %>

<div class="page-container" style="max-width: 1100px; margin: 0 auto; padding: 20px;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; flex-wrap: wrap; gap: 15px;">
        <h2 style="margin: 0;">Modpacks</h2>
        <% if (user && (user.isAdmin || user.isZeus)) { %>
            <a href="/modpacks/upload/new" class="btn btn-primary">Upload Modpack</a>
        <% } %>
    </div>

    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>
    
    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <%
    const pinnedModpacks = modpacks.filter(mp => mp.is_pinned);
    const unpinnedModpacks = modpacks.filter(mp => !mp.is_pinned);
    const isAdmin = user && user.isAdmin;
    %>

    <% if (modpacks.length === 0) { %>
        <div style="text-align: center; padding: 60px 20px; background: var(--camo-medium); border-radius: 8px; border: 1px solid var(--olive);">
            <p style="font-size: 1.2em; color: var(--text-secondary); margin-bottom: 15px;">No modpacks uploaded yet.</p>
            <% if (user && (user.isAdmin || user.isZeus)) { %>
                <a href="/modpacks/upload/new" class="btn btn-primary">Upload Your First Modpack</a>
            <% } %>
        </div>
    <% } else { %>

        <% if (pinnedModpacks.length > 0) { %>
            <div style="margin-bottom: 10px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 15px;">
                    <span style="font-size: 1.1em;">📌</span>
                    <h3 style="margin: 0; color: var(--accent); font-size: 1em; letter-spacing: 1px; text-transform: uppercase;">Pinned</h3>
                </div>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 20px; margin-bottom: 35px;">
                    <% pinnedModpacks.forEach(mp => { %>
                        <%- include('./modpack-card', { mp, formatSize, isAdmin }) %>
                    <% }) %>
                </div>
                <% if (unpinnedModpacks.length > 0) { %>
                    <hr style="border: none; border-top: 1px solid var(--olive); margin-bottom: 25px; opacity: 0.4;">
                <% } %>
            </div>
        <% } %>

        <% if (unpinnedModpacks.length > 0) { %>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 20px;">
                <% unpinnedModpacks.forEach(mp => { %>
                    <%- include('./modpack-card', { mp, formatSize, isAdmin }) %>
                <% }) %>
            </div>
        <% } %>

    <% } %>

</div>


<%- include('../partials/footer') %>
