<%- include('../partials/header') %>

<div class="page-container" style="max-width: 1100px; margin: 0 auto; padding: 20px;">

    <a href="/modpacks" style="color: var(--accent); text-decoration: none; font-size: 0.9em; display: inline-block; margin-bottom: 15px;">
        ← Back to Modpacks
    </a>

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <div style="background: var(--camo-medium); border: 1px solid var(--olive); border-radius: 8px; padding: 25px; margin-bottom: 25px;">
        
        <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 15px;">
            <div>
                <h2 style="margin: 0 0 5px 0; font-family: 'Orbitron', monospace;"><%= modpack.name %></h2>
                <% if (modpack.description) { %>
                    <p style="color: var(--text-secondary); margin: 5px 0 0 0;"><%= modpack.description %></p>
                <% } %>
                <p style="color: var(--text-secondary); font-size: 0.85em; margin: 8px 0 0 0;">
                    Uploaded by <strong><%= modpack.creator_name || 'Unknown' %></strong> on <%= new Date(modpack.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                </p>
            </div>
            <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                <a href="/modpacks/<%= modpack.id %>/download" class="btn btn-primary">⬇️ Download Preset</a>
                <% if (user && (user.isAdmin || user.isZeus)) { %>
                    <form action="/modpacks/<%= modpack.id %>/reindex" method="POST" style="display: inline;">
                        <button type="submit" class="btn" title="Re-fetch all mod data from Steam">🔄 Re-index</button>
                    </form>
                    <form action="/modpacks/<%= modpack.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this modpack?');">
                        <button type="submit" class="btn btn-danger">🗑️ Delete</button>
                    </form>
                <% } %>
            </div>
        </div>

        <div style="display: flex; gap: 30px; margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--olive); flex-wrap: wrap;">
            <div style="text-align: center;">
                <div style="font-family: 'Orbitron', monospace; font-size: 1.8em; color: var(--accent);"><%= modpack.mod_count %></div>
                <div style="color: var(--text-secondary); font-size: 0.85em; text-transform: uppercase; letter-spacing: 1px;">Mods</div>
            </div>
            <div style="text-align: center;">
                <div style="font-family: 'Orbitron', monospace; font-size: 1.8em; color: var(--accent);" id="totalSizeDisplay"><%= formatSize(totalSize) %></div>
                <div style="color: var(--text-secondary); font-size: 0.85em; text-transform: uppercase; letter-spacing: 1px;">Total Size</div>
            </div>
            <div style="text-align: center;">
                <div style="font-family: 'Orbitron', monospace; font-size: 1.8em;" id="indexStatusDisplay">
                    <% if (modpack.index_status === 'completed') { %>
                        <span style="color: #4CAF50;">✅</span>
                    <% } else if (modpack.index_status === 'indexing') { %>
                        <span style="color: var(--accent);">⏳</span>
                    <% } else if (modpack.index_status === 'failed') { %>
                        <span style="color: #E74C3C;">❌</span>
                    <% } else { %>
                        <span style="color: var(--text-secondary);">⏳</span>
                    <% } %>
                </div>
                <div style="color: var(--text-secondary); font-size: 0.85em; text-transform: uppercase; letter-spacing: 1px;" id="indexStatusText">
                    <% if (modpack.index_status === 'completed') { %>
                        Indexed
                    <% } else if (modpack.index_status === 'indexing') { %>
                        Indexing (<%= modpack.index_progress %>/<%= modpack.mod_count %>)
                    <% } else if (modpack.index_status === 'failed') { %>
                        Index Failed
                    <% } else { %>
                        Pending
                    <% } %>
                </div>
            </div>
        </div>

        <% if (modpack.index_status === 'failed' && modpack.index_error) { %>
            <div style="margin-top: 15px; padding: 10px 15px; background: rgba(231,76,60,0.15); border: 1px solid rgba(231,76,60,0.3); border-radius: 6px; color: #E74C3C; font-size: 0.9em;">
                ⚠️ Indexing error: <%= modpack.index_error %>
            </div>
        <% } %>

    </div>

    <div style="background: var(--camo-medium); border: 1px solid var(--olive); border-radius: 8px; overflow: hidden;">
        
        <div style="padding: 15px 20px; border-bottom: 1px solid var(--olive); display: flex; justify-content: space-between; align-items: center;">
            <h3 style="margin: 0; font-size: 1em; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary);">Mod List</h3>
            <input type="text" id="modSearch" placeholder="Filter mods..." 
                   style="background: var(--camo-dark); border: 1px solid var(--olive); color: var(--text-primary); padding: 6px 12px; border-radius: 4px; font-size: 0.9em; width: 200px;">
        </div>

        <div id="modList">
            <% if (mods.length === 0) { %>
                <div style="padding: 40px; text-align: center; color: var(--text-secondary);">
                    No mods found in this modpack.
                </div>
            <% } else { %>
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="background: rgba(0,0,0,0.2); text-transform: uppercase; font-size: 0.8em; letter-spacing: 1px; color: var(--text-secondary);">
                            <th style="padding: 10px 15px; text-align: left; width: 50px;"></th>
                            <th style="padding: 10px 15px; text-align: left; cursor: pointer; user-select: none;" onclick="sortTable('name')" title="Sort by name">
                                Name <span id="sort-name-icon" style="opacity: 0.4;">▼</span>
                            </th>
                            <th style="padding: 10px 15px; text-align: right; width: 100px; cursor: pointer; user-select: none;" onclick="sortTable('size')" title="Sort by size">
                                Size <span id="sort-size-icon" style="opacity: 0.4;">▼</span>
                            </th>
                            <th style="padding: 10px 15px; text-align: center; width: 80px;">Link</th>
                        </tr>
                    </thead>
                    <tbody id="modTableBody">
                        <% mods.forEach((mod, index) => { %>
                            <tr class="mod-row" 
                                data-name="<%= (mod.steam_name || mod.display_name).toLowerCase() %>" 
                                data-size="<%= parseInt(mod.file_size) || 0 %>" 
                                style="border-bottom: 1px solid rgba(255,255,255,0.05); transition: background 0.15s;<%= index % 2 === 0 ? '' : ' background: rgba(0,0,0,0.1);' %>">
                                <td style="padding: 8px 15px;">
                                    <% if (mod.icon_url) { %>
                                        <img src="<%= mod.icon_url %>" alt="" 
                                             style="width: 40px; height: 40px; border-radius: 4px; object-fit: cover; border: 1px solid var(--olive);">
                                    <% } else { %>
                                        <div style="width: 40px; height: 40px; border-radius: 4px; background: var(--camo-dark); border: 1px solid var(--olive); display: flex; align-items: center; justify-content: center; color: var(--text-secondary); font-size: 0.8em;">
                                            🧩
                                        </div>
                                    <% } %>
                                </td>
                                <td style="padding: 8px 15px;">
                                    <div style="font-weight: 500; color: var(--text-primary);">
                                        <%= mod.steam_name || mod.display_name %>
                                    </div>
                                    <% if (mod.steam_name && mod.steam_name !== mod.display_name) { %>
                                        <div style="font-size: 0.8em; color: var(--text-secondary);">
                                            Preset name: <%= mod.display_name %>
                                        </div>
                                    <% } %>
                                </td>
                                <td style="padding: 8px 15px; text-align: right; font-family: 'Roboto Mono', monospace; font-size: 0.85em; color: var(--text-secondary);">
                                    <%= formatSize(mod.file_size) %>
                                </td>
                                <td style="padding: 8px 15px; text-align: center;">
                                    <a href="<%= mod.steam_url %>" target="_blank" rel="noopener" 
                                       style="color: #449EBD; text-decoration: none; font-size: 0.9em;" title="Open on Steam Workshop">
                                        🔗 Steam
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>

</div>

<style>
    .mod-row:hover {
        background: rgba(209, 143, 33, 0.08) !important;
    }
    th[onclick]:hover {
        color: var(--accent) !important;
    }
</style>

<script>
document.getElementById('modSearch').addEventListener('input', function() {
    const query = this.value.toLowerCase();
    document.querySelectorAll('.mod-row').forEach(row => {
        const name = row.getAttribute('data-name');
        row.style.display = name.includes(query) ? '' : 'none';
    });
});

let currentSort = { column: null, direction: 'asc' };

function sortTable(column) {
    const tbody = document.getElementById('modTableBody');
    if (!tbody) return;
    
    const rows = Array.from(tbody.querySelectorAll('.mod-row'));
    
    // Toggle direction if clicking same column, otherwise default to desc for size, asc for name
    if (currentSort.column === column) {
        currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
    } else {
        currentSort.column = column;
        currentSort.direction = column === 'size' ? 'desc' : 'asc';
    }
    
    rows.sort((a, b) => {
        let valA, valB;
        if (column === 'size') {
            valA = parseInt(a.getAttribute('data-size')) || 0;
            valB = parseInt(b.getAttribute('data-size')) || 0;
        } else {
            valA = a.getAttribute('data-name') || '';
            valB = b.getAttribute('data-name') || '';
        }
        
        let cmp;
        if (typeof valA === 'number') {
            cmp = valA - valB;
        } else {
            cmp = valA.localeCompare(valB);
        }
        
        return currentSort.direction === 'asc' ? cmp : -cmp;
    });
    
    // Re-append sorted rows and re-stripe
    rows.forEach((row, i) => {
        row.style.background = i % 2 !== 0 ? 'rgba(0,0,0,0.1)' : '';
        tbody.appendChild(row);
    });
    
    document.getElementById('sort-name-icon').style.opacity = '0.4';
    document.getElementById('sort-name-icon').textContent = '▼';
    document.getElementById('sort-size-icon').style.opacity = '0.4';
    document.getElementById('sort-size-icon').textContent = '▼';
    
    const activeIcon = document.getElementById('sort-' + column + '-icon');
    activeIcon.style.opacity = '1';
    activeIcon.textContent = currentSort.direction === 'asc' ? '▲' : '▼';
}

// Auto-refresh indexing status if not yet completed
<% if (modpack.index_status === 'indexing' || modpack.index_status === 'pending') { %>
(function pollStatus() {
    const interval = setInterval(async () => {
        try {
            const res = await fetch('/modpacks/<%= modpack.id %>/status');
            const data = await res.json();
            
            const statusDisplay = document.getElementById('indexStatusDisplay');
            const statusText = document.getElementById('indexStatusText');
            const sizeDisplay = document.getElementById('totalSizeDisplay');

            if (data.status === 'completed') {
                statusDisplay.innerHTML = '<span style="color: #4CAF50;">✅</span>';
                statusText.textContent = 'Indexed';
                sizeDisplay.textContent = data.totalSizeFormatted;
                clearInterval(interval);
                // Reload to show updated mod info
                setTimeout(() => location.reload(), 1000);
            } else if (data.status === 'indexing') {
                statusDisplay.innerHTML = '<span style="color: var(--accent);">⏳</span>';
                statusText.textContent = `Indexing (${data.progress}/${data.total})`;
                if (data.totalSizeFormatted) {
                    sizeDisplay.textContent = data.totalSizeFormatted;
                }
            } else if (data.status === 'failed') {
                statusDisplay.innerHTML = '<span style="color: #E74C3C;">❌</span>';
                statusText.textContent = 'Index Failed';
                clearInterval(interval);
            }
        } catch (e) {
            console.error('Status poll error:', e);
        }
    }, 3000); // Poll every 3 seconds
})();
<% } %>
</script>

<%- include('../partials/footer') %>
