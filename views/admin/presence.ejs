<%- include('../partials/header') %>


<main class="container" style="max-width:1240px;padding-top:30px;">

    <div style="display:flex;align-items:center;gap:10px;margin-bottom:22px;">
        <span style="font-size:1.8em;">📊</span>
        <div>
            <h1 style="font-family:var(--heading-font);font-size:1.4em;color:var(--accent);margin:0;">MEMBER ACTIVITY</h1>
            <div style="font-size:0.78em;color:var(--khaki);margin-top:2px;">Server join/leave events &amp; message-based retention analytics</div>
        </div>
    </div>

    <%
    function netColor(n) { return n > 0 ? 'green' : n < 0 ? 'red' : ''; }
    function netSign(n)  { return n > 0 ? '+' : ''; }
    function fmtDate(d) {
        const s = d instanceof Date ? d.toISOString() : String(d);
        return s.slice(0, 16).replace('T', ' ');
    }
    %>

    <!-- ── Summary chips ──────────────────────────────────────────────────── -->
    <div class="act-chips">
        <div class="act-chip <%= joins_today > 0 ? 'green-border' : '' %>">
            <span class="chip-icon">➕</span>
            <div>
                <div class="chip-value green"><%= joins_today %></div>
                <div class="chip-label">JOINS TODAY</div>
            </div>
        </div>
        <div class="act-chip <%= leaves_today > 0 ? 'red-border' : '' %>">
            <span class="chip-icon">➖</span>
            <div>
                <div class="chip-value red"><%= leaves_today %></div>
                <div class="chip-label">LEAVES TODAY</div>
            </div>
        </div>
        <div class="act-chip">
            <span class="chip-icon">📈</span>
            <div>
                <div class="chip-value <%= netColor(net_month) %>"><%= netSign(net_month) %><%= net_month %></div>
                <div class="chip-label">NET 30-DAY GROWTH</div>
            </div>
        </div>
        <div class="act-chip">
            <span class="chip-icon">💬</span>
            <div>
                <div class="chip-value"><%= dau || 0 %></div>
                <div class="chip-label">ACTIVE TODAY (MSG)</div>
            </div>
        </div>
        <div class="act-chip">
            <span class="chip-icon">📅</span>
            <div>
                <div class="chip-value blue"><%= wau || 0 %></div>
                <div class="chip-label">WAU</div>
            </div>
        </div>
        <div class="act-chip">
            <span class="chip-icon">📆</span>
            <div>
                <div class="chip-value purple"><%= mau || 0 %></div>
                <div class="chip-label">MAU</div>
            </div>
        </div>
        <div class="act-chip">
            <span class="chip-icon">⏳</span>
            <div>
                <div class="chip-value"><%= avg_tenure_left || '—' %><% if (avg_tenure_left) { %><span style="font-size:0.45em;color:var(--khaki);">d</span><% } %></div>
                <div class="chip-label">AVG TENURE (LEAVERS)</div>
            </div>
        </div>
    </div>

    <!-- ── Growth chart + DAU chart ──────────────────────────────────────── -->
    <div class="act-grid-2">

        <div class="act-card">
            <div class="act-card-title">📥📤 SERVER GROWTH — 30 DAYS</div>
            <%
            const maxGrowth = Math.max(...daily_growth.map(d => Math.max(d.joins, d.leaves)), 1);
            %>
            <div class="growth-chart">
                <% daily_growth.forEach((d, i) => {
                    const jh = Math.round((d.joins  / maxGrowth) * 90);
                    const lh = Math.round((d.leaves / maxGrowth) * 90);
                    const showLbl = (i % 5 === 0);
                %>
                <div class="growth-col" title="<%= d.date %> — +<%= d.joins %> joins, -<%= d.leaves %> leaves (net <%= d.net >= 0 ? '+' : '' %><%= d.net %>)">
                    <div style="display:flex;flex-direction:column;align-items:center;gap:1px;height:90px;justify-content:flex-end;">
                        <% if (d.joins > 0) { %>
                        <div style="width:100%;height:<%= jh %>px;background:linear-gradient(180deg,#52c85a,#2a6e30);border-radius:3px 3px 0 0;min-height:2px;"></div>
                        <% } %>
                        <% if (d.leaves > 0) { %>
                        <div style="width:100%;height:<%= lh %>px;background:linear-gradient(180deg,#e05555,#7a2020);border-radius:3px 3px 0 0;min-height:2px;margin-top:1px;"></div>
                        <% } %>
                    </div>
                    <span class="growth-lbl"><%= showLbl ? d.date.slice(5) : '' %></span>
                </div>
                <% }); %>
            </div>
            <div style="display:flex;gap:16px;margin-top:8px;font-size:0.72em;color:var(--khaki);">
                <span><span style="color:#52c85a;">■</span> Joins</span>
                <span><span style="color:#e05555;">■</span> Leaves</span>
            </div>
        </div>

        <div class="act-card">
            <div class="act-card-title">💬 DAILY ACTIVE MEMBERS — 30 DAYS</div>
            <% const maxDau = Math.max(...daily_active.map(d => d.users), 1); %>
            <div class="bar-chart tall" style="gap:2px;">
                <% daily_active.forEach((d, i) => {
                    const h = Math.round((d.users / maxDau) * 100);
                    const showLbl = (i % 5 === 0);
                %>
                <div class="bar-col" title="<%= d.date %>: <%= d.users %> active members">
                    <div class="bar-inner">
                        <div class="bar-fill blue" style="height:<%= h %>%;width:100%;"></div>
                    </div>
                    <span class="bar-lbl"><%= showLbl ? d.date.slice(5) : '' %></span>
                </div>
                <% }); %>
            </div>
        </div>

    </div>

    <!-- ── Retention + weekly + peak hours ───────────────────────────────── -->
    <div class="act-grid-3">

        <div class="act-card">
            <div class="act-card-title">🔄 WEEK-OVER-WEEK RETENTION</div>
            <% if (retention_weeks.length === 0) { %>
                <p style="color:var(--khaki);font-size:0.85em;opacity:0.6;">Not enough data yet.</p>
            <% } else { %>
            <table class="act-table">
                <thead>
                    <tr>
                        <th>WEEK OF</th>
                        <th class="r">ACTIVE</th>
                        <th class="r">RETAINED</th>
                        <th class="r">RATE</th>
                    </tr>
                </thead>
                <tbody>
                    <% retention_weeks.forEach(r => {
                        const rc = r.rate >= 70 ? '#52c85a' : r.rate >= 40 ? 'var(--accent)' : '#e05555';
                    %>
                    <tr>
                        <td class="khaki"><%= r.week_label %></td>
                        <td class="r accent"><%= r.active %></td>
                        <td class="r"><%= r.retained %></td>
                        <td class="r" style="min-width:72px;">
                            <span style="color:<%= rc %>;font-weight:700;"><%= r.rate %>%</span>
                            <div class="ret-bar-wrap">
                                <div class="ret-bar-fill" style="width:<%= r.rate %>%;background:<%= rc %>;opacity:0.7;"></div>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <% } %>
        </div>

        <div class="act-card">
            <div class="act-card-title">📊 WEEKLY ACTIVE</div>
            <% if (weekly_active.length === 0) { %>
                <p style="color:var(--khaki);font-size:0.85em;opacity:0.6;">Not enough data yet.</p>
            <% } else {
                const maxWau = Math.max(...weekly_active.map(w => w.users), 1);
            %>
            <div class="bar-chart" style="height:110px;">
                <% weekly_active.forEach(w => {
                    const h = Math.round((w.users / maxWau) * 100);
                %>
                <div class="bar-col" title="Week of <%= w.week_label %>: <%= w.users %> active">
                    <span class="bar-val"><%= w.users %></span>
                    <div class="bar-inner">
                        <div class="bar-fill green" style="height:<%= h %>%;width:100%;"></div>
                    </div>
                    <span class="bar-lbl"><%= w.week_label %></span>
                </div>
                <% }); %>
            </div>
            <% } %>
        </div>

        <div class="act-card">
            <div class="act-card-title">🕐 PEAK HOURS</div>
            <% const maxPeak = Math.max(...peak_hours.map(h => h.messages), 1); %>
            <div class="bar-chart" style="height:110px;gap:2px;">
                <% peak_hours.forEach(h => {
                    const ht = Math.round((h.messages / maxPeak) * 100);
                    const showLbl = (h.hour % 6 === 0);
                %>
                <div class="bar-col" title="<%= h.hour %>:00 — <%= h.messages %> messages">
                    <div class="bar-inner">
                        <div class="bar-fill purple" style="height:<%= ht %>%;width:100%;min-height:<%= h.messages > 0 ? 2 : 0 %>px;"></div>
                    </div>
                    <span class="bar-lbl"><%= showLbl ? h.hour + 'h' : '' %></span>
                </div>
                <% }); %>
            </div>
        </div>

    </div>

    <!-- ── New member engagement ─────────────────────────────────────────── -->
    <div class="act-card" style="margin-bottom:20px;">
        <div class="act-card-title">🎯 NEW MEMBER ENGAGEMENT — LAST 30 DAYS</div>
        <div class="engage-wrap">
            <%
            const engRate  = new_member_engagement.rate;
            const engColor = engRate >= 70 ? '#52c85a' : engRate >= 40 ? 'var(--accent)' : '#e05555';
            const engBg    = engRate >= 70 ? 'rgba(82,200,90,0.15)' : engRate >= 40 ? 'rgba(252,176,13,0.15)' : 'rgba(220,80,80,0.15)';
            %>
            <div class="engage-ring" style="background:<%= engBg %>;border:3px solid <%= engColor %>;color:<%= engColor %>;">
                <%= engRate %>%
            </div>
            <div class="engage-detail">
                <strong><%= new_member_engagement.engaged %></strong> of <strong><%= new_member_engagement.total %></strong> new members who joined in the last 30 days have sent at least one message.<br>
                <% if (engRate >= 70) { %>
                    <span style="color:#52c85a;">Strong onboarding — most new recruits are engaging.</span>
                <% } else if (engRate >= 40) { %>
                    <span style="color:var(--accent);">Moderate engagement — room to improve onboarding.</span>
                <% } else if (new_member_engagement.total > 0) { %>
                    <span style="color:#e05555;">Low engagement — many new members are not chatting after joining.</span>
                <% } else { %>
                    <span style="color:var(--khaki);opacity:0.6;">No new joins in the last 30 days.</span>
                <% } %>
            </div>
        </div>
    </div>

    <!-- ── Top chatters + top channels ───────────────────────────────────── -->
    <div class="act-grid-2">

        <div class="act-card">
            <div class="act-card-title">🏆 TOP CHATTERS — 30 DAYS</div>
            <% if (top_chatters.length === 0) { %>
                <p style="color:var(--khaki);font-size:0.85em;opacity:0.6;">No data yet.</p>
            <% } else { %>
            <table class="act-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>MEMBER</th>
                        <th class="r">MSGS</th>
                        <th class="r">DAYS</th>
                        <th class="r">LAST SEEN</th>
                    </tr>
                </thead>
                <tbody>
                    <% top_chatters.forEach((m, i) => { %>
                    <tr>
                        <td class="rank"><%= i + 1 %></td>
                        <td><%= m.discord_name %></td>
                        <td class="r accent"><%= m.messages %></td>
                        <td class="r khaki"><%= m.active_days %>d</td>
                        <td class="r khaki" style="font-size:0.8em;"><%= fmtDate(m.last_message) %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <% } %>
        </div>

        <div class="act-card">
            <div class="act-card-title">🔊 TOP CHANNELS — 30 DAYS</div>
            <% if (top_channels.length === 0) { %>
                <p style="color:var(--khaki);font-size:0.85em;opacity:0.6;">No data yet.</p>
            <% } else {
                const maxChanMsgs = Math.max(...top_channels.map(c => c.messages), 1);
            %>
            <table class="act-table">
                <thead>
                    <tr>
                        <th>CHANNEL</th>
                        <th class="r">MSGS</th>
                        <th class="r">USERS</th>
                    </tr>
                </thead>
                <tbody>
                    <% top_channels.forEach(c => {
                        const pct = Math.round((c.messages / maxChanMsgs) * 100);
                    %>
                    <tr>
                        <td>
                            #<%= c.channel_name %>
                            <div class="ret-bar-wrap"><div class="ret-bar-fill" style="width:<%= pct %>%;background:var(--olive-light);opacity:0.7;"></div></div>
                        </td>
                        <td class="r accent"><%= c.messages %></td>
                        <td class="r khaki"><%= c.unique_users %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <% } %>
        </div>

    </div>

    <!-- ── Recent joins + leaves ─────────────────────────────────────────── -->
    <div class="act-grid-2">

        <div class="act-card">
            <div class="act-card-title">➕ RECENT JOINS</div>
            <% if (recent_joins.length === 0) { %>
                <p style="color:var(--khaki);font-size:0.85em;opacity:0.6;">No joins recorded yet.</p>
            <% } else { %>
            <table class="act-table">
                <thead>
                    <tr>
                        <th>MEMBER</th>
                        <th class="r">ACCOUNT AGE</th>
                        <th class="r">JOINED</th>
                    </tr>
                </thead>
                <tbody>
                    <% recent_joins.forEach(j => { %>
                    <tr>
                        <td class="green"><%= j.discord_name %></td>
                        <td class="r khaki"><%= j.account_age_days != null ? j.account_age_days + 'd' : '—' %></td>
                        <td class="r khaki" style="font-size:0.8em;"><%= fmtDate(j.occurred_at) %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <% } %>
        </div>

        <div class="act-card">
            <div class="act-card-title">➖ RECENT LEAVES</div>
            <% if (recent_leaves.length === 0) { %>
                <p style="color:var(--khaki);font-size:0.85em;opacity:0.6;">No leaves recorded yet.</p>
            <% } else { %>
            <table class="act-table">
                <thead>
                    <tr>
                        <th>MEMBER</th>
                        <th class="r">TENURE</th>
                        <th class="r">LEFT</th>
                    </tr>
                </thead>
                <tbody>
                    <% recent_leaves.forEach(l => { %>
                    <tr>
                        <td class="red"><%= l.discord_name %></td>
                        <td class="r khaki"><%= l.days_stayed != null ? l.days_stayed + 'd' : '—' %></td>
                        <td class="r khaki" style="font-size:0.8em;"><%= fmtDate(l.occurred_at) %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <% } %>
        </div>

    </div>

    <p style="font-size:0.72em;color:var(--khaki);opacity:0.45;margin-top:4px;text-align:right;">
        Message content is never stored — only metadata (who, when, which channel).
        Active users are members who sent at least one message in the period.
    </p>

</main>

<%- include('../partials/footer') %>
