<%- include('../partials/header') %>

<style>
.stat-bar { display:flex; gap:28px; flex-wrap:wrap; margin-top:16px; padding-top:16px; border-top:1px solid rgba(107,142,35,0.3); }
.stat-chip { display:flex; flex-direction:column; align-items:center; }
.stat-val { font-family:var(--heading-font); font-size:1.7em; color:var(--accent); line-height:1; }
.stat-lbl { font-size:0.7em; color:var(--khaki); margin-top:3px; }

.top-row { display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-bottom:20px; }
.top-row h2 { margin:0; font-size:1.1em; color:var(--khaki); letter-spacing:2px; }

.cards-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:16px; }
.item-card {
    background:linear-gradient(135deg,rgba(0,0,0,0.45) 0%,rgba(10,20,10,0.45) 100%);
    border:1px solid rgba(107,142,35,0.5);
    border-radius:12px;
    padding:18px 20px;
    display:flex; flex-direction:column;
    transition:border-color 0.2s, transform 0.2s;
}
.item-card:hover { border-color:rgba(252,176,13,0.5); transform:translateY(-2px); }
.card-body { flex:1; }
.card-footer { display:flex; gap:8px; margin-top:14px; padding-top:14px; border-top:1px solid rgba(107,142,35,0.2); }
.card-meta { font-size:0.82em; color:var(--khaki); padding:10px 0; border-top:1px solid rgba(107,142,35,0.15); margin-top:10px; display:flex; align-items:center; justify-content:space-between; gap:12px; }

.act { padding:5px 10px; border-radius:6px; font-size:0.76em; font-weight:700; text-decoration:none; cursor:pointer; border:1px solid transparent; transition:all 0.2s; white-space:nowrap; display:inline-block; font-family:var(--body-font); flex:1; text-align:center; }
.act-edit { background:rgba(252,176,13,0.1); border-color:rgba(252,176,13,0.35); color:var(--accent); }
.act-edit:hover { background:rgba(252,176,13,0.22); }
.act-del  { background:rgba(231,76,60,0.1);  border-color:rgba(231,76,60,0.35);  color:#ff7b7b; }
.act-del:hover  { background:rgba(231,76,60,0.22); }

.empty-state { text-align:center; padding:48px 20px; color:var(--khaki); opacity:.6; }
.empty-icon  { font-size:3em; margin-bottom:12px; }
.empty-state p { font-size:.9em; margin-top:6px; }
</style>

<% const totalAwards = medals.reduce((s, m) => s + m.awarded_count, 0); %>

<div class="container">
    <header>
        <h1>MANAGE MEDALS</h1>
        <div class="subtitle">Medal System Administration</div>
        <div class="stat-bar">
            <div class="stat-chip">
                <span class="stat-val"><%= medals.length %></span>
                <span class="stat-lbl">Total Medals</span>
            </div>
            <div class="stat-chip">
                <span class="stat-val"><%= totalAwards %></span>
                <span class="stat-lbl">Total Awards</span>
            </div>
        </div>
    </header>

    <section class="section">
        <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
        <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

        <div class="top-row">
            <h2>ALL MEDALS (<%= medals.length %>)</h2>
            <a href="/admin/medals/add" class="btn btn-primary">➕ Create Medal</a>
        </div>

        <% if (medals.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon">🏅</div>
                <strong>No medals yet</strong>
                <p>Create your first medal to start recognising members.</p>
            </div>
        <% } else { %>
            <div class="cards-grid">
                <% medals.forEach(medal => { %>
                <div class="item-card" style="border-left:3px solid <%= medal.color %>;">
                    <div class="card-body">
                        <div style="display:flex; align-items:flex-start; gap:14px; margin-bottom:10px;">
                            <span style="font-size:2.4em; line-height:1; flex-shrink:0;"><%= medal.icon %></span>
                            <div>
                                <div style="font-family:var(--heading-font); font-size:0.95em; color:<%= medal.color %>; margin-bottom:4px;"><%= medal.name %></div>
                                <div style="font-size:0.82em; color:var(--khaki); line-height:1.5;"><%= medal.description %></div>
                            </div>
                        </div>
                        <div class="card-meta">
                            <span>Awarded <strong style="color:var(--accent);"><%= medal.awarded_count %></strong> time<%= medal.awarded_count !== 1 ? 's' : '' %></span>
                            <span style="display:inline-flex; align-items:center; gap:6px; font-size:0.85em;">
                                Color
                                <span style="display:inline-block; width:16px; height:16px; background:<%= medal.color %>; border-radius:3px; border:1px solid rgba(255,255,255,0.2); vertical-align:middle;"></span>
                            </span>
                        </div>
                    </div>
                    <div class="card-footer">
                        <a href="/admin/medals/edit/<%= medal.id %>" class="act act-edit">✏️ Edit</a>
                        <form method="POST" action="/admin/medals/delete/<%= medal.id %>" style="flex:1"
                              onsubmit="return confirm('Delete this medal? It will be removed from all users who have it.')">
                            <button type="submit" class="act act-del" style="width:100%;">🗑️ Delete</button>
                        </form>
                    </div>
                </div>
                <% }) %>
            </div>
        <% } %>
    </section>

    <div class="mt-2">
        <a href="/admin" class="btn">← Back to Dashboard</a>
    </div>
</div>

<%- include('../partials/footer') %>
