<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>MANAGE TOOLS</h1>
        <div class="subtitle">Internal Tools Administration</div>
    </header>

    <section class="section">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h2 style="margin: 0;">All Tools</h2>
            <a href="/admin/tools/add" class="btn btn-primary">➕ Add New Tool</a>
        </div>

        <% if (success) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>
        
        <% if (error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>

        <% if (tools.length === 0) { %>
            <div class="card text-center">
                <h3>No Tools Yet</h3>
                <p>Create your first internal tool to get started.</p>
                <a href="/admin/tools/add" class="btn btn-primary mt-2">Add First Tool</a>
            </div>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Title</th>
                        <th>Link</th>
                        <th>Visible</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% tools.forEach(tool => { %>
                        <tr>
                            <td><%= tool.order_index %></td>
                            <td><strong><%= tool.title %></strong></td>
                            <td><a href="<%= tool.link %>" target="_blank" style="color: var(--accent);"><%= tool.link %></a></td>
                            <td>
                                <button onclick="toggleVisibility(<%= tool.id %>)" 
                                        class="btn" 
                                        style="<%= tool.is_visible ? 'background: var(--olive);' : 'background: #888;' %> padding: 6px 12px;">
                                    <%= tool.is_visible ? '✅ Visible' : '❌ Hidden' %>
                                </button>
                            </td>
                            <td>
                                <a href="/admin/tools/edit/<%= tool.id %>" class="btn" style="padding: 6px 12px;">Edit</a>
                                <form method="POST" action="/admin/tools/delete/<%= tool.id %>" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this tool?');">
                                    <button type="submit" class="btn btn-danger" style="padding: 6px 12px;">Delete</button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </section>

    <section class="section">
        <a href="/admin" class="btn">← Back to Dashboard</a>
    </section>
</div>

<script>
async function toggleVisibility(id) {
    try {
        const response = await fetch(`/admin/tools/toggle/${id}`, {
            method: 'POST'
        });
        const data = await response.json();
        
        if (data.success) {
            location.reload();
        } else {
            alert('Failed to toggle visibility');
        }
    } catch (error) {
        alert('Error toggling visibility');
    }
}
</script>

<%- include('../partials/footer') %>
