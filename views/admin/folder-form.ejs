<%- include('../partials/header') %>


<div class="container">
    <header>
        <h1>CREATE FOLDER</h1>
        <div class="subtitle">Gallery Organization</div>
    </header>

    <section class="section">
        <div class="form-wrap" style="max-width:600px;">
            <form method="POST" action="/admin/gallery/add-folder">

                <div class="field">
                    <label for="name">Folder Name *</label>
                    <input type="text" id="name" name="name" required
                           placeholder="e.g., Operation Red Dawn">
                </div>

                <div class="field">
                    <label for="parent_id">Parent Folder (Optional)</label>
                    <select id="parent_id" name="parent_id">
                        <option value="">None (Root Level)</option>
                        <% folders.forEach(folder => { %>
                            <option value="<%= folder.id %>"><%= folder.path %></option>
                        <% }); %>
                    </select>
                    <small>Select a parent to create a subfolder. Leave empty for a root-level folder.</small>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" style="flex:1;">📁 Create Folder</button>
                    <a href="/admin/gallery" class="btn">Cancel</a>
                </div>
            </form>

            <div class="info-box">
                <strong>💡 Tips</strong>
                <p>
                    Use descriptive names like "Operation Red Dawn" or "Training Session 2024-01".<br>
                    Create parent folders for categories (e.g., "Operations", "Training") then subfolders for specific events.<br>
                    Example structure: Operations → Operation Red Dawn → Screenshots
                </p>
            </div>
        </div>
    </section>
</div>

<%- include('../partials/footer') %>
