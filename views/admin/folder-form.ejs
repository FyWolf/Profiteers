<%- include('../partials/header') %>

<style>
.form-wrap { max-width:600px; margin:0 auto; }
.field { margin-bottom:20px; }
.field label { display:block; font-size:0.8em; color:var(--khaki); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:7px; }
.field input, .field textarea, .field select {
    width:100%; padding:10px 14px;
    background:rgba(0,0,0,0.4);
    border:1px solid rgba(107,142,35,0.5);
    border-radius:7px;
    color:var(--sand);
    font-family:var(--body-font);
    font-size:0.92em;
    transition:border-color 0.2s;
}
.field input:focus, .field select:focus { outline:none; border-color:var(--accent); box-shadow:0 0 8px rgba(252,176,13,0.15); }
.field small { display:block; margin-top:5px; font-size:0.78em; color:var(--khaki); opacity:.7; }
.form-actions { display:flex; gap:12px; margin-top:28px; padding-top:20px; border-top:1px solid rgba(107,142,35,0.25); }
.info-box { padding:14px 18px; background:rgba(52,152,219,0.07); border-left:3px solid rgba(52,152,219,0.5); border-radius:0 8px 8px 0; margin-top:24px; }
.info-box p { font-size:0.86em; color:var(--khaki); line-height:1.75; margin:0; }
.info-box strong { color:#6bb8f7; display:block; margin-bottom:6px; text-transform:uppercase; font-size:0.88em; letter-spacing:0.5px; }
</style>

<div class="container">
    <header>
        <h1>CREATE FOLDER</h1>
        <div class="subtitle">Gallery Organization</div>
    </header>

    <section class="section">
        <div class="form-wrap">
            <form method="POST" action="/admin/gallery/add-folder">

                <div class="field">
                    <label for="name">Folder Name *</label>
                    <input type="text" id="name" name="name" required
                           placeholder="e.g., Operation Red Dawn">
                </div>

                <div class="field">
                    <label for="parent_id">Parent Folder (Optional)</label>
                    <select id="parent_id" name="parent_id">
                        <option value="">None (Root Level)</option>
                        <% folders.forEach(folder => { %>
                            <option value="<%= folder.id %>"><%= folder.path %></option>
                        <% }); %>
                    </select>
                    <small>Select a parent to create a subfolder. Leave empty for a root-level folder.</small>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" style="flex:1;">📁 Create Folder</button>
                    <a href="/admin/gallery" class="btn">Cancel</a>
                </div>
            </form>

            <div class="info-box">
                <strong>💡 Tips</strong>
                <p>
                    Use descriptive names like "Operation Red Dawn" or "Training Session 2024-01".<br>
                    Create parent folders for categories (e.g., "Operations", "Training") then subfolders for specific events.<br>
                    Example structure: Operations → Operation Red Dawn → Screenshots
                </p>
            </div>
        </div>
    </section>
</div>

<%- include('../partials/footer') %>
