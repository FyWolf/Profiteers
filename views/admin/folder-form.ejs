<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>CREATE FOLDER</h1>
        <div class="subtitle">Gallery Organization</div>
    </header>

    <section class="section" style="max-width: 600px; margin: 0 auto 30px;">
        <form method="POST" action="/admin/gallery/add-folder">
            <div class="form-group">
                <label for="name">Folder Name *</label>
                <input type="text" 
                       id="name" 
                       name="name" 
                       required 
                       placeholder="e.g., Operation Red Dawn">
            </div>

            <div class="form-group">
                <label for="parent_id">Parent Folder (Optional)</label>
                <select id="parent_id" name="parent_id">
                    <option value="">None (Root Level)</option>
                    <% folders.forEach(folder => { %>
                        <option value="<%= folder.id %>"><%= folder.path %></option>
                    <% }); %>
                </select>
                <small style="color: var(--khaki); display: block; margin-top: 5px;">
                    Select a parent to create a subfolder. Leave empty for a root-level folder.
                </small>
            </div>

            <div style="display: flex; gap: 15px; margin-top: 30px;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">
                    📁 Create Folder
                </button>
                <a href="/admin/gallery" class="btn" style="flex: 0 0 auto;">Cancel</a>
            </div>
        </form>
    </section>

    <section class="section" style="max-width: 600px; margin: 0 auto;">
        <h3>💡 Tips</h3>
        <ul style="margin-left: 20px; line-height: 2;">
            <li>Use descriptive names like "Operation Red Dawn" or "Training Session 2024-01"</li>
            <li>Create parent folders for categories (e.g., "Operations", "Training")</li>
            <li>Create subfolders for specific events under parent folders</li>
            <li>Folder structure example: Operations → Operation Red Dawn → Screenshots</li>
        </ul>
    </section>
</div>

<%- include('../partials/footer') %>
