<%- include('../partials/header') %>


<div class="container">
    <header>
        <h1>MANAGE ROLES</h1>
        <div class="subtitle">
            Roles for
            <strong style="color:var(--accent);">
                <%= targetUser.discord_global_name || targetUser.username %>
            </strong>
        </div>
    </header>

    <section class="section">
        <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
        <% if (error)   { %><div class="alert alert-error"><%= error %></div><% } %>

        <%# Current roles %>
        <div class="roles-section">
            <h3>Current Roles (<%= userRoles.length %>)</h3>
            <% if (userRoles.length === 0) { %>
                <div class="empty-msg">This user has no roles assigned.</div>
            <% } else { %>
                <% userRoles.forEach(role => { %>
                <div class="role-card">
                    <div class="role-info">
                        <div class="role-name">
                            <%= role.name %>
                            <% if (role.is_system) { %><span class="system-badge">SYSTEM</span><% } %>
                        </div>
                        <% if (role.description) { %>
                            <div class="role-desc"><%= role.description %></div>
                        <% } %>
                        <div class="role-since">
                            Assigned <%= new Date(role.assigned_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                        </div>
                    </div>
                    <form method="POST"
                          action="/admin/users/<%= targetUser.id %>/roles/revoke/<%= role.id %>"
                          onsubmit="return confirm('Remove the <%= role.name %> role from this user?')">
                        <button type="submit" class="revoke-btn">Remove</button>
                    </form>
                </div>
                <% }) %>
            <% } %>
        </div>

        <%# Assign new role %>
        <div class="roles-section">
            <h3>Assign Role</h3>
            <% if (availableRoles.length === 0) { %>
                <div class="empty-msg">No additional roles available to assign.</div>
            <% } else { %>
                <form method="POST" action="/admin/users/<%= targetUser.id %>/roles/assign" class="assign-form">
                    <select name="roleId" class="assign-select" required>
                        <option value="" disabled selected>Select a role...</option>
                        <% availableRoles.forEach(role => { %>
                            <option value="<%= role.id %>">
                                <%= role.name %><%= role.description ? ` — ${role.description}` : '' %>
                            </option>
                        <% }) %>
                    </select>
                    <button type="submit" class="assign-btn">Assign Role</button>
                </form>
            <% } %>
        </div>
    </section>

    <div style="margin-bottom:30px;">
        <a href="/admin/users" class="btn">← Back to Users</a>
    </div>
</div>

<%- include('../partials/footer') %>
