<%- include('../partials/header') %>

<style>
.form-wrap { max-width:720px; margin:0 auto; }
.field { margin-bottom:20px; }
.field label { display:block; font-size:0.8em; color:var(--khaki); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:7px; }
.field input, .field textarea, .field select {
    width:100%; padding:10px 14px;
    background:rgba(0,0,0,0.4);
    border:1px solid rgba(107,142,35,0.5);
    border-radius:7px;
    color:var(--sand);
    font-family:var(--body-font);
    font-size:0.92em;
    transition:border-color 0.2s;
}
.field input:focus, .field textarea:focus { outline:none; border-color:var(--accent); box-shadow:0 0 8px rgba(252,176,13,0.15); }
.field textarea { min-height:90px; resize:vertical; }
.field small { display:block; margin-top:5px; font-size:0.78em; color:var(--khaki); opacity:.7; }
.color-row { display:flex; gap:12px; align-items:center; }
.color-row input[type=color] { width:48px; height:42px; border:1px solid rgba(107,142,35,0.5); border-radius:7px; cursor:pointer; padding:2px; background:rgba(0,0,0,0.4); flex-shrink:0; }
.color-row .color-text { flex:1; }
.upload-box { padding:14px 16px; background:rgba(52,152,219,0.07); border:1px solid rgba(52,152,219,0.35); border-radius:8px; margin-bottom:14px; }
.upload-box strong { color:#6bb8f7; display:block; margin-bottom:8px; font-size:0.85em; text-transform:uppercase; letter-spacing:0.5px; }
.img-preview-box { margin-top:14px; padding:16px; background:rgba(0,0,0,0.3); border:1px solid rgba(107,142,35,0.4); border-radius:8px; text-align:center; }
.img-preview-box .preview-label { font-size:0.78em; color:var(--khaki); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:10px; }
.preview-card {
    background:linear-gradient(135deg,rgba(0,0,0,0.45) 0%,rgba(10,20,10,0.45) 100%);
    border:1px solid rgba(107,142,35,0.5);
    border-radius:12px;
    padding:18px 20px;
}
.form-actions { display:flex; gap:12px; margin-top:28px; padding-top:20px; border-top:1px solid rgba(107,142,35,0.25); }
</style>

<div class="container">
    <header>
        <h1><%= action === 'add' ? 'CREATE TRAINING' : 'EDIT TRAINING' %></h1>
        <div class="subtitle">Training Certification System</div>
    </header>

    <section class="section">
        <div class="form-wrap">
            <form method="POST" action="/admin/trainings/<%= action === 'add' ? 'add' : 'edit/' + training.id %>" enctype="multipart/form-data">

                <div class="field">
                    <label for="name">Training Name *</label>
                    <input type="text" id="name" name="name"
                           value="<%= training ? training.name : '' %>" required maxlength="100"
                           placeholder="e.g., Combat Life Saver (CLS)">
                </div>

                <div class="field">
                    <label for="discord_role_id">Discord Role ID *</label>
                    <input type="text" id="discord_role_id" name="discord_role_id"
                           value="<%= training ? training.discord_role_id : '' %>" required maxlength="50"
                           placeholder="e.g., 1265517416071430185">
                    <small>Server Settings → Roles → Right-click role → Copy ID (Developer Mode must be on)</small>
                </div>

                <div class="field">
                    <label for="description">Description (Optional)</label>
                    <textarea id="description" name="description"
                              placeholder="Brief description of this training…"><%= training ? training.description || '' : '' %></textarea>
                </div>

                <div class="field">
                    <label for="color">Badge Color</label>
                    <div class="color-row">
                        <input type="color" id="color" name="color"
                               value="<%= training ? training.color : '#3498DB' %>">
                        <input type="text" id="colorText" class="color-text"
                               value="<%= training ? training.color : '#3498DB' %>" readonly>
                    </div>
                    <small>Choose a color for this training badge</small>
                </div>

                <div class="field">
                    <label>Badge Image</label>
                    <div class="upload-box">
                        <strong>📤 Upload Badge Image</strong>
                        <input type="file" id="badge_upload" name="badge_upload" accept="image/*">
                        <small style="opacity:1; margin-top:8px;">PNG recommended, 512×512px, under 500KB</small>
                    </div>

                    <label for="image_url" style="font-size:0.78em; opacity:.8;">Or enter URL manually:</label>
                    <input type="text" id="image_url" name="image_url"
                           value="<%= training ? training.image_url : '/images/badges/default-training.png' %>"
                           placeholder="/images/badges/your-badge.png">
                    <small>Path will be set automatically when you upload a file</small>

                    <div class="img-preview-box">
                        <div class="preview-label">Image Preview</div>
                        <img id="imagePreview"
                             src="<%= training ? training.image_url : '/images/badges/default-training.png' %>"
                             alt="Training Badge Preview"
                             style="max-width:160px; max-height:160px; border-radius:8px; border:2px solid rgba(107,142,35,0.5);"
                             onerror="this.src='/images/badges/default-training.png'; this.style.borderColor='#e74c3c';">
                        <div id="imageStatus" style="margin-top:10px; font-size:0.82em;"></div>
                    </div>
                </div>

                <div class="field">
                    <label for="display_order">Display Order</label>
                    <input type="number" id="display_order" name="display_order"
                           value="<%= training ? training.display_order : 0 %>" min="0" placeholder="0">
                    <small>Lower numbers appear first (0, 1, 2…)</small>
                </div>

                <div class="field">
                    <label>Preview</label>
                    <div class="preview-card" id="preview" style="border-left:4px solid <%= training ? training.color : '#3498DB' %>;">
                        <div style="display:flex; align-items:flex-start; gap:16px;">
                            <img id="previewBadge"
                                 src="<%= training ? training.image_url : '/images/badges/default-training.png' %>"
                                 alt="Training Badge"
                                 style="width:72px; height:72px; object-fit:contain; border-radius:8px; border:2px solid <%= training ? training.color : '#3498DB' %>; flex-shrink:0;"
                                 onerror="this.src='/images/badges/default-training.png';">
                            <div style="flex:1;">
                                <div id="previewName" style="font-family:var(--heading-font); font-size:0.95em; color:<%= training ? training.color : '#3498DB' %>; margin-bottom:6px;">
                                    <%= training ? training.name : 'Training Name' %>
                                </div>
                                <div id="previewDesc" style="font-size:0.82em; color:var(--khaki); line-height:1.55;">
                                    <%= training && training.description ? training.description : 'Training description will appear here…' %>
                                </div>
                                <div style="font-size:0.78em; color:var(--khaki); margin-top:10px; opacity:.7;">Auto-synced from Discord role</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" style="flex:1;">
                        <%= action === 'add' ? '➕ Create Training' : '💾 Save Changes' %>
                    </button>
                    <a href="/admin/trainings" class="btn">Cancel</a>
                </div>
            </form>
        </div>
    </section>
</div>

<script>
const nameInput = document.getElementById('name');
const descInput = document.getElementById('description');
const colorInput = document.getElementById('color');
const colorText = document.getElementById('colorText');
const imageUrlInput = document.getElementById('image_url');
const badgeUpload = document.getElementById('badge_upload');

const previewName = document.getElementById('previewName');
const previewDesc = document.getElementById('previewDesc');
const previewBadge = document.getElementById('previewBadge');
const imagePreview = document.getElementById('imagePreview');
const imageStatus = document.getElementById('imageStatus');
const preview = document.getElementById('preview');

nameInput.addEventListener('input', () => {
    previewName.textContent = nameInput.value || 'Training Name';
});

descInput.addEventListener('input', () => {
    previewDesc.textContent = descInput.value || 'Training description will appear here…';
});

colorInput.addEventListener('input', () => {
    const color = colorInput.value;
    colorText.value = color;
    previewName.style.color = color;
    preview.style.borderLeftColor = color;
    previewBadge.style.borderColor = color;
});

badgeUpload.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (file) {
        if (!file.type.startsWith('image/')) {
            imageStatus.textContent = '❌ Please select an image file';
            imageStatus.style.color = '#e74c3c';
            return;
        }

        if (file.size > 5 * 1024 * 1024) { // max 5MB
            imageStatus.textContent = '❌ Image too large (max 5MB)';
            imageStatus.style.color = '#e74c3c';
            return;
        }

        const reader = new FileReader();
        reader.onload = (event) => {
            imagePreview.src = event.target.result;
            previewBadge.src = event.target.result;
            imageStatus.textContent = '✅ Image ready to upload';
            imageStatus.style.color = '#2ecc71';
        };
        reader.readAsDataURL(file);

        // Set the image_url to what it will be after upload
        const filename = file.name.toLowerCase().replace(/[^a-z0-9.-]/g, '-');
        imageUrlInput.value = '/images/badges/' + filename;
        imageStatus.textContent = '✅ Will be saved as: ' + filename;
        imageStatus.style.color = '#2ecc71';
    }
});

imageUrlInput.addEventListener('input', () => {
    const url = imageUrlInput.value;
    updateImagePreviews(url);
});

function updateImagePreviews(url) {
    imagePreview.src = url;
    previewBadge.src = url;

    const testImg = new Image();
    testImg.onload = () => {
        imageStatus.textContent = '✅ Image loaded successfully';
        imageStatus.style.color = '#2ecc71';
    };
    testImg.onerror = () => {
        imageStatus.textContent = '❌ Image not found or failed to load';
        imageStatus.style.color = '#e74c3c';
    };
    testImg.src = url;
}

function setImage(url) {
    imageUrlInput.value = url;
    updateImagePreviews(url);
}

if (!badgeUpload.files || badgeUpload.files.length === 0) {
    updateImagePreviews(imageUrlInput.value);
}
</script>

<%- include('../partials/footer') %>
