<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>DEBUG</h1>
        <div class="subtitle">Maintenance &amp; sanity-check tools for production</div>
    </header>

    <section class="section">
        <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
        <% if (error)   { %><div class="alert alert-error"><%= error %></div><% } %>

        <!-- ── Staff LOA role sanity check ──────────────────────────────── -->
        <div class="panel" style="margin-bottom:18px;">
            <h3 style="margin:0 0 6px;">🛡️ Staff LOA role check</h3>
            <p style="margin:0 0 14px;font-size:0.86em;color:var(--khaki);opacity:0.8;">
                Compares the staff-LOA Discord role against who should hold it (members with an
                active staff LOA). Running the check changes nothing; apply fixes to grant the role
                to anyone missing it and revoke it from anyone holding it without an active staff LOA.
            </p>

            <form method="POST" action="/admin/debug/staff-loa/audit" style="display:inline;">
                <button type="submit" class="btn btn-primary">Run check</button>
            </form>

            <% if (staffLoaAudit) { %>
                <% if (!staffLoaAudit.configured) { %>
                    <div class="alert alert-error" style="margin-top:14px;">
                        <code>DISCORD_STAFF_LOA_ROLE_ID</code> is not configured — nothing to check.
                    </div>
                <% } else if (!staffLoaAudit.available) { %>
                    <div class="alert alert-error" style="margin-top:14px;">
                        Could not reach Discord to enumerate guild members. Check the bot token / guild id.
                    </div>
                <% } else {
                    const missing = staffLoaAudit.missing || [];
                    const extra   = staffLoaAudit.extra || [];
                    const inSync  = missing.length === 0 && extra.length === 0;
                %>
                    <div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap;">
                        <div class="stat-chip"><span class="stat-val"><%= staffLoaAudit.okCount %></span><span class="stat-lbl">Correct</span></div>
                        <div class="stat-chip"><span class="stat-val" style="color:#e86070;"><%= missing.length %></span><span class="stat-lbl">Missing role</span></div>
                        <div class="stat-chip"><span class="stat-val" style="color:#f1c40f;"><%= extra.length %></span><span class="stat-lbl">Should not have</span></div>
                    </div>

                    <% if (inSync) { %>
                        <div class="alert alert-success" style="margin-top:14px;">✅ Everyone has the correct staff-LOA role.</div>
                    <% } else { %>
                        <% if (missing.length) { %>
                            <div style="margin-top:14px;">
                                <strong style="color:#e86070;">Missing the role (active staff LOA, role not applied):</strong>
                                <ul style="margin:6px 0 0;padding-left:20px;color:var(--khaki);font-size:0.9em;list-style:none;">
                                    <% missing.forEach(m => { %>
                                    <li style="display:flex;align-items:center;gap:8px;margin-bottom:5px;">
                                        <span style="flex:1;min-width:0;"><%= m.name %> <span style="opacity:0.5;">(<%= m.discord_id %>)</span></span>
                                        <form method="POST" action="/admin/debug/staff-loa/fix-one" style="margin:0;">
                                            <input type="hidden" name="discord_id" value="<%= m.discord_id %>">
                                            <input type="hidden" name="action" value="grant">
                                            <button type="submit" class="btn" style="padding:3px 10px;font-size:0.78em;">Grant</button>
                                        </form>
                                    </li>
                                    <% }) %>
                                </ul>
                            </div>
                        <% } %>
                        <% if (extra.length) { %>
                            <div style="margin-top:14px;">
                                <strong style="color:#f1c40f;">Holds the role with no active staff LOA:</strong>
                                <ul style="margin:6px 0 0;padding-left:20px;color:var(--khaki);font-size:0.9em;list-style:none;">
                                    <% extra.forEach(m => { %>
                                    <li style="display:flex;align-items:center;gap:8px;margin-bottom:5px;">
                                        <span style="flex:1;min-width:0;"><%= m.name %> <span style="opacity:0.5;">(<%= m.discord_id %>)</span></span>
                                        <form method="POST" action="/admin/debug/staff-loa/fix-one" style="margin:0;"
                                              onsubmit="return confirm('Revoke the staff-LOA role from <%= m.name %>?')">
                                            <input type="hidden" name="discord_id" value="<%= m.discord_id %>">
                                            <input type="hidden" name="action" value="revoke">
                                            <button type="submit" class="btn btn-danger" style="padding:3px 10px;font-size:0.78em;">Revoke</button>
                                        </form>
                                    </li>
                                    <% }) %>
                                </ul>
                            </div>
                        <% } %>
                        <form method="POST" action="/admin/debug/staff-loa/fix" style="margin-top:16px;"
                              onsubmit="return confirm('Apply staff-LOA role fixes? This will grant <%= missing.length %> and revoke <%= extra.length %> role(s) in Discord.')">
                            <button type="submit" class="btn btn-primary">Apply fixes (grant <%= missing.length %>, revoke <%= extra.length %>)</button>
                        </form>
                    <% } %>
                <% } %>
            <% } %>
        </div>

        <!-- ── ORBAT Squad Discord Role Audit ──────────────────────────── -->
        <div class="panel" style="margin-bottom:18px;">
            <h3 style="margin:0 0 6px;">🎮 ORBAT Squad Discord Role Audit</h3>
            <p style="margin:0 0 14px;font-size:0.86em;color:var(--khaki);opacity:0.8;">
                Compares Discord roles against ORBAT squad assignments. Finds members who have a
                squad's Discord role but aren't assigned to that squad, and members assigned to a
                squad who are missing the squad's Discord role.
            </p>

            <form method="POST" action="/admin/debug/orbat-roles/audit" style="display:inline;">
                <button type="submit" class="btn btn-primary">Run check</button>
            </form>

            <% if (orbatRolesAudit) { %>
                <% if (!orbatRolesAudit.configured) { %>
                    <div class="alert alert-error" style="margin-top:14px;">
                        Discord bot is not configured — nothing to check.
                    </div>
                <% } else if (orbatRolesAudit.available === false) { %>
                    <div class="alert alert-error" style="margin-top:14px;">
                        Could not reach Discord to enumerate guild members. Check the bot token / guild id.
                    </div>
                <% } else if (orbatRolesAudit.message) { %>
                    <div class="alert" style="margin-top:14px;"><%= orbatRolesAudit.message %></div>
                <% } else { %>
                    <% const squads = orbatRolesAudit.squads || []; %>
                    <div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap;">
                        <div class="stat-chip"><span class="stat-val"><%= squads.length %></span><span class="stat-lbl">Squads with roles</span></div>
                    </div>

                    <% squads.forEach(squad => { %>
                        <% const totalIssues = squad.missing.length + squad.extra.length; %>
                        <div style="margin-top:16px;padding:12px;background:rgba(0,0,0,0.15);border-radius:6px;border-left:3px solid <%= totalIssues > 0 ? '#f1c40f' : '#2ecc71' %>;">
                            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:8px;">
                                <strong style="color:var(--sand);"><%= squad.templateName %> / <%= squad.squadName %></strong>
                                <span style="font-size:0.78em;color:var(--khaki);">Role ID: <code><%= squad.discordRoleId %></code></span>
                                <span style="font-size:0.78em;color:var(--khaki);">Assigned: <%= squad.assignedCount %></span>
                                <span style="font-size:0.78em;color:var(--khaki);">Role holders: <%= squad.roleHolderCount %></span>
                            </div>

                            <% if (totalIssues === 0) { %>
                                <div style="font-size:0.85em;color:#2ecc71;">✅ All good — no discrepancies.</div>
                            <% } else { %>
                                <% if (squad.missing.length > 0) { %>
                                    <div style="margin-top:8px;">
                                        <strong style="color:#e86070;font-size:0.85em;">Missing role (assigned but don't have the Discord role):</strong>
                                        <ul style="margin:4px 0 0;padding-left:16px;color:var(--khaki);font-size:0.85em;list-style:none;">
                                            <% squad.missing.forEach(m => { %>
                                            <li style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                                                <span style="flex:1;min-width:0;"><%= m.name %> <span style="opacity:0.5;">(<%= m.discord_id %>)</span><% if (!m.inGuild) { %><span style="color:#e86070;font-size:0.85em;"> ⚠ not in guild</span><% } %></span>
                                                <form method="POST" action="/admin/debug/orbat-roles/fix-missing" style="margin:0;flex-shrink:0;"
                                                      onsubmit="return confirm('Grant squad role to <%= m.name %>?')">
                                                    <input type="hidden" name="squadId" value="<%= squad.squadId %>">
                                                    <input type="hidden" name="discordIds" value="<%= m.discord_id %>">
                                                    <button type="submit" class="btn" style="padding:2px 8px;font-size:0.72em;">Grant</button>
                                                </form>
                                            </li>
                                            <% }) %>
                                        </ul>
                                        <form method="POST" action="/admin/debug/orbat-roles/fix-missing" style="margin-top:6px;"
                                              onsubmit="return confirm('Grant the squad role to <%= squad.missing.length %> member(s)?')">
                                            <input type="hidden" name="squadId" value="<%= squad.squadId %>">
                                            <% squad.missing.forEach(m => { %>
                                            <input type="hidden" name="discordIds" value="<%= m.discord_id %>">
                                            <% }) %>
                                            <button type="submit" class="btn" style="padding:3px 10px;font-size:0.78em;">Grant all <%= squad.missing.length %></button>
                                        </form>
                                    </div>
                                <% } %>
                                <% if (squad.extra.length > 0) { %>
                                    <div style="margin-top:8px;">
                                        <strong style="color:#f1c40f;font-size:0.85em;">Extra role (has the role but not assigned to squad):</strong>
                                        <ul style="margin:4px 0 0;padding-left:16px;color:var(--khaki);font-size:0.85em;list-style:none;">
                                            <% squad.extra.forEach(m => { %>
                                            <li style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                                                <span style="flex:1;min-width:0;"><%= m.name %> <span style="opacity:0.5;">(<%= m.discord_id %>)</span></span>
                                                <form method="POST" action="/admin/debug/orbat-roles/fix-extra" style="margin:0;flex-shrink:0;"
                                                      onsubmit="return confirm('Revoke squad role from <%= m.name %>?')">
                                                    <input type="hidden" name="squadId" value="<%= squad.squadId %>">
                                                    <input type="hidden" name="discordIds" value="<%= m.discord_id %>">
                                                    <button type="submit" class="btn btn-danger" style="padding:2px 8px;font-size:0.72em;">Revoke</button>
                                                </form>
                                            </li>
                                            <% }) %>
                                        </ul>
                                        <form method="POST" action="/admin/debug/orbat-roles/fix-extra" style="margin-top:6px;"
                                              onsubmit="return confirm('Revoke the squad role from <%= squad.extra.length %> member(s)?')">
                                            <input type="hidden" name="squadId" value="<%= squad.squadId %>">
                                            <% squad.extra.forEach(m => { %>
                                            <input type="hidden" name="discordIds" value="<%= m.discord_id %>">
                                            <% }) %>
                                            <button type="submit" class="btn btn-danger" style="padding:3px 10px;font-size:0.78em;">Revoke all <%= squad.extra.length %></button>
                                        </form>
                                    </div>
                                <% } %>
                            <% } %>
                        </div>
                    <% }); %>
                <% } %>
            <% } %>
        </div>
    </section>
</div>

<%- include('../partials/footer') %>
