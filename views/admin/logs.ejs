<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>ACTION LOG</h1>
        <div class="subtitle">Audit trail — who did what, where &amp; when</div>
    </header>

    <section class="section">

        <%# ── Filter bar ─────────────────────────────────────────── %>
        <form method="GET" action="/admin/logs" class="log-filters">
            <input type="text" name="q" value="<%= filters.search %>" placeholder="Search action, path or user…" class="log-input" style="flex:2 1 220px;">

            <select name="category" class="log-input">
                <option value="">All categories</option>
                <% categories.forEach(c => { %>
                    <option value="<%= c %>" <%= filters.category === c ? 'selected' : '' %>><%= c %></option>
                <% }) %>
            </select>

            <select name="user" class="log-input">
                <option value="">All users</option>
                <% actors.forEach(a => { %>
                    <option value="<%= a.user_id %>" <%= String(filters.user) === String(a.user_id) ? 'selected' : '' %>><%= a.name %></option>
                <% }) %>
            </select>

            <select name="method" class="log-input">
                <% ['', 'POST', 'PATCH', 'PUT', 'DELETE'].forEach(m => { %>
                    <option value="<%= m %>" <%= filters.method === m ? 'selected' : '' %>><%= m || 'All methods' %></option>
                <% }) %>
            </select>

            <select name="status" class="log-input">
                <option value="" <%= filters.status === '' ? 'selected' : '' %>>All results</option>
                <option value="success" <%= filters.status === 'success' ? 'selected' : '' %>>Success</option>
                <option value="failed" <%= filters.status === 'failed' ? 'selected' : '' %>>Failed / denied</option>
            </select>

            <button type="submit" class="create-btn">Filter</button>
            <a href="/admin/logs" class="btn">Reset</a>
        </form>

        <div style="margin:14px 0 10px; color:var(--khaki); font-size:0.85em; opacity:0.8;">
            <strong style="color:var(--accent);"><%= total.toLocaleString() %></strong> action<%= total === 1 ? '' : 's' %> recorded
            <% if (totalPages > 1) { %> · page <%= page %> of <%= totalPages %><% } %>
        </div>

        <% if (logs.length === 0) { %>
            <div style="text-align:center; padding:48px 20px; color:var(--khaki); opacity:0.6;">
                <div style="font-size:3em; margin-bottom:12px;">📜</div>
                <strong>No actions match these filters</strong>
            </div>
        <% } else { %>
        <div style="overflow-x:auto;">
        <table class="roles-table log-table">
            <thead>
                <tr>
                    <th>When</th>
                    <th>Who</th>
                    <th>Action</th>
                    <th>Category</th>
                    <th>Target</th>
                    <th>Where</th>
                    <th>Result</th>
                </tr>
            </thead>
            <tbody>
                <%
                // ── Display helpers (shared across all rows) ──────────────────
                // Parse a JSON column whether mysql2 returns it as an object or a string.
                const asObj = (v) => {
                    if (v == null) return null;
                    if (typeof v === 'object') return v;
                    try { return JSON.parse(v); } catch (e) { return null; }
                };
                const esc = (s) => String(s).replace(/[&<>"']/g, c => (
                    { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c]
                ));
                // snake_case / camelCase column → readable label, with acronyms.
                const ACR = { id:'ID', url:'URL', ip:'IP', lr:'LR', sr:'SR', loa:'LOA', orbat:'ORBAT', tfar:'TFAR', acl:'ACL', html:'HTML' };
                const humanizeKey = (key) => String(key)
                    .replace(/_/g, ' ')
                    .replace(/([a-z0-9])([A-Z])/g, '$1 $2')
                    .split(' ').filter(Boolean)
                    .map((w, idx) => {
                        const lw = w.toLowerCase();
                        if (ACR[lw]) return ACR[lw];
                        return idx === 0 ? lw.charAt(0).toUpperCase() + lw.slice(1) : lw;
                    }).join(' ');
                const isBoolKey = (key) =>
                    /^(is|has|can)([A-Z]|_)/.test(key) ||
                    /(_published|_enabled|_active|_visible|_pinned)$/i.test(key);
                // Format a single value as readable, escaped HTML.
                const fmtVal = (key, value) => {
                    if (isBoolKey(key)) {
                        if (value === true || value === 1 || value === '1' || value === 'on' || value === 'true')
                            return '<span class="diff-bool-y">✓ Yes</span>';
                        if (value === false || value === 0 || value === '0' || value === 'false' || value === 'off' || value === null || value === '')
                            return '<span class="diff-bool-n">✗ No</span>';
                    }
                    if (value === null || value === undefined || value === '')
                        return '<span class="diff-empty">empty</span>';
                    if (value === true)  return '<span class="diff-bool-y">✓ Yes</span>';
                    if (value === false) return '<span class="diff-bool-n">✗ No</span>';
                    // Resolve foreign-key ids (user_id, slot_type_id, …) to a name.
                    const fkName = nameForField(key, value);
                    if (fkName) return `<span class="kv-name">${esc(fkName)}</span> <span class="kv-id">#${esc(value)}</span>`;
                    const str = typeof value === 'object' ? JSON.stringify(value) : String(value);
                    if (/^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(str))
                        return `<span class="diff-swatch" style="background:${esc(str)}"></span> <span class="diff-mono">${esc(str)}</span>`;
                    if (/(_at|_date|date|time)$/i.test(key)) {
                        let d = null;
                        if (/^\d{9,13}$/.test(str)) d = new Date(str.length > 10 ? Number(str) : Number(str) * 1000);
                        else if (/^\d{4}-\d{2}-\d{2}/.test(str)) { const t = new Date(str); if (!isNaN(t)) d = t; }
                        if (d && !isNaN(d))
                            return `<span title="${esc(str)}">${esc(d.toLocaleString('en-GB', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }))}</span>`;
                    }
                    if (str.length > 200) return `<span title="${esc(str)}">${esc(str.slice(0, 200))}…</span>`;
                    return esc(str);
                };
                %>
                <% logs.forEach((log, i) => {
                    const when = new Date(log.created_at);
                    const ok = log.success === 1 || log.success === true;
                    const changes = asObj(log.changes);
                    const before  = asObj(log.before_data);
                    const after   = asObj(log.after_data);
                    const bodyObj = asObj(log.body);
                    const isDelete = before && !after && !changes;
                    const hasBody  = bodyObj && Object.keys(bodyObj).length > 0;
                    const hasDetail = !!(changes || isDelete || hasBody);
                    // Fields to show for a deleted record (skip empty columns to cut noise).
                    const deletedFields = isDelete
                        ? Object.keys(before).filter(k => before[k] !== null && before[k] !== '')
                        : [];
                    let toggleLabel = '';
                    if (changes)       toggleLabel = `🔍 ${Object.keys(changes).length} field${Object.keys(changes).length === 1 ? '' : 's'} changed`;
                    else if (isDelete) toggleLabel = '🗑 View deleted record';
                    else if (hasBody)  toggleLabel = '📋 View submitted data';
                %>
                <tr>
                    <td style="white-space:nowrap;">
                        <span title="<%= when.toISOString() %>"><%= when.toLocaleString('en-GB', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></span>
                    </td>
                    <td>
                        <% if (log.actor_name) { %>
                            <div class="role-name" style="font-size:0.92em;"><%= log.actor_name %></div>
                        <% } else { %>
                            <span style="opacity:0.6;">— anonymous —</span>
                        <% } %>
                        <% if (log.ip) { %><div class="role-desc" style="font-size:0.72em;"><%= log.ip %></div><% } %>
                    </td>
                    <td>
                        <div style="font-weight:500;"><%= log.action_label %></div>
                        <% if (hasDetail) { %>
                            <button type="button" class="log-diff-toggle" onclick="toggleDiff(<%= i %>)"><%= toggleLabel %></button>
                        <% } %>
                    </td>
                    <td><span class="count-chip"><%= log.category || '—' %></span></td>
                    <td>
                        <% if (log.target_type) { %>
                            <span style="color:var(--khaki);"><%= humanizeKey(log.target_type) %></span>
                            <% if (log.targetName) { %>
                                <div><strong class="kv-name"><%= log.targetName %></strong> <span class="kv-id">#<%= log.target_id %></span></div>
                            <% } else if (log.target_id) { %>
                                <strong>#<%= log.target_id %></strong>
                            <% } %>
                        <% } else { %>—<% } %>
                    </td>
                    <td>
                        <div>
                            <span class="log-method log-method-<%= log.method.toLowerCase() %>"><%= log.method %></span>
                            <code class="log-path" title="<%= log.path %>"><%= log.path.length > 40 ? log.path.slice(0, 40) + '…' : log.path %></code>
                        </div>
                        <% if (log.destination) { %>
                            <a class="log-goto" href="<%= log.destination %>" target="_blank" rel="noopener" title="Open the page where this happened">Open ↗</a>
                        <% } %>
                    </td>
                    <td style="white-space:nowrap;">
                        <span class="log-status <%= ok ? 'log-ok' : 'log-fail' %>"><%= log.status_code %></span>
                    </td>
                </tr>
                <% if (hasDetail) { %>
                <tr id="diff-<%= i %>" class="log-detail-row" hidden>
                    <td colspan="7">
                        <% if (changes) { %>
                        <div class="log-detail">
                            <div class="log-detail-title">🔍 Changed fields</div>
                            <table class="log-kv log-kv--diff">
                                <thead><tr><th>Field</th><th>Before</th><th>After</th></tr></thead>
                                <tbody>
                                <% Object.keys(changes).forEach(k => { %>
                                    <tr>
                                        <th class="kv-field"><%= humanizeKey(k) %></th>
                                        <td class="kv-before"><%- fmtVal(k, changes[k].from) %></td>
                                        <td class="kv-after"><%- fmtVal(k, changes[k].to) %></td>
                                    </tr>
                                <% }) %>
                                </tbody>
                            </table>
                        </div>
                        <% } else if (isDelete) { %>
                        <div class="log-detail">
                            <div class="log-detail-title">🗑 Deleted record</div>
                            <table class="log-kv">
                                <tbody>
                                <% deletedFields.forEach(k => { %>
                                    <tr><th class="kv-field"><%= humanizeKey(k) %></th><td class="kv-value"><%- fmtVal(k, before[k]) %></td></tr>
                                <% }) %>
                                </tbody>
                            </table>
                        </div>
                        <% } else if (hasBody) { %>
                        <div class="log-detail">
                            <div class="log-detail-title">📋 Submitted data</div>
                            <table class="log-kv">
                                <tbody>
                                <% Object.keys(bodyObj).forEach(k => { %>
                                    <tr><th class="kv-field"><%= humanizeKey(k) %></th><td class="kv-value"><%- fmtVal(k, bodyObj[k]) %></td></tr>
                                <% }) %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>
                    </td>
                </tr>
                <% } %>
                <% }) %>
            </tbody>
        </table>
        </div>

        <%# ── Pagination ────────────────────────────────────────────── %>
        <% if (totalPages > 1) {
            const qs = (p) => {
                const u = new URLSearchParams();
                if (filters.search)   u.set('q', filters.search);
                if (filters.category) u.set('category', filters.category);
                if (filters.method)   u.set('method', filters.method);
                if (filters.user)     u.set('user', filters.user);
                if (filters.status)   u.set('status', filters.status);
                u.set('page', p);
                return '/admin/logs?' + u.toString();
            };
        %>
        <div class="log-pagination">
            <% if (page > 1) { %><a href="<%= qs(page - 1) %>" class="btn">← Prev</a><% } %>
            <span style="color:var(--khaki); opacity:0.8; align-self:center;">Page <%= page %> / <%= totalPages %></span>
            <% if (page < totalPages) { %><a href="<%= qs(page + 1) %>" class="btn">Next →</a><% } %>
        </div>
        <% } %>
        <% } %>
    </section>

</div>

<script>
function toggleDiff(i) {
    const row = document.getElementById('diff-' + i);
    if (row) row.hidden = !row.hidden;
}
</script>

<%- include('../partials/footer') %>
