<%- include('../partials/header') %>

<style>
.form-wrap { max-width:760px; margin:0 auto; }
.field { margin-bottom:20px; }
.field label { display:block; font-size:0.8em; color:var(--khaki); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:7px; }
.field input, .field textarea, .field select {
    width:100%; padding:10px 14px;
    background:rgba(0,0,0,0.4);
    border:1px solid rgba(107,142,35,0.5);
    border-radius:7px;
    color:var(--sand);
    font-family:var(--body-font);
    font-size:0.92em;
    transition:border-color 0.2s;
}
.field input:focus, .field textarea:focus, .field select:focus { outline:none; border-color:var(--accent); box-shadow:0 0 8px rgba(252,176,13,0.15); }
.field textarea { min-height:90px; resize:vertical; }
.field small { display:block; margin-top:5px; font-size:0.78em; color:var(--khaki); opacity:.7; }
.field .current-img { margin-bottom:10px; }
.field .current-img img { max-width:180px; border-radius:8px; border:1px solid rgba(107,142,35,0.4); }
.field .current-img p { font-size:0.8em; color:var(--khaki); margin-top:4px; opacity:.7; }
.form-actions { display:flex; gap:12px; margin-top:28px; padding-top:20px; border-top:1px solid rgba(107,142,35,0.25); }
</style>

<div class="container">
    <header>
        <h1><%= mode === 'add' ? 'ADD NEW TOOL' : 'EDIT TOOL' %></h1>
        <div class="subtitle">Internal Tools Administration</div>
    </header>

    <section class="section">
        <div class="form-wrap">
            <form method="POST"
                  action="<%= mode === 'add' ? '/admin/tools/add' : `/admin/tools/edit/${tool.id}` %>"
                  enctype="multipart/form-data">

                <div class="field">
                    <label for="title">Tool Title *</label>
                    <input type="text" id="title" name="title"
                           value="<%= tool ? tool.title : '' %>" required
                           placeholder="e.g., RPT Analyzer">
                </div>

                <div class="field">
                    <label for="description">Description</label>
                    <textarea id="description" name="description"
                              placeholder="Brief description of what this tool does"><%= tool ? tool.description : '' %></textarea>
                </div>

                <div class="field">
                    <label for="link">Link / URL *</label>
                    <input type="text" id="link" name="link"
                           value="<%= tool ? tool.link : '' %>" required
                           placeholder="e.g., /tools/analyzer.html or https://example.com">
                    <small>Can be a relative path (/tools/file.html) or full URL (https://…)</small>
                </div>

                <div class="field">
                    <label for="image">Tool Image</label>
                    <% if (tool && tool.image_url) { %>
                        <div class="current-img">
                            <img src="<%= tool.image_url %>" alt="Current image">
                            <p>Current image — upload a new one to replace it</p>
                        </div>
                    <% } %>
                    <input type="file" id="image" name="image" accept="image/*">
                    <small>Recommended: 400×300px or similar ratio</small>
                </div>

                <div class="field">
                    <label for="order_index">Display Order</label>
                    <input type="number" id="order_index" name="order_index"
                           value="<%= tool ? tool.order_index : 0 %>" min="0" placeholder="0">
                    <small>Lower numbers appear first (0, 1, 2…)</small>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" style="flex:1;">
                        <%= mode === 'add' ? '➕ Add Tool' : '💾 Save Changes' %>
                    </button>
                    <a href="/admin/tools" class="btn">Cancel</a>
                </div>
            </form>
        </div>
    </section>
</div>

<%- include('../partials/footer') %>
