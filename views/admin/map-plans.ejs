<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>MANAGE MAP PLANS</h1>
        <div class="subtitle">User plans &amp; installed terrains</div>
        <div class="stat-bar">
            <div class="stat-chip">
                <span class="stat-val"><%= plans.length %></span>
                <span class="stat-lbl">Total Plans</span>
            </div>
            <div class="stat-chip">
                <span class="stat-val"><%= terrains.length %></span>
                <span class="stat-lbl">Installed Terrains</span>
            </div>
        </div>
    </header>

    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error)   { %><div class="alert alert-error"><%= error %></div><% } %>

    <!-- ─── Terrains ─────────────────────────────────────────────── -->
    <section class="section">
        <h2>INSTALLED TERRAINS</h2>

        <div style="background:rgba(20,32,20,0.5);border:1px solid var(--border);border-radius:6px;padding:18px;margin-bottom:24px;">
            <h3 style="color:var(--accent);margin-bottom:12px;">Import Terrain</h3>
            <p style="color:var(--khaki);font-size:0.85em;margin-bottom:14px;">
                Upload a pre-rendered terrain zip. The zip's root must contain <code>meta.json</code> or <code>map.json</code>.
                If the zip wraps everything in a single top folder, that folder name is used as the world name (override below).
            </p>
            <form method="POST" action="/admin/map-plans/terrains/import" enctype="multipart/form-data">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:12px;">
                    <div>
                        <label style="display:block;color:var(--muted);font-size:0.78em;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:5px;">Zip File *</label>
                        <input type="file" name="terrain" accept=".zip" required style="width:100%;color:var(--sand);">
                    </div>
                    <div>
                        <label style="display:block;color:var(--muted);font-size:0.78em;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:5px;">World Name (optional)</label>
                        <input type="text" name="world_name" placeholder="auto-detected" pattern="[a-zA-Z0-9_-]+"
                               style="width:100%;background:var(--input-bg);border:1px solid var(--border);border-radius:4px;color:var(--sand);padding:7px 10px;font-family:inherit;">
                    </div>
                </div>
                <label style="display:flex;align-items:center;gap:8px;color:var(--khaki);font-size:0.9em;margin-bottom:12px;">
                    <input type="checkbox" name="overwrite" value="1">
                    Overwrite if a terrain with this name already exists
                </label>
                <button type="submit" class="btn btn-primary">⬆ Import Terrain</button>
            </form>
        </div>

        <% if (terrains.length === 0) { %>
            <div class="empty-state" style="padding:30px;text-align:center;color:var(--khaki);">
                <p>No terrains installed yet.</p>
            </div>
        <% } else { %>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;">
            <% terrains.forEach(t => { %>
                <div style="background:rgba(0,0,0,0.4);border:1px solid var(--olive);border-radius:6px;overflow:hidden;">
                    <div style="height:120px;background:#1a1a1a url('/images/maps/<%= t.worldName %>/preview_512.png') center/cover;"></div>
                    <div style="padding:12px;">
                        <div style="font-weight:700;color:var(--accent);"><%= t.displayName %></div>
                        <div style="color:var(--khaki);font-size:0.8em;margin-top:3px;font-family:monospace;"><%= t.worldName %></div>
                        <% if (t.worldSize) { %>
                            <div style="color:#888;font-size:0.75em;margin-top:2px;"><%= (t.worldSize/1000).toFixed(1) %> km × <%= (t.worldSize/1000).toFixed(1) %> km</div>
                        <% } %>
                        <button class="btn btn-danger" style="margin-top:10px;width:100%;" onclick="deleteTerrain('<%= t.worldName %>')">Delete</button>
                    </div>
                </div>
            <% }); %>
            </div>
        <% } %>
    </section>

    <!-- ─── Plans ────────────────────────────────────────────────── -->
    <section class="section" style="margin-top:32px;">
        <h2>USER PLANS</h2>
        <% if (plans.length === 0) { %>
            <div class="empty-state" style="padding:30px;text-align:center;color:var(--khaki);">
                <p>No plans created yet.</p>
            </div>
        <% } else { %>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Owner</th>
                    <th>Terrain</th>
                    <th>Layers</th>
                    <th>Annotations</th>
                    <th>Members</th>
                    <th>Link</th>
                    <th>Updated</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% plans.forEach(p => { %>
                <tr>
                    <td><a href="/plans/<%= p.id %>" style="color:var(--accent);"><%= p.name %></a></td>
                    <td><%= p.owner_username %></td>
                    <td><%= p.map_world || '—' %></td>
                    <td><%= p.layer_count %></td>
                    <td><%= p.ann_count %></td>
                    <td><%= p.member_count %></td>
                    <td><%= p.link_access === 'view' ? '🔗' : '' %></td>
                    <td style="font-size:0.78em;color:var(--khaki);"><%= new Date(p.updated_at).toLocaleString() %></td>
                    <td>
                        <button class="btn" onclick="transferPlan(<%= p.id %>)">Transfer</button>
                        <button class="btn btn-danger" onclick="deletePlan(<%= p.id %>)">Delete</button>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
        <% } %>
    </section>
</div>

<script>
async function deletePlan(id) {
    if (!confirm('Delete this plan and all its layers/annotations? This cannot be undone.')) return;
    const r = await fetch('/admin/map-plans/' + id, { method: 'DELETE' });
    const data = await r.json();
    if (data.success) location.reload();
    else alert(data.error || 'Failed');
}

async function transferPlan(id) {
    const username = prompt('Transfer to which username?');
    if (!username) return;
    const r = await fetch('/admin/map-plans/' + id + '/transfer', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username })
    });
    const data = await r.json();
    if (data.success) location.reload();
    else alert(data.error || 'Failed');
}

async function deleteTerrain(world) {
    if (!confirm('Delete terrain "' + world + '"? This removes its files. Existing plans referencing it will be left with a broken terrain pointer.')) return;
    const r = await fetch('/admin/map-plans/terrains/' + encodeURIComponent(world), { method: 'DELETE' });
    const data = await r.json();
    if (data.success) location.reload();
    else alert(data.error || 'Failed');
}
</script>

<%- include('../partials/footer') %>
