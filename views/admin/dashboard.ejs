<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>ADMIN DASHBOARD</h1>
        <div class="subtitle">Management Control Panel</div>
    </header>

    <section class="section">
        <h2>📊 Statistics</h2>
        <div class="grid grid-3">
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">🔧</div>
                <h3><%= stats.tools %></h3>
                <p>Tools</p>
                <a href="/admin/tools" class="btn mt-2">Manage</a>
            </div>
            
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">📁</div>
                <h3><%= stats.folders %></h3>
                <p>Gallery Folders</p>
                <a href="/admin/gallery" class="btn mt-2">Manage</a>
            </div>
            
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">🖼️</div>
                <h3><%= stats.images %></h3>
                <p>Gallery Images</p>
                <a href="/admin/gallery" class="btn mt-2">Manage</a>
            </div>
            
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">👥</div>
                <h3><%= stats.users %></h3>
                <p>Registered Users</p>
                <a href="/admin/users" class="btn mt-2">Manage</a>
            </div>
            
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">🏅</div>
                <h3><%= stats.medals || 0 %></h3>
                <p>Medals Created</p>
                <a href="/admin/medals" class="btn mt-2">Manage</a>
            </div>
            
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">🎓</div>
                <h3><%= stats.trainings || 0 %></h3>
                <p>Trainings</p>
                <a href="/admin/trainings" class="btn mt-2">Manage</a>
            </div>
        </div>
    </section>

    <section class="section">
        <h2>📈 Website Traffic</h2>
        <div class="grid grid-3" style="margin-bottom: 1.5rem;">
            <div class="card text-center">
                <div style="font-size: 2.5em; color: var(--accent); margin-bottom: 10px;">👁️</div>
                <h3><%= analytics.views_today %></h3>
                <p>Views Today</p>
            </div>
            <div class="card text-center">
                <div style="font-size: 2.5em; color: var(--accent); margin-bottom: 10px;">📅</div>
                <h3><%= analytics.views_week %></h3>
                <p>Views (7 days)</p>
            </div>
            <div class="card text-center">
                <div style="font-size: 2.5em; color: var(--accent); margin-bottom: 10px;">🗓️</div>
                <h3><%= analytics.views_month %></h3>
                <p>Views (30 days)</p>
            </div>
            <div class="card text-center">
                <div style="font-size: 2.5em; color: var(--accent); margin-bottom: 10px;">👤</div>
                <h3><%= analytics.unique_today %></h3>
                <p>Unique Users Today</p>
            </div>
            <div class="card text-center">
                <div style="font-size: 2.5em; color: var(--accent); margin-bottom: 10px;">👥</div>
                <h3><%= analytics.unique_week %></h3>
                <p>Unique Users (7 days)</p>
            </div>
        </div>

        <% if (dailyViews.length > 0) { %>
        <% const maxViews = Math.max(...dailyViews.map(d => d.views), 1); %>
        <div class="card" style="margin-bottom: 1.5rem;">
            <h3 style="margin-bottom: 1rem;">Daily Views (last 7 days)</h3>
            <div style="display: flex; align-items: flex-end; gap: 8px; height: 80px;">
                <% dailyViews.forEach(day => { %>
                <% const barHeight = Math.max(Math.round((day.views / maxViews) * 100), 4); %>
                <% const d = new Date(day.date); %>
                <% const label = d.toLocaleDateString('en-US', { weekday: 'short', month: 'numeric', day: 'numeric', timeZone: 'UTC' }); %>
                <div style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%; justify-content: flex-end;">
                    <span style="font-size: 0.7em; color: var(--accent);"><%= day.views %></span>
                    <div style="width: 100%; background: var(--accent); height: <%= barHeight %>%; border-radius: 3px 3px 0 0;" title="<%= label %>: <%= day.views %> views"></div>
                    <span style="font-size: 0.65em; white-space: nowrap; color: var(--sand-dim, #aaa);"><%= label %></span>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <% if (topPages.length > 0) { %>
        <div class="card">
            <h3 style="margin-bottom: 1rem;">Top Pages (last 7 days)</h3>
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--border, #444);">
                        <th style="text-align: left; padding: 6px 8px;">Page</th>
                        <th style="text-align: right; padding: 6px 8px;">Views</th>
                    </tr>
                </thead>
                <tbody>
                    <% topPages.forEach(page => { %>
                    <tr style="border-bottom: 1px solid var(--border-subtle, #333);">
                        <td style="padding: 6px 8px; font-family: monospace;"><%= page.path === '/' ? '/ (Home)' : page.path %></td>
                        <td style="padding: 6px 8px; text-align: right; color: var(--accent);"><%= page.views %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>
    </section>

    <section class="section">
        <h2>🛠️ Quick Actions</h2>
        <div class="grid grid-2">
            <a href="/admin/tools/add" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>➕ Add New Tool</h3>
                <p>Create a new internal tool listing</p>
            </a>
            
            <a href="/admin/gallery/add-folder" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>📁 Create Gallery Folder</h3>
                <p>Add a new folder to organize images</p>
            </a>
            
            <a href="/admin/gallery/upload" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>⬆️ Upload Images</h3>
                <p>Add new images to the gallery</p>
            </a>
            
            <a href="/admin/users" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>👥 Manage Users</h3>
                <p>View and manage user accounts</p>
            </a>
            
            <a href="/admin/medals" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>🏅 Manage Medals</h3>
                <p>Create and award medals</p>
            </a>
            
            <a href="/admin/trainings" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>🎓 Manage Trainings</h3>
                <p>Manage training certifications</p>
            </a>
            
            <a href="/orbat/templates" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>📋 Manage ORBATs</h3>
                <p>Create and manage ORBAT templates</p>
            </a>
            
            <a href="/loa/all" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>🛑 View All LOAs</h3>
                <p>Manage leave of absence requests</p>
            </a>
            
            <a href="/" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>🌐 View Public Site</h3>
                <p>See the website as visitors do</p>
            </a>
        </div>
    </section>
</div>

<%- include('../partials/footer') %>
