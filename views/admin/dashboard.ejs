<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>ADMIN DASHBOARD</h1>
        <div class="subtitle">Management Control Panel</div>
    </header>

    <section class="section">
        <h2>📊 Statistics</h2>
        <div class="grid grid-3">
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">🔧</div>
                <h3><%= stats.tools %></h3>
                <p>Tools</p>
                <a href="/admin/tools" class="btn mt-2">Manage</a>
            </div>
            
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">📁</div>
                <h3><%= stats.folders %></h3>
                <p>Gallery Folders</p>
                <a href="/admin/gallery" class="btn mt-2">Manage</a>
            </div>
            
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">🖼️</div>
                <h3><%= stats.images %></h3>
                <p>Gallery Images</p>
                <a href="/admin/gallery" class="btn mt-2">Manage</a>
            </div>
            
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">👥</div>
                <h3><%= stats.users %></h3>
                <p>Registered Users</p>
                <a href="/admin/users" class="btn mt-2">Manage</a>
            </div>
            
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">🏅</div>
                <h3><%= stats.medals || 0 %></h3>
                <p>Medals Created</p>
                <a href="/admin/medals" class="btn mt-2">Manage</a>
            </div>
            
            <div class="card text-center">
                <div style="font-size: 3em; color: var(--accent); margin-bottom: 10px;">🎓</div>
                <h3><%= stats.trainings || 0 %></h3>
                <p>Trainings</p>
                <a href="/admin/trainings" class="btn mt-2">Manage</a>
            </div>
        </div>
    </section>

    <section class="section">
        <h2>🛠️ Quick Actions</h2>
        <div class="grid grid-2">
            <a href="/admin/tools/add" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>➕ Add New Tool</h3>
                <p>Create a new internal tool listing</p>
            </a>
            
            <a href="/admin/gallery/add-folder" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>📁 Create Gallery Folder</h3>
                <p>Add a new folder to organize images</p>
            </a>
            
            <a href="/admin/gallery/upload" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>⬆️ Upload Images</h3>
                <p>Add new images to the gallery</p>
            </a>
            
            <a href="/admin/users" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>👥 Manage Users</h3>
                <p>View and manage user accounts</p>
            </a>
            
            <a href="/admin/medals" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>🏅 Manage Medals</h3>
                <p>Create and award medals</p>
            </a>
            
            <a href="/admin/trainings" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>🎓 Manage Trainings</h3>
                <p>Manage training certifications</p>
            </a>
            
            <a href="/orbat/templates" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>📋 Manage ORBATs</h3>
                <p>Create and manage ORBAT templates</p>
            </a>
            
            <a href="/loa/all" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>🛑 View All LOAs</h3>
                <p>Manage leave of absence requests</p>
            </a>
            
            <a href="/" class="card" style="text-decoration: none; color: var(--sand);">
                <h3>🌐 View Public Site</h3>
                <p>See the website as visitors do</p>
            </a>
        </div>
    </section>
</div>

<%- include('../partials/footer') %>
