<%- include('../partials/header') %>


<div class="container">
    <header>
        <h1>ADMIN DASHBOARD</h1>
        <div class="subtitle">Management Control Panel</div>
    </header>

    <%# ── Quick stats bar ─────────────────────────────────────── %>
    <section class="section" style="padding: 20px 28px;">
        <div class="dash-stat-bar">
            <div class="dash-stat-chip">
                <span class="chip-icon">👥</span>
                <div><div class="chip-value"><%= stats.users %></div><div class="chip-label">Registered Users</div></div>
            </div>
            <div class="dash-stat-chip">
                <span class="chip-icon">🔧</span>
                <div><div class="chip-value"><%= stats.tools %></div><div class="chip-label">Tools</div></div>
            </div>
            <div class="dash-stat-chip">
                <span class="chip-icon">🖼️</span>
                <div><div class="chip-value"><%= stats.images %></div><div class="chip-label">Gallery Images</div></div>
            </div>
            <div class="dash-stat-chip">
                <span class="chip-icon">🏅</span>
                <div><div class="chip-value"><%= stats.medals || 0 %></div><div class="chip-label">Medals</div></div>
            </div>
            <div class="dash-stat-chip">
                <span class="chip-icon">🎓</span>
                <div><div class="chip-value"><%= stats.trainings || 0 %></div><div class="chip-label">Trainings</div></div>
            </div>
        </div>
    </section>

    <%# ── Traffic ─────────────────────────────────────────────── %>
    <section class="section">
        <h2>📈 Website Traffic</h2>

        <%# Page views row %>
        <div class="chart-label" style="margin-bottom:8px;">Page Views</div>
        <div class="traffic-row" style="margin-bottom:16px;">
            <div class="traffic-num">
                <div class="t-val"><%= analytics.views_today %></div>
                <div class="t-label">Views Today</div>
            </div>
            <div class="traffic-num">
                <div class="t-val"><%= analytics.views_week %></div>
                <div class="t-label">Views (7 days)</div>
            </div>
            <div class="traffic-num">
                <div class="t-val"><%= analytics.views_month %></div>
                <div class="t-label">Views (30 days)</div>
            </div>
        </div>

        <%# Sessions + IPs row %>
        <div class="chart-label" style="margin-bottom:8px;">Unique Visitors</div>
        <div class="traffic-row">
            <div class="traffic-num sessions">
                <div class="t-val"><%= analytics.sessions_today %></div>
                <div class="t-label">Sessions Today</div>
            </div>
            <div class="traffic-num sessions">
                <div class="t-val"><%= analytics.sessions_week %></div>
                <div class="t-label">Sessions (7 days)</div>
            </div>
            <div class="traffic-num ips">
                <div class="t-val"><%= analytics.unique_ips_week %></div>
                <div class="t-label">Unique IPs (7 days)</div>
            </div>
        </div>

        <p style="font-size:0.78em; color:var(--khaki); opacity:0.65; margin:10px 0 0;">
            🤖 Bots filtered out —
            <strong style="color:var(--accent); opacity:1;"><%= analytics.bots_today %></strong> today &nbsp;·&nbsp;
            <strong style="color:var(--accent); opacity:1;"><%= analytics.bots_week %></strong> this week
            &nbsp;·&nbsp; Sessions = 30-min rolling anonymous cookie
        </p>

        <%# ── Row 1: daily bar + top pages ─────────────────── %>
        <% if (dailyViews.length > 0 || topPages.length > 0) { %>
        <div class="chart-grid-2">

            <% if (dailyViews.length > 0) { %>
            <% const maxDV = Math.max(...dailyViews.map(d => d.views), 1); %>
            <div>
                <div class="chart-label">Daily views — last 7 days</div>
                <div class="bar-chart">
                    <% dailyViews.forEach(day => { %>
                    <% const h = Math.max(Math.round((day.views / maxDV) * 100), 4); %>
                    <% const lbl = new Date(day.date).toLocaleDateString('en-US', { weekday: 'short', timeZone: 'UTC' }); %>
                    <div class="bar-col">
                        <span class="bar-val"><%= day.views %></span>
                        <div class="bar-inner">
                            <div class="bar-fill" style="height:<%= h %>%;width:100%;"></div>
                        </div>
                        <span class="bar-lbl"><%= lbl %></span>
                    </div>
                    <% }) %>
                </div>
            </div>
            <% } %>

            <% if (topPages.length > 0) { %>
            <% const maxPV = topPages[0].views; %>
            <div>
                <div class="chart-label">Top pages — last 7 days</div>
                <table class="pages-table">
                    <thead><tr><th>Page</th><th>Views</th></tr></thead>
                    <tbody>
                        <% topPages.forEach(page => { %>
                        <tr>
                            <td class="path">
                                <%= page.path === '/' ? '/ (Home)' : page.path %>
                                <div class="page-bar"><div class="page-bar-fill" style="width:<%= Math.round((page.views/maxPV)*100) %>%"></div></div>
                            </td>
                            <td class="views"><%= page.views %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>

        </div>
        <% } %>

        <%# ── Row 2: hourly heatmap + device + referrers ──── %>
        <% const hasHourly   = hourlyViews.some(h => h.views > 0); %>
        <% const hasDevice   = deviceBreakdown.length > 0; %>
        <% const hasReferrer = topReferrers.length > 0; %>

        <% if (hasHourly || hasDevice || hasReferrer) { %>
        <div class="chart-grid-3" style="margin-top:24px;">

            <%# Hourly heatmap %>
            <% if (hasHourly) { %>
            <% const maxHV = Math.max(...hourlyViews.map(h => h.views), 1); %>
            <div>
                <div class="chart-label">Activity by hour — last 7 days (UTC)</div>
                <div class="bar-chart dense">
                    <% hourlyViews.forEach(h => { %>
                    <% const ht = Math.max(Math.round((h.views / maxHV) * 100), 2); %>
                    <div class="bar-col" title="<%= h.hour %>:00 — <%= h.views %> views">
                        <div class="bar-inner">
                            <div class="bar-fill" style="height:<%= ht %>%;width:100%;<%= h.views === 0 ? 'opacity:0.2;' : '' %>"></div>
                        </div>
                        <span class="bar-lbl"><%= h.hour % 6 === 0 ? h.hour : '' %></span>
                    </div>
                    <% }) %>
                </div>
            </div>
            <% } %>

            <%# Device breakdown %>
            <% if (hasDevice) { %>
            <% const deviceTotal = deviceBreakdown.reduce((s, d) => s + d.views, 0); %>
            <%
                const deviceIcon = { desktop: '🖥️', mobile: '📱', tablet: '🗂️' };
            %>
            <div>
                <div class="chart-label">Device types — last 7 days</div>
                <% deviceBreakdown.forEach(d => { %>
                <% const pct = deviceTotal > 0 ? Math.round((d.views / deviceTotal) * 100) : 0; %>
                <div class="device-row">
                    <span class="device-icon"><%= deviceIcon[d.device_type] || '💻' %></span>
                    <span class="device-label"><%= d.device_type %></span>
                    <div class="device-bar-wrap"><div class="device-bar-fill" style="width:<%= pct %>%"></div></div>
                    <span class="device-pct"><%= pct %>%</span>
                    <span class="device-cnt"><%= d.views %></span>
                </div>
                <% }) %>
            </div>
            <% } %>

            <%# Top referrers %>
            <% if (hasReferrer) { %>
            <% const maxRV = topReferrers[0].views; %>
            <div>
                <div class="chart-label">Traffic sources — last 7 days</div>
                <table class="pages-table">
                    <thead><tr><th>Source</th><th>Views</th></tr></thead>
                    <tbody>
                        <% topReferrers.forEach(r => { %>
                        <tr>
                            <td>
                                <%= r.source %>
                                <div class="page-bar"><div class="ref-bar-fill" style="width:<%= Math.round((r.views/maxRV)*100) %>%"></div></div>
                            </td>
                            <td class="views" style="color:#6bb8f7;"><%= r.views %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>

        </div>
        <% } %>

    </section>

    <%# ── Management ──────────────────────────────────────────── %>
    <section class="section">
        <h2>⚙️ Management</h2>
        <%
        const perms = (locals.user && locals.user.permissions) ? locals.user.permissions : [];
        const can = p => locals.user && perms.includes(p);
        %>
        <div class="manage-grid">

            <% if (can('tools.manage')) { %>
            <div class="manage-card">
                <div class="manage-card-top">
                    <span class="manage-icon">🔧</span>
                    <div class="manage-badge"><%= stats.tools %><span class="manage-badge-sub">tools</span></div>
                </div>
                <div class="manage-title">Tools</div>
                <div class="manage-desc">Manage internal tool listings available to members.</div>
                <div class="manage-card-footer">
                    <a href="/admin/tools" class="manage-link primary">Manage</a>
                    <a href="/admin/tools/add" class="manage-link secondary">+ New</a>
                </div>
            </div>
            <% } %>

            <% if (can('gallery.manage')) { %>
            <div class="manage-card">
                <div class="manage-card-top">
                    <span class="manage-icon">🖼️</span>
                    <div class="manage-badge"><%= stats.images %><span class="manage-badge-sub"><%= stats.folders %> folders</span></div>
                </div>
                <div class="manage-title">Gallery</div>
                <div class="manage-desc">Manage image folders and upload new screenshots.</div>
                <div class="manage-card-footer">
                    <a href="/admin/gallery" class="manage-link primary">Manage</a>
                    <a href="/admin/gallery/upload" class="manage-link secondary">+ Upload</a>
                </div>
            </div>
            <% } %>

            <% if (can('users.view')) { %>
            <div class="manage-card">
                <div class="manage-card-top">
                    <span class="manage-icon">👥</span>
                    <div class="manage-badge"><%= stats.users %><span class="manage-badge-sub">members</span></div>
                </div>
                <div class="manage-title">Users</div>
                <div class="manage-desc">View and manage member accounts and permissions.</div>
                <div class="manage-card-footer">
                    <a href="/admin/users" class="manage-link primary">Manage</a>
                </div>
            </div>
            <% } %>

            <% if (can('medals.manage')) { %>
            <div class="manage-card">
                <div class="manage-card-top">
                    <span class="manage-icon">🏅</span>
                    <div class="manage-badge"><%= stats.medals || 0 %><span class="manage-badge-sub">medals</span></div>
                </div>
                <div class="manage-title">Medals</div>
                <div class="manage-desc">Create medals and award them to members for achievements.</div>
                <div class="manage-card-footer">
                    <a href="/admin/medals" class="manage-link primary">Manage</a>
                </div>
            </div>
            <% } %>

            <% if (can('trainings.manage')) { %>
            <div class="manage-card">
                <div class="manage-card-top">
                    <span class="manage-icon">🎓</span>
                    <div class="manage-badge"><%= stats.trainings || 0 %><span class="manage-badge-sub">trainings</span></div>
                </div>
                <div class="manage-title">Trainings</div>
                <div class="manage-desc">Manage training certifications available to members.</div>
                <div class="manage-card-footer">
                    <a href="/admin/trainings" class="manage-link primary">Manage</a>
                </div>
            </div>
            <% } %>

            <% if (can('roles.manage')) { %>
            <div class="manage-card">
                <div class="manage-card-top"><span class="manage-icon">🔐</span></div>
                <div class="manage-title">Roles & Permissions</div>
                <div class="manage-desc">Create roles, assign permissions, and manage user access.</div>
                <div class="manage-card-footer">
                    <a href="/admin/roles" class="manage-link primary">Manage</a>
                    <a href="/admin/roles/create" class="manage-link secondary">+ New Role</a>
                </div>
            </div>
            <% } %>

            <% if (can('info.manage')) { %>
            <div class="manage-card">
                <div class="manage-card-top"><span class="manage-icon">ℹ️</span></div>
                <div class="manage-title">Information Page</div>
                <div class="manage-desc">Configure servers, staff directory, kit regulations and TFAR guide content.</div>
                <div class="manage-card-footer">
                    <a href="/admin/info/servers" class="manage-link primary">Servers</a>
                    <a href="/admin/info/kit" class="manage-link secondary">Kit Regs</a>
                </div>
            </div>
            <% } %>

            <% if (can('lore.manage')) { %>
            <div class="manage-card">
                <div class="manage-card-top"><span class="manage-icon">📡</span></div>
                <div class="manage-title">Lore Terminal</div>
                <div class="manage-desc">Edit lore terminal nodes, files, and hidden content.</div>
                <div class="manage-card-footer">
                    <a href="/lore/admin" class="manage-link primary">Manage</a>
                    <a href="/lore" class="manage-link secondary">View Terminal</a>
                </div>
            </div>
            <% } %>

            <div class="manage-card">
                <div class="manage-card-top"><span class="manage-icon">📋</span></div>
                <div class="manage-title">ORBATs</div>
                <div class="manage-desc">Create and manage order of battle templates for operations.</div>
                <div class="manage-card-footer">
                    <a href="/orbat/templates" class="manage-link primary">Manage</a>
                </div>
            </div>

            <div class="manage-card">
                <div class="manage-card-top"><span class="manage-icon">🎯</span></div>
                <div class="manage-title">Operations</div>
                <div class="manage-desc">Schedule and manage operations, missions, and side ops.</div>
                <div class="manage-card-footer">
                    <a href="/operations/manage/list" class="manage-link primary">Manage</a>
                </div>
            </div>

            <div class="manage-card">
                <div class="manage-card-top"><span class="manage-icon">🛑</span></div>
                <div class="manage-title">Leave of Absence</div>
                <div class="manage-desc">Review and manage pending LOA requests from members.</div>
                <div class="manage-card-footer">
                    <a href="/loa/all" class="manage-link primary">View All</a>
                </div>
            </div>

            <div class="manage-card">
                <div class="manage-card-top"><span class="manage-icon">🎒</span></div>
                <div class="manage-title">Modpacks</div>
                <div class="manage-desc">Upload and manage mission modpacks for players.</div>
                <div class="manage-card-footer">
                    <a href="/modpacks" class="manage-link primary">Manage</a>
                    <a href="/modpacks/upload/new" class="manage-link secondary">+ Upload</a>
                </div>
            </div>

            <div class="manage-card">
                <div class="manage-card-top"><span class="manage-icon">📊</span></div>
                <div class="manage-title">Member Activity</div>
                <div class="manage-desc">Server join/leave trends, message-based DAU/WAU/MAU, retention cohorts, and new member engagement stats.</div>
                <div class="manage-card-footer">
                    <a href="/admin/presence" class="manage-link primary">View Stats</a>
                </div>
            </div>

        </div>
    </section>
</div>

<%- include('../partials/footer') %>
