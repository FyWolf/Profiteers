<%- include('../partials/header') %>

<style>
.stat-bar { display:flex; gap:28px; flex-wrap:wrap; margin-top:16px; padding-top:16px; border-top:1px solid rgba(107,142,35,0.3); }
.stat-chip { display:flex; flex-direction:column; align-items:center; }
.stat-val { font-family:var(--heading-font); font-size:1.7em; color:var(--accent); line-height:1; }
.stat-lbl { font-size:0.7em; color:var(--khaki); margin-top:3px; }

.top-row { display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-bottom:20px; }
.top-row h2 { margin:0; font-size:1.1em; color:var(--khaki); letter-spacing:2px; }

.info-box { padding:14px 18px; background:rgba(52,152,219,0.07); border-left:3px solid rgba(52,152,219,0.5); border-radius:0 8px 8px 0; margin-bottom:22px; }
.info-box p { font-size:0.86em; color:var(--khaki); line-height:1.75; margin:0; }
.info-box strong { color:#6bb8f7; }

.cards-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:16px; }
.item-card {
    background:linear-gradient(135deg,rgba(0,0,0,0.45) 0%,rgba(10,20,10,0.45) 100%);
    border:1px solid rgba(107,142,35,0.5);
    border-radius:12px;
    padding:18px 20px;
    display:flex; flex-direction:column;
    transition:border-color 0.2s, transform 0.2s;
}
.item-card:hover { border-color:rgba(252,176,13,0.5); transform:translateY(-2px); }
.card-body { flex:1; }
.card-footer { display:flex; gap:8px; margin-top:14px; padding-top:14px; border-top:1px solid rgba(107,142,35,0.2); }
.card-meta { font-size:0.8em; color:var(--khaki); background:rgba(0,0,0,0.25); border-radius:6px; padding:10px 12px; margin-top:12px; display:flex; flex-direction:column; gap:5px; }
.role-id { font-family:monospace; font-size:0.88em; background:rgba(0,0,0,0.35); padding:2px 7px; border-radius:4px; color:var(--sand); opacity:.8; }

.act { padding:5px 10px; border-radius:6px; font-size:0.76em; font-weight:700; text-decoration:none; cursor:pointer; border:1px solid transparent; transition:all 0.2s; white-space:nowrap; display:inline-block; font-family:var(--body-font); flex:1; text-align:center; }
.act-edit { background:rgba(252,176,13,0.1); border-color:rgba(252,176,13,0.35); color:var(--accent); }
.act-edit:hover { background:rgba(252,176,13,0.22); }
.act-del  { background:rgba(231,76,60,0.1);  border-color:rgba(231,76,60,0.35);  color:#ff7b7b; }
.act-del:hover  { background:rgba(231,76,60,0.22); }

.empty-state { text-align:center; padding:48px 20px; color:var(--khaki); opacity:.6; }
.empty-icon  { font-size:3em; margin-bottom:12px; }
.empty-state p { font-size:.9em; margin-top:6px; }
</style>

<% const totalAssigned = trainings.reduce((s, t) => s + t.assigned_count, 0); %>

<div class="container">
    <header>
        <h1>MANAGE TRAININGS</h1>
        <div class="subtitle">Training Certification System</div>
        <div class="stat-bar">
            <div class="stat-chip">
                <span class="stat-val"><%= trainings.length %></span>
                <span class="stat-lbl">Training Types</span>
            </div>
            <div class="stat-chip">
                <span class="stat-val"><%= totalAssigned %></span>
                <span class="stat-lbl">Total Assignments</span>
            </div>
        </div>
    </header>

    <section class="section">
        <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
        <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

        <div class="info-box">
            <p>
                <strong>Automatic:</strong> Trainings sync when users log in via Discord.<br>
                <strong>Manual:</strong> Use "🎓 Trainings" on a user's row to force a sync.<br>
                <strong>Requirement:</strong> Users must hold the linked Discord role to receive the training.
            </p>
        </div>

        <div class="top-row">
            <h2>ALL TRAININGS (<%= trainings.length %>)</h2>
            <a href="/admin/trainings/add" class="btn btn-primary">➕ Create Training</a>
        </div>

        <% if (trainings.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon">🎓</div>
                <strong>No trainings yet</strong>
                <p>Create your first training certification to get started.</p>
            </div>
        <% } else { %>
            <div class="cards-grid">
                <% trainings.forEach(training => { %>
                <div class="item-card" style="border-left:3px solid <%= training.color %>;">
                    <div class="card-body">
                        <div style="display:flex; align-items:flex-start; gap:14px; margin-bottom:10px;">
                            <img src="<%= training.image_url || '/images/badges/default-training.png' %>"
                                 alt="<%= training.name %>"
                                 style="width:64px; height:64px; object-fit:contain; border-radius:8px; border:2px solid <%= training.color %>; flex-shrink:0;"
                                 onerror="this.src='/images/badges/default-training.png';">
                            <div>
                                <div style="font-family:var(--heading-font); font-size:0.92em; color:<%= training.color %>; margin-bottom:4px;"><%= training.name %></div>
                                <% if (training.description) { %>
                                <div style="font-size:0.82em; color:var(--khaki); line-height:1.5;"><%= training.description %></div>
                                <% } %>
                            </div>
                        </div>
                        <div class="card-meta">
                            <div>Discord Role ID: <span class="role-id"><%= training.discord_role_id %></span></div>
                            <div style="display:flex; justify-content:space-between;">
                                <span>Order: <strong><%= training.display_order %></strong></span>
                                <span>Assigned: <strong style="color:var(--accent);"><%= training.assigned_count %></strong> user<%= training.assigned_count !== 1 ? 's' : '' %></span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer">
                        <a href="/admin/trainings/edit/<%= training.id %>" class="act act-edit">✏️ Edit</a>
                        <form method="POST" action="/admin/trainings/delete/<%= training.id %>" style="flex:1"
                              onsubmit="return confirm('Delete this training? It will be removed from all users.')">
                            <button type="submit" class="act act-del" style="width:100%;">🗑️ Delete</button>
                        </form>
                    </div>
                </div>
                <% }) %>
            </div>
        <% } %>
    </section>

    <div class="mt-2">
        <a href="/admin" class="btn">← Back to Dashboard</a>
    </div>
</div>

<%- include('../partials/footer') %>
