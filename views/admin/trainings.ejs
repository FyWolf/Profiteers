<%- include('../partials/header') %>

<style>
.card-meta { font-size:0.8em; color:var(--khaki); background:rgba(0,0,0,0.25); border-radius:6px; padding:10px 12px; margin-top:12px; display:flex; flex-direction:column; gap:5px; }
</style>

<% const totalAssigned = trainings.reduce((s, t) => s + t.assigned_count, 0); %>

<div class="container">
    <header>
        <h1>MANAGE TRAININGS</h1>
        <div class="subtitle">Training Certification System</div>
        <div class="stat-bar">
            <div class="stat-chip">
                <span class="stat-val"><%= trainings.length %></span>
                <span class="stat-lbl">Training Types</span>
            </div>
            <div class="stat-chip">
                <span class="stat-val"><%= totalAssigned %></span>
                <span class="stat-lbl">Total Assignments</span>
            </div>
        </div>
    </header>

    <section class="section">
        <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
        <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

        <div class="info-box">
            <p>
                <strong>Automatic:</strong> Trainings sync when users log in via Discord.<br>
                <strong>Manual:</strong> Use "🎓 Trainings" on a user's row to force a sync.<br>
                <strong>Requirement:</strong> Users must hold the linked Discord role to receive the training.
            </p>
        </div>

        <div class="top-row">
            <h2>ALL TRAININGS (<%= trainings.length %>)</h2>
            <a href="/admin/trainings/add" class="btn btn-primary">➕ Create Training</a>
        </div>

        <% if (trainings.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon">🎓</div>
                <strong>No trainings yet</strong>
                <p>Create your first training certification to get started.</p>
            </div>
        <% } else { %>
            <div class="cards-grid">
                <% trainings.forEach(training => { %>
                <div class="item-card" style="border-left:3px solid <%= training.color %>;">
                    <div class="card-body">
                        <div style="display:flex; align-items:flex-start; gap:14px; margin-bottom:10px;">
                            <img src="<%= training.image_url || '/images/badges/default-training.png' %>"
                                 alt="<%= training.name %>"
                                 style="width:64px; height:64px; object-fit:contain; border-radius:8px; border:2px solid <%= training.color %>; flex-shrink:0;"
                                 onerror="this.src='/images/badges/default-training.png';">
                            <div>
                                <div style="font-family:var(--heading-font); font-size:0.92em; color:<%= training.color %>; margin-bottom:4px;"><%= training.name %></div>
                                <% if (training.description) { %>
                                <div style="font-size:0.82em; color:var(--khaki); line-height:1.5;"><%= training.description %></div>
                                <% } %>
                            </div>
                        </div>
                        <div class="card-meta">
                            <div>Discord Role ID: <span class="role-id"><%= training.discord_role_id %></span></div>
                            <div style="display:flex; justify-content:space-between;">
                                <span>Order: <strong><%= training.display_order %></strong></span>
                                <span>Assigned: <strong style="color:var(--accent);"><%= training.assigned_count %></strong> user<%= training.assigned_count !== 1 ? 's' : '' %></span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer">
                        <a href="/admin/trainings/edit/<%= training.id %>" class="act act-edit">✏️ Edit</a>
                        <form method="POST" action="/admin/trainings/delete/<%= training.id %>" style="flex:1"
                              onsubmit="return confirm('Delete this training? It will be removed from all users.')">
                            <button type="submit" class="act act-del" style="width:100%;">🗑️ Delete</button>
                        </form>
                    </div>
                </div>
                <% }) %>
            </div>
        <% } %>
    </section>

    <div class="mt-2">
        <a href="/admin" class="btn">← Back to Dashboard</a>
    </div>
</div>

<%- include('../partials/footer') %>
