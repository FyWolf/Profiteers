<%- include('../partials/header') %>


<div class="container">
    <header>
        <h1>UPLOAD IMAGES</h1>
        <div class="subtitle">Add to Gallery</div>
    </header>

    <section class="section">
        <div class="form-wrap" style="max-width:800px;">
            <form method="POST" action="/admin/gallery/upload" enctype="multipart/form-data">

                <div class="field">
                    <label for="folder_id">Destination Folder *</label>
                    <select id="folder_id" name="folder_id" required>
                        <option value="">Select a folder…</option>
                        <% folders.forEach(folder => { %>
                            <option value="<%= folder.id %>"><%= folder.path %></option>
                        <% }); %>
                    </select>
                    <small>Don't see your folder? <a href="/admin/gallery/add-folder">Create one first →</a></small>
                </div>

                <div class="field">
                    <label for="images">Select Images *</label>
                    <input type="file" id="images" name="images"
                           accept="image/*" multiple required
                           onchange="previewImages(this)">
                    <small>Select multiple images at once. Max 10MB per file.</small>
                </div>

                <div id="imagePreview" class="preview-grid" style="display:none;"></div>

                <div id="captionsContainer" style="display:none; margin-top:20px;">
                    <div style="font-size:0.8em; color:var(--khaki); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:10px;">Captions (Optional)</div>
                    <div id="captionInputs"></div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" style="flex:1;">⬆️ Upload Images</button>
                    <a href="/admin/gallery" class="btn">Cancel</a>
                </div>
            </form>

            <div class="info-box">
                <strong>💡 Upload Tips</strong>
                <p>
                    Supported formats: JPG, PNG, GIF, WebP.<br>
                    Maximum file size: 10MB per image.<br>
                    You can select multiple images at once — images will be timestamped automatically.
                </p>
            </div>
        </div>
    </section>
</div>

<script>
function previewImages(input) {
    const preview = document.getElementById('imagePreview');
    const captionsContainer = document.getElementById('captionsContainer');
    const captionInputs = document.getElementById('captionInputs');

    preview.innerHTML = '';
    captionInputs.innerHTML = '';

    if (input.files && input.files.length > 0) {
        preview.style.display = 'grid';
        captionsContainer.style.display = 'block';

        Array.from(input.files).forEach((file, index) => {
            const reader = new FileReader();
            reader.onload = function(e) {
                const div = document.createElement('div');
                div.className = 'preview-item';
                div.innerHTML = `
                    <img src="${e.target.result}">
                    <p>${file.name}</p>
                `;
                preview.appendChild(div);
            };
            reader.readAsDataURL(file);

            const captionDiv = document.createElement('div');
            captionDiv.className = 'caption-field';
            captionDiv.innerHTML = `
                <label>${file.name}</label>
                <input type="text" name="captions" placeholder="Optional caption for this image"
                       style="width:100%; padding:8px 12px; background:rgba(0,0,0,0.4); border:1px solid rgba(107,142,35,0.5); border-radius:7px; color:var(--sand); font-family:var(--body-font); font-size:0.88em;">
            `;
            captionInputs.appendChild(captionDiv);
        });
    } else {
        preview.style.display = 'none';
        captionsContainer.style.display = 'none';
    }
}
</script>

<%- include('../partials/footer') %>
