<%- include('../../partials/header') %>


<div class="container">
    <header>
        <h1><%= role ? 'EDIT ROLE' : 'CREATE ROLE' %></h1>
        <div class="subtitle"><%= role ? `Editing: ${role.name}` : 'Define a new role and assign permissions' %></div>
    </header>

    <% if (error) { %><div class="alert alert-error" style="margin-bottom:20px;"><%= error %></div><% } %>

    <form method="POST" action="/admin/roles/<%= role ? role.id + '/edit' : 'create' %>">
        <div class="form-card">
            <div class="form-group">
                <label class="form-label" for="name">Role Name</label>
                <input type="text"
                       id="name"
                       name="name"
                       class="form-input"
                       value="<%= role ? role.name : '' %>"
                       placeholder="e.g. Moderator, Zeus, Content Manager"
                       <%= role && role.is_system ? 'disabled' : '' %>
                       required>
                <% if (role && role.is_system) { %>
                    <input type="hidden" name="name" value="<%= role.name %>">
                    <div style="font-size:0.75em; color:var(--khaki); margin-top:5px; opacity:0.7;">
                        System role names cannot be changed.
                    </div>
                <% } %>
            </div>

            <div class="form-group">
                <label class="form-label" for="description">Description <span style="opacity:0.5;">(optional)</span></label>
                <textarea id="description"
                          name="description"
                          class="form-textarea"
                          placeholder="Describe what this role is for..."><%= role ? (role.description || '') : '' %></textarea>
            </div>
        </div>

        <div class="form-card">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
                <h3 style="margin:0; font-size:0.9em; color:var(--khaki); letter-spacing:2px; text-transform:uppercase;">
                    Permissions
                </h3>
                <div style="display:flex; gap:10px;">
                    <button type="button" class="select-all-btn" onclick="setAll(true)">Select all</button>
                    <button type="button" class="select-all-btn" onclick="setAll(false)">Clear all</button>
                </div>
            </div>

            <%
            // Group permissions by category
            const grouped = {};
            permissions.forEach(p => {
                if (!grouped[p.category]) grouped[p.category] = [];
                grouped[p.category].push(p);
            });
            const categoryOrder = ['admin', 'users', 'content', 'operations', 'general'];
            const sortedCats = Object.keys(grouped).sort((a, b) => {
                const ai = categoryOrder.indexOf(a);
                const bi = categoryOrder.indexOf(b);
                if (ai === -1 && bi === -1) return a.localeCompare(b);
                if (ai === -1) return 1;
                if (bi === -1) return -1;
                return ai - bi;
            });
            %>

            <% sortedCats.forEach(cat => { %>
            <div class="perm-section">
                <div class="perm-category-label cat-<%= cat %>">
                    <span class="cat-dot"></span>
                    <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
                </div>
                <div class="perm-grid">
                    <% grouped[cat].forEach(perm => {
                        const isChecked = rolePerms.includes(perm.id);
                    %>
                    <label class="perm-item <%= isChecked ? 'checked' : '' %>"
                           for="perm-<%= perm.id %>">
                        <input type="checkbox"
                               id="perm-<%= perm.id %>"
                               name="permissions"
                               value="<%= perm.id %>"
                               <%= isChecked ? 'checked' : '' %>
                               onchange="this.closest('.perm-item').classList.toggle('checked', this.checked)">
                        <div>
                            <div class="perm-name"><%= perm.name %></div>
                            <% if (perm.description) { %>
                                <div class="perm-desc"><%= perm.description %></div>
                            <% } %>
                        </div>
                    </label>
                    <% }) %>
                </div>
            </div>
            <% }) %>
        </div>

        <div class="btn-row" style="margin-bottom:30px;">
            <button type="submit" class="btn-save">
                <%= role ? 'Save Changes' : 'Create Role' %>
            </button>
            <a href="/admin/roles" class="btn-cancel">Cancel</a>
        </div>
    </form>
</div>

<script>
function setAll(checked) {
    document.querySelectorAll('.perm-item input[type="checkbox"]').forEach(cb => {
        cb.checked = checked;
        cb.closest('.perm-item').classList.toggle('checked', checked);
    });
}
</script>

<%- include('../../partials/footer') %>
