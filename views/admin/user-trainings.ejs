<%- include('../partials/header') %>

<style>
.top-row { display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-bottom:20px; }
.top-row h2 { margin:0; font-size:1.1em; color:var(--khaki); letter-spacing:2px; }

.info-box { padding:14px 18px; background:rgba(52,152,219,0.07); border-left:3px solid rgba(52,152,219,0.5); border-radius:0 8px 8px 0; }
.info-box p { font-size:0.86em; color:var(--khaki); line-height:1.75; margin:0; }
.info-box strong { color:#6bb8f7; }

.sync-panel { display:flex; align-items:center; gap:16px; flex-wrap:wrap; }
.sync-panel p { font-size:0.88em; color:var(--khaki); flex:1; min-width:200px; margin:0; }

.cards-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:14px; }
.item-card {
    background:linear-gradient(135deg,rgba(0,0,0,0.45) 0%,rgba(10,20,10,0.45) 100%);
    border:1px solid rgba(107,142,35,0.5);
    border-radius:12px;
    padding:16px 18px;
    transition:border-color 0.2s;
}
.item-card:hover { border-color:rgba(252,176,13,0.4); }
.card-meta { font-size:0.78em; color:var(--khaki); margin-top:10px; padding-top:10px; border-top:1px solid rgba(107,142,35,0.15); display:flex; flex-direction:column; gap:3px; }
.synced-badge { display:inline-block; margin-top:6px; padding:3px 8px; background:rgba(52,152,219,0.15); border:1px solid rgba(52,152,219,0.3); border-radius:4px; font-size:0.85em; color:#6bb8f7; }

.check-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:10px; }
.check-row {
    display:flex; align-items:center; gap:12px;
    padding:10px 14px;
    background:rgba(0,0,0,0.25);
    border-radius:8px;
    border:1px solid rgba(107,142,35,0.2);
    transition:border-color 0.2s;
}
.check-row.assigned { border-color:rgba(107,142,35,0.5); background:rgba(107,142,35,0.08); }
.check-row .check-icon { font-size:1.3em; flex-shrink:0; }
.check-row .check-name { font-size:0.85em; flex:1; }
.check-row .check-status { font-size:0.72em; font-weight:700; }
.check-row.assigned .check-status { color:var(--olive-light); }
.check-row:not(.assigned) .check-status { color:var(--khaki); opacity:.5; }

.local-note { padding:14px 18px; background:rgba(149,165,166,0.07); border-left:3px solid rgba(149,165,166,0.4); border-radius:0 8px 8px 0; font-size:0.88em; color:var(--khaki); }

.empty-state { text-align:center; padding:40px 20px; color:var(--khaki); opacity:.6; }
.empty-icon  { font-size:3em; margin-bottom:12px; }
.empty-state p { font-size:.9em; margin-top:6px; }
</style>

<%
    const displayName = (user.discord_global_name && user.discord_global_name !== user.discord_username)
        ? user.discord_global_name
        : user.username;
    const avatarUrl = user.discord_avatar
        ? `https://cdn.discordapp.com/avatars/${user.discord_id}/${user.discord_avatar}.png?size=64`
        : null;
    const assignedIds = new Set(userTrainings.map(t => t.id));
%>

<div class="container">
    <header>
        <h1>USER TRAININGS</h1>
        <div class="subtitle" style="display:flex; align-items:center; justify-content:center; gap:10px;">
            <% if (avatarUrl) { %>
                <img src="<%= avatarUrl %>" style="width:28px; height:28px; border-radius:50%; border:2px solid var(--olive);">
            <% } %>
            <%= displayName %>
            <% if (user.discord_username) { %>
                <span style="font-size:0.7em; opacity:.6;">@<%= user.discord_username %></span>
            <% } %>
        </div>
    </header>

    <% if (success) { %><div class="alert alert-success" style="margin-bottom:16px;"><%= success %></div><% } %>
    <% if (error) { %><div class="alert alert-error" style="margin-bottom:16px;"><%= error %></div><% } %>

    <%# ── Sync panel ───────────────────────────── %>
    <section class="section">
        <div class="top-row"><h2>DISCORD SYNC</h2></div>

        <% if (user.auth_type === 'discord') { %>
        <div class="info-box" style="margin-bottom:16px;">
            <p>Syncing fetches this user's current Discord roles and updates their training certifications accordingly.</p>
        </div>
        <div class="sync-panel">
            <p>Last sync is reflected in the training cards below. Click to re-sync from Discord now.</p>
            <button id="syncBtn" class="btn btn-primary" onclick="syncTrainings()">🔄 Sync Now</button>
        </div>
        <div id="syncResult" style="margin-top:14px; display:none;"></div>
        <% } else { %>
        <div class="local-note">
            ℹ️ <strong>Local account</strong> — Discord sync is only available for Discord-authenticated users.
        </div>
        <% } %>
    </section>

    <%# ── Current trainings ────────────────────── %>
    <section class="section">
        <div class="top-row">
            <h2>CURRENT TRAININGS (<%= userTrainings.length %>)</h2>
        </div>

        <% if (userTrainings.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon">🎓</div>
                <strong>No trainings assigned</strong>
                <p>
                    <% if (user.auth_type === 'discord') { %>
                        This user has no matching Discord roles, or a sync hasn't been run yet.
                    <% } else { %>
                        Trainings are assigned automatically via Discord roles.
                    <% } %>
                </p>
            </div>
        <% } else { %>
            <div class="cards-grid">
                <% userTrainings.forEach(training => { %>
                <div class="item-card" style="border-left:3px solid <%= training.color %>;">
                    <div style="display:flex; align-items:flex-start; gap:12px;">
                        <img src="<%= training.image_url || '/images/badges/default-training.png' %>"
                             alt="<%= training.name %>"
                             style="width:56px; height:56px; object-fit:contain; border-radius:8px; border:2px solid <%= training.color %>; flex-shrink:0;"
                             onerror="this.src='/images/badges/default-training.png';">
                        <div style="flex:1;">
                            <div style="font-family:var(--heading-font); font-size:0.9em; color:<%= training.color %>; margin-bottom:3px;"><%= training.name %></div>
                            <% if (training.description) { %>
                                <div style="font-size:0.8em; color:var(--khaki); line-height:1.5;"><%= training.description %></div>
                            <% } %>
                            <div class="card-meta">
                                <span>Synced: <strong><%= new Date(training.synced_at).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %></strong></span>
                                <span>Verified: <strong><%= new Date(training.last_verified).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %></strong></span>
                                <span class="synced-badge">✅ Auto-synced from Discord</span>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        <% } %>
    </section>

    <%# ── All available trainings ─────────────── %>
    <section class="section">
        <div class="top-row">
            <h2>ALL AVAILABLE TRAININGS (<%= allTrainings.length %>)</h2>
        </div>
        <p style="font-size:0.83em; color:var(--khaki); opacity:.7; margin-bottom:16px;">
            Users earn these automatically when they hold the corresponding Discord role.
        </p>
        <div class="check-grid">
            <% allTrainings.forEach(training => { %>
            <% const isAssigned = assignedIds.has(training.id); %>
            <div class="check-row <%= isAssigned ? 'assigned' : '' %>">
                <img src="<%= training.image_url || '/images/badges/default-training.png' %>"
                     alt=""
                     style="width:32px; height:32px; object-fit:contain; border-radius:4px; border:1px solid <%= training.color %>; flex-shrink:0;"
                     onerror="this.src='/images/badges/default-training.png';">
                <span class="check-name" style="color:<%= isAssigned ? training.color : 'var(--khaki)' %>"><%= training.name %></span>
                <span class="check-status"><%= isAssigned ? '✓' : '—' %></span>
            </div>
            <% }) %>
        </div>
    </section>

    <div style="display:flex; gap:10px; margin-bottom:30px;">
        <a href="/admin/users" class="btn">← Back to Users</a>
        <a href="/admin/trainings" class="btn">Manage Trainings</a>
    </div>
</div>

<script>
async function syncTrainings() {
    const btn    = document.getElementById('syncBtn');
    const result = document.getElementById('syncResult');
    btn.disabled = true;
    btn.textContent = '🔄 Syncing…';
    result.style.display = 'none';
    try {
        const res  = await fetch('/admin/users/<%= user.id %>/sync-trainings', { method: 'POST' });
        const data = await res.json();
        result.style.display = 'block';
        if (data.success) {
            result.className = 'alert alert-success';
            result.textContent = `✅ ${data.message}`;
            setTimeout(() => location.reload(), 1500);
        } else {
            result.className = 'alert alert-error';
            result.textContent = `❌ ${data.error || 'Failed to sync trainings'}`;
            btn.disabled = false;
            btn.textContent = '🔄 Sync Now';
        }
    } catch {
        result.style.display = 'block';
        result.className = 'alert alert-error';
        result.textContent = '❌ Error syncing trainings';
        btn.disabled = false;
        btn.textContent = '🔄 Sync Now';
    }
}
</script>

<%- include('../partials/footer') %>
