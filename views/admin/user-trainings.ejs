<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>USER TRAININGS</h1>
        <div class="subtitle">
            <% if (user.discord_global_name && user.discord_global_name !== user.discord_username) { %>
                <%= user.discord_global_name %> (@<%= user.discord_username %>)
            <% } else { %>
                <%= user.username %>
            <% } %>
        </div>
    </header>

    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>
    
    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (user.auth_type === 'discord') { %>
        <section class="section">
            <div style="padding: 20px; background: rgba(52, 152, 219, 0.1); border: 2px solid #3498DB; border-radius: 8px;">
                <h3 style="color: #3498DB; margin-bottom: 15px;">🔄 Sync Trainings from Discord</h3>
                <p style="margin-bottom: 15px; color: var(--khaki);">
                    Click the button below to fetch this user's current Discord roles and update their training certifications.
                </p>
                <button id="syncBtn" class="btn btn-primary" onclick="syncTrainings()" style="width: 100%;">
                    🔄 Sync Trainings Now
                </button>
                <div id="syncResult" style="margin-top: 15px; display: none;"></div>
            </div>
        </section>
    <% } else { %>
        <section class="section">
            <div class="card" style="background: rgba(149, 165, 166, 0.1); border: 2px solid #95A5A6;">
                <h3 style="color: #95A5A6;">ℹ️ Local Account</h3>
                <p style="color: var(--khaki);">
                    This is a local account (not Discord). Training sync is only available for Discord users.
                </p>
            </div>
        </section>
    <% } %>

    <section class="section">
        <h2 style="margin-bottom: 20px;">
            Current Trainings
            <span style="color: var(--khaki); font-size: 0.7em; font-weight: normal;">
                (<%= userTrainings.length %>)
            </span>
        </h2>

        <% if (userTrainings.length === 0) { %>
            <div class="card text-center">
                <div style="font-size: 4em; opacity: 0.3; margin-bottom: 15px;">🎓</div>
                <h3>No Trainings Assigned</h3>
                <p style="color: var(--khaki);">
                    <% if (user.auth_type === 'discord') { %>
                        This user hasn't completed any trainings yet, or they need to be synced.<br>
                        Click "Sync Trainings" above to check their Discord roles.
                    <% } else { %>
                        Trainings are automatically assigned based on Discord roles.
                    <% } %>
                </p>
            </div>
        <% } else { %>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;">
                <% userTrainings.forEach(training => { %>
                    <div class="card" style="border-left: 4px solid <%= training.color %>;">
                        <div style="display: flex; align-items: start; gap: 15px; margin-bottom: 12px;">
                            <img src="<%= training.image_url || '/images/badges/default-training.png' %>" 
                                 alt="<%= training.name %>" 
                                 style="width: 70px; height: 70px; object-fit: contain; border-radius: 8px; border: 2px solid <%= training.color %>;"
                                 onerror="this.src='/images/badges/default-training.png';">
                            <div style="flex: 1;">
                                <h3 style="color: <%= training.color %>; margin-bottom: 6px; font-size: 1.1em;">
                                    <%= training.name %>
                                </h3>
                                <% if (training.description) { %>
                                    <p style="color: var(--khaki); font-size: 0.9em; margin-bottom: 10px;">
                                        <%= training.description %>
                                    </p>
                                <% } %>
                            </div>
                        </div>
                        
                        <div style="font-size: 0.85em; color: var(--khaki); opacity: 0.8; padding-top: 12px; border-top: 1px solid rgba(178, 178, 125, 0.2);">
                            <div><strong>Synced:</strong> <%= new Date(training.synced_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
                            <div><strong>Last Verified:</strong> <%= new Date(training.last_verified).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
                            <div style="margin-top: 6px; padding: 6px; background: rgba(52, 152, 219, 0.2); border-radius: 4px;">
                                ✅ Auto-synced from Discord role
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </section>

    <section class="section">
        <h2 style="margin-bottom: 20px;">📋 All Available Trainings</h2>
        <p style="color: var(--khaki); margin-bottom: 15px;">
            These are all the training certifications that can be earned. Users automatically receive these when they have the corresponding Discord role.
        </p>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 15px;">
            <% allTrainings.forEach(training => { %>
                <div class="card" style="border-left: 4px solid <%= training.color %>; padding: 15px; opacity: <%= userTrainings.some(ut => ut.id === training.id) ? '1' : '0.6' %>;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div style="font-size: 2em;">
                            <%= training.icon %>
                        </div>
                        <div style="flex: 1;">
                            <strong style="color: <%= training.color %>;">
                                <%= training.name %>
                            </strong>
                            <% if (userTrainings.some(ut => ut.id === training.id)) { %>
                                <div style="font-size: 0.8em; color: var(--accent); margin-top: 4px;">
                                    ✅ Assigned
                                </div>
                            <% } else { %>
                                <div style="font-size: 0.8em; color: var(--khaki); margin-top: 4px;">
                                    ⏸️ Not assigned
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </section>

    <section class="section">
        <div style="display: flex; gap: 15px;">
            <a href="/admin/users" class="btn">← Back to Users</a>
            <a href="/admin/trainings" class="btn">Manage Trainings</a>
        </div>
    </section>
</div>

<script>
async function syncTrainings() {
    const btn = document.getElementById('syncBtn');
    const result = document.getElementById('syncResult');
    
    btn.disabled = true;
    btn.textContent = '🔄 Syncing...';
    result.style.display = 'none';
    
    try {
        const response = await fetch('/admin/users/<%= user.id %>/sync-trainings', {
            method: 'POST'
        });
        const data = await response.json();
        
        result.style.display = 'block';
        
        if (data.success) {
            result.className = 'alert alert-success';
            result.textContent = `✅ ${data.message}`;
            
            // Reload page after 1.5 seconds to show updated trainings
            setTimeout(() => location.reload(), 1500);
        } else {
            result.className = 'alert alert-error';
            result.textContent = `❌ ${data.error || 'Failed to sync trainings'}`;
            btn.disabled = false;
            btn.textContent = '🔄 Sync Trainings Now';
        }
    } catch (error) {
        result.style.display = 'block';
        result.className = 'alert alert-error';
        result.textContent = '❌ Error syncing trainings';
        btn.disabled = false;
        btn.textContent = '🔄 Sync Trainings Now';
    }
}
</script>

<%- include('../partials/footer') %>
