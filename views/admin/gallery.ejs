<%- include('../partials/header') %>

<div class="container">
    <header>
        <h1>MANAGE GALLERY</h1>
        <div class="subtitle">Gallery Administration</div>
    </header>

    <section class="section">
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; margin-bottom: 20px;">
            <h2 style="margin: 0;">Gallery Management</h2>
            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                <a href="/admin/gallery/add-folder" class="btn">📁 New Folder</a>
                <a href="/admin/gallery/upload" class="btn btn-primary">⬆️ Upload Images</a>
            </div>
        </div>

        <% if (success) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>
        
        <% if (error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>
    </section>

    <section class="section">
        <h2>📁 Folders (<%= folders.length %>)</h2>
        
        <% if (folders.length === 0) { %>
            <div class="card text-center">
                <h3>No Folders Yet</h3>
                <p>Create your first folder to organize gallery images.</p>
                <a href="/admin/gallery/add-folder" class="btn btn-primary mt-2">Create First Folder</a>
            </div>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Folder Path</th>
                        <th>Parent</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% folders.forEach(folder => { %>
                        <tr>
                            <td>
                                <strong><%= folder.path %></strong>
                            </td>
                            <td><%= folder.parent_id ? 'Has Parent' : 'Root' %></td>
                            <td><%= new Date(folder.created_at).toLocaleDateString() %></td>
                            <td>
                                <a href="/gallery/folder/<%= folder.id %>" class="btn" style="padding: 6px 12px;" target="_blank">View</a>
                                <form method="POST" action="/admin/gallery/delete-folder/<%= folder.id %>" style="display: inline;" onsubmit="return confirm('Delete this folder and ALL its contents (including subfolders and images)? This cannot be undone!');">
                                    <button type="submit" class="btn btn-danger" style="padding: 6px 12px;">Delete</button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </section>

    <section class="section">
        <h2>🖼️ Recent Images</h2>
        
        <% if (recentImages.length === 0) { %>
            <div class="card text-center">
                <h3>No Images Yet</h3>
                <p>Upload images to populate the gallery.</p>
                <a href="/admin/gallery/upload" class="btn btn-primary mt-2">Upload First Images</a>
            </div>
        <% } else { %>
            <div class="grid grid-4">
                <% recentImages.forEach(image => { %>
                    <div class="card">
                        <img src="/uploads/gallery/<%= image.filename %>" 
                             alt="<%= image.original_name %>" 
                             style="width: 100%; height: 150px; object-fit: cover; border-radius: 8px; margin-bottom: 10px;">
                        
                        <p style="font-size: 0.85em; margin-bottom: 5px;">
                            📁 <%= image.folder_name %>
                        </p>
                        <p style="font-size: 0.85em; color: var(--khaki);">
                            👤 <%= image.username %>
                        </p>
                        
                        <button onclick="deleteImage(<%= image.id %>)" class="btn btn-danger" style="width: 100%; margin-top: 10px; padding: 6px;">
                            Delete
                        </button>
                    </div>
                <% }); %>
            </div>
            
            <p class="text-center mt-2" style="color: var(--khaki);">
                Showing last 20 images • <a href="/gallery" style="color: var(--accent);">View all in gallery →</a>
            </p>
        <% } %>
    </section>

    <section class="section">
        <a href="/admin" class="btn">← Back to Dashboard</a>
    </section>
</div>

<script>
async function deleteImage(id) {
    if (!confirm('Are you sure you want to delete this image?')) return;
    
    try {
        const response = await fetch(`/admin/gallery/delete-image/${id}`, {
            method: 'POST'
        });
        const data = await response.json();
        
        if (data.success) {
            location.reload();
        } else {
            alert('Failed to delete image');
        }
    } catch (error) {
        alert('Error deleting image');
    }
}
</script>

<%- include('../partials/footer') %>
