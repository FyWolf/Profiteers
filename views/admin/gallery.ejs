<%- include('../partials/header') %>

<style>
.stat-bar { display:flex; gap:28px; flex-wrap:wrap; margin-top:16px; padding-top:16px; border-top:1px solid rgba(107,142,35,0.3); }
.stat-chip { display:flex; flex-direction:column; align-items:center; }
.stat-val { font-family:var(--heading-font); font-size:1.7em; color:var(--accent); line-height:1; }
.stat-lbl { font-size:0.7em; color:var(--khaki); margin-top:3px; }

.top-row { display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap; margin-bottom:20px; }
.top-row h2 { margin:0; font-size:1.1em; color:var(--khaki); letter-spacing:2px; }

.admin-table { width:100%; border-collapse:collapse; }
.admin-table th { padding:10px 12px; font-size:0.7em; color:var(--khaki); border-bottom:2px solid rgba(107,142,35,0.35); font-family:var(--heading-font); letter-spacing:1px; text-align:left; opacity:.85; white-space:nowrap; }
.admin-table td { padding:11px 12px; border-bottom:1px solid rgba(107,142,35,0.1); vertical-align:middle; }
.admin-table tbody tr:hover td { background:rgba(107,142,35,0.05); }

.act { padding:5px 10px; border-radius:6px; font-size:0.76em; font-weight:700; text-decoration:none; cursor:pointer; border:1px solid transparent; transition:all 0.2s; white-space:nowrap; display:inline-block; font-family:var(--body-font); }
.act-view { background:rgba(107,142,35,0.1); border-color:rgba(107,142,35,0.4); color:var(--olive-light); }
.act-view:hover { background:rgba(107,142,35,0.22); }
.act-del  { background:rgba(231,76,60,0.1);  border-color:rgba(231,76,60,0.35); color:#ff7b7b; }
.act-del:hover  { background:rgba(231,76,60,0.22); }

.images-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:14px; }
.img-card {
    background:rgba(0,0,0,0.4);
    border:1px solid rgba(107,142,35,0.4);
    border-radius:10px;
    overflow:hidden;
    transition:border-color 0.2s, transform 0.2s;
}
.img-card:hover { border-color:rgba(252,176,13,0.5); transform:translateY(-2px); }
.img-card img { width:100%; height:130px; object-fit:cover; display:block; }
.img-card-body { padding:10px; }
.img-meta { font-size:0.75em; color:var(--khaki); margin-bottom:8px; }
.img-del { width:100%; padding:5px; border-radius:5px; font-size:0.75em; font-weight:700; background:rgba(231,76,60,0.1); border:1px solid rgba(231,76,60,0.35); color:#ff7b7b; cursor:pointer; transition:background 0.2s; }
.img-del:hover { background:rgba(231,76,60,0.22); }

.empty-state { text-align:center; padding:48px 20px; color:var(--khaki); opacity:.6; }
.empty-icon  { font-size:3em; margin-bottom:12px; }
.empty-state p { font-size:.9em; margin-top:6px; }

.folder-badge { display:inline-block; padding:2px 8px; border-radius:4px; font-size:0.75em; background:rgba(107,142,35,0.15); border:1px solid rgba(107,142,35,0.3); color:var(--olive-light); }
</style>

<div class="container">
    <header>
        <h1>MANAGE GALLERY</h1>
        <div class="subtitle">Gallery Administration</div>
        <div class="stat-bar">
            <div class="stat-chip">
                <span class="stat-val"><%= folders.length %></span>
                <span class="stat-lbl">Folders</span>
            </div>
            <div class="stat-chip">
                <span class="stat-val"><%= recentImages.length %></span>
                <span class="stat-lbl">Recent Images</span>
            </div>
        </div>
    </header>

    <% if (success) { %><div class="alert alert-success" style="margin-bottom:16px;"><%= success %></div><% } %>
    <% if (error) { %><div class="alert alert-error" style="margin-bottom:16px;"><%= error %></div><% } %>

    <%# ── Folders ──────────────────────────────── %>
    <section class="section">
        <div class="top-row">
            <h2>FOLDERS (<%= folders.length %>)</h2>
            <div style="display:flex; gap:8px;">
                <a href="/admin/gallery/add-folder" class="btn">📁 New Folder</a>
                <a href="/admin/gallery/upload" class="btn btn-primary">⬆️ Upload Images</a>
            </div>
        </div>

        <% if (folders.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon">📁</div>
                <strong>No folders yet</strong>
                <p>Create a folder to start organising gallery images.</p>
            </div>
        <% } else { %>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Folder Path</th>
                        <th>Level</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% folders.forEach(folder => { %>
                    <tr>
                        <td><strong style="font-family:monospace; font-size:0.9em;"><%= folder.path %></strong></td>
                        <td>
                            <span class="folder-badge"><%= folder.parent_id ? 'Sub-folder' : 'Root' %></span>
                        </td>
                        <td style="font-size:0.82em; color:var(--khaki);">
                            <%= new Date(folder.created_at).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %>
                        </td>
                        <td>
                            <div style="display:flex; gap:6px;">
                                <a href="/gallery/folder/<%= folder.id %>" target="_blank" class="act act-view">View</a>
                                <form method="POST" action="/admin/gallery/delete-folder/<%= folder.id %>" style="display:inline"
                                      onsubmit="return confirm('Delete this folder and ALL its contents? This cannot be undone.')">
                                    <button type="submit" class="act act-del">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>

    <%# ── Recent Images ────────────────────────── %>
    <section class="section">
        <div class="top-row">
            <h2>RECENT IMAGES</h2>
            <a href="/gallery" target="_blank" style="font-size:0.82em; color:var(--accent); text-decoration:none;">View full gallery →</a>
        </div>

        <% if (recentImages.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon">🖼️</div>
                <strong>No images yet</strong>
                <p>Upload images to populate the gallery.</p>
            </div>
        <% } else { %>
            <div class="images-grid">
                <% recentImages.forEach(image => { %>
                <div class="img-card">
                    <img src="/uploads/gallery/<%= image.filename %>" alt="<%= image.original_name %>">
                    <div class="img-card-body">
                        <div class="img-meta">
                            <div>📁 <%= image.folder_name %></div>
                            <div>👤 <%= image.username %></div>
                        </div>
                        <button onclick="deleteImage(<%= image.id %>)" class="img-del">Delete</button>
                    </div>
                </div>
                <% }) %>
            </div>
            <p style="font-size:0.8em; color:var(--khaki); opacity:.6; margin-top:14px; text-align:center;">
                Showing last 20 uploaded images
            </p>
        <% } %>
    </section>

    <div class="mt-2">
        <a href="/admin" class="btn">← Back to Dashboard</a>
    </div>
</div>

<script>
async function deleteImage(id) {
    if (!confirm('Delete this image?')) return;
    try {
        const res  = await fetch(`/admin/gallery/delete-image/${id}`, { method: 'POST' });
        const data = await res.json();
        if (data.success) location.reload();
        else alert('Failed to delete image');
    } catch { alert('Error deleting image'); }
}
</script>

<%- include('../partials/footer') %>
