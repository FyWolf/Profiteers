/* ═══════════════════════════════════════════════════════════════════════
   HELPERS
   ═══════════════════════════════════════════════════════════════════════ */
function setSaveStatus(status, text) {
    const el = document.getElementById('save-status');
    el.className = status;
    el.textContent = text;
    if (status === 'saved') setTimeout(() => { if (el.textContent === text) el.textContent = ''; }, 3000);
}

async function apiFetch(url, method = 'GET', body = null) {
    const opts = { method, headers: { 'Content-Type': 'application/json' } };
    if (body) opts.body = JSON.stringify(body);
    const res = await fetch(url, opts);
    return res.json();
}

function makeNATOIcon(sidc, label, rotation = 0, size = 35) {
    const sym = new ms.Symbol(sidc, {
        size,
        uniqueDesignation: label || '',
        strokeWidth: 4,
    });
    const anchor  = sym.getAnchor();
    const symSize = sym.getSize();
    const svg = sym.asSVG();
    const html = rotation
        ? `<div style="transform:rotate(${rotation}deg);transform-origin:${anchor.x}px ${anchor.y}px;display:inline-block">${svg}</div>`
        : svg;
    return L.divIcon({
        className:  'nato-marker',
        html,
        iconSize:   [symSize.width, symSize.height],
        iconAnchor: [anchor.x, anchor.y],
    });
}

function makeTextIcon(text, color) {
    return L.divIcon({
        className: 'nato-marker',
        html: `<div style="
            background:rgba(22,24,24,0.88);border:1px solid ${color};border-radius:3px;
            color:${color};font-size:12px;font-family:monospace;padding:2px 6px;
            white-space:nowrap;font-weight:700;letter-spacing:0.05em;
            text-shadow:0 0 4px rgba(0,0,0,0.8);
        ">${text || '?'}</div>`,
        iconSize:   null,
        iconAnchor: [0, 12],
    });
}

/* ═══════════════════════════════════════════════════════════════════════
   MAP INIT
   ═══════════════════════════════════════════════════════════════════════ */
function initMap() {
    map = L.map('map', {
        center:          [0.14, 0.14],
        zoom:            11,
        zoomControl:     false,
        doubleClickZoom: false,
    });

    L.control.zoom({ position: 'topright' }).addTo(map);

    map.on('mousemove', e => {
        if (!worldConfig) return;
        const a = latLngToArma(e.latlng);
        const x = Math.round(Math.max(0, a.x)).toString().padStart(5, '0');
        const y = Math.round(Math.max(0, a.y)).toString().padStart(5, '0');
        document.getElementById('coords').textContent = `X: ${x}  Y: ${y}`;
    });

    map.on('move zoom moveend zoomend', updateMinimap);

    if (CAN_EDIT) {
        map.on('click',        onMapClick);
        map.on('dblclick',     onMapDblClick);
        map.on('mousemove',    onMapMouseMove);
        map.on('contextmenu',  onMapContextMenu);
    }
}

/* ═══════════════════════════════════════════════════════════════════════
   ARMA COORDINATE CONVERSION  (MapLibre / EPSG:3857 mode)
   Arma coords: [0,0] = bottom-left, X increases right, Y increases up.
   In EPSG:3857 we map armaX → lng and armaY → lat by dividing by
   METERS_PER_DEGREE (111320). World bounds stay near origin (0,0).
   ═══════════════════════════════════════════════════════════════════════ */
function armaToLatLng(armaX, armaY) {
    return L.latLng(armaY / METERS_PER_DEGREE, armaX / METERS_PER_DEGREE);
}

function latLngToArma(latlng) {
    return {
        x: latlng.lng * METERS_PER_DEGREE,
        y: latlng.lat * METERS_PER_DEGREE,
    };
}

/* ═══════════════════════════════════════════════════════════════════════
   WORLD / TERRAIN LOADING  (MapLibre GL 5 + PMTiles 4)
   Mirrors the OCAP leafletRenderer.ts MapLibre init path exactly.
   Terrain data lives at public/images/maps/{worldName}/:
     map.json / meta.json — config & display info
     styles/topo.json     — MapLibre GL style
     tiles/*.pmtiles      — vector tile archives
   ═══════════════════════════════════════════════════════════════════════ */
async function loadWorldConfig(worldName) {
    setWorldStatus('', `Loading ${worldName}…`);
    try {
        const base = `/images/maps/${encodeURIComponent(worldName)}`;

        const [cfgRes, metaRes] = await Promise.all([
            fetch(`${base}/map.json`),
            fetch(`${base}/meta.json`).catch(() => null),
        ]);
        if (!cfgRes.ok) throw new Error(`map.json not found (HTTP ${cfgRes.status})`);

        const cfg  = await cfgRes.json();
        const meta = (metaRes && metaRes.ok) ? await metaRes.json() : {};

        worldConfig = {
            worldName,
            displayName: meta.displayName || cfg.name || worldName,
            worldSize:   cfg.worldSize    || meta.worldSize || 10240,
            maxZoom:     cfg.maxZoom      ?? 18,
            minZoom:     cfg.minZoom      ?? 8,
        };

        // absBase: root of the app, used to resolve all relative paths in the
        // style document. Must end with '/'.
        const absBase = window.location.origin + '/';
        const isAbsoluteUrl = u => /^(\w+:)?\/\/|^data:/.test(u);
        const makeAbsolute  = u => isAbsoluteUrl(u) ? u : absBase + u.replace(/^\//, '');

        // Register PMTiles protocol once — wrap handler to rewrite relative paths.
        // Style stores "pmtiles://images/maps/altis/tiles/…" (no host) which the
        // Protocol class cannot open; we prepend absBase to make it absolute.
        if (!window._pmtilesRegistered) {
            const protocol = new pmtiles.Protocol();
            maplibregl.addProtocol('pmtiles', (params, abortController) => {
                const rest = params.url.slice('pmtiles://'.length);
                const url  = (!rest.startsWith('http') && !rest.startsWith('/'))
                    ? 'pmtiles://' + absBase + rest
                    : params.url;
                return protocol.tile({ ...params, url }, abortController);
            });
            window._pmtilesRegistered = true;
        }

        // transformRequest: resolves every remaining relative URL MapLibre
        // fetches (sprites, glyphs, tile template strings, etc.).
        const transformRequest = url => ({ url: makeAbsolute(url) });

        // patchStyle: fetch a style JSON and fix sprite/glyphs paths.
        // Preserves sprite variant (sprite vs sprite-dark) from original path.
        async function patchStyle(url) {
            const res = await fetch(url);
            if (!res.ok) throw new Error(`Style not found: ${url}`);
            const s = await res.json();
            const spriteName = typeof s.sprite === 'string'
                ? s.sprite.split('/').pop()   // keep 'sprite' or 'sprite-dark'
                : 'sprite';
            s.sprite = `${window.location.origin}/images/maps/${worldName}/styles/${spriteName}`;
            if (typeof s.glyphs === 'string') s.glyphs = makeAbsolute(s.glyphs);
            return s;
        }

        // Load preferred style (saved in localStorage), falling back to topo.json
        const savedStyle = localStorage.getItem('map-style') || 'topo.json';
        let style;
        try {
            style = await patchStyle(`${base}/styles/${savedStyle}`);
            activeStyleFile = savedStyle;
        } catch {
            style = await patchStyle(`${base}/styles/topo.json`);
            activeStyleFile = 'topo.json';
        }

        // Remove old terrain layer if any
        if (maplibreLayer) { map.removeLayer(maplibreLayer); maplibreLayer = null; }

        maplibreLayer = L.maplibreGL({
            style,
            interactive:       false,
            renderWorldCopies: false,
            transformRequest,
        }).addTo(map);

        // MapLibre GL's canvas sits on top of the Leaflet canvas. Even with
        // interactive:false the container still has pointer-events by default,
        // which blocks Leaflet dblclick / mousemove events needed for drawing.
        // Force pointer-events:none on both the container and canvas.
        try {
            const glMap  = maplibreLayer.getMaplibreMap();
            const canvas = glMap.getCanvas();
            canvas.style.pointerEvents          = 'none';
            canvas.parentElement.style.pointerEvents = 'none';
        } catch (_) { /* layer not ready yet — CSS rule below acts as fallback */ }

        // Fit map to world bounds
        const maxDeg    = worldConfig.worldSize / METERS_PER_DEGREE;
        const mapBounds = L.latLngBounds([0, 0], [maxDeg, maxDeg]);
        map.setMaxBounds(mapBounds.pad(0.05));
        map.setMinZoom(worldConfig.minZoom);
        map.setMaxZoom(worldConfig.maxZoom);
        map.fitBounds(mapBounds);

        document.getElementById('map-placeholder').style.display = 'none';
        setWorldStatus('ok', worldConfig.displayName);
        initMinimap(worldName);

        // Probe available style variants and build the style switcher.
        // patchStyle is captured in closure above.
        buildStyleSwitcher(base, worldName, patchStyle);

        return true;
    } catch (err) {
        console.error('Failed to load world config:', err);
        worldConfig = null;
        setWorldStatus('err', `Failed to load terrain: ${err.message}`);
        return false;
    }
}

function setWorldStatus(cls, text) {
    const el = document.getElementById('world-status');
    el.className = cls;
    el.textContent = text;
}

/* ═══════════════════════════════════════════════════════════════════════
   MINIMAP OVERVIEW
   ═══════════════════════════════════════════════════════════════════════ */
function initMinimap(worldName) {
    const wrap = document.getElementById('minimap-wrap');
    const img  = document.getElementById('minimap-img');
    if (!wrap || !img) return;
    img.onload  = () => { wrap.style.display = ''; updateMinimap(); };
    img.onerror = () => { wrap.style.display = 'none'; };
    img.src = `/images/maps/${encodeURIComponent(worldName)}/preview_512.png`;
}

function updateMinimap() {
    if (!worldConfig) return;
    const viewport = document.getElementById('minimap-viewport');
    const imgWrap  = document.getElementById('minimap-img-wrap');
    if (!viewport || !imgWrap) return;

    const worldDeg = worldConfig.worldSize / METERS_PER_DEGREE;
    const bounds   = map.getBounds();

    // Clamp to world extent
    const south = Math.max(bounds.getSouth(), 0);
    const north = Math.min(bounds.getNorth(), worldDeg);
    const west  = Math.max(bounds.getWest(),  0);
    const east  = Math.min(bounds.getEast(),  worldDeg);

    // Convert to % of image (note: image Y axis is inverted vs lat)
    const left   = (west  / worldDeg) * 100;
    const top    = ((worldDeg - north) / worldDeg) * 100;
    const width  = ((east - west)  / worldDeg) * 100;
    const height = ((north - south) / worldDeg) * 100;

    viewport.style.left   = left   + '%';
    viewport.style.top    = top    + '%';
    viewport.style.width  = Math.max(width,  0.5) + '%';
    viewport.style.height = Math.max(height, 0.5) + '%';
}

(function wireMinimapUI() {
    // Toggle collapse
    document.getElementById('minimap-toggle')?.addEventListener('click', () => {
        const wrap = document.getElementById('minimap-wrap');
        const btn  = document.getElementById('minimap-toggle');
        const collapsed = wrap.classList.toggle('collapsed');
        btn.textContent = collapsed ? '+' : '−';
    });

    // Click on minimap to pan main map
    document.getElementById('minimap-img-wrap')?.addEventListener('click', e => {
        if (!worldConfig) return;
        const rect     = e.currentTarget.getBoundingClientRect();
        const fx       = (e.clientX - rect.left)  / rect.width;
        const fy       = (e.clientY - rect.top)   / rect.height;
        const worldDeg = worldConfig.worldSize / METERS_PER_DEGREE;
        map.panTo([(1 - fy) * worldDeg, fx * worldDeg]);
    });
})();

/* ═══════════════════════════════════════════════════════════════════════
   MAP STYLE SWITCHER
   Probes the 4 OCAP style variants via HEAD requests, shows buttons for
   available ones, and switches the MapLibre GL style on click.
   ═══════════════════════════════════════════════════════════════════════ */
const STYLE_VARIANTS = [
    { file: 'topo.json',          label: 'Topographic' },
    { file: 'topo-dark.json',     label: 'Topo Dark'   },
    { file: 'topo-relief.json',   label: 'Topo Relief' },
    { file: 'color-relief.json',  label: 'Color Relief' },
];

let activeStyleFile = 'topo.json';

async function buildStyleSwitcher(base, worldName, patchStyle) {
    const switcher = document.getElementById('style-switcher');
    const btnWrap  = document.getElementById('style-btns');
    btnWrap.innerHTML = '';

    // Probe all variants in parallel
    const probes = await Promise.all(STYLE_VARIANTS.map(async v => {
        try {
            const r = await fetch(`${base}/styles/${v.file}`, { method: 'HEAD' });
            return { ...v, available: r.ok };
        } catch { return { ...v, available: false }; }
    }));

    const available = probes.filter(v => v.available);
    if (available.length <= 1) {
        switcher.style.display = 'none';
        return; // nothing to switch between
    }

    switcher.style.display = 'block';

    // Restore previously saved style preference
    const saved = localStorage.getItem('map-style') || 'topo.json';
    if (available.find(v => v.file === saved)) activeStyleFile = saved;

    for (const v of available) {
        const btn = document.createElement('button');
        btn.className = 'style-btn' + (v.file === activeStyleFile ? ' active' : '');
        btn.textContent = v.label;
        btn.addEventListener('click', async () => {
            if (v.file === activeStyleFile) return;
            activeStyleFile = v.file;
            localStorage.setItem('map-style', v.file);
            btnWrap.querySelectorAll('.style-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            try {
                const glMap = maplibreLayer.getMaplibreMap();
                const newStyle = await patchStyle(`${base}/styles/${v.file}`);
                glMap.setStyle(newStyle);
            } catch (err) {
                console.error('Style switch error:', err);
            }
        });
        btnWrap.appendChild(btn);
    }
}



/* ═══════════════════════════════════════════════════════════════════════
   LOAD DATA
   ═══════════════════════════════════════════════════════════════════════ */
async function loadData() {
    try {
        const data = await apiFetch(`/operations/${OP_ID}/map/data`);
        if (!data.success) return;

        // Load terrain tiles before rendering annotations
        if (data.mapWorld) {
            await loadWorldConfig(data.mapWorld);
        }

        for (const layer of data.layers) {
            createLocalLayer(layer);
            for (const ann of layer.annotations) {
                renderAnnotation(ann);
            }
        }

        if (data.layers.length > 0) setActiveLayer(data.layers[0].id);
        renderLayerPanel();
    } catch (err) {
        console.error('Failed to load map data:', err);
    }
}

/* ═══════════════════════════════════════════════════════════════════════
   LAYER MANAGEMENT
   ═══════════════════════════════════════════════════════════════════════ */
function createLocalLayer(meta) {
    const group = L.layerGroup().addTo(map);
    if (!meta.is_visible) map.removeLayer(group);
    layers[meta.id] = { meta, group, featureMap: {} };
}

function setActiveLayer(id) {
    activeLayerId = id;
    document.querySelectorAll('.layer-item').forEach(el => {
        el.classList.toggle('active', parseInt(el.dataset.id) === id);
    });
}

async function apiCreateLayer(name, color) {
    setSaveStatus('saving', 'Saving…');
    const data = await apiFetch(`/operations/${OP_ID}/map/layers`, 'POST', { name, color });
    if (data.success) {
        createLocalLayer(data.layer);
        setActiveLayer(data.layer.id);
        renderLayerPanel();
        setSaveStatus('saved', 'Saved');
    } else {
        setSaveStatus('error', 'Error');
    }
}

async function apiDeleteLayer(id) {
    if (!confirm(`Delete layer "${layers[id]?.meta.name}"?\nAll annotations in this layer will be removed.`)) return;
    setSaveStatus('saving', 'Saving…');
    const data = await apiFetch(`/operations/${OP_ID}/map/layers/${id}`, 'DELETE');
    if (data.success) {
        map.removeLayer(layers[id].group);
        delete layers[id];
        if (activeLayerId === id) {
            const remaining = Object.keys(layers);
            setActiveLayer(remaining.length ? parseInt(remaining[0]) : null);
        }
        renderLayerPanel();
        setSaveStatus('saved', 'Saved');
    } else {
        setSaveStatus('error', 'Error');
    }
}

async function apiToggleLayerVisible(id) {
    const l = layers[id];
    if (!l) return;
    const nowVisible = !l.meta.is_visible;
    l.meta.is_visible = nowVisible;
    nowVisible ? l.group.addTo(map) : map.removeLayer(l.group);

    await apiFetch(`/operations/${OP_ID}/map/layers/${id}`, 'PATCH', { is_visible: nowVisible });
    renderLayerPanel();
}

async function apiToggleLayerPublic(id) {
    const l = layers[id];
    if (!l) return;
    const nowPublic = !l.meta.is_public;
    l.meta.is_public = nowPublic;
    await apiFetch(`/operations/${OP_ID}/map/layers/${id}`, 'PATCH', { is_public: nowPublic });
    renderLayerPanel();
}

async function apiUpdateLayer(id, name, color) {
    const l = layers[id];
    if (!l) return;
    l.meta.name  = name;
    l.meta.color = color;
    setSaveStatus('saving', 'Saving…');
    const data = await apiFetch(`/operations/${OP_ID}/map/layers/${id}`, 'PATCH', { name, color });
    if (data.success) { renderLayerPanel(); setSaveStatus('saved', 'Saved'); }
    else setSaveStatus('error', 'Error');
}

function renderLayerPanel() {
    const list = document.getElementById('layer-list');
    list.innerHTML = '';

    const layerArr = Object.values(layers).sort((a,b) => a.meta.display_order - b.meta.display_order);

    for (const { meta } of layerArr) {
        const count = Object.keys(layers[meta.id].featureMap).length;
        const div   = document.createElement('div');
        div.className = `layer-item${meta.id === activeLayerId ? ' active' : ''}${!meta.is_visible ? ' hidden' : ''}`;
        div.dataset.id = meta.id;
        div.style.setProperty('--layer-color', meta.color);

        const isDraft = meta.is_public === 0 || meta.is_public === false;
        div.innerHTML = `
            <div class="swatch" style="background:${meta.color}"></div>
            <span class="lname">${meta.name}</span>
            ${isDraft ? '<span class="layer-draft-badge">DRAFT</span>' : ''}
            <span class="layer-count">${count}</span>
            ${CAN_EDIT ? `
            <div class="layer-actions">
                <button class="layer-btn vis"    title="${meta.is_visible ? 'Hide' : 'Show'} layer">${meta.is_visible ? '👁' : '◌'}</button>
                <button class="layer-btn pub ${isDraft ? 'draft' : ''}" title="${isDraft ? 'Publish layer (make visible to public)' : 'Unpublish layer (hide from public)'}">${isDraft ? '🔒' : '🌐'}</button>
                <button class="layer-btn edit"   title="Rename / recolour">✏</button>
                <button class="layer-btn delete" title="Delete layer">🗑</button>
            </div>` : ''}
        `;

        div.addEventListener('click', e => {
            if (e.target.closest('.layer-actions')) return;
            setActiveLayer(meta.id);
        });

        if (CAN_EDIT) {
            div.querySelector('.vis')?.addEventListener('click',    e => { e.stopPropagation(); apiToggleLayerVisible(meta.id); });
            div.querySelector('.pub')?.addEventListener('click',    e => { e.stopPropagation(); apiToggleLayerPublic(meta.id); });
            div.querySelector('.edit')?.addEventListener('click',   e => { e.stopPropagation(); openLayerModal('edit', meta.id); });
            div.querySelector('.delete')?.addEventListener('click', e => { e.stopPropagation(); apiDeleteLayer(meta.id); });
        }

        list.appendChild(div);
    }

    if (layerArr.length === 0) {
        list.innerHTML = '<div style="padding:16px;color:#444;font-size:0.78em;text-align:center;">No layers yet.<br>Click "+ New" to add one.</div>';
    }

    // Update layer select in properties panel
    const prLayer = document.getElementById('pr-layer');
    if (prLayer) {
        prLayer.innerHTML = '';
        for (const { meta } of layerArr) {
            const opt = document.createElement('option');
            opt.value = meta.id;
            opt.textContent = meta.name;
            prLayer.appendChild(opt);
        }
    }
}

/* ═══════════════════════════════════════════════════════════════════════
   ANNOTATION RENDERING
   ═══════════════════════════════════════════════════════════════════════ */
function renderAnnotation(ann) {
    const l = layers[ann.layer_id];
    if (!l || !worldConfig) return;
    const p = ann.properties || {};

    let feature;

    // Geometry coordinates are stored as Arma [x, y] meters.
    if (ann.type === 'nato_marker') {
        const [ax, ay] = ann.geometry.coordinates;
        const rotation = p.rotation || 0;
        feature = L.marker(armaToLatLng(ax, ay), {
            icon: makeNATOIcon(p.sidc || '130110000000000000000000000000', p.label, rotation),
            draggable: !!CAN_EDIT,
        });
        if (CAN_EDIT) {
            feature.on('dragend', async () => {
                const newLl = feature.getLatLng();
                const a2    = latLngToArma(newLl);
                const newGeom = { ...ann.geometry, coordinates: [a2.x, a2.y] };
                setSaveStatus('saving', 'Saving…');
                const r = await apiFetch(`/operations/${OP_ID}/map/annotations/${ann.id}`, 'PATCH', { geometry: newGeom });
                if (r.success) {
                    ann.geometry = newGeom;
                    setSaveStatus('saved', 'Saved');
                    // Reposition the rotation handle if this marker is selected
                    if (selectedId === ann.id) showSelectionOverlay(feature, ann.id, ann.layer_id);
                } else {
                    setSaveStatus('error', 'Error saving position');
                }
            });
        }
    } else if (ann.type === 'text') {
        const [ax, ay] = ann.geometry.coordinates;
        feature = L.marker(armaToLatLng(ax, ay), { icon: makeTextIcon(p.label, p.color || '#F5C518') });
    } else if (ann.type === 'polyline') {
        const coords = ann.geometry.coordinates.map(([ax, ay]) => armaToLatLng(ax, ay));
        feature = L.polyline(coords, {
            color:     p.color     || '#e74c3c',
            weight:    p.weight    || 2,
            dashArray: p.dashArray || null,
        });
    } else if (ann.type === 'polygon' || ann.type === 'rectangle') {
        const coords = ann.geometry.coordinates[0].map(([ax, ay]) => armaToLatLng(ax, ay));
        feature = L.polygon(coords, {
            color:       p.color     || '#e74c3c',
            weight:      p.weight    || 2,
            dashArray:   p.dashArray || null,
            fillOpacity: 0.12,
        });
    } else if (ann.type === 'circle') {
        const [ax, ay] = ann.geometry.center;
        feature = L.circle(armaToLatLng(ax, ay), {
            radius:      p.radius    || 100,   // Arma meters = real meters in EPSG:3857
            color:       p.color     || '#e74c3c',
            weight:      p.weight    || 2,
            dashArray:   p.dashArray || null,
            fillOpacity: 0.1,
        });
    } else {
        return;
    }

    if (p.label && ann.type !== 'nato_marker' && ann.type !== 'text') {
        feature.bindTooltip(p.label, { permanent: true, direction: 'center', className: 'leaflet-tooltip-dark' });
    }

    if (CAN_EDIT) {
        feature.on('click', e => { L.DomEvent.stop(e); selectAnnotation(ann.id, ann.layer_id); });
    }

    feature.addTo(l.group);
    l.featureMap[ann.id] = { feature, ann };
}

function removeFeatureFromMap(annId, layerId) {
    const l = layers[layerId];
    if (!l || !l.featureMap[annId]) return;
    l.group.removeLayer(l.featureMap[annId].feature);
    delete l.featureMap[annId];
}

/* ═══════════════════════════════════════════════════════════════════════
   ANNOTATION SELECTION / PROPERTIES
   ═══════════════════════════════════════════════════════════════════════ */
function selectAnnotation(annId, layerId) {
    clearSelectionOverlay();
    selectedId      = annId;
    selectedLayerId = layerId;

    const l   = layers[layerId];
    const rec = l?.featureMap[annId];
    if (!rec) return;

    const p   = rec.ann.properties || {};
    const type = rec.ann.type;

    document.getElementById('props-type-label').textContent = type.replace('_', ' ').toUpperCase();
    document.getElementById('pr-label').value = p.label  || '';
    document.getElementById('pr-color').value = p.color  || '#e74c3c';

    const prLayer = document.getElementById('pr-layer');
    if (prLayer) prLayer.value = layerId;

    const showWeight   = ['polyline','polygon','rectangle','circle'].includes(type);
    const showRotation = type === 'nato_marker';
    document.getElementById('pr-weight-row').style.display   = showWeight   ? '' : 'none';
    document.getElementById('pr-dash-row').style.display     = showWeight   ? '' : 'none';
    document.getElementById('pr-rotation-row').style.display = showRotation ? '' : 'none';
    if (showWeight) {
        document.getElementById('pr-weight').value = String(p.weight || 2);
        document.getElementById('pr-dash').value   = p.dashArray || '';
    }
    if (showRotation) {
        const rot = p.rotation || 0;
        document.getElementById('pr-rotation').value   = rot;
        document.getElementById('pr-rotation-val').textContent = rot + '°';
    }

    document.getElementById('props-panel').classList.add('open');

    // Show rotation handle for NATO markers
    if (type === 'nato_marker') showSelectionOverlay(rec.feature, annId, layerId);
}

function deselectAnnotation() {
    clearSelectionOverlay();
    selectedId = selectedLayerId = null;
    document.getElementById('props-panel')?.classList.remove('open');
}

async function saveAnnotationProps() {
    if (!selectedId) return;
    const l   = layers[selectedLayerId];
    const rec = l?.featureMap[selectedId];
    if (!rec) return;

    const ann  = rec.ann;
    const type = ann.type;

    const newProps = {
        ...ann.properties,
        label:    document.getElementById('pr-label').value.trim(),
        color:    document.getElementById('pr-color').value,
    };
    if (['polyline','polygon','rectangle','circle'].includes(type)) {
        newProps.weight    = parseInt(document.getElementById('pr-weight').value);
        newProps.dashArray = document.getElementById('pr-dash').value || null;
    }
    if (type === 'nato_marker') {
        newProps.rotation = parseInt(document.getElementById('pr-rotation').value) || 0;
    }

    const newLayerId = parseInt(document.getElementById('pr-layer').value);

    setSaveStatus('saving', 'Saving…');
    const data = await apiFetch(`/operations/${OP_ID}/map/annotations/${selectedId}`, 'PATCH',
        { properties: newProps });

    if (data.success) {
        // Move to different layer if changed
        if (newLayerId !== selectedLayerId) {
            removeFeatureFromMap(selectedId, selectedLayerId);
            const newAnn = { ...ann, layer_id: newLayerId, properties: newProps };
            await apiFetch(`/operations/${OP_ID}/map/annotations/${selectedId}`, 'PATCH',
                { properties: newProps });
            // Re-render in new layer (simplified: reload)
            renderAnnotation(newAnn);
            layers[newLayerId].featureMap[selectedId] = { feature: layers[newLayerId].featureMap[selectedId]?.feature, ann: newAnn };
        } else {
            // Remove and re-render with new style
            removeFeatureFromMap(selectedId, selectedLayerId);
            renderAnnotation({ ...ann, properties: newProps });
        }

        renderLayerPanel();
        deselectAnnotation();
        setSaveStatus('saved', 'Saved');
    } else {
        setSaveStatus('error', 'Error saving');
    }
}

async function deleteSelectedAnnotation() {
    if (!selectedId || !confirm('Delete this annotation?')) return;
    setSaveStatus('saving', 'Saving…');
    const data = await apiFetch(`/operations/${OP_ID}/map/annotations/${selectedId}`, 'DELETE');
    if (data.success) {
        removeFeatureFromMap(selectedId, selectedLayerId);
        renderLayerPanel();
        deselectAnnotation();
        setSaveStatus('saved', 'Saved');
    } else {
        setSaveStatus('error', 'Error');
    }
}

/* ═══════════════════════════════════════════════════════════════════════
   SELECTION OVERLAY  (rotation handle for NATO markers)
   ═══════════════════════════════════════════════════════════════════════ */
let selectionOverlay = { handle: null, line: null };

function showSelectionOverlay(marker, annId, layerId) {
    clearSelectionOverlay();
    if (!CAN_EDIT || !marker) return;

    const rec = layers[layerId]?.featureMap[annId];
    if (!rec) return;

    const rotation = rec.ann.properties?.rotation || 0;
    const HANDLE_DIST = 52; // pixels from marker centre to handle

    function getHandleLatLng(deg) {
        const mPx = map.latLngToLayerPoint(marker.getLatLng());
        const rad  = deg * Math.PI / 180;
        return map.layerPointToLatLng(L.point(
            mPx.x + HANDLE_DIST * Math.sin(rad),
            mPx.y - HANDLE_DIST * Math.cos(rad)
        ));
    }

    const handleLatLng = getHandleLatLng(rotation);

    const line = L.polyline([marker.getLatLng(), handleLatLng], {
        color: 'rgba(252,176,13,0.7)', weight: 1.5, dashArray: '5 4', interactive: false
    }).addTo(map);

    const handle = L.marker(handleLatLng, {
        icon: L.divIcon({
            className: '',
            html: '<div class="rot-handle"></div>',
            iconSize:   [12, 12],
            iconAnchor: [6, 6],
        }),
        draggable: true,
        zIndexOffset: 3000,
    }).addTo(map);

    handle.on('drag', () => {
        const hPx = map.latLngToLayerPoint(handle.getLatLng());
        const mPx = map.latLngToLayerPoint(marker.getLatLng());
        const deg = Math.round(((Math.atan2(hPx.x - mPx.x, -(hPx.y - mPx.y)) * 180 / Math.PI) + 360) % 360);
        line.setLatLngs([marker.getLatLng(), handle.getLatLng()]);

        // Live icon update
        const p = rec.ann.properties || {};
        marker.setIcon(makeNATOIcon(p.sidc || '130110000000000000000000000000', p.label, deg));
        marker._pendingRotation = deg;

        // Sync rotation slider
        const slider = document.getElementById('pr-rotation');
        if (slider) { slider.value = deg; document.getElementById('pr-rotation-val').textContent = deg + '°'; }
    });

    handle.on('dragend', async () => {
        const deg = marker._pendingRotation ?? (rec.ann.properties?.rotation || 0);
        const newProps = { ...rec.ann.properties, rotation: deg };
        rec.ann.properties = newProps;
        delete marker._pendingRotation;

        // Snap handle to exact position
        handle.setLatLng(getHandleLatLng(deg));
        line.setLatLngs([marker.getLatLng(), handle.getLatLng()]);

        setSaveStatus('saving', 'Saving…');
        const r = await apiFetch(`/operations/${OP_ID}/map/annotations/${annId}`, 'PATCH', { properties: newProps });
        setSaveStatus(r.success ? 'saved' : 'error', r.success ? 'Saved' : 'Error saving rotation');
    });

    // Also update line when main marker is dragged
    marker.on('drag', () => {
        const deg = rec.ann.properties?.rotation || 0;
        const hll = getHandleLatLng(deg);
        line.setLatLngs([marker.getLatLng(), hll]);
        handle.setLatLng(hll);
    });

    selectionOverlay = { handle, line };
}

function clearSelectionOverlay() {
    if (selectionOverlay.handle) { map.removeLayer(selectionOverlay.handle); }
    if (selectionOverlay.line)   { map.removeLayer(selectionOverlay.line);   }
    selectionOverlay = { handle: null, line: null };
}

/* ═══════════════════════════════════════════════════════════════════════
   METIS MARKER SQF EXPORT
   ═══════════════════════════════════════════════════════════════════════ */

// milsymbol v3 entity code → Metis icon ID
const ENTITY_TO_METIS = {
    '000000': 37, '121100':  1, '121102':  2, '121104':  3,
    '120500':  4, '120400':  5, '130100':  9, '130101': 10,
    '110100': 11, '110102': 11, '110103': 11, '110104': 11, '110107': 11,
    '110200': 12, '110300': 13, '140700': 14, '140701': 15, '140702': 16,
    '130300': 17, '130301': 18, '130800': 19, '130801': 20,
    '121300': 21, '120501': 22, '121303': 23, '141200': 27,
    '111000': 28, '161300': 30, '163400': 31, '163600': 32,
    '121700': 39, '121800': 40,
};
// SIDC echelon (positions 8-9) → Metis size ID
const ECHELON_TO_SIZE = {
    '00': 0,'11': 1,'12': 2,'13': 3,'14': 4,'15': 5,
    '16': 6,'17': 7,'18': 8,'21': 9,'22':10,'23':11,'24':12,
};
// Arma color names ordered by approximate hue (for nearest-color lookup)
const ARMA_COLORS = [
    { name: 'ColorBlack',       r:   0, g:   0, b:   0 },
    { name: 'ColorWhite',       r: 255, g: 255, b: 255 },
    { name: 'ColorRed',         r: 229, g:   0, b:   0 },
    { name: 'ColorBlue',        r:   0, g:   0, b: 255 },
    { name: 'ColorGreen',       r:   0, g: 204, b:   0 },
    { name: 'ColorYellow',      r: 216, g: 216, b:   0 },
    { name: 'ColorOrange',      r: 216, g: 102, b:   0 },
    { name: 'ColorBrown',       r: 127, g:  63, b:   0 },
    { name: 'ColorKhaki',       r: 127, g: 153, b: 102 },
    { name: 'ColorPink',        r: 255, g:  76, b: 102 },
    { name: 'ColorGrey',        r: 127, g: 127, b: 127 },
    { name: 'ColorBlufor',      r:   0, g:  76, b: 153 },
    { name: 'ColorOpfor',       r: 127, g:   0, b:   0 },
    { name: 'ColorIndependent', r:   0, g: 127, b:   0 },
    { name: 'ColorCivilian',    r: 102, g:   0, b: 127 },
];

function hexToRgb(hex) {
    const h = hex.replace('#','');
    if (h.length === 3) return { r: parseInt(h[0]+h[0],16), g: parseInt(h[1]+h[1],16), b: parseInt(h[2]+h[2],16) };
    return { r: parseInt(h.slice(0,2),16), g: parseInt(h.slice(2,4),16), b: parseInt(h.slice(4,6),16) };
}

function colorToArma(hex) {
    if (!hex) return 'ColorBlack';
    const { r, g, b } = hexToRgb(hex);
    let best = ARMA_COLORS[0], bestDist = Infinity;
    for (const c of ARMA_COLORS) {
        const d = (r-c.r)**2 + (g-c.g)**2 + (b-c.b)**2;
        if (d < bestDist) { bestDist = d; best = c; }
    }
    return best.name;
}

function sidcToMetis(sidc) {
    // Null/missing SIDC → unknown generic unit (still renders a visible frame in Metis)
    if (!sidc || sidc.length < 20) return { sideid: 'unk', dashed: false, icon: 37, mod1: 0, mod2: 0, size: 0 };
    const affil  = sidc[3];
    const status = sidc[6];
    const echelon = sidc.slice(8, 10);
    const entity  = sidc.slice(10, 16);
    const m1      = sidc.slice(16, 18);
    const m2      = sidc.slice(18, 20);

    const sideid = ({ '3':'blu','2':'blu','5':'red','6':'red','4':'neu' })[affil] || 'unk';
    const dashed = status === '1';  // anticipated/planned
    const icon   = ENTITY_TO_METIS[entity] ?? 0;
    const size   = ECHELON_TO_SIZE[echelon] ?? 0;
    const mod1   = m1 === '98' ? 7 : 0;
    const mod2   = m2 === '51' ? 7 : 0;

    return { sideid, dashed, icon, mod1, mod2, size };
}

function toArma(v) {
    if (v === null || v === undefined) return 'null';
    if (typeof v === 'string')  return '"' + v.replace(/"/g, '""') + '"';
    if (typeof v === 'boolean') return v ? 'true' : 'false';
    if (typeof v === 'number')  return isFinite(v) ? String(Math.round(v * 100) / 100) : '0';
    if (Array.isArray(v))       return '[' + v.map(toArma).join(',') + ']';
    return 'null';
}

function generateSQF() {
    const icons   = [];
    const polys   = [];
    const metis   = [];
    let   id      = 0;

    for (const layer of Object.values(layers)) {
        for (const rec of Object.values(layer.featureMap)) {
            const ann = rec.ann;
            const p   = ann.properties || {};
            id++;

            if (ann.type === 'nato_marker') {
                const [ax, ay] = ann.geometry.coordinates;
                const ms2 = sidcToMetis(p.sidc);
                metis.push([String(id), ax, ay, ms2.sideid, ms2.dashed, ms2.icon, ms2.mod1, ms2.mod2, ms2.size, p.label || '', 1]);

            } else if (ann.type === 'polyline') {
                const flat = ann.geometry.coordinates.flatMap(([x, y]) => [x, y]);
                polys.push([String(id), flat, colorToArma(p.color)]);

            } else if (ann.type === 'polygon' || ann.type === 'rectangle') {
                const ring = ann.geometry.coordinates[0];
                const flat = ring.flatMap(([x, y]) => [x, y]);
                polys.push([String(id), flat, colorToArma(p.color)]);

            } else if (ann.type === 'circle') {
                const [cx, cy] = ann.geometry.center;
                const r = p.radius || 100;
                const pts = [];
                for (let i = 0; i <= 32; i++) {
                    const a = (i / 32) * 2 * Math.PI;
                    pts.push(cx + r * Math.cos(a), cy + r * Math.sin(a));
                }
                polys.push([String(id), pts, colorToArma(p.color)]);

            } else if (ann.type === 'text') {
                const [ax, ay] = ann.geometry.coordinates;
                // Export text as a small dot marker with the label text set
                icons.push([String(id), ax, ay, 'hd_dot', colorToArma(p.color || '#F5C518'), p.label || '', 0, 0.6]);
            }
        }
    }

    if (metis.length === 0 && polys.length === 0 && icons.length === 0) {
        return '// No exportable annotations found on this map.';
    }

    const dataStr = toArma([icons, polys, metis]);

    return `private _data = ${dataStr};

_data params ['_icons', '_poly', '_metis'];

if (!isNil 'gtd_map_allMarkers') then {
  { deleteMarker _x; } forEach gtd_map_allMarkers;
};
if (!isNil 'gtd_map_allMetisMarkers') then {
  { [_x] call mts_markers_fnc_deleteMarker } forEach gtd_map_allMetisMarkers;
};
gtd_map_allMarkers = [];
gtd_map_allMetisMarkers = [];

{
  _x params ['_id', '_ix', '_iy', '_itype', '_icolor', '_itext', '_idir', ['_iscale', 1]];
  private _m = createMarker [format ['_USER_DEFINED #%1/profiteers_i%2/0', clientOwner, _id], [_ix, _iy], 0];
  _m setMarkerShape 'ICON';
  _m setMarkerDir _idir;
  _m setMarkerColor _icolor;
  _m setMarkerText _itext;
  _m setMarkerType _itype;
  _m setMarkerSize [_iscale, _iscale];
  gtd_map_allMarkers pushBack _m;
} forEach _icons;

{
  _x params ['_id', '_points', '_color'];
  _points params ['_px', '_py'];
  private _m = createMarker [format ['_USER_DEFINED #%1/profiteers_p%2/0', clientOwner, _id], [_px, _py], 0];
  _m setMarkerShape 'polyline';
  _m setMarkerPolyline _points;
  _m setMarkerColor _color;
  gtd_map_allMarkers pushBack _m;
} forEach _poly;

{
  _x params ['_id', '_mx', '_my', '_sideid', '_dashed', '_icon', '_mod1', '_mod2', '_size', '_designation', ['_scale', 1]];
  private _m = [[_mx,_my], 0, true, [[_sideid, _dashed], [_icon, _mod1, _mod2], [_size, false, false], [], _designation], _scale * 1.3] call mts_markers_fnc_createMarker;
  gtd_map_allMetisMarkers pushBack _m;
} forEach _metis;

publicVariable 'gtd_map_allMarkers';
publicVariable 'gtd_map_allMetisMarkers';`;
}

function openExportModal() {
    const sqf = generateSQF();
    document.getElementById('export-sqf-text').value = sqf;
    document.getElementById('export-modal').classList.add('open');
}

/* ═══════════════════════════════════════════════════════════════════════
   DRAWING TOOLS
   ═══════════════════════════════════════════════════════════════════════ */
function setDrawMode(mode) {
    cancelDrawing();
    drawMode = mode;

    document.querySelectorAll('.tb-btn').forEach(b => b.classList.remove('active'));
    const id = { select:'tb-select', nato_marker:'tb-nato', polyline:'tb-line',
                 polygon:'tb-poly', rectangle:'tb-rect', circle:'tb-circle', text:'tb-text' }[mode];
    document.getElementById(id)?.classList.add('active');

    const mapEl = document.getElementById('map');
    mapEl.classList.toggle('draw-mode', mode !== 'select');

    if (mode === 'select') {
        map.dragging.enable();
    } else {
        map.dragging.enable(); // still allow panning while in draw mode
    }
}

function cancelDrawing() {
    drawPoints = [];
    rectStart  = null;
    circCenter = null;
    if (previewLine)  { map.removeLayer(previewLine);  previewLine  = null; }
    if (previewRect)  { map.removeLayer(previewRect);  previewRect  = null; }
    if (previewCirc)  { map.removeLayer(previewCirc);  previewCirc  = null; }
}

function onMapClick(e) {
    if (!worldConfig) {
        if (CAN_EDIT) setWorldStatus('err', 'Set a world name first');
        return;
    }
    if (!activeLayerId) {
        alert('Please select or create a layer first.');
        return;
    }
    const ll = e.latlng;
    const a  = latLngToArma(ll);

    switch (drawMode) {
        case 'select':
            deselectAnnotation();
            break;

        case 'nato_marker':
            pendingNATOLatLng = ll;
            openNATOModal(ll);
            break;

        case 'text': {
            const label = prompt('Enter label text:');
            if (!label) return;
            saveAnnotation('text',
                { type: 'Point', coordinates: [a.x, a.y] },
                { label, color: drawColor });
            break;
        }

        case 'polyline':
            drawPoints.push(ll);
            refreshPreviewLine(ll);
            break;

        case 'polygon':
            drawPoints.push(ll);
            refreshPreviewLine(ll);
            break;

        case 'rectangle':
            if (!rectStart) {
                rectStart = ll;
            } else {
                const rs = latLngToArma(rectStart);
                const re = a;
                const coords = [
                    [rs.x, rs.y], [re.x, rs.y],
                    [re.x, re.y], [rs.x, re.y],
                    [rs.x, rs.y],
                ];
                saveAnnotation('rectangle',
                    { type: 'Polygon', coordinates: [coords] },
                    { color: drawColor, weight: drawWeight, dashArray: drawDash || null });
                cancelDrawing();
            }
            break;

        case 'circle':
            if (!circCenter) {
                circCenter = ll;
            } else {
                const cc = latLngToArma(circCenter);
                // map.distance() returns real metres in EPSG:3857 = Arma metres
                const radius = Math.round(map.distance(circCenter, ll));
                saveAnnotation('circle',
                    { type: 'Point', center: [cc.x, cc.y] },
                    { radius, color: drawColor, weight: drawWeight, dashArray: drawDash || null });
                cancelDrawing();
            }
            break;
    }
}

function finishDrawing() {
    if (drawMode === 'polyline' && drawPoints.length >= 2) {
        const coords = drawPoints.map(p => { const a = latLngToArma(p); return [a.x, a.y]; });
        saveAnnotation('polyline',
            { type: 'LineString', coordinates: coords },
            { color: drawColor, weight: drawWeight, dashArray: drawDash || null });
        cancelDrawing();
    } else if (drawMode === 'polygon' && drawPoints.length >= 3) {
        const ring   = [...drawPoints, drawPoints[0]];
        const coords = ring.map(p => { const a = latLngToArma(p); return [a.x, a.y]; });
        saveAnnotation('polygon',
            { type: 'Polygon', coordinates: [coords] },
            { color: drawColor, weight: drawWeight, dashArray: drawDash || null, fillOpacity: 0.12 });
        cancelDrawing();
    }
}

function onMapDblClick(e) {
    L.DomEvent.stop(e);
    finishDrawing();
}

function onMapContextMenu(e) {
    if (drawMode === 'polyline' || drawMode === 'polygon') {
        L.DomEvent.stop(e);
        finishDrawing();
    }
}

function onMapMouseMove(e) {
    const ll = e.latlng;

    if ((drawMode === 'polyline' || drawMode === 'polygon') && drawPoints.length > 0) {
        refreshPreviewLine(ll);
    }

    if (drawMode === 'rectangle' && rectStart) {
        if (previewRect) map.removeLayer(previewRect);
        previewRect = L.rectangle([rectStart, ll], {
            color: drawColor, weight: drawWeight, dashArray: '4 4', fillOpacity: 0.06
        }).addTo(map);
    }

    if (drawMode === 'circle' && circCenter) {
        if (previewCirc) map.removeLayer(previewCirc);
        const r = map.distance(circCenter, ll);
        previewCirc = L.circle(circCenter, {
            radius: r, color: drawColor, weight: drawWeight, dashArray: '4 4', fillOpacity: 0.06
        }).addTo(map);
    }
}

function refreshPreviewLine(mouseLl) {
    if (previewLine) map.removeLayer(previewLine);
    const pts  = [...drawPoints, mouseLl];
    const opts = { color: drawColor, weight: drawWeight, dashArray: '4 4', opacity: 0.7 };
    previewLine = (drawMode === 'polygon' && pts.length > 2)
        ? L.polygon(pts, { ...opts, fillOpacity: 0.05 }).addTo(map)
        : L.polyline(pts, opts).addTo(map);
}

/* ═══════════════════════════════════════════════════════════════════════
   SAVE ANNOTATION TO API
   ═══════════════════════════════════════════════════════════════════════ */
async function saveAnnotation(type, geometry, properties) {
    if (!activeLayerId) return;
    setSaveStatus('saving', 'Saving…');
    const data = await apiFetch(`/operations/${OP_ID}/map/annotations`, 'POST', {
        layer_id: activeLayerId, type, geometry, properties
    });
    if (data.success) {
        renderAnnotation({ id: data.id, layer_id: activeLayerId, type, geometry, properties });
        renderLayerPanel();
        setSaveStatus('saved', 'Saved');
    } else {
        setSaveStatus('error', 'Save error');
    }
}

/* ═══════════════════════════════════════════════════════════════════════
   NATO SIDC BUILDER
   ═══════════════════════════════════════════════════════════════════════ */
const natoSt = { affil:'3', symSet:'10', echelon:'00', entity:'000000', hq:false, tf:false, fd:false };
let natoSelectedSIDC = null;

function natoComputeSIDC() {
    const hqtf = (natoSt.hq ? 1 : 0) | (natoSt.tf ? 2 : 0) | (natoSt.fd ? 4 : 0);
    return '10' + '0' + natoSt.affil + natoSt.symSet + '0' + hqtf + natoSt.echelon + natoSt.entity + '0000';
}

function natoAffilFrameSVG(shape, color) {
    const s = 'stroke="black" stroke-width="3"';
    const f = `fill="${color}" fill-opacity="0.92"`;
    const d = 'stroke-dasharray="6,4"';
    switch(shape) {
        case 'fri':  return `<svg width="38" height="27" viewBox="0 0 28 20"><rect x="1" y="1" width="26" height="18" rx="1" ${s} ${f}/></svg>`;
        case 'asf':  return `<svg width="38" height="27" viewBox="0 0 28 20"><rect x="1" y="1" width="26" height="18" rx="1" stroke="none" fill="${color}" fill-opacity="0.35"/><rect x="1" y="1" width="26" height="18" rx="1" stroke-width="4" ${d} stroke="${color}" fill="none"/><rect x="1" y="1" width="26" height="18" rx="1" ${s} fill="none"/></svg>`;
        case 'hos':  return `<svg width="34" height="34" viewBox="0 0 26 26"><path d="M13,1 L25,13 13,25 1,13 Z" ${s} ${f}/></svg>`;
        case 'sus':  return `<svg width="34" height="34" viewBox="0 0 26 26"><path d="M13,1 L25,13 13,25 1,13 Z" stroke="none" fill="${color}" fill-opacity="0.35"/><path d="M13,1 L25,13 13,25 1,13 Z" stroke-width="4" ${d} stroke="${color}" fill="none"/><path d="M13,1 L25,13 13,25 1,13 Z" ${s} fill="none"/></svg>`;
        case 'neu':  return `<svg width="32" height="32" viewBox="0 0 24 24"><rect x="1" y="1" width="22" height="22" ${s} ${f}/></svg>`;
        case 'unk':  return `<svg width="32" height="32" viewBox="0 0 24 24"><circle cx="12" cy="12" r="11" ${s} ${f}/></svg>`;
        case 'pend': return `<svg width="32" height="32" viewBox="0 0 24 24"><circle cx="12" cy="12" r="11" stroke="none" fill="${color}" fill-opacity="0.35"/><circle cx="12" cy="12" r="11" stroke-width="4" ${d} stroke="${color}" fill="none"/><circle cx="12" cy="12" r="11" ${s} fill="none"/></svg>`;
    }
    return '';
}

function natoUpdatePreview() {
    const sidc = natoComputeSIDC();
    document.getElementById('nato-sidc-input').value = sidc;
    const box = document.getElementById('nato-preview-box');
    if (!box) return;
    if (typeof ms === 'undefined') { box.textContent = '?'; return; }
    try { box.innerHTML = new ms.Symbol(sidc, { size: 55, strokeWidth: 4 }).asSVG(); }
    catch(e) { box.textContent = '?'; }
}

function natoPopulateEntities(filter) {
    const sel = document.getElementById('nato-entity-select');
    if (!sel) return;
    const entries = SIDC_ENTITIES[natoSt.symSet] || [];
    const q = (filter || '').toLowerCase();
    const filtered = q ? entries.filter(e => e.l.toLowerCase().includes(q) || e.g.toLowerCase().includes(q)) : entries;
    const groups = {};
    for (const e of filtered) (groups[e.g] = groups[e.g] || []).push(e);
    sel.innerHTML = '';
    for (const [grp, items] of Object.entries(groups)) {
        const og = document.createElement('optgroup');
        og.label = grp;
        for (const item of items) {
            const opt = document.createElement('option');
            opt.value = item.v;
            opt.textContent = item.l;
            if (item.v === natoSt.entity) opt.selected = true;
            og.appendChild(opt);
        }
        sel.appendChild(og);
    }
    if (!filtered.find(e => e.v === natoSt.entity) && filtered.length > 0) {
        natoSt.entity = filtered[0].v;
        if (sel.options[0]) sel.options[0].selected = true;
    }
}

function natoInitModal() {
    // Affiliation buttons — build once
    const afRow = document.getElementById('nato-affil-row');
    if (afRow && !afRow.dataset.built) {
        afRow.dataset.built = '1';
        for (const a of SIDC_AFFILS) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'nato-affil-btn';
            btn.dataset.affil = a.v;
            btn.innerHTML = natoAffilFrameSVG(a.shape, a.color) + '<span>' + a.l + '</span>';
            btn.onclick = () => {
                natoSt.affil = a.v;
                document.querySelectorAll('.nato-affil-btn').forEach(b => b.classList.toggle('active', b.dataset.affil === a.v));
                natoUpdatePreview();
            };
            afRow.appendChild(btn);
        }
    }
    // Sync affil active state
    document.querySelectorAll('.nato-affil-btn').forEach(b => b.classList.toggle('active', b.dataset.affil === natoSt.affil));

    // Symbol set
    const symSel = document.getElementById('nato-symset');
    if (symSel) {
        symSel.value = natoSt.symSet;
        symSel.onchange = () => { natoSt.symSet = symSel.value; natoSt.entity = '000000'; natoPopulateEntities(); natoUpdatePreview(); };
    }
    // Echelon
    const echelSel = document.getElementById('nato-echelon');
    if (echelSel) { echelSel.value = natoSt.echelon; echelSel.onchange = () => { natoSt.echelon = echelSel.value; natoUpdatePreview(); }; }
    // Modifiers
    const chkHQ = document.getElementById('nato-chk-hq');
    const chkTF = document.getElementById('nato-chk-tf');
    const chkFD = document.getElementById('nato-chk-fd');
    if (chkHQ) { chkHQ.checked = natoSt.hq; chkHQ.onchange = () => { natoSt.hq = chkHQ.checked; natoUpdatePreview(); }; }
    if (chkTF) { chkTF.checked = natoSt.tf; chkTF.onchange = () => { natoSt.tf = chkTF.checked; natoUpdatePreview(); }; }
    if (chkFD) { chkFD.checked = natoSt.fd; chkFD.onchange = () => { natoSt.fd = chkFD.checked; natoUpdatePreview(); }; }
    // Entity select
    natoPopulateEntities();
    const entSel = document.getElementById('nato-entity-select');
    if (entSel) entSel.onchange = () => { natoSt.entity = entSel.value; natoUpdatePreview(); };
    // Entity filter
    const entFilter = document.getElementById('nato-entity-filter');
    if (entFilter) entFilter.oninput = () => natoPopulateEntities(entFilter.value.trim());
    // SIDC direct edit
    const sidcIn = document.getElementById('nato-sidc-input');
    if (sidcIn) sidcIn.oninput = () => {
        const raw = sidcIn.value.replace(/\D/g, '').slice(0, 20).padEnd(20, '0');
        if (raw.length >= 20) {
            natoSt.affil = raw[3]; natoSt.symSet = raw.slice(4, 6);
            const hqtf = parseInt(raw[7]) || 0;
            natoSt.hq = !!(hqtf & 1); natoSt.tf = !!(hqtf & 2); natoSt.fd = !!(hqtf & 4);
            natoSt.echelon = raw.slice(8, 10); natoSt.entity = raw.slice(10, 16);
            document.querySelectorAll('.nato-affil-btn').forEach(b => b.classList.toggle('active', b.dataset.affil === natoSt.affil));
            const ss = document.getElementById('nato-symset');  if (ss) ss.value = natoSt.symSet;
            const es = document.getElementById('nato-echelon'); if (es) es.value = natoSt.echelon;
            if (chkHQ) chkHQ.checked = natoSt.hq;
            if (chkTF) chkTF.checked = natoSt.tf;
            if (chkFD) chkFD.checked = natoSt.fd;
            natoPopulateEntities();
            const box = document.getElementById('nato-preview-box');
            if (box && typeof ms !== 'undefined') {
                try { box.innerHTML = new ms.Symbol(raw, { size: 55, strokeWidth: 4 }).asSVG(); } catch(e) {}
            }
        }
    };
}

function openNATOModal(latlng) {
    pendingNATOLatLng = latlng;
    natoSelectedSIDC  = null;
    document.getElementById('nato-label').value = '';
    natoSt.affil = '3'; natoSt.symSet = '10'; natoSt.echelon = '00';
    natoSt.entity = '000000'; natoSt.hq = false; natoSt.tf = false; natoSt.fd = false;
    natoInitModal();
    natoUpdatePreview();
    const ef = document.getElementById('nato-entity-filter'); if (ef) ef.value = '';
    document.getElementById('nato-modal').classList.add('open');
}

function closeNATOModal() {
    document.getElementById('nato-modal').classList.remove('open');
    pendingNATOLatLng = null;
    natoSelectedSIDC  = null;
}

async function confirmNATOPlacement() {
    if (!pendingNATOLatLng) return;
    const sidc  = natoComputeSIDC();
    const label = document.getElementById('nato-label').value.trim();
    const a     = latLngToArma(pendingNATOLatLng);
    closeNATOModal();
    await saveAnnotation('nato_marker',
        { type: 'Point', coordinates: [a.x, a.y] },
        { sidc, label, color: drawColor });
}

/* ═══════════════════════════════════════════════════════════════════════
   LAYER MODAL
   ═══════════════════════════════════════════════════════════════════════ */
function openLayerModal(mode, layerId = null) {
    lmodalMode    = mode;
    lmodalLayerId = layerId;
    const title = document.getElementById('lmodal-title');
    const nameInput  = document.getElementById('lmodal-name');
    const colorInput = document.getElementById('lmodal-color');

    if (mode === 'edit' && layerId) {
        title.textContent       = 'Edit Layer';
        nameInput.value         = layers[layerId].meta.name;
        colorInput.value        = layers[layerId].meta.color;
    } else {
        title.textContent = 'New Layer';
        nameInput.value   = '';
        colorInput.value  = '#3498DB';
    }
    document.getElementById('layer-modal').classList.add('open');
    nameInput.focus();
}

function closeLayerModal() {
    document.getElementById('layer-modal').classList.remove('open');
}

async function saveLayerModal() {
    const name  = document.getElementById('lmodal-name').value.trim();
    const color = document.getElementById('lmodal-color').value;
    if (!name) return;
    closeLayerModal();
    if (lmodalMode === 'add') {
        await apiCreateLayer(name, color);
    } else if (lmodalMode === 'edit') {
        await apiUpdateLayer(lmodalLayerId, name, color);
    }
}

/* ═══════════════════════════════════════════════════════════════════════
   KEYBOARD SHORTCUTS
   ═══════════════════════════════════════════════════════════════════════ */
document.addEventListener('keydown', e => {
    if (!CAN_EDIT) return;
    if (['INPUT','TEXTAREA'].includes(e.target.tagName)) return;

    switch (e.key) {
        case 'Escape':     setDrawMode('select'); closeNATOModal(); break;
        case 'm': case 'M': setDrawMode('nato_marker'); break;
        case 'l': case 'L': setDrawMode('polyline'); break;
        case 'p': case 'P': setDrawMode('polygon'); break;
        case 'r': case 'R': setDrawMode('rectangle'); break;
        case 'c': case 'C': setDrawMode('circle'); break;
        case 't': case 'T': setDrawMode('text'); break;
        case 'Backspace':
            if (drawPoints.length > 0) {
                drawPoints.pop();
                if (previewLine) { map.removeLayer(previewLine); previewLine = null; }
            }
            break;
    }
});

/* ═══════════════════════════════════════════════════════════════════════
   WIRE UP UI EVENTS
   ═══════════════════════════════════════════════════════════════════════ */
if (CAN_EDIT) {
    document.getElementById('btn-add-layer')?.addEventListener('click', () => openLayerModal('add'));

    document.getElementById('tb-select')?.addEventListener('click', () => setDrawMode('select'));
    document.getElementById('tb-nato')?.addEventListener('click',   () => setDrawMode('nato_marker'));
    document.getElementById('tb-line')?.addEventListener('click',   () => setDrawMode('polyline'));
    document.getElementById('tb-poly')?.addEventListener('click',   () => setDrawMode('polygon'));
    document.getElementById('tb-rect')?.addEventListener('click',   () => setDrawMode('rectangle'));
    document.getElementById('tb-circle')?.addEventListener('click', () => setDrawMode('circle'));
    document.getElementById('tb-text')?.addEventListener('click',   () => setDrawMode('text'));
    document.getElementById('tb-undo')?.addEventListener('click',   () => {
        if (drawPoints.length > 0) {
            drawPoints.pop();
            if (previewLine) { map.removeLayer(previewLine); previewLine = null; }
        } else if (rectStart) {
            rectStart = null;
            if (previewRect) { map.removeLayer(previewRect); previewRect = null; }
        } else if (circCenter) {
            circCenter = null;
            if (previewCirc) { map.removeLayer(previewCirc); previewCirc = null; }
        }
    });

    document.getElementById('draw-color')?.addEventListener('input',  e => { drawColor  = e.target.value; });
    document.getElementById('draw-weight')?.addEventListener('input', e => { drawWeight = parseInt(e.target.value); });

    // NATO modal
    document.getElementById('nato-modal-close')?.addEventListener('click', closeNATOModal);
    document.getElementById('nato-cancel')?.addEventListener('click',      closeNATOModal);
    document.getElementById('nato-confirm')?.addEventListener('click',     confirmNATOPlacement);

    // Properties panel
    document.getElementById('props-close')?.addEventListener('click',     deselectAnnotation);
    document.getElementById('btn-props-save')?.addEventListener('click',  saveAnnotationProps);
    document.getElementById('btn-props-delete')?.addEventListener('click', deleteSelectedAnnotation);

    // Layer modal
    document.getElementById('lmodal-cancel')?.addEventListener('click', closeLayerModal);
    document.getElementById('lmodal-save')?.addEventListener('click',   saveLayerModal);
    document.getElementById('lmodal-name')?.addEventListener('keydown', e => { if (e.key === 'Enter') saveLayerModal(); });

    // Rotation slider live preview
    document.getElementById('pr-rotation')?.addEventListener('input', e => {
        const deg = parseInt(e.target.value) || 0;
        document.getElementById('pr-rotation-val').textContent = deg + '°';
        if (selectedId && selectedLayerId) {
            const rec = layers[selectedLayerId]?.featureMap[selectedId];
            if (rec && rec.ann.type === 'nato_marker') {
                const p = rec.ann.properties || {};
                rec.feature.setIcon(makeNATOIcon(p.sidc || '130110000000000000000000000000', p.label, deg));
            }
        }
    });

    // Controls hint panel toggle
    document.getElementById('hint-header')?.addEventListener('click', () => {
        const panel = document.getElementById('hint-panel');
        panel.classList.toggle('collapsed');
    });

    // Close modals on backdrop click
    document.getElementById('nato-modal')?.addEventListener('click', e => {
        if (e.target === document.getElementById('nato-modal')) closeNATOModal();
    });
    document.getElementById('layer-modal')?.addEventListener('click', e => {
        if (e.target === document.getElementById('layer-modal')) closeLayerModal();
    });
    document.getElementById('export-modal')?.addEventListener('click', e => {
        if (e.target === document.getElementById('export-modal')) document.getElementById('export-modal').classList.remove('open');
    });
}

// Export button (available to all users)
document.getElementById('btn-export-sqf')?.addEventListener('click', openExportModal);
document.getElementById('export-close')?.addEventListener('click', () => document.getElementById('export-modal').classList.remove('open'));
document.getElementById('export-copy')?.addEventListener('click', async () => {
    const text = document.getElementById('export-sqf-text').value;
    try {
        await navigator.clipboard.writeText(text);
        const btn = document.getElementById('export-copy');
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = orig, 1800);
    } catch { document.getElementById('export-sqf-text').select(); document.execCommand('copy'); }
});

/* ═══════════════════════════════════════════════════════════════════════
   SESSION KEEP-ALIVE — ping every 10 min so the session never expires
   while the user has the map open
   ═══════════════════════════════════════════════════════════════════════ */
setInterval(() => fetch('/ping', { credentials: 'same-origin' }).catch(() => {}), 10 * 60 * 1000);

/* ═══════════════════════════════════════════════════════════════════════
   BOOT
   ═══════════════════════════════════════════════════════════════════════ */
initMap();
loadData();
</script>
