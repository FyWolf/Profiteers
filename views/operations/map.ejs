<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Roboto+Mono:wght@400;700&display=swap" rel="stylesheet">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/maplibre-gl@5/dist/maplibre-gl.css">
<script src="https://cdn.jsdelivr.net/npm/maplibre-gl@5/dist/maplibre-gl.js"></script>
<script src="https://cdn.jsdelivr.net/npm/pmtiles@4/dist/pmtiles.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@maplibre/maplibre-gl-leaflet@0.1.3/leaflet-maplibre-gl.js"></script>
<script src="https://cdn.jsdelivr.net/npm/milsymbol@3.0.4/dist/milsymbol.js"></script>

<style>
/* ─── Design tokens (matches site palette) ───────────────────────── */
:root {
    --camo-dark:   #1a2a1a;
    --camo-mid:    #2e3b2e;
    --camo-deep:   #111a11;
    --olive:       #6b8e23;
    --olive-light: #8ab23a;
    --khaki:       #b2b27d;
    --sand:        #f4f3e8;
    --accent:      #fcb00d;
    --accent-dim:  rgba(252,176,13,0.15);
    --border:      #3a4a2a;
    --border-mid:  rgba(107,142,35,0.35);
    --shadow:      rgba(0,0,0,0.6);
    --muted:       #7a8a6a;
    --panel-bg:    rgba(20,32,20,0.97);
    --input-bg:    rgba(15,25,15,0.9);
}

/* ─── Reset & layout ─────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
    height: 100%;
    background: linear-gradient(135deg, var(--camo-dark) 0%, var(--camo-mid) 100%);
    color: var(--sand);
    font-family: 'Roboto Mono', 'Courier New', monospace;
    font-size: 13px;
    overflow: hidden;
}

/* ─── Top bar ────────────────────────────────────────────────────── */
#topbar {
    height: 50px;
    background: linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(20,35,20,0.95) 100%);
    border-bottom: 3px solid var(--accent);
    box-shadow: 0 4px 16px var(--shadow);
    display: flex; align-items: center; gap: 10px; padding: 0 14px;
    flex-shrink: 0; z-index: 1000; position: relative;
}
#topbar .back-btn {
    display: flex; align-items: center; gap: 5px; color: var(--khaki);
    text-decoration: none; font-size: 0.82em; padding: 5px 10px;
    border: 1px solid var(--border); border-radius: 5px; transition: all 0.2s;
    font-weight: 600;
}
#topbar .back-btn:hover {
    color: var(--accent); border-color: var(--accent);
    background: var(--accent-dim);
}
#topbar .op-title {
    color: var(--accent);
    font-family: 'Orbitron', sans-serif;
    font-weight: 700; font-size: 0.88em;
    letter-spacing: 0.08em;
    text-shadow: 0 0 10px rgba(252,176,13,0.4);
    flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
#topbar .mode-badge {
    font-size: 0.7em; padding: 3px 9px; border-radius: 4px;
    font-weight: 700; letter-spacing: 0.1em; font-family: 'Orbitron', sans-serif;
    background: rgba(107,142,35,0.2); color: var(--khaki); border: 1px solid var(--border);
}
#topbar .mode-badge.edit {
    background: rgba(138,178,58,0.2); color: var(--olive-light);
    border-color: var(--olive-light);
}
#save-status {
    font-size: 0.7em; color: var(--muted); white-space: nowrap;
    min-width: 60px; text-align: right;
}
#save-status.saving { color: var(--accent); }
#save-status.saved  { color: var(--olive-light); }
#save-status.error  { color: #e74c3c; }

/* ─── Page body ──────────────────────────────────────────────────── */
#page { display: flex; height: calc(100vh - 50px); }

/* ─── Sidebar ────────────────────────────────────────────────────── */
#sidebar {
    width: 255px; flex-shrink: 0;
    background: linear-gradient(180deg, rgba(20,32,20,0.98) 0%, rgba(15,26,15,0.98) 100%);
    border-right: 2px solid var(--border);
    display: flex; flex-direction: column; overflow: hidden;
    box-shadow: 2px 0 12px rgba(0,0,0,0.4);
}
#sidebar-header {
    padding: 11px 12px 9px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(0,0,0,0.2);
}
#sidebar-header h2 {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.68em; letter-spacing: 0.2em; color: var(--olive-light);
    text-transform: uppercase;
}
#btn-add-layer {
    font-size: 0.72em; background: var(--border); color: var(--khaki);
    border: 1px solid var(--olive); border-radius: 4px;
    padding: 3px 9px; cursor: pointer; transition: all 0.2s;
    font-family: inherit; font-weight: 700;
}
#btn-add-layer:hover {
    background: var(--olive); color: white;
    box-shadow: 0 2px 8px rgba(107,142,35,0.4);
}

#layer-list { flex: 1; overflow-y: auto; padding: 5px 0; }
#layer-list::-webkit-scrollbar { width: 4px; }
#layer-list::-webkit-scrollbar-track { background: transparent; }
#layer-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

.layer-item {
    display: flex; align-items: center; gap: 7px; padding: 7px 10px;
    cursor: pointer; border-left: 3px solid transparent; transition: all 0.15s;
    user-select: none;
}
.layer-item:hover  { background: rgba(107,142,35,0.12); }
.layer-item.active {
    background: rgba(107,142,35,0.18);
    border-left-color: var(--layer-color, var(--olive));
}
.layer-item .swatch { width: 11px; height: 11px; border-radius: 2px; flex-shrink: 0; box-shadow: 0 0 3px rgba(0,0,0,0.5); }
.layer-item .lname  { flex: 1; color: var(--sand); font-size: 0.84em; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.layer-item.hidden .lname { opacity: 0.38; }
.layer-item .layer-count { font-size: 0.68em; color: var(--muted); white-space: nowrap; }
.layer-actions { display: none; gap: 3px; }
.layer-item:hover .layer-actions { display: flex; }
.layer-btn {
    background: none; border: none; color: var(--muted); cursor: pointer;
    font-size: 0.82em; padding: 1px 4px; border-radius: 3px; transition: all 0.1s;
}
.layer-btn:hover { color: var(--sand); background: rgba(255,255,255,0.08); }
.layer-btn.delete:hover { color: #e74c3c; background: rgba(231,76,60,0.1); }
.layer-btn.pub.draft    { color: #e6a000; }
.layer-btn.pub.draft:hover { color: #ffd04a; background: rgba(230,160,0,0.1); }
.layer-draft-badge {
    font-size: 0.6em; color: #e6a000; background: rgba(230,160,0,0.15);
    border: 1px solid rgba(230,160,0,0.3); border-radius: 3px;
    padding: 1px 5px; white-space: nowrap; letter-spacing: 0.04em; flex-shrink: 0;
}

/* ─── Map area ───────────────────────────────────────────────────── */
#map-wrap { flex: 1; position: relative; }
#map { width: 100%; height: 100%; }

/* ─── Drawing toolbar ────────────────────────────────────────────── */
#toolbar {
    position: absolute; top: 10px; left: 10px; z-index: 900;
    background: linear-gradient(135deg, rgba(20,32,20,0.95) 0%, rgba(15,26,15,0.95) 100%);
    border: 1px solid var(--border); border-radius: 7px;
    display: flex; align-items: center;
    gap: 2px; padding: 5px 7px; backdrop-filter: blur(6px);
    box-shadow: 0 4px 16px var(--shadow);
}
.tb-btn {
    background: none; border: 1px solid transparent; border-radius: 4px;
    color: var(--khaki); cursor: pointer; font-size: 0.77em; padding: 4px 10px;
    transition: all 0.15s; white-space: nowrap; display: flex; align-items: center;
    gap: 4px; font-family: inherit;
}
.tb-btn:hover  { background: rgba(107,142,35,0.2); color: var(--sand); border-color: var(--border); }
.tb-btn.active { background: var(--accent-dim); color: var(--accent); border-color: var(--accent); }
.tb-sep { width: 1px; height: 20px; background: var(--border); margin: 0 3px; }

#color-picker-wrap { display: flex; align-items: center; gap: 5px; }
#color-picker-wrap label { color: var(--muted); font-size: 0.75em; }
#draw-color { width: 22px; height: 22px; border: none; border-radius: 3px; cursor: pointer; padding: 0; background: none; }
#draw-weight { width: 60px; accent-color: var(--accent); }

/* ─── Cursor states ──────────────────────────────────────────────── */
#map.draw-mode         { cursor: crosshair !important; }
#map.draw-mode.placing { cursor: cell !important; }

/* ─── Coordinates display ────────────────────────────────────────── */
#coords {
    position: absolute; bottom: 8px; left: 10px; z-index: 900;
    background: rgba(20,32,20,0.88); border: 1px solid var(--border);
    border-radius: 4px; padding: 3px 8px; font-size: 0.7em; color: var(--olive-light);
    pointer-events: none; letter-spacing: 0.05em;
}

/* ─── Minimap overview ───────────────────────────────────────────── */
#minimap-wrap {
    position: absolute; bottom: 40px; right: 12px; z-index: 800;
    width: 185px; background: rgba(12,22,12,0.93);
    border: 1px solid var(--olive); border-radius: 7px;
    box-shadow: 0 4px 18px rgba(0,0,0,0.6);
    display: none; overflow: hidden;
    transition: opacity 0.2s;
}
#minimap-wrap.collapsed #minimap-img-wrap { display: none; }
#minimap-header {
    padding: 4px 8px 4px 10px; display: flex; align-items: center;
    background: rgba(0,0,0,0.35); border-bottom: 1px solid var(--border);
    gap: 6px;
}
#minimap-label {
    flex: 1; font-size: 0.66em; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.09em;
}
#minimap-toggle {
    background: none; border: none; color: var(--muted); cursor: pointer;
    font-size: 1em; padding: 0 2px; line-height: 1; transition: color 0.1s;
}
#minimap-toggle:hover { color: var(--sand); }
#minimap-img-wrap {
    position: relative; width: 100%; padding-bottom: 100%; cursor: crosshair;
}
#minimap-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; display: block;
    image-rendering: auto;
}
#minimap-viewport {
    position: absolute; pointer-events: none;
    border: 2px solid rgba(252,176,13,0.95);
    background: rgba(252,176,13,0.08);
    box-shadow: 0 0 0 1px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(0,0,0,0.3);
    min-width: 3px; min-height: 3px;
}

/* ─── Controls hint panel ───────────────────────────────────────── */
#hint-panel {
    position: absolute; bottom: 8px; right: 12px; z-index: 810;
    width: 250px; background: rgba(12,22,12,0.93);
    border: 1px solid var(--olive); border-radius: 7px;
    font-size: 0.88em; overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.4);
}
#hint-panel.collapsed #hint-body { display: none; }
#hint-panel.collapsed #hint-toggle { transform: rotate(180deg); }
#hint-header {
    padding: 6px 10px 6px 12px; display: flex; align-items: center; gap: 6px;
    background: rgba(0,0,0,0.35); border-bottom: 1px solid var(--border); cursor: pointer;
    user-select: none;
}
#hint-header:hover #hint-label { color: var(--sand); }
#hint-label { flex: 1; font-size: 0.78em; color: var(--muted); text-transform: uppercase; letter-spacing: 0.09em; }
#hint-toggle { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 0.9em; padding: 0 2px; line-height: 1; transition: transform 0.2s, color 0.1s; }
#hint-toggle:hover { color: var(--sand); }
#hint-body { padding: 10px 12px; display: flex; flex-direction: column; gap: 3px; }
.hint-sep { font-size: 0.78em; color: var(--accent); text-transform: uppercase; letter-spacing: 0.08em; margin: 7px 0 3px; opacity: 0.85; }
.hint-sep:first-child { margin-top: 0; }
.hint-row { display: flex; align-items: baseline; gap: 8px; line-height: 1.6; }
.hint-key {
    background: rgba(178,178,125,0.1); border: 1px solid var(--border);
    border-radius: 3px; padding: 1px 6px; font-family: monospace; font-size: 0.9em;
    color: var(--sand); white-space: nowrap; flex-shrink: 0;
}
.hint-desc { color: var(--khaki); font-size: 0.95em; }

/* ─── NATO SIDC Builder Modal ────────────────────────────────────── */
#nato-modal {
    display: none; position: fixed; inset: 0; z-index: 2000;
    background: rgba(0,0,0,0.75); backdrop-filter: blur(3px);
    align-items: center; justify-content: center;
}
#nato-modal.open { display: flex; }
#nato-box {
    background: linear-gradient(135deg, rgba(20,32,20,0.99) 0%, rgba(15,26,15,0.99) 100%);
    border: 2px solid var(--olive); border-radius: 10px;
    width: min(860px, 96vw); max-height: 94vh; display: flex; flex-direction: column;
    box-shadow: 0 12px 48px rgba(0,0,0,0.7); overflow: hidden;
}
#nato-box-header {
    padding: 14px 20px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 10px;
    background: rgba(0,0,0,0.2); border-radius: 8px 8px 0 0; flex-shrink: 0;
}
#nato-box-header h3 {
    flex: 1; color: var(--accent);
    font-family: 'Orbitron', sans-serif;
    font-size: 0.95em; letter-spacing: 0.1em;
    text-shadow: 0 0 8px rgba(252,176,13,0.3);
}
#nato-modal-close {
    background: none; border: none; color: var(--muted); font-size: 1.3em;
    cursor: pointer; padding: 3px 8px; border-radius: 4px; transition: all 0.15s;
}
#nato-modal-close:hover { color: var(--sand); background: rgba(255,255,255,0.08); }
#nato-body {
    padding: 16px 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 16px; flex: 1;
}
.nato-sec-label {
    font-size: 0.78em; color: var(--muted); text-transform: uppercase;
    letter-spacing: 0.08em; margin-bottom: 6px;
}
/* SIDC row */
.nato-sidc-row { display: flex; gap: 14px; align-items: center; }
#nato-sidc-input {
    flex: 1; background: var(--input-bg); border: 1px solid var(--border);
    border-radius: 5px; color: var(--sand); font-family: 'Courier New', monospace;
    font-size: 1em; padding: 8px 12px; letter-spacing: 0.12em;
}
#nato-sidc-input:focus { outline: none; border-color: var(--accent); }
#nato-preview-box {
    width: 110px; height: 110px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.07); border: 1px solid var(--border); border-radius: 6px;
}
/* Affiliation */
.nato-affil-row { display: flex; gap: 6px; flex-wrap: wrap; }
.nato-affil-btn {
    flex: 1; min-width: 85px; display: flex; flex-direction: column;
    align-items: center; gap: 6px; padding: 9px 6px;
    border: 1px solid var(--border); border-radius: 6px;
    background: rgba(255,255,255,0.03); cursor: pointer;
    font-size: 0.76em; color: var(--muted); font-family: inherit;
    transition: all 0.15s; line-height: 1.3;
}
.nato-affil-btn:hover { border-color: var(--olive); color: var(--sand); background: rgba(107,142,35,0.08); }
.nato-affil-btn.active { border-color: var(--accent); background: rgba(252,176,13,0.12); color: var(--accent); }
/* Row for symset + echelon + modifiers */
.nato-ctrl-row { display: flex; gap: 14px; flex-wrap: wrap; align-items: flex-end; }
.nato-field { display: flex; flex-direction: column; gap: 5px; }
.nato-field > label { font-size: 0.8em; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
.nato-sel {
    background: var(--input-bg); border: 1px solid var(--border); border-radius: 5px;
    color: var(--sand); font-size: 0.92em; padding: 7px 10px; font-family: inherit;
}
.nato-sel:focus { outline: none; border-color: var(--accent); }
.nato-checks { display: flex; gap: 14px; align-items: center; padding-bottom: 7px; }
.nato-checks label {
    display: flex; align-items: center; gap: 6px; font-size: 0.88em;
    color: var(--muted); cursor: pointer; user-select: none;
}
.nato-checks input[type=checkbox] { accent-color: var(--accent); cursor: pointer; width: 15px; height: 15px; }
/* Entity search + list */
#nato-entity-filter {
    width: 100%; background: var(--input-bg); border: 1px solid var(--border);
    border-radius: 5px; color: var(--sand); font-size: 0.92em; padding: 7px 11px;
    font-family: inherit; box-sizing: border-box; margin-bottom: 6px;
}
#nato-entity-filter:focus { outline: none; border-color: var(--accent); }
#nato-entity-select {
    width: 100%; height: 160px; background: var(--input-bg); border: 1px solid var(--border);
    border-radius: 5px; color: var(--sand); font-size: 0.92em; padding: 3px; font-family: inherit;
}
#nato-entity-select:focus { outline: none; border-color: var(--accent); }
#nato-entity-select optgroup { color: var(--muted); font-style: normal; font-size: 0.85em; }
#nato-entity-select option { padding: 3px 6px; }
/* Label */
#nato-label {
    width: 100%; background: var(--input-bg); border: 1px solid var(--border);
    border-radius: 5px; color: var(--sand); font-size: 0.92em; padding: 7px 11px;
    font-family: inherit; box-sizing: border-box;
}
#nato-label:focus { outline: none; border-color: var(--accent); }
/* Footer */
#nato-footer {
    padding: 12px 20px; border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; gap: 10px;
    background: rgba(0,0,0,0.15); flex-shrink: 0;
}
.nato-footer-btn {
    font-size: 0.9em; padding: 8px 22px; border-radius: 6px; cursor: pointer;
    border: 1px solid var(--border); background: rgba(15,26,15,0.8);
    color: var(--khaki); font-family: inherit; transition: all 0.15s; font-weight: 600;
}
.nato-footer-btn:hover { border-color: var(--olive); color: var(--sand); background: rgba(107,142,35,0.15); }
.nato-footer-btn.primary {
    background: linear-gradient(135deg, var(--accent) 0%, #e6a000 100%);
    color: #1a2a1a; border-color: var(--accent); font-weight: 700;
}
.nato-footer-btn.primary:hover { box-shadow: 0 4px 12px rgba(252,176,13,0.4); }

/* ─── Properties popover ─────────────────────────────────────────── */
#props-panel {
    position: absolute; right: 10px; top: 10px; z-index: 900;
    background: linear-gradient(135deg, rgba(20,32,20,0.97) 0%, rgba(15,26,15,0.97) 100%);
    border: 1px solid var(--olive); border-radius: 8px; width: 215px; display: none;
    backdrop-filter: blur(6px); box-shadow: 0 4px 20px var(--shadow);
}
#props-panel.open { display: block; }
#props-header {
    padding: 8px 11px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 6px;
    background: rgba(0,0,0,0.2); border-radius: 8px 8px 0 0;
}
#props-header span {
    flex: 1; font-size: 0.72em; color: var(--olive-light);
    letter-spacing: 0.1em; text-transform: uppercase;
    font-family: 'Orbitron', sans-serif;
}
#props-close { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 1em; border-radius: 3px; transition: all 0.1s; }
#props-close:hover { color: var(--sand); background: rgba(255,255,255,0.08); }
#props-body { padding: 10px; display: flex; flex-direction: column; gap: 7px; }
.prop-row { display: flex; flex-direction: column; gap: 3px; }
.prop-row label { font-size: 0.68em; color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase; }
.prop-row input[type=text], .prop-row select {
    background: var(--input-bg); border: 1px solid var(--border); border-radius: 4px;
    color: var(--sand); font-size: 0.8em; padding: 5px 7px; font-family: inherit; width: 100%;
}
.prop-row input[type=text]:focus, .prop-row select:focus {
    outline: none; border-color: var(--accent);
    box-shadow: 0 0 6px rgba(252,176,13,0.2);
}
.prop-row select option { background: #1a2a1a; }
.prop-row input[type=color] { width: 100%; height: 28px; border: 1px solid var(--border); border-radius: 4px; cursor: pointer; background: var(--input-bg); }
#props-footer { padding: 8px 10px; border-top: 1px solid var(--border); display: flex; gap: 6px; }
#btn-props-save {
    flex: 1; background: linear-gradient(135deg, var(--accent) 0%, #e6a000 100%);
    color: #1a2a1a; border: none; border-radius: 5px; padding: 6px;
    cursor: pointer; font-weight: 700; font-size: 0.78em; font-family: inherit;
    transition: all 0.15s;
}
#btn-props-save:hover { box-shadow: 0 3px 10px rgba(252,176,13,0.4); }
#btn-props-delete {
    background: rgba(40,10,10,0.8); color: #e74c3c;
    border: 1px solid rgba(231,76,60,0.4); border-radius: 5px;
    padding: 6px 9px; cursor: pointer; font-size: 0.78em; font-family: inherit; transition: all 0.15s;
}
#btn-props-delete:hover { background: #e74c3c; color: #fff; border-color: #e74c3c; }

/* ─── Drawing preview ────────────────────────────────────────────── */
.preview-line { stroke-dasharray: 6 4; opacity: 0.6; }

/* ─── Layer-edit modal ───────────────────────────────────────────── */
#layer-modal {
    display: none; position: fixed; inset: 0; z-index: 3000;
    background: rgba(0,0,0,0.72); backdrop-filter: blur(3px);
    align-items: center; justify-content: center;
}
#layer-modal.open { display: flex; }
#layer-box {
    background: linear-gradient(135deg, rgba(20,32,20,0.99) 0%, rgba(15,26,15,0.99) 100%);
    border: 2px solid var(--olive); border-radius: 10px;
    padding: 22px; width: 310px; display: flex; flex-direction: column; gap: 14px;
    box-shadow: 0 12px 48px var(--shadow);
}
#layer-box h3 {
    color: var(--accent);
    font-family: 'Orbitron', sans-serif;
    font-size: 0.88em; letter-spacing: 0.08em;
    text-shadow: 0 0 8px rgba(252,176,13,0.3);
}
.lmodal-row { display: flex; flex-direction: column; gap: 5px; }
.lmodal-row label { font-size: 0.7em; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
.lmodal-row input[type=text] {
    background: var(--input-bg); border: 1px solid var(--border); border-radius: 5px;
    color: var(--sand); font-size: 0.85em; padding: 7px 9px; font-family: inherit;
}
.lmodal-row input[type=text]:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 6px rgba(252,176,13,0.2); }
.lmodal-row input[type=color] { width: 100%; height: 34px; border: 1px solid var(--border); border-radius: 5px; background: var(--input-bg); cursor: pointer; }
.lmodal-btns { display: flex; gap: 8px; justify-content: flex-end; margin-top: 4px; }
.lmodal-btn {
    font-size: 0.8em; padding: 7px 16px; border-radius: 5px; cursor: pointer;
    border: 1px solid var(--border); background: rgba(15,26,15,0.8);
    color: var(--khaki); font-family: inherit; font-weight: 600; transition: all 0.15s;
}
.lmodal-btn:hover { border-color: var(--olive); color: var(--sand); background: rgba(107,142,35,0.15); }
.lmodal-btn.primary {
    background: linear-gradient(135deg, var(--accent) 0%, #e6a000 100%);
    color: #1a2a1a; border-color: var(--accent); font-weight: 700;
}
.lmodal-btn.primary:hover { box-shadow: 0 4px 12px rgba(252,176,13,0.4); }

/* ─── Map placeholder ────────────────────────────────────────────── */
#map-placeholder {
    position: absolute; inset: 0; z-index: 400;
    background: rgba(10,18,10,0.92); display: flex; align-items: center; justify-content: center;
    pointer-events: none;
}
#map-placeholder > div { text-align: center; }
#map-placeholder .ph-title {
    color: var(--border); font-size: 0.95em; letter-spacing: 0.1em; margin-bottom: 6px;
    font-family: 'Orbitron', sans-serif;
}
#map-placeholder .ph-sub { color: rgba(58,74,42,0.8); font-size: 0.75em; }

/* ─── World config panel ─────────────────────────────────────────── */
#world-panel {
    border-top: 1px solid var(--border); flex-shrink: 0; padding: 9px 12px 11px;
    background: rgba(0,0,0,0.15);
}
#world-panel h2 {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.62em; letter-spacing: 0.2em; color: var(--olive-light);
    text-transform: uppercase; margin-bottom: 5px;
}
#world-status { font-size: 0.72em; color: var(--muted); min-height: 14px; margin-bottom: 8px; }
#world-status.ok  { color: var(--olive-light); }
#world-status.err { color: #e74c3c; }

/* ─── Map style switcher ──────────────────────────────────────────── */
#style-switcher { display: none; margin-top: 6px; }
#style-switcher h2 {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.62em; letter-spacing: 0.2em; color: var(--olive-light);
    text-transform: uppercase; margin-bottom: 5px;
}
#style-btns { display: flex; flex-direction: column; gap: 3px; }
.style-btn {
    font-size: 0.72em; padding: 5px 9px; border-radius: 4px; cursor: pointer;
    background: rgba(15,26,15,0.6); border: 1px solid var(--border);
    color: var(--muted); font-family: inherit; text-align: left; transition: all 0.15s;
}
.style-btn:hover  { background: rgba(107,142,35,0.15); color: var(--sand); border-color: var(--olive); }
.style-btn.active {
    background: rgba(138,178,58,0.15); color: var(--olive-light);
    border-color: var(--olive-light); font-weight: 700;
}

/* ─── MapLibre GL canvas — must not capture Leaflet pointer events ── */
.maplibregl-canvas-container,
.maplibregl-canvas { pointer-events: none !important; }

/* ─── Leaflet overrides ──────────────────────────────────────────── */
.leaflet-control-zoom a {
    background: rgba(20,32,20,0.95) !important; color: var(--khaki) !important;
    border-color: var(--border) !important; font-weight: 700 !important;
}
.leaflet-control-zoom a:hover {
    background: rgba(107,142,35,0.25) !important; color: var(--accent) !important;
    border-color: var(--olive) !important;
}
.leaflet-tooltip-dark {
    background: rgba(20,32,20,0.9); border: 1px solid var(--border);
    color: var(--sand); font-size: 11px; border-radius: 4px;
}
.nato-marker { background: none !important; border: none !important; }

/* ─── Rotation handle ────────────────────────────────────────────── */
.rot-handle {
    width: 12px; height: 12px; border-radius: 50%;
    background: var(--accent); border: 2px solid #1a2a1a;
    cursor: grab; box-shadow: 0 0 6px rgba(252,176,13,0.6);
}
.rot-handle:active { cursor: grabbing; }

/* ─── Export SQF button ──────────────────────────────────────────── */
#btn-export-sqf {
    margin-left: auto;
    padding: 5px 14px; font-size: 0.72em; font-family: 'Orbitron', sans-serif;
    font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    background: rgba(15,26,15,0.8); border: 1px solid var(--olive);
    color: var(--olive-light); border-radius: 5px; cursor: pointer;
    transition: all 0.15s;
}
#btn-export-sqf:hover { background: rgba(107,142,35,0.25); color: var(--sand); border-color: var(--accent); }

/* ─── Export modal ───────────────────────────────────────────────── */
#export-modal {
    position: fixed; inset: 0; z-index: 3000;
    background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    display: none;
}
#export-modal.open { display: flex; }
#export-box {
    background: var(--panel-bg); border: 1px solid var(--olive);
    border-radius: 10px; padding: 22px 24px; width: 620px; max-width: 96vw;
    box-shadow: 0 8px 32px rgba(0,0,0,0.7);
}
#export-box h3 {
    font-family: 'Orbitron', sans-serif; font-size: 0.9em;
    color: var(--accent); letter-spacing: 0.12em; text-transform: uppercase;
    margin-bottom: 14px; border-bottom: 1px solid var(--border); padding-bottom: 10px;
}
#export-info { font-size: 0.75em; color: var(--muted); margin-bottom: 10px; }
#export-info strong { color: var(--olive-light); }
#export-sqf-text {
    width: 100%; height: 260px; resize: vertical;
    background: rgba(0,0,0,0.5); border: 1px solid var(--border); border-radius: 6px;
    color: var(--sand); font-family: 'Roboto Mono', monospace; font-size: 0.72em;
    padding: 10px 12px; line-height: 1.5; box-sizing: border-box;
}
#export-sqf-text:focus { outline: none; border-color: var(--accent); }
#export-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 12px; }
.export-btn {
    font-size: 0.78em; padding: 8px 18px; border-radius: 5px; cursor: pointer;
    font-family: inherit; font-weight: 600; transition: all 0.15s;
    border: 1px solid var(--border); background: rgba(15,26,15,0.8); color: var(--khaki);
}
.export-btn:hover { border-color: var(--olive); color: var(--sand); }
.export-btn.primary {
    background: linear-gradient(135deg, var(--accent) 0%, #e6a000 100%);
    color: #1a2a1a; border-color: var(--accent); font-weight: 700;
}
.export-btn.primary:hover { box-shadow: 0 4px 12px rgba(252,176,13,0.4); }

/* ─── Rotation row in properties panel ──────────────────────────── */
#pr-rotation-row input[type=range] { width: 100%; cursor: pointer; accent-color: var(--accent); }
</style>
</head>
<body>

<!-- ─── Top bar ──────────────────────────────────────────────────────── -->
<div id="topbar">
    <a href="/operations/<%= operation.id %>" class="back-btn">← Back</a>
    <div class="op-title"><%= operation.title %> — MISSION MAP</div>
    <% if (canEdit) { %>
        <span class="mode-badge edit">EDIT</span>
    <% } else { %>
        <span class="mode-badge">VIEW ONLY</span>
    <% } %>
    <span id="save-status"></span>
    <button id="btn-export-sqf" title="Export all markers as Metis Marker SQF script">⬇ Export SQF</button>
</div>

<!-- ─── Page body ────────────────────────────────────────────────────── -->
<div id="page">

    <!-- Sidebar -->
    <div id="sidebar">
        <div id="sidebar-header">
            <h2>Layers</h2>
            <% if (canEdit) { %>
                <button id="btn-add-layer" title="Add layer">+ New</button>
            <% } %>
        </div>
        <div id="layer-list"></div>

        <!-- Terrain indicator + map style switcher -->
        <div id="world-panel">
            <h2>Terrain</h2>
            <div id="world-status"></div>
            <div id="style-switcher">
                <h2>Map Style</h2>
                <div id="style-btns"></div>
            </div>
        </div>
    </div>

    <!-- Map -->
    <div id="map-wrap">
        <!-- Drawing toolbar (edit mode only) -->
        <% if (canEdit) { %>
        <div id="toolbar">
            <button class="tb-btn active" id="tb-select" title="Select / pan (Esc)">✦ Select</button>
            <button class="tb-btn" id="tb-nato"   title="Place NATO marker (M)">📍 Marker</button>
            <div class="tb-sep"></div>
            <button class="tb-btn" id="tb-line"   title="Draw line (L) — click points, right-click to finish">╱ Line</button>
            <button class="tb-btn" id="tb-poly"   title="Draw polygon (P) — click points, right-click to finish">⬟ Polygon</button>
            <button class="tb-btn" id="tb-rect"   title="Draw rectangle (R) — two clicks">▭ Rect</button>
            <button class="tb-btn" id="tb-circle" title="Draw circle (C) — click center then edge">⊙ Circle</button>
            <button class="tb-btn" id="tb-text"   title="Place text label (T)">T Text</button>
            <div class="tb-sep"></div>
            <div id="color-picker-wrap">
                <label>Color</label>
                <input type="color" id="draw-color" value="#e74c3c" title="Stroke / fill color">
            </div>
            <label style="color:#666;font-size:0.75em;margin-left:4px;">Wt</label>
            <input type="range" id="draw-weight" min="1" max="8" value="2" title="Line weight">
            <div class="tb-sep"></div>
            <button class="tb-btn" id="tb-undo" title="Undo last point (Backspace while drawing)">↩ Undo</button>
        </div>
        <% } %>

        <div id="map">
            <div id="map-placeholder">
                <div>
                    <div class="ph-title">NO TERRAIN LOADED</div>
                    <% if (canEdit) { %>
                    <div class="ph-sub">Enter a world name in the sidebar to load the Arma terrain</div>
                    <% } else { %>
                    <div class="ph-sub">Terrain not configured for this operation</div>
                    <% } %>
                </div>
            </div>
        </div>
        <div id="coords">—</div>

        <!-- Minimap overview -->
        <div id="minimap-wrap">
            <div id="minimap-header">
                <span id="minimap-label">Overview</span>
                <button id="minimap-toggle" title="Collapse / expand">−</button>
            </div>
            <div id="minimap-img-wrap">
                <img id="minimap-img" alt="Terrain overview" draggable="false">
                <div id="minimap-viewport"></div>
            </div>
        </div>

        <!-- Controls hint (edit mode only) -->
        <% if (canEdit) { %>
        <div id="hint-panel" class="collapsed">
            <div id="hint-header">
                <span id="hint-label">? Controls</span>
                <button id="hint-toggle" title="Show / hide controls">▼</button>
            </div>
            <div id="hint-body">
                <div class="hint-sep">Tools</div>
                <div class="hint-row"><span class="hint-key">Esc</span><span class="hint-desc">Select / pan</span></div>
                <div class="hint-row"><span class="hint-key">M</span><span class="hint-desc">Place NATO marker</span></div>
                <div class="hint-row"><span class="hint-key">L</span><span class="hint-desc">Draw line</span></div>
                <div class="hint-row"><span class="hint-key">P</span><span class="hint-desc">Draw polygon</span></div>
                <div class="hint-row"><span class="hint-key">R</span><span class="hint-desc">Draw rectangle</span></div>
                <div class="hint-row"><span class="hint-key">C</span><span class="hint-desc">Draw circle</span></div>
                <div class="hint-row"><span class="hint-key">T</span><span class="hint-desc">Place text label</span></div>
                <div class="hint-sep">While drawing (Line / Polygon)</div>
                <div class="hint-row"><span class="hint-key">Click</span><span class="hint-desc">Add a point</span></div>
                <div class="hint-row"><span class="hint-key">Right-click</span><span class="hint-desc">Finish shape</span></div>
                <div class="hint-row"><span class="hint-key">Double-click</span><span class="hint-desc">Finish shape</span></div>
                <div class="hint-row"><span class="hint-key">Backspace</span><span class="hint-desc">Undo last point</span></div>
                <div class="hint-row"><span class="hint-key">Esc</span><span class="hint-desc">Cancel drawing</span></div>
                <div class="hint-sep">Selection</div>
                <div class="hint-row"><span class="hint-key">Click shape</span><span class="hint-desc">Select &amp; edit</span></div>
                <div class="hint-row"><span class="hint-key">Del</span><span class="hint-desc">Delete selected</span></div>
            </div>
        </div>
        <% } %>

        <!-- Properties panel -->
        <% if (canEdit) { %>
        <div id="props-panel">
            <div id="props-header">
                <span id="props-type-label">ANNOTATION</span>
                <button id="props-close">✕</button>
            </div>
            <div id="props-body">
                <div class="prop-row" id="pr-label-row">
                    <label>Label</label>
                    <input type="text" id="pr-label" placeholder="e.g. 1st Platoon">
                </div>
                <div class="prop-row" id="pr-color-row">
                    <label>Color</label>
                    <input type="color" id="pr-color">
                </div>
                <div class="prop-row" id="pr-weight-row">
                    <label>Line weight</label>
                    <select id="pr-weight">
                        <option value="1">1px — Thin</option>
                        <option value="2" selected>2px — Normal</option>
                        <option value="3">3px — Medium</option>
                        <option value="5">5px — Thick</option>
                        <option value="8">8px — Heavy</option>
                    </select>
                </div>
                <div class="prop-row" id="pr-dash-row">
                    <label>Line style</label>
                    <select id="pr-dash">
                        <option value="">Solid</option>
                        <option value="6 4">Dashed</option>
                        <option value="2 4">Dotted</option>
                        <option value="10 5 2 5">Dash-dot</option>
                    </select>
                </div>
                <div class="prop-row" id="pr-layer-row">
                    <label>Layer</label>
                    <select id="pr-layer"></select>
                </div>
                <div class="prop-row" id="pr-rotation-row" style="display:none">
                    <label>Rotation</label>
                    <div style="display:flex;align-items:center;gap:8px">
                        <input type="range" id="pr-rotation" min="0" max="359" value="0" style="flex:1">
                        <span id="pr-rotation-val" style="color:var(--olive-light);font-size:0.8em;min-width:34px;text-align:right">0°</span>
                    </div>
                </div>
            </div>
            <div id="props-footer">
                <button id="btn-props-delete">🗑 Delete</button>
                <button id="btn-props-save">Save</button>
            </div>
        </div>
        <% } %>
    </div>
</div>

<!-- ─── NATO Picker Modal ─────────────────────────────────────────────── -->
<% if (canEdit) { %>
<div id="nato-modal">
    <div id="nato-box">
        <div id="nato-box-header">
            <h3>NATO MILITARY SYMBOL BUILDER</h3>
            <button id="nato-modal-close">✕</button>
        </div>
        <div id="nato-body">

            <!-- SIDC direct input + live preview -->
            <div>
                <div class="nato-sec-label">SIDC Code</div>
                <div class="nato-sidc-row">
                    <input type="text" id="nato-sidc-input" maxlength="20" spellcheck="false" value="10031000000000000000">
                    <div id="nato-preview-box"></div>
                </div>
            </div>

            <!-- Affiliation -->
            <div>
                <div class="nato-sec-label">Affiliation</div>
                <div class="nato-affil-row" id="nato-affil-row"></div>
            </div>

            <!-- Symbol set · Echelon · Modifiers -->
            <div class="nato-ctrl-row">
                <div class="nato-field">
                    <label>Symbol Set</label>
                    <select id="nato-symset" class="nato-sel">
                        <option value="10">Land Unit</option>
                        <option value="11">Land Civilian</option>
                        <option value="15">Land Equipment</option>
                        <option value="01">Air</option>
                        <option value="30">Sea Surface</option>
                        <option value="40">Activity / Event</option>
                    </select>
                </div>
                <div class="nato-field">
                    <label>Echelon / Size</label>
                    <select id="nato-echelon" class="nato-sel">
                        <option value="00">— None —</option>
                        <option value="11">Team / Crew</option>
                        <option value="12">Squad</option>
                        <option value="13">Section</option>
                        <option value="14">Platoon</option>
                        <option value="15">Company</option>
                        <option value="16">Battalion</option>
                        <option value="17">Regiment</option>
                        <option value="18">Brigade</option>
                        <option value="21">Division</option>
                        <option value="22">Corps</option>
                        <option value="23">Army</option>
                        <option value="24">Army Group</option>
                    </select>
                </div>
                <div class="nato-field">
                    <label>Modifiers</label>
                    <div class="nato-checks">
                        <label><input type="checkbox" id="nato-chk-hq"> HQ</label>
                        <label><input type="checkbox" id="nato-chk-tf"> Task Force</label>
                        <label><input type="checkbox" id="nato-chk-fd"> Feint/Dummy</label>
                    </div>
                </div>
            </div>

            <!-- Entity / Symbol -->
            <div class="nato-field" style="width:100%">
                <label>Symbol / Entity</label>
                <input type="text" id="nato-entity-filter" placeholder="Filter symbols…" autocomplete="off">
                <select id="nato-entity-select" size="6"></select>
            </div>

            <!-- Label -->
            <div class="nato-field" style="width:100%">
                <label>Designation / Label</label>
                <input type="text" id="nato-label" placeholder="e.g. 1st PLT, Obj. EAGLE, ALPHA…" maxlength="60">
            </div>

        </div>
        <div id="nato-footer">
            <button class="nato-footer-btn" id="nato-cancel">Cancel</button>
            <button class="nato-footer-btn primary" id="nato-confirm">Place on Map</button>
        </div>
    </div>
</div>

<!-- Layer edit/add modal -->
<div id="layer-modal">
    <div id="layer-box">
        <h3 id="lmodal-title">New Layer</h3>
        <div class="lmodal-row">
            <label>Name</label>
            <input type="text" id="lmodal-name" placeholder="e.g. Friendly Forces" maxlength="60">
        </div>
        <div class="lmodal-row">
            <label>Color</label>
            <input type="color" id="lmodal-color" value="#3498DB">
        </div>
        <div class="lmodal-btns">
            <button class="lmodal-btn" id="lmodal-cancel">Cancel</button>
            <button class="lmodal-btn primary" id="lmodal-save">Save</button>
        </div>
    </div>
</div>
<% } %>

<!-- ─── Export SQF Modal (visible to all) ────────────────────────────── -->
<div id="export-modal">
    <div id="export-box">
        <h3>Export — Metis Marker SQF</h3>
        <div id="export-info">
            Paste this script into the Arma 3 debug console or a mission <code>init.sqf</code>.<br>
            Requires <strong>Metis Marker</strong> and <strong>CBA_A3</strong>.
        </div>
        <textarea id="export-sqf-text" readonly spellcheck="false"></textarea>
        <div id="export-footer">
            <button class="export-btn" id="export-close">Close</button>
            <button class="export-btn primary" id="export-copy">Copy to Clipboard</button>
        </div>
    </div>
</div>

<script>
/* ═══════════════════════════════════════════════════════════════════════
   CONSTANTS & CATALOGUE
   ═══════════════════════════════════════════════════════════════════════ */
const OP_ID    = <%- operation.id %>;
const CAN_EDIT = <%- canEdit ? 'true' : 'false' %>;

// SIDC Builder — entity catalog keyed by symbol set (2-char code).
// Uses 20-char numeric SIDC (APP-6D / MIL-STD-2525D) that milsymbol v3 supports natively.
// Format: version(2) + context(1) + affil(1) + symSet(2) + status(1) + hqtf(1) + echelon(2) + entity(6) + mod1(2) + mod2(2)
// Stored SIDCs from previous version (30-char APP-6E) still render correctly as milsymbol
// reads the same fields at the same positions for both formats.
const SIDC_ENTITIES = {
    '10': [ // Land Unit
        { g:'General',           v:'000000', l:'Unspecified / Generic' },
        { g:'C2',                v:'110000', l:'Command and Control' },
        { g:'C2',                v:'110200', l:'Civil Affairs' },
        { g:'C2',                v:'110500', l:'Liaison' },
        { g:'C2',                v:'111000', l:'Signal' },
        { g:'C2',                v:'111001', l:'Signal › Radio' },
        { g:'C2',                v:'111002', l:'Signal › Radio Relay' },
        { g:'Manoeuvre',         v:'120000', l:'Manoeuvre (Generic)' },
        { g:'Manoeuvre',         v:'120300', l:'Amphibious' },
        { g:'Manoeuvre',         v:'120400', l:'Anti-Tank / Anti-Armour' },
        { g:'Manoeuvre',         v:'120401', l:'Anti-Tank › Armoured' },
        { g:'Manoeuvre',         v:'120402', l:'Anti-Tank › Motorized' },
        { g:'Manoeuvre',         v:'120500', l:'Armour / Tank' },
        { g:'Manoeuvre',         v:'120501', l:'Armour › Recon / Cavalry' },
        { g:'Manoeuvre',         v:'120502', l:'Armour › Amphibious' },
        { g:'Manoeuvre',         v:'120600', l:'Army Aviation (Rotary Wing)' },
        { g:'Manoeuvre',         v:'120601', l:'Army Aviation › Recon' },
        { g:'Manoeuvre',         v:'120800', l:'Aviation Fixed Wing' },
        { g:'Manoeuvre',         v:'121000', l:'Combined Arms' },
        { g:'Manoeuvre',         v:'121100', l:'Infantry' },
        { g:'Manoeuvre',         v:'121101', l:'Infantry › Amphibious' },
        { g:'Manoeuvre',         v:'121102', l:'Infantry › Mechanized / Armoured' },
        { g:'Manoeuvre',         v:'121104', l:'Infantry › Motorized' },
        { g:'Manoeuvre',         v:'121105', l:'Infantry › Mech. with Main Gun' },
        { g:'Manoeuvre',         v:'121200', l:'Observer' },
